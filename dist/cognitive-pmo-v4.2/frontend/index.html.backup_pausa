  'bf-edt': '1.0 | Planificación y Diseño Global | Arquitectura / JdP\n2.0 | Adquisición y Preparación | JdP\n3.0 | Implementación Entorno DESA | Jefa UNIX\n4.0 | Implementación Entorno PRE | Jefa UNIX\n5.0 | Pruebas y Certificación en PRE | JdP\n6.0 | Implementación Entorno PRO | Jefa UNIX\n7.0 | Go-Live y Estabilización | Jefe Operaciones\n8.0 | Cierre del Proyecto | JdP',
  'bf-asunciones': '• Los recursos de los departamentos internos (UNIX, Redes, Storage) estarán disponibles según lo planificado\n• El hardware adquirido será entregado por los proveedores en el plazo de 10 semanas estipulado\n• La colaboración activa del equipo de desarrollo de la aplicación piloto para facilitar su migración\n• No habrá cambios significativos en las políticas de seguridad corporativas durante la ejecución del proyecto',
  'bf-riesgos': 'Retraso en entrega de hardware (cadena suministro) | 3 | 5 | Mitigar — Orden de compra en Semana 2\nFalta experiencia interna en OpenShift | 4 | 4 | Mitigar — Contratar consultoría Red Hat\nResistencia cultural al cambio (DevOps) | 4 | 3 | Mitigar — Workshops, demos y champions\nVulnerabilidad crítica en pentesting PRE | 2 | 5 | Mitigar — Hardening desde Fase 1, reservar 2 semanas remediación\nFalta disponibilidad personal clave | 3 | 3 | Mitigar — Técnico backup para roles críticos',
  'bf-capex': '204000',
  'bf-opex': '152000',
  'bf-personal': '159575',
  'bf-servicios': '50000',
  'bf-contingencia': '15',
  'bf-horas': '2455',
  'bf-tarifa': '65',
  'bf-financiero': 'VAN: -22.698€ (conservador, +93.842€ ajustado) | TIR: 9.12% | Payback: 3.98 años',
  'bf-interesados': 'Javier Fernández | CIO/Patrocinador | A favor | Alto | Gestionar de cerca — informes semanales\nLaura Giménez | CISO/Seguridad | Neutral | Alto | Mantener satisfecha — involucrar desde diseño\nMarcos Herrero | CFO/Finanzas | Neutral | Alto | Mantener informado — Business Case VAN/TIR\nElena Prieto | Jefa Desarrollo | A favor | Medio | Gestionar de cerca — app piloto champion\nDavid Sánchez | Jefe Operaciones | En contra | Medio | Mitigar — involucrar en manuales operación\nSofía Vega | Jefa UNIX | Neutral | Bajo | Colaborar — transferir conocimiento paulatinamente\nConsultoría Red Hat | Socio Tecnológico | A favor | Medio | Gestionar de cerca — SOW claro',
  'bf-area': 'Infraestructura',
  'bf-calidad': 'ISO/IEC 27001, ISO 9001, PCI DSS, GDPR, Normativa Interna Seguridad Cajamar',
  'bf-comunicaciones': 'C01 Semanal: Reunión equipo proyecto (Acta de Reunión) — JdP → Equipo\nC02 Mensual: Informe Estado Ejecutivo (semáforo, hitos, presupuesto) — JdP → Sponsor, CISO, CFO\nC03 Por fase: Informe Cierre de Fase — JdP → Sponsor, Arquitecto\nC04 Ad-hoc: Notificación Riesgo Crítico — JdP → Sponsor y Afectados\nC05 Pre Go-Live: Plan de Go-Live detallado — Jefe Operaciones → Equipo, Sponsor\nC06 Final: Informe Final de Cierre con lecciones aprendidas — JdP → Todos',
};

function buildLoadExample() {
  Object.entries(BUILD_EXAMPLE_OPENSHIFT).forEach(([id, val]) => {
    const el = document.getElementById(id);
    if (!el) return;
    if (el.tagName === 'SELECT') { el.value = val; }
    else { el.value = val; }
  });
  // Select first PM if available
  const pmSel = document.getElementById('bf-pm');
  if (pmSel && pmSel.options.length > 1) pmSel.selectedIndex = 1;
  showToast('Ejemplo OpenShift cargado — navega por las 5 pestañas para ver todos los datos');
}

function resetBuildForm() {
  Object.keys(BUILD_EXAMPLE_OPENSHIFT).forEach(id => {
    const el = document.getElementById(id);
    if (el) el.value = el.tagName === 'SELECT' ? el.options[0]?.value || '' : '';
  });
  document.getElementById('bf-duracion').value = '40';
  document.getElementById('bf-contingencia').value = '15';
  document.getElementById('bf-tarifa').value = '65';
  document.getElementById('bf-prioridad').value = 'Alta';
  document.getElementById('build-proj-id').textContent = '';
  resetPipeline('build');
}

async function buildSaveToBuffer(data) {
  const nombre = data['bf-nombre'] || 'Sin nombre';
  const payload = {
    id_proyecto: null,
    nombre: nombre,
    presupuesto: parseFloat(data['bf-presupuesto']) || 0,
    duracion_semanas: parseInt(data['bf-duracion']) || 20,
    prioridad: data['bf-prioridad'] || 'Media',
    plan_data: {...data},
  };
  try {
    const r = await authFetch(API_BASE + '/build/plans', {
      method: 'POST', headers: {'Content-Type':'application/json'},
      body: JSON.stringify(payload)
    });
    if (r.ok) {
      await loadBuildPlansFromDB();
      return;
    }
  } catch(e) { console.warn('Error saving plan:', e); }
  // Fallback to memory
  const entry = {
    id: 'BLD-' + Date.now().toString(36).toUpperCase(),
    nombre, presupuesto: data['bf-presupuesto'] || '0',
    prioridad: data['bf-prioridad'] || 'Media',
    timestamp: new Date().toLocaleString('es-ES'), fields: {...data},
  };
  _buildBuffer.unshift(entry);
  renderBuildBuffer();
}

function renderBuildBuffer() {
  const list = document.getElementById('build-buffer-list');
  document.getElementById('build-buffer-count').textContent = '(' + _buildBuffer.length + ')';
  if (!_buildBuffer.length) {
    list.innerHTML = '<div style="font-size:10px;color:var(--text3);text-align:center;padding:8px;">Sin proyectos registrados</div>';
    return;
  }
  const prioColors = {Crítica:'var(--red)',Alta:'var(--orange)',Media:'var(--yellow)',Baja:'var(--green)'};
  list.innerHTML = _buildBuffer.map((b, i) => `
    <div style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:8px 10px;margin-bottom:6px;border-left:3px solid ${prioColors[b.prioridad]||'var(--text3)'};">
      <div style="display:flex;align-items:center;gap:8px;">
        <div style="flex:1;min-width:0;">
          <div style="font-size:12px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${escHtml(b.nombre)}</div>
          <div style="font-size:9px;color:var(--text3);display:flex;gap:8px;margin-top:2px;">
            <span style="font-family:var(--mono);">${b.id}</span>
            <span>${b.timestamp}</span>
            <span style="color:${prioColors[b.prioridad]||'var(--text3)'};">${b.prioridad}</span>
            <span style="font-family:var(--mono);color:var(--green);">${Number(b.presupuesto||0).toLocaleString('es-ES')}€</span>
          </div>
        </div>
      </div>
      <div style="display:flex;gap:4px;margin-top:6px;flex-wrap:wrap;">
        <button onclick="buildRestoreFromBuffer(${i})" style="background:var(--blue-bg);border:1px solid rgba(45,126,247,.3);color:var(--blue);border-radius:4px;padding:2px 8px;font-size:9px;font-weight:600;cursor:pointer;">
          ↩ Restaurar
        </button>
        <button onclick="buildRerunFromBuffer(${i})" style="background:var(--green-bg);border:1px solid rgba(63,185,80,.3);color:var(--green);border-radius:4px;padding:2px 8px;font-size:9px;font-weight:600;cursor:pointer;">
          ▶ Re-ejecutar
        </button>
        <button onclick="buildDownloadPDF(${i})" style="background:rgba(245,158,11,.15);border:1px solid rgba(245,158,11,.3);color:#f59e0b;border-radius:4px;padding:2px 8px;font-size:9px;font-weight:600;cursor:pointer;">
          ↓ Plan PDF
        </button>
        <button onclick="buildDeletePlan(${i})" style="background:var(--red-bg);border:1px solid rgba(248,81,73,.3);color:var(--red);border-radius:4px;padding:2px 8px;font-size:9px;font-weight:600;cursor:pointer;margin-left:auto;">
          ✕ Eliminar
        </button>
      </div>
    </div>
  `).join('');
}

function buildRestoreFromBuffer(idx) {
  const entry = _buildBuffer[idx];
  if (!entry || !entry.fields) return;
  Object.entries(entry.fields).forEach(([id, val]) => {
    const el = document.getElementById(id);
    if (el) el.value = val;
  });
  buildFormStep(1, document.querySelector('#build-form-nav .filter-chip'));
  showToast('Proyecto "' + entry.nombre.substring(0, 40) + '" restaurado en el formulario');
}

function buildRerunFromBuffer(idx) {
  const entry = _buildBuffer[idx];
  if (!entry || !entry.fields) return;
  // Restore fields without re-registering
  Object.entries(entry.fields).forEach(([id, val]) => {
    const el = document.getElementById(id);
    if (el) el.value = val;
  });
  // Build the enriched text and execute pipeline directly (no save to buffer)
  const f = id => (document.getElementById(id)?.value||'').trim();
  const nombre = f('bf-nombre');
  let text = `=== PLAN DE PROYECTO PMBOK 7 (Re-ejecución: ${entry.id}) ===\nNOMBRE: ${nombre}\nPM: ${document.getElementById('bf-pm')?.selectedOptions[0]?.textContent||''}\nPRIORIDAD: ${f('bf-prioridad')}\nPRESUPUESTO: ${f('bf-presupuesto')}€ | DURACIÓN: ${f('bf-duracion')} semanas\n`;
  if (f('bf-resumen')) text += `\n--- BUSINESS CASE ---\n${f('bf-resumen')}\n`;
  if (f('bf-justificacion')) text += `\nJUSTIFICACIÓN:\n${f('bf-justificacion')}\n`;
  if (f('bf-objetivos')) text += `\nOBJETIVOS SMART:\n${f('bf-objetivos')}\n`;
  if (f('bf-entregables')) text += `\nENTREGABLES:\n${f('bf-entregables')}\n`;
  if (f('bf-hitos')) text += `\nHITOS:\n${f('bf-hitos')}\n`;
  if (f('bf-edt')) text += `\n--- EDT/WBS ---\n${f('bf-edt')}\n`;
  if (f('bf-riesgos')) text += `\n--- RIESGOS ---\n${f('bf-riesgos')}\n`;
  text += `\nCAPEX: ${f('bf-capex')||0}€ | OPEX: ${f('bf-opex')||0}€ | Personal: ${f('bf-personal')||0}€\n`;
  if (f('bf-interesados')) text += `\n--- INTERESADOS ---\n${f('bf-interesados')}\n`;
  document.getElementById('build-input').value = text;
  document.getElementById('build-proj-id').textContent = nombre.substring(0, 30);
  showToast('Re-ejecutando pipeline para "' + nombre.substring(0,30) + '" (sin duplicar registro)');
  executePipeline('build');
}

function buildDownloadPDF(idx) {
  const entry = _buildBuffer[idx];
  if (!entry || !entry.fields) return;
  const f = entry.fields;
  // Build HTML document for PDF
  const html = `<!DOCTYPE html><html><head><meta charset="utf-8"><title>Plan de Proyecto — ${f['bf-nombre']||'Proyecto'}</title>
<style>body{font-family:Arial,sans-serif;max-width:800px;margin:0 auto;padding:40px;color:#222;font-size:13px;line-height:1.6;}
h1{color:#059669;border-bottom:3px solid #059669;padding-bottom:10px;font-size:22px;}
h2{color:#0369a1;margin-top:30px;border-bottom:1px solid #ddd;padding-bottom:5px;font-size:16px;}
h3{color:#92400e;font-size:14px;}
.meta{background:#f0fdf4;border:1px solid #bbf7d0;border-radius:8px;padding:15px;margin:15px 0;display:flex;gap:30px;flex-wrap:wrap;}
.meta-item{text-align:center;}.meta-val{font-size:20px;font-weight:bold;color:#059669;}.meta-label{font-size:10px;color:#666;text-transform:uppercase;}
pre{background:#f8fafc;border:1px solid #e2e8f0;border-radius:6px;padding:12px;font-size:12px;white-space:pre-wrap;line-height:1.5;}
.footer{margin-top:40px;border-top:2px solid #059669;padding-top:10px;font-size:10px;color:#888;text-align:center;}
table{width:100%;border-collapse:collapse;margin:10px 0;}th{background:#f1f5f9;text-align:left;padding:6px 10px;font-size:11px;border:1px solid #e2e8f0;}
td{padding:6px 10px;border:1px solid #e2e8f0;font-size:12px;}</style></head><body>
<h1>Plan de Proyecto PMBOK 7</h1>
<h2 style="color:#059669;font-size:20px;">${f['bf-nombre']||''}</h2>
<div class="meta">
<div class="meta-item"><div class="meta-val">${Number(f['bf-presupuesto']||0).toLocaleString('es-ES')}€</div><div class="meta-label">Presupuesto</div></div>
<div class="meta-item"><div class="meta-val">${f['bf-duracion']||'—'} sem</div><div class="meta-label">Duración</div></div>
<div class="meta-item"><div class="meta-val">${f['bf-prioridad']||'—'}</div><div class="meta-label">Prioridad</div></div>
<div class="meta-item"><div class="meta-val">${f['bf-horas']||'—'}h</div><div class="meta-label">Horas Est.</div></div>
<div class="meta-item"><div class="meta-val">${f['bf-contingencia']||'15'}%</div><div class="meta-label">Contingencia</div></div>
</div>
<p><strong>ID Registro:</strong> ${entry.id} | <strong>Fecha:</strong> ${entry.timestamp}</p>
<h2>PASO 1: Caso de Negocio (Business Case)</h2>
<h3>Resumen Ejecutivo</h3><pre>${f['bf-resumen']||'No definido'}</pre>
<h3>Justificación</h3><pre>${f['bf-justificacion']||'No definida'}</pre>
<h3>Beneficios Esperados</h3><pre>${f['bf-beneficios']||'No definidos'}</pre>
<h3>Contrabeneficios</h3><pre>${f['bf-contrabeneficios']||'No definidos'}</pre>
<h3>Evaluación Financiera</h3><p>${f['bf-financiero']||'No definida'}</p>
<h2>PASO 2: Acta de Constitución</h2>
<h3>Descripción de Alto Nivel</h3><pre>${f['bf-descripcion']||'No definida'}</pre>
<h3>Objetivos SMART</h3><pre>${f['bf-objetivos']||'No definidos'}</pre>
<h3>Entregables Principales</h3><pre>${f['bf-entregables']||'No definidos'}</pre>
<h3>Hitos del Proyecto</h3><pre>${f['bf-hitos']||'No definidos'}</pre>
<p><strong>Patrocinador:</strong> ${f['bf-sponsor']||'No definido'}</p>
<p><strong>Criterios de Éxito:</strong> ${f['bf-criterios']||'No definidos'}</p>
<h2>PASO 3: Alcance y EDT</h2>
<h3>Alcance del Producto</h3><pre>${f['bf-alcance']||'No definido'}</pre>
<h3>Exclusiones</h3><pre>${f['bf-exclusiones']||'No definidas'}</pre>
<h3>Restricciones</h3><pre>${f['bf-restricciones']||'No definidas'}</pre>
<h3>EDT / WBS</h3><pre>${f['bf-edt']||'No definida'}</pre>
<h3>Asunciones</h3><pre>${f['bf-asunciones']||'No definidas'}</pre>
<h2>PASO 4: Riesgos y Costes</h2>
<h3>Registro de Riesgos</h3><pre>${f['bf-riesgos']||'No definidos'}</pre>
<h3>Desglose de Costes</h3>
<table><tr><th>Concepto</th><th>Importe</th></tr>
<tr><td>CAPEX (Hardware, Infra)</td><td>${Number(f['bf-capex']||0).toLocaleString('es-ES')}€</td></tr>
<tr><td>OPEX (Licencias, SW)</td><td>${Number(f['bf-opex']||0).toLocaleString('es-ES')}€</td></tr>
<tr><td>Personal Interno (${f['bf-horas']||0}h @ ${f['bf-tarifa']||65}€/h)</td><td>${Number(f['bf-personal']||0).toLocaleString('es-ES')}€</td></tr>
<tr><td>Servicios Externos</td><td>${Number(f['bf-servicios']||0).toLocaleString('es-ES')}€</td></tr>
<tr style="font-weight:bold;background:#f0fdf4;"><td>Subtotal</td><td>${(Number(f['bf-capex']||0)+Number(f['bf-opex']||0)+Number(f['bf-personal']||0)+Number(f['bf-servicios']||0)).toLocaleString('es-ES')}€</td></tr>
<tr style="font-weight:bold;"><td>Contingencia (${f['bf-contingencia']||15}%)</td><td>${Math.round((Number(f['bf-capex']||0)+Number(f['bf-opex']||0)+Number(f['bf-personal']||0)+Number(f['bf-servicios']||0))*Number(f['bf-contingencia']||15)/100).toLocaleString('es-ES')}€</td></tr>
<tr style="font-weight:bold;background:#059669;color:white;"><td>PRESUPUESTO TOTAL</td><td>${Number(f['bf-presupuesto']||0).toLocaleString('es-ES')}€</td></tr>
</table>
<h2>PASO 5: Interesados y Calidad</h2>
<h3>Matriz de Interesados</h3><pre>${f['bf-interesados']||'No definidos'}</pre>
<p><strong>Estándares de Calidad:</strong> ${f['bf-calidad']||'No definidos'}</p>
<h3>Plan de Comunicaciones</h3><pre>${f['bf-comunicaciones']||'No definido'}</pre>
<div class="footer">
<p>Cognitive PMO — Plan de Proyecto PMBOK 7 · Generado el ${new Date().toLocaleDateString('es-ES')} · Jose Antonio Martinez Victoria</p>
<p>Master Universitario en Dirección Estratégica de Proyectos</p>
</div></body></html>`;
  // Open in new window for printing/PDF
  const w = window.open('', '_blank');
  w.document.write(html);
  w.document.close();
  w.onload = () => { setTimeout(() => w.print(), 500); };
}

async function buildDeletePlan(idx) {
  const entry = _buildBuffer[idx];
  if (!entry) return;
  const nombre = entry.nombre || 'Sin nombre';
  if (!confirm(`¿Eliminar el plan de proyecto?\n\n"${nombre}"\nID: ${entry.id}\n\nEsta acción no se puede deshacer.`)) return;
  if (entry.fromDB && entry.id) {
    try {
      const r = await authFetch(API_BASE + '/build/plans/' + encodeURIComponent(entry.id), {method:'DELETE'});
      if (!r.ok) { showToast('Error eliminando plan'); return; }
    } catch(e) { showToast('Error: '+e.message); return; }
  }
  _buildBuffer.splice(idx, 1);
  renderBuildBuffer();
  showToast('Plan "' + nombre.substring(0,40) + '" eliminado');
}

function buildFormStep(n, el) {
  document.querySelectorAll('.build-form-step').forEach(s => { s.classList.remove('active'); s.style.display = 'none'; });
  document.querySelectorAll('#build-form-nav .filter-chip').forEach(c => c.classList.remove('active'));
  const step = document.getElementById('bf-step-'+n);
  if (step) { step.style.display = 'block'; step.classList.add('active'); }
  if (el) el.classList.add('active');
}
function loadBuildPMSelect() {
  const sel = document.getElementById('bf-pm');
  if (!sel || sel.options.length > 1) return;
  authFetch(API_BASE + '/pmo/managers').then(r=>r.json()).then(pms => {
    pms.forEach(p => {
      const opt = document.createElement('option');
      opt.value = p.id_pm;
      opt.textContent = p.id_pm + ' — ' + p.nombre + ' (' + p.nivel + ')';
      sel.appendChild(opt);
    });
  }).catch(()=>{});
}
setTimeout(() => {
  loadBuildPMSelect();
  loadBuildPlansFromDB();
}, 600);

async function loadBuildPlansFromDB() {
  try {
    const r = await authFetch(API_BASE + '/build/plans');
    const plans = await r.json();
    _buildBuffer = plans.map(p => {
      const d = typeof p.plan_data === 'string' ? JSON.parse(p.plan_data) : p.plan_data;
      return {
        id: p.id,
        nombre: p.nombre,
        presupuesto: p.presupuesto || d['bf-presupuesto'] || '0',
        prioridad: p.prioridad || d['bf-prioridad'] || 'Media',
        timestamp: p.created_at ? new Date(p.created_at).toLocaleString('es-ES') : '',
        fields: d,
        fromDB: true,
      };
    });
    renderBuildBuffer();
  } catch(e) { console.warn('Error loading build plans:', e); }
}

async function buildSubmitAndPipeline() {
  var nombreEl = document.getElementById('bf-nombre');
  var nombre = nombreEl ? nombreEl.value.trim() : '';
  if (!nombre) { if (nombreEl) nombreEl.focus(); showToast('Introduce el nombre del proyecto'); return; }
  var f = function(id) { var el = document.getElementById(id); return el ? (el.value || '').trim() : ''; };
  var fSel = function(id) { var el = document.getElementById(id); return el && el.selectedOptions && el.selectedOptions[0] ? el.selectedOptions[0].textContent : ''; };
  var text = '=== PLAN DE PROYECTO PMBOK 7 ===\nNOMBRE: ' + nombre + '\nPM: ' + fSel('bf-pm') + '\nPRIORIDAD: ' + f('bf-prioridad') + '\nPRESUPUESTO: ' + f('bf-presupuesto') + '€ | DURACIÓN: ' + f('bf-duracion') + ' semanas\n';
  if (f('bf-resumen')) text += '\n--- BUSINESS CASE ---\n' + f('bf-resumen') + '\n';
  if (f('bf-justificacion')) text += '\nJUSTIFICACIÓN:\n' + f('bf-justificacion') + '\n';
  if (f('bf-beneficios')) text += '\nBENEFICIOS:\n' + f('bf-beneficios') + '\n';
  if (f('bf-contrabeneficios')) text += '\nCONTRABENEFICIOS:\n' + f('bf-contrabeneficios') + '\n';
  if (f('bf-descripcion')) text += '\n--- ACTA CONSTITUCIÓN ---\n' + f('bf-descripcion') + '\n';
  if (f('bf-objetivos')) text += '\nOBJETIVOS SMART:\n' + f('bf-objetivos') + '\n';
  if (f('bf-entregables')) text += '\nENTREGABLES:\n' + f('bf-entregables') + '\n';
  if (f('bf-hitos')) text += '\nHITOS:\n' + f('bf-hitos') + '\n';
  if (f('bf-sponsor')) text += '\nSPONSOR: ' + f('bf-sponsor') + '\n';
  if (f('bf-criterios')) text += 'CRITERIOS SALIDA: ' + f('bf-criterios') + '\n';
  if (f('bf-alcance')) text += '\n--- ALCANCE ---\n' + f('bf-alcance') + '\n';
  if (f('bf-exclusiones')) text += '\nEXCLUSIONES:\n' + f('bf-exclusiones') + '\n';
  if (f('bf-restricciones')) text += '\nRESTRICCIONES:\n' + f('bf-restricciones') + '\n';
  if (f('bf-edt')) text += '\n--- EDT/WBS ---\n' + f('bf-edt') + '\n';
  if (f('bf-asunciones')) text += '\nASUNCIONES:\n' + f('bf-asunciones') + '\n';
  if (f('bf-riesgos')) text += '\n--- RIESGOS ---\n' + f('bf-riesgos') + '\n';
  text += '\n--- COSTES ---\nCAPEX: ' + (f('bf-capex')||'0') + '€ | OPEX: ' + (f('bf-opex')||'0') + '€ | Personal: ' + (f('bf-personal')||'0') + '€\nServicios: ' + (f('bf-servicios')||'0') + '€ | Contingencia: ' + f('bf-contingencia') + '% | Horas: ' + (f('bf-horas')||'0') + 'h @ ' + (f('bf-tarifa')||'65') + '€/h\n';
  if (f('bf-financiero')) text += 'VAN/TIR: ' + f('bf-financiero') + '\n';
  if (f('bf-interesados')) text += '\n--- INTERESADOS ---\n' + f('bf-interesados') + '\n';
  if (f('bf-calidad')) text += '\nCALIDAD: ' + f('bf-calidad') + '\n';
  if (f('bf-comunicaciones')) text += '\n--- COMUNICACIONES ---\n' + f('bf-comunicaciones') + '\n';
  document.getElementById('build-input').value = text;
  document.getElementById('build-proj-id').textContent = nombre.substring(0, 30);
  // Save to buffer
  var bufferData = {};
  Object.keys(BUILD_EXAMPLE_OPENSHIFT).forEach(function(id) {
    const el = document.getElementById(id);
    if (el) bufferData[id] = el.value;
  });
  buildSaveToBuffer(bufferData);
  showToast('Plan PMBOK compilado y guardado en buffer — ejecutando pipeline IA...');
  executePipeline('build');
}

// ── RUN BUFFER (persistent) ──
let _runBuffer = [];

async function loadRunPlansFromDB() {
  try {
    const r = await authFetch(API_BASE + '/run/plans');
    const plans = await r.json();
    _runBuffer = plans.map(p => {
      const d = typeof p.plan_data === 'string' ? JSON.parse(p.plan_data) : p.plan_data;
      return { id: p.id, nombre: p.nombre, prioridad: p.prioridad || 'P3', area: p.area || '', sla: p.sla_horas || 0, timestamp: p.created_at ? new Date(p.created_at).toLocaleString('es-ES') : '', fields: d, fromDB: true };
    });
    renderRunBuffer();
  } catch(e) { console.warn('Error loading run plans:', e); }
}

async function runSaveToBuffer(data) {
  const nombre = data['itsm-desc'] || data['run-input'] || 'Incidencia sin descripción';
  const payload = { nombre, prioridad: data['itsm-prio'] || 'P3', area: data['itsm-area'] || '', sla_horas: parseFloat(data['itsm-sla']) || null, plan_data: {...data} };
  try {
    const r = await authFetch(API_BASE + '/run/plans', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(payload) });
    if (r.ok) { await loadRunPlansFromDB(); return; }
  } catch(e) {}
  _runBuffer.unshift({ id:'RUN-'+Date.now().toString(36), nombre, prioridad:data['itsm-prio']||'P3', area:data['itsm-area']||'', sla:data['itsm-sla']||0, timestamp:new Date().toLocaleString('es-ES'), fields:{...data} });
  renderRunBuffer();
}

function renderRunBuffer() {
  const list = document.getElementById('run-buffer-list');
  document.getElementById('run-buffer-count').textContent = '(' + _runBuffer.length + ')';
  if (!_runBuffer.length) { list.innerHTML = '<div style="font-size:10px;color:var(--text3);text-align:center;padding:8px;">Sin incidencias registradas</div>'; return; }
  const prioColors = {P1:'var(--red)',P2:'var(--orange)',P3:'var(--yellow)',P4:'var(--green)'};
  list.innerHTML = _runBuffer.map((b, i) => `
    <div style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:8px 10px;margin-bottom:6px;border-left:3px solid ${prioColors[b.prioridad]||'var(--text3)'};">
      <div style="display:flex;align-items:center;gap:8px;">
        <span style="font-family:var(--mono);font-size:12px;font-weight:800;color:${prioColors[b.prioridad]||'var(--text3)'};">${b.prioridad}</span>
        <div style="flex:1;min-width:0;">
          <div style="font-size:11px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${escHtml(b.nombre)}</div>
          <div style="font-size:9px;color:var(--text3);display:flex;gap:8px;margin-top:1px;">
            <span style="font-family:var(--mono);">${b.id}</span>
            <span>${b.area||''}</span>
            ${b.sla?`<span>SLA: ${b.sla}h</span>`:''}
            <span>${b.timestamp}</span>
          </div>
        </div>
      </div>
      <div style="display:flex;gap:4px;margin-top:6px;flex-wrap:wrap;">
        <button onclick="runRestoreFromBuffer(${i})" style="background:var(--blue-bg);border:1px solid rgba(45,126,247,.3);color:var(--blue);border-radius:4px;padding:2px 8px;font-size:9px;font-weight:600;cursor:pointer;">↩ Restaurar</button>
        <button onclick="runRerunFromBuffer(${i})" style="background:var(--green-bg);border:1px solid rgba(63,185,80,.3);color:var(--green);border-radius:4px;padding:2px 8px;font-size:9px;font-weight:600;cursor:pointer;">▶ Re-ejecutar</button>
        <button onclick="runDeletePlan(${i})" style="background:var(--red-bg);border:1px solid rgba(248,81,73,.3);color:var(--red);border-radius:4px;padding:2px 8px;font-size:9px;font-weight:600;cursor:pointer;margin-left:auto;">✕ Eliminar</button>
      </div>
    </div>
  `).join('');
}

function runRestoreFromBuffer(idx) {
  const e = _runBuffer[idx];
  if (!e || !e.fields) return;
  const f = e.fields;
  if (f['itsm-catalogo']) document.getElementById('itsm-catalogo').value = f['itsm-catalogo'];
  if (f['itsm-canal']) document.getElementById('itsm-canal').value = f['itsm-canal'];
  if (f['itsm-impacto']) document.getElementById('itsm-impacto').value = f['itsm-impacto'];
  if (f['itsm-urgencia']) document.getElementById('itsm-urgencia').value = f['itsm-urgencia'];
  if (f['itsm-sla']) document.getElementById('itsm-sla').value = f['itsm-sla'];
  if (f['itsm-servicio']) document.getElementById('itsm-servicio').value = f['itsm-servicio'];
  if (f['itsm-reporter']) document.getElementById('itsm-reporter').value = f['itsm-reporter'];
  if (f['itsm-ci']) document.getElementById('itsm-ci').value = f['itsm-ci'];
  if (f['itsm-impacto-neg']) document.getElementById('itsm-impacto-neg').value = f['itsm-impacto-neg'];
  if (f['run-input']) document.getElementById('run-input').value = f['run-input'];
  itsmCalcPriority();
  if (f['itsm-catalogo']) itsmCatalogoChanged();
  showToast('Incidencia restaurada en el formulario');
}

function runRerunFromBuffer(idx) {
  runRestoreFromBuffer(idx);
  const desc = document.getElementById('run-input').value.trim();
  if (!desc) { showToast('Sin descripción para ejecutar'); return; }
  const prio = document.getElementById('itsm-prio-calc').textContent || 'P3';
  const enriched = `[RE-RUN ${_runBuffer[idx].id}] ${prio} | ${desc}`;
  document.getElementById('run-input').value = enriched;
  showToast('Re-ejecutando pipeline (sin duplicar registro)');
  executePipeline('run');
}

async function runDeletePlan(idx) {
  const e = _runBuffer[idx];
  if (!e) return;
  if (!confirm(`¿Eliminar la incidencia registrada?\n\n"${e.nombre.substring(0,60)}"\nID: ${e.id}\n\nEsta acción no se puede deshacer.`)) return;
  if (e.fromDB && e.id) {
    try { await authFetch(API_BASE + '/run/plans/' + encodeURIComponent(e.id), {method:'DELETE'}); } catch(ex) {}
  }
  _runBuffer.splice(idx, 1);
  renderRunBuffer();
  showToast('Incidencia eliminada');
}

// Load catalog + inject agent icons + run buffer + CMDB dropdown
setTimeout(() => {
  loadItsmCatalog();
  loadRunPlansFromDB();
  loadCmdbSelect('itsm-ci');
  loadCmdbSelect('bf-cmdb-activos', true);
  // Inject agent SVG icons into idle flow diagrams
  const runIconMap = {1:'AG1',2:'AG2',3:'AG3',4:'AG4'};
  const buildIconMap = {1:'AG5',2:'AG6',3:'AG7'};
  Object.entries(runIconMap).forEach(([n,agId]) => {
    const el = document.getElementById('run-flow-icon-'+n);
    if (el && AGENT_ICONS[agId]) el.innerHTML = AGENT_ICONS[agId].replace(/width:40px;height:40px/g,'width:30px;height:30px');
  });
  Object.entries(buildIconMap).forEach(([n,agId]) => {
    const el = document.getElementById('build-flow-icon-'+n);
    if (el && AGENT_ICONS[agId]) el.innerHTML = AGENT_ICONS[agId].replace(/width:40px;height:40px/g,'width:30px;height:30px');
  });
}, 300);

// ══════════════════ RUN DASHBOARD VISUAL ══════════════════
var _runSlaTimer = null;

async function executeRunPipeline(text) {
  var execBtn = document.getElementById('run-exec-btn');
  var statusEl = document.getElementById('run-status-val');
  if (execBtn) execBtn.disabled = true;
  if (statusEl) { statusEl.textContent = 'Running'; statusEl.style.color = 'var(--blue)'; }

  var area = document.getElementById('run-pipeline-area');
  var idleEl = document.getElementById('run-pipeline-idle');
  if (idleEl) idleEl.style.display = 'none';
  var oldSteps = document.getElementById('run-steps');
  if (oldSteps) oldSteps.remove();

  var dashboard = document.createElement('div');
  dashboard.className = 'run-dashboard';
  dashboard.id = 'run-steps';
  area.appendChild(dashboard);

  var pipeline = createAnimatedPipeline(['AG-001', 'AG-002', 'AG-004', 'AG-012']);
  dashboard.appendChild(pipeline);

  var slaArea = document.createElement('div');
  slaArea.id = 'run-sla-area';
  dashboard.appendChild(slaArea);

  var progressArea = document.createElement('div');
  progressArea.id = 'run-progress';
  dashboard.appendChild(progressArea);

  var logContainer = document.createElement('div');
  var logTitle = document.createElement('div');
  logTitle.className = 'build-section-title';
  logTitle.textContent = 'Panel de actividad';
  var logBox = document.createElement('div');
  logBox.className = 'build-log';
  logBox.id = 'run-live-log';
  logContainer.appendChild(logTitle);
  logContainer.appendChild(logBox);
  dashboard.appendChild(logContainer);

  var sessionId = 'run-' + Date.now();
  var startTime = Date.now();
  function elapsed() {
    var s = Math.floor((Date.now() - startTime) / 1000);
    var m = Math.floor(s / 60); s = s % 60;
    return (m < 10 ? '0' + m : m) + ':' + (s < 10 ? '0' + s : s);
  }
  function addLog(agent, cls, msg, isTool) {
    var log = document.getElementById('run-live-log');
    if (!log) return;
    var entry = document.createElement('div');
    entry.className = 'build-log-entry';
    var ts = document.createElement('span'); ts.className = 'build-log-time'; ts.textContent = elapsed();
    var ag = document.createElement('span'); ag.className = 'build-log-agent ' + cls; ag.textContent = agent;
    var mg = document.createElement('span'); if (isTool) mg.className = 'build-log-tool'; mg.textContent = msg;
    entry.appendChild(ts); entry.appendChild(ag); entry.appendChild(mg);
    log.appendChild(entry); log.scrollTop = log.scrollHeight;
  }
  function addPreview(title, color, content) {
    var w = document.createElement('div');
    var t = document.createElement('div'); t.className = 'build-section-title'; t.style.color = color; t.textContent = title;
    var b = document.createElement('div');
    b.style.cssText = 'background:#22262e;border:1px solid #333840;border-left:3px solid ' + color + ';border-radius:8px;padding:12px;margin-bottom:12px;max-height:180px;overflow-y:auto;font-size:12px;color:#b0b4bc;white-space:pre-wrap;';
    b.textContent = content.substring(0, 2000);
    w.appendChild(t); w.appendChild(b); progressArea.appendChild(w);
  }

  var slaTimerId = null;
  var globalPrio = 'P3';
  var globalSlaHours = 24;

  try {
    addLog('AG-001', 'dispatcher', 'Incidencia recibida. Clasificando...', false);
    addLog('AG-001', 'dispatcher', 'tool: query_catalogo()', true);

    var resp1 = await authFetch(API_BASE + '/agents/AG-001/invoke', {
      method: 'POST', headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({message: text, session_id: sessionId})
    });
    var r1 = await resp1.json();
    if (!resp1.ok) throw new Error(r1.detail || 'AG-001 error');
    var result1 = r1.response || r1.result || '';

    setAgentState('AG-001', 'done', '\u2713');
    setAgentState('AG-002', 'active');
    addLog('AG-001', 'dispatcher', 'Clasificada. Tareas creadas.', false);

    var prioMatch = result1.match(/\b(P[1-4])\b/);
    globalPrio = prioMatch ? prioMatch[1] : 'P3';
    var slaMap = {P1: 4, P2: 8, P3: 24, P4: 72};
    globalSlaHours = slaMap[globalPrio] || 24;

    var now = new Date();
    var slaLimite = new Date(now.getTime() + globalSlaHours * 3600000);
    var prioColor = globalPrio === 'P1' ? '#ef4444' : globalPrio === 'P2' ? '#eab308' : '#3b82f6';
    var inicioStr = now.toLocaleString('es-ES', {day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'});
    var limiteStr = slaLimite.toLocaleString('es-ES', {day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'});

    var slaBox = document.createElement('div');
    slaBox.style.cssText = 'display:flex;align-items:center;gap:20px;padding:16px 20px;border:1px solid ' + prioColor + '40;border-radius:10px;margin-bottom:12px;background:linear-gradient(90deg,' + prioColor + '10,transparent);';
    slaBox.innerHTML = '<div><div id="sla-countdown" style="font-size:36px;font-weight:700;font-family:monospace;letter-spacing:2px;color:' + prioColor + ';">--:--:--</div><div style="font-size:11px;color:#8b8f98;">Tiempo restante SLA</div></div>' +
      '<div style="flex:1"><div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:6px;"><span style="color:#8b8f98">Inicio: ' + inicioStr + '</span><span style="font-weight:600">L\u00edmite: ' + limiteStr + '</span></div>' +
      '<div style="height:6px;background:#181b20;border-radius:3px;overflow:hidden;margin-bottom:4px;"><div id="sla-progress" style="height:100%;border-radius:3px;background:' + prioColor + ';width:0%;transition:width 1s;"></div></div>' +
      '<div style="display:flex;justify-content:space-between;font-size:11px;"><span id="sla-pct" style="color:#8b8f98">0% consumido</span><span style="color:' + prioColor + ';font-weight:600;">' + globalPrio + ' \u2014 SLA: ' + globalSlaHours + 'h</span></div></div>';
    slaArea.appendChild(slaBox);

    var totalMs = slaLimite.getTime() - now.getTime();
    slaTimerId = setInterval(function() {
      var rem = slaLimite.getTime() - Date.now();
      var el = Date.now() - now.getTime();
      var pct = Math.min(100, Math.round((el / totalMs) * 100));
      var cd = document.getElementById('sla-countdown');
      if (!cd) { clearInterval(slaTimerId); return; }
      if (rem <= 0) { cd.textContent='00:00:00'; clearInterval(slaTimerId); return; }
      var h=Math.floor(rem/3600000),m2=Math.floor((rem%3600000)/60000),s2=Math.floor((rem%60000)/1000);
      cd.textContent=(h<10?'0'+h:h)+':'+(m2<10?'0'+m2:m2)+':'+(s2<10?'0'+s2:s2);
      var pg=document.getElementById('sla-progress'); if(pg) pg.style.width=pct+'%';
      var pc=document.getElementById('sla-pct'); if(pc) pc.textContent=pct+'% consumido';
    }, 1000);

    // AG-001 formatted fields
    var dispDiv = document.createElement('div');
    var dispTitle = document.createElement('div');
    dispTitle.className = 'build-section-title'; dispTitle.style.color = '#3b82f6';
    dispTitle.textContent = 'AG-001 Dispatcher \u2014 Clasificaci\u00f3n';
    dispDiv.appendChild(dispTitle);
    var ticketMatch = result1.match(/INC-[\w-]+/);
    var ticketId = ticketMatch ? ticketMatch[0] : '';
    var areaMatch = result1.match(/[Áá]rea[:\s]*([^\n*]+)/i);
    var areaVal = areaMatch ? areaMatch[1].replace(/\*/g,'').trim() : '';
    var tareasMatch = result1.match(/(\d+)\s*tareas/i);
    var numTareas = tareasMatch ? tareasMatch[1] : '';
    var matchCat = result1.match(/[Mm]atch[:\s]*(\d+)%/);
    var matchPct = matchCat ? matchCat[1] + '%' : '';
    var fieldsGrid = document.createElement('div'); fieldsGrid.className = 'build-summary';
    var fieldsInner = document.createElement('div'); fieldsInner.className = 'build-summary-grid';
    function addField(label, value, color) {
      var item = document.createElement('div'); item.className = 'build-summary-item';
      var lbl = document.createElement('div'); lbl.className = 'bsi-label'; lbl.textContent = label;
      var val = document.createElement('div'); val.className = 'bsi-value'; if (color) val.style.color = color; val.textContent = value || '\u2014';
      item.appendChild(lbl); item.appendChild(val); fieldsInner.appendChild(item);
    }
    addField('Ticket', ticketId, '#3b82f6');
    addField('Prioridad', globalPrio, globalPrio === 'P1' ? '#ef4444' : globalPrio === 'P2' ? '#eab308' : '#3b82f6');
    addField('SLA', globalSlaHours + ' horas', '#ef4444');
    addField('Match cat\u00e1logo', matchPct, '#22c55e');
    addField('\u00c1rea', areaVal, null);
    addField('Tareas', numTareas + ' multi-silo', null);
    fieldsGrid.appendChild(fieldsInner);
    var impactoMatch = result1.match(/[Ii]mpacto[:\s]*([^\n]+)/);
    if (impactoMatch) {
      var impDiv = document.createElement('div'); impDiv.style.cssText = 'margin-top:8px;padding-top:8px;border-top:1px solid #333840;font-size:12px;color:#8b8f98;';
      impDiv.textContent = impactoMatch[1].replace(/\*/g,'').trim(); fieldsGrid.appendChild(impDiv);
    }
    dispDiv.appendChild(fieldsGrid); progressArea.appendChild(dispDiv);

    // Read tasks from DB for AG-002 context
    var tasksContext = '';
    try {
      var tasksForAG002 = await authFetch(API_BASE + '/kanban/tareas');
      var allTForAG002 = await tasksForAG002.json();
      var recentT = allTForAG002.filter(function(t) { return t.fecha_creacion && new Date(t.fecha_creacion) > new Date(Date.now() - 120000); });
      if (recentT.length > 0) {
        tasksContext = '\n\nTareas creadas por AG-001:\n';
        recentT.forEach(function(t) {
          var d2 = {}; try { d2 = JSON.parse(t.descripcion || '{}'); } catch(e) {}
          tasksContext += 'task_id:' + t.id + ' | ' + t.titulo + ' | silo:' + (d2.silo || 'Soporte') + ' | skill:' + (d2.skill_requerida || '') + ' | sla_min:' + (d2.sla_tarea_minutos || 60) + ' | ticket:' + (ticketId || '') + '\n';
        });
      }
    } catch(ex) {}

    addLog('AG-002', 'resource', 'Buscando t\u00e9cnicos (' + recentT.length + ' tareas)...', false);
    addLog('AG-002', 'resource', 'tool: query_staff_by_skill()', true);

    var resp2 = await authFetch(API_BASE + '/agents/AG-002/invoke', {
      method: 'POST', headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({message: 'Resultado del Dispatcher:\n' + result1.substring(0, 800) + tasksContext, session_id: sessionId})
    });
    var r2 = await resp2.json();
    if (!resp2.ok) throw new Error(r2.detail || 'AG-002 error');
    var result2 = r2.response || r2.result || '';

    var needsBuffer = result2.toLowerCase().indexOf('needs_buffer') >= 0 || result2.indexOf('IMPOSIBLE') >= 0;

    if (needsBuffer) {
      setAgentState('AG-002', 'done', '\u2713');
      setAgentState('AG-004', 'active');
      addLog('AG-002', 'resource', 'Escalando al Buffer...', false);
    } else {
      setAgentState('AG-002', 'done', '\u2713');
      var st004 = document.getElementById('step-AG-004');
      if (st004) { st004.className = 'agent-step waiting'; st004.style.opacity = '0.3'; }
      var s004 = document.getElementById('status-AG-004');
      if (s004) { s004.textContent = 'No requerido'; s004.style.display = 'block'; s004.style.color = '#8b8f98'; }
      addLog('AG-002', 'resource', 'Candidatos propuestos.', false);
    }
    // Parse and render AG-002 candidates
    var candidatesDiv = document.createElement('div');
    var candTitle = document.createElement('div');
    candTitle.className = 'build-section-title';
    candTitle.style.color = '#a855f7';
    candTitle.textContent = 'AG-002 Resource Manager \u2014 Selecciona t\u00e9cnicos';
    candidatesDiv.appendChild(candTitle);

    var candidatesTasks = [];
    // Strategy 1: Find JSON array between ```json and ```
    var codeBlockMatch = result2.match(/```json\s*([\s\S]*?)```/);
    if (codeBlockMatch) {
      try { candidatesTasks = JSON.parse(codeBlockMatch[1].trim()); } catch(e) {}
    }
    // Strategy 2: Find standalone JSON array by tracking bracket depth
    if (!candidatesTasks.length) {
      try {
        var lines = result2.split('\n');
        var jsonLines = [];
        var depth = 0;
        var capturing = false;
        for (var li = 0; li < lines.length; li++) {
          var line = lines[li];
          if (!capturing && line.trim().charAt(0) === '[') { capturing = true; }
          if (capturing) {
            jsonLines.push(line);
            for (var ci = 0; ci < line.length; ci++) {
              if (line[ci] === '[' || line[ci] === '{') depth++;
              if (line[ci] === ']' || line[ci] === '}') depth--;
            }
            if (depth <= 0 && jsonLines.length > 1) {
              try { candidatesTasks = JSON.parse(jsonLines.join('\n')); } catch(e2) {}
              if (candidatesTasks.length) break;
              jsonLines = []; depth = 0; capturing = false;
            }
          }
        }
      } catch(ex) {}
    }
    // Strategy 3: Extract individual task objects with candidatos
    if (!candidatesTasks.length) {
      try {
        var objMatches = result2.match(/\{[^{}]*"tarea"[^{}]*"candidatos"\s*:\s*\[[^\]]*\][^{}]*\}/g);
        if (objMatches) {
          candidatesTasks = objMatches.map(function(m) { try { return JSON.parse(m); } catch(e) { return null; } }).filter(Boolean);
        }
      } catch(ex3) {}
    }

    if (candidatesTasks.length > 0) {
      candidatesTasks.forEach(function(task) {
        var taskCard = document.createElement('div');
        taskCard.className = 'run-cand-task';
        var taskHead = document.createElement('div');
        taskHead.className = 'run-cand-task-head';
        var taskTitle = document.createElement('span');
        taskTitle.className = 'run-cand-task-title';
        taskTitle.textContent = task.tarea || '';
        var siloTag = document.createElement('span');
        var siloName = (task.silo || 'Soporte').toLowerCase();
        var siloClass = 'run-cand-silo silo-' + (siloName === 'base de datos' || siloName === 'bbdd' ? 'bbdd' : siloName === 'redes' ? 'redes' : siloName === 'unix' || siloName === 'linux' ? 'unix' : siloName === 'windows' ? 'win' : siloName === 'seguridad' ? 'seg' : siloName === 'backend' ? 'backend' : 'soporte');
        siloTag.className = siloClass;
        siloTag.textContent = task.silo || 'Soporte';
        var miniSla = document.createElement('span');
        miniSla.className = 'run-cand-mini-sla';
        var slaMins = task.sla_tarea_minutos || 60;
        miniSla.textContent = 'SLA: ' + Math.floor(slaMins/60) + 'h ' + (slaMins%60) + 'min';
        taskHead.appendChild(taskTitle);
        taskHead.appendChild(siloTag);
        taskHead.appendChild(miniSla);
        taskCard.appendChild(taskHead);
        var candList = document.createElement('div');
        candList.style.cssText = 'display:flex;flex-direction:column;gap:4px;';
        (task.candidatos || []).forEach(function(cand) {
          var item = document.createElement('div');
          item.className = 'run-cand-item' + (cand.recomendado ? ' recommended' : '');
          var avatar = document.createElement('div');
          avatar.className = 'run-cand-avatar';
          avatar.style.cssText = 'background:rgba(34,197,94,.2);color:#22c55e;';
          avatar.textContent = (cand.nombre || '??').split(' ').map(function(w){return w[0]||'';}).join('').substring(0,2);
          var info = document.createElement('div'); info.style.flex = '1';
          var name = document.createElement('div'); name.className = 'run-cand-name'; name.textContent = cand.nombre || cand.id || '';
          var detail = document.createElement('div'); detail.className = 'run-cand-detail';
          detail.textContent = (cand.nivel || '') + ' | ' + (cand.silo || '') + ' | Carga: ' + (cand.carga || 0) + 'h';
          info.appendChild(name); info.appendChild(detail);
          var score = document.createElement('div'); score.className = 'run-cand-score';
          score.style.color = (cand.score || 0) >= 80 ? '#22c55e' : (cand.score || 0) >= 60 ? '#eab308' : '#8b8f98';
          score.textContent = (cand.score || 0);
          var btn = document.createElement('button'); btn.className = 'run-cand-btn'; btn.textContent = 'Elegir';
          btn.onclick = function() {
            if (cand.id && task.task_id) {
              authFetch(API_BASE + '/asignar/tecnico', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({task_id:task.task_id,id_recurso:cand.id,ticket_id:task.ticket_id||''})}).catch(function(){});
            }
            btn.textContent = '\u2713 Asignado';
            btn.className = 'run-cand-btn assigned';
            item.className = 'run-cand-item selected';
            candList.querySelectorAll('.run-cand-item').forEach(function(other) { if (other !== item) other.style.opacity = '0.4'; });
            var allKanbanCards = document.querySelectorAll('.build-kanban-card .bkc-title');
            allKanbanCards.forEach(function(cardTitle) {
              var tarea = (task.tarea || '').replace(/^T\d+:\s*/, '').substring(0, 15);
              if (tarea && cardTitle.textContent.indexOf(tarea) >= 0) {
                var parentCard = cardTitle.parentElement;
                var existing = parentCard.querySelector('.bkc-tech-assigned');
                if (existing) existing.remove();
                var techTag = document.createElement('div'); techTag.className = 'bkc-tech-assigned';
                techTag.style.cssText = 'font-size:9px;color:#22c55e;margin-top:2px;';
                techTag.textContent = '\u2713 ' + (cand.nombre || cand.id);
                parentCard.appendChild(techTag);
              }
            });
          };
          item.appendChild(avatar); item.appendChild(info); item.appendChild(score); item.appendChild(btn);
          candList.appendChild(item);
        });
        taskCard.appendChild(candList);
        candidatesDiv.appendChild(taskCard);
      });
    } else {
      addPreview('AG-002 Resource Manager \u2014 Candidatos', '#a855f7', result2);
    }
    progressArea.appendChild(candidatesDiv);

    var finalResult = result2;
    if (needsBuffer) {
      addLog('AG-004', 'buffer', 'Evaluando RUN vs BUILD...', false);
      var resp4 = await authFetch(API_BASE + '/agents/AG-004/invoke', {
        method: 'POST', headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({message: 'Escalado:\n' + result2.substring(0, 1500), session_id: sessionId})
      });
      var r4 = await resp4.json();
      if (!resp4.ok) throw new Error(r4.detail || 'AG-004 error');
      finalResult = r4.response || r4.result || '';
      setAgentState('AG-004', 'done', '\u2713');
      addLog('AG-004', 'buffer', 'Reasignaci\u00f3n completada.', false);
      addPreview('AG-004 Buffer \u2014 Decisi\u00f3n', '#06b6d4', finalResult);
    }

    // ═══ AG-012 TASK ADVISOR ═══
    setAgentState('AG-012', 'active');
    addLog('AG-012', 'advisor', 'Enriqueciendo tarjetas con instrucciones t\u00e9cnicas...', false);
    addLog('AG-012', 'advisor', 'tool: query_cmdb_activo()', true);
    try {
      var tkResp012 = await authFetch(API_BASE + '/kanban/tareas');
      var allTk012 = await tkResp012.json();
      var recentTasks012 = allTk012.filter(function(t) {
        return t.fecha_creacion && new Date(t.fecha_creacion) > new Date(Date.now() - 300000);
      });
      if (recentTasks012.length > 0) {
        var taskSummary = recentTasks012.map(function(t) { return t.id + ': ' + t.titulo; }).join('\n');
        var resp12 = await authFetch(API_BASE + '/agents/AG-012/invoke', {
          method: 'POST', headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({message: 'Enriquece estas tarjetas:\n' + taskSummary.substring(0, 1500), session_id: sessionId})
        });
        if (resp12.ok) addLog('AG-012', 'advisor', 'Instrucciones generadas para ' + recentTasks012.length + ' tarjetas.', false);
      }
    } catch(ex12) {
      addLog('AG-012', 'advisor', 'Completado con warnings.', false);
    }
    setAgentState('AG-012', 'done', '\u2713');

    setPipelineComplete(true);
    addLog('CHAIN', 'dispatcher', 'Pipeline RUN completado en ' + elapsed(), false);

    try {
      var tkResp = await authFetch(API_BASE + '/kanban/tareas');
      var allTasks = await tkResp.json();
      var recent = allTasks.filter(function(t) { return t.fecha_creacion && new Date(t.fecha_creacion) > new Date(Date.now() - 300000); });
      if (recent.length > 0) {
        var kanbanTitle = document.createElement('div'); kanbanTitle.className = 'build-section-title';
        kanbanTitle.textContent = 'Tarjetas Kanban - Clic para expandir instrucciones';
        progressArea.appendChild(kanbanTitle);
        var kanbanGrid = document.createElement('div'); kanbanGrid.className = 'build-kanban';
        var colNames = ['Backlog', 'En Progreso', 'En Revisi\u00f3n', 'Done'];
        var cols = {}; colNames.forEach(function(cn) { cols[cn] = []; });
        recent.forEach(function(t) { var c = cols[t.columna] ? t.columna : 'Backlog'; cols[c].push(t); });
        colNames.forEach(function(cn) {
          var col = document.createElement('div'); col.className = 'build-kanban-col';
          var header = document.createElement('div'); header.className = 'build-kanban-header'; header.textContent = cn;
          var body = document.createElement('div'); body.className = 'build-kanban-body';
          (cols[cn] || []).forEach(function(t) {
            var card = document.createElement('div'); card.className = 'build-kanban-card';
            card.dataset.taskId = t.id;
            var tDesc = {}; try { tDesc = JSON.parse(t.descripcion || '{}'); } catch(e) {}
            var tSilo = (tDesc.silo || 'Soporte').toLowerCase();
            var siloColor = tSilo === 'redes' ? '#06b6d4' : tSilo === 'bbdd' ? '#a855f7' : (tSilo === 'unix' || tSilo === 'linux') ? '#22c55e' : tSilo === 'windows' ? '#3b82f6' : tSilo === 'seguridad' ? '#ef4444' : tSilo === 'backend' ? '#f97316' : '#8b8f98';
            card.style.borderLeftColor = siloColor;
            var tDiv = document.createElement('div'); tDiv.className = 'bkc-title'; tDiv.textContent = (t.titulo || '').substring(0, 45);
            card.appendChild(tDiv);
            var mDiv = document.createElement('div'); mDiv.className = 'bkc-meta';
            var pb = document.createElement('span'); pb.style.cssText = 'font-size:9px;font-weight:700;padding:1px 5px;border-radius:3px;background:rgba(239,68,68,.2);color:#ef4444;'; pb.textContent = globalPrio;
            mDiv.appendChild(pb);
            var siloSpan = document.createElement('span'); siloSpan.className = 'bkc-silo';
            siloSpan.style.cssText = 'background:' + siloColor + '20;color:' + siloColor + ';'; siloSpan.textContent = tDesc.silo || 'Soporte';
            mDiv.appendChild(siloSpan);
            if (t.id_tecnico) { var ts2 = document.createElement('span'); ts2.style.cssText = 'font-size:9px;color:#22c55e;'; ts2.textContent = t.id_tecnico; mDiv.appendChild(ts2); }
            card.appendChild(mDiv);
            var taskSlaMins2 = tDesc.sla_tarea_minutos || 0;
            if (taskSlaMins2 > 0) { var slaDiv = document.createElement('div'); slaDiv.className = 'bkc-sla'; slaDiv.textContent = '\u23f1 ' + Math.floor(taskSlaMins2/60) + 'h ' + (taskSlaMins2%60) + 'min'; card.appendChild(slaDiv); }
            card.onclick = function() { toggleRunTaskDetail(t.id, progressArea); };
            body.appendChild(card);
          });
          col.appendChild(header); col.appendChild(body); kanbanGrid.appendChild(col);
        });
        progressArea.appendChild(kanbanGrid);
        var detailPanel = document.createElement('div'); detailPanel.id = 'run-task-detail-panel';
        progressArea.appendChild(detailPanel);
      }
    } catch(ex) {}

  } catch(e) {
    addLog('ERROR', 'dispatcher', e.message, false);
    setPipelineComplete(false);
  }
  if (execBtn) execBtn.disabled = false;
  if (statusEl) { statusEl.textContent = 'Idle'; statusEl.style.color = 'var(--yellow)'; }
}

function toggleRunTaskDetail(taskId, container) {
  var existing = document.getElementById('run-task-modal-overlay');
  if (existing) { if (existing.dataset.taskId === taskId) { existing.remove(); return; } existing.remove(); }
  authFetch(API_BASE + '/kanban/tareas').then(function(r) { return r.json(); }).then(function(tasks) {
    var task = tasks.find(function(t) { return t.id === taskId; });
    if (!task) return;
    var desc = {}; try { desc = JSON.parse(task.descripcion || '{}'); } catch(e) {}
    var cmdbItems = (desc.contexto_cmdb && desc.contexto_cmdb.items) || [];
    var instrucciones = desc.instrucciones || [];
    var checklist = desc.checklist || [];
    var silo = desc.silo || 'Soporte';
    var slaTarea = desc.sla_tarea_minutos || 60;
    var overlay = document.createElement('div'); overlay.className = 'run-modal-overlay';
    overlay.id = 'run-task-modal-overlay'; overlay.dataset.taskId = taskId;
    overlay.onclick = function(e) { if (e.target === overlay) overlay.remove(); };
    var modal = document.createElement('div'); modal.className = 'run-modal-content';
    // Header
    var head = document.createElement('div'); head.style.cssText = 'padding:14px 16px;border-bottom:1px solid #333840;display:flex;justify-content:space-between;align-items:center;';
    var headLeft = document.createElement('div'); headLeft.style.cssText = 'display:flex;align-items:center;gap:8px;';
    var titleSpan = document.createElement('span'); titleSpan.style.cssText = 'font-weight:600;font-size:15px;'; titleSpan.textContent = task.titulo || '';
    var sk = (silo || 'soporte').toLowerCase().replace('base de datos','bbdd');
    sk = sk === 'bbdd' ? 'bbdd' : sk === 'redes' ? 'redes' : (sk === 'unix' || sk === 'linux') ? 'unix' : sk === 'windows' ? 'win' : sk === 'seguridad' ? 'seg' : 'soporte';
    var siloTag = document.createElement('span'); siloTag.className = 'run-cand-silo silo-' + sk; siloTag.textContent = silo;
    headLeft.appendChild(titleSpan); headLeft.appendChild(siloTag);
    var headRight = document.createElement('div'); headRight.style.cssText = 'display:flex;align-items:center;gap:12px;';
    var pctSpan = document.createElement('span'); pctSpan.id = 'modal-pct-' + taskId;
    pctSpan.style.cssText = 'font-size:22px;font-weight:700;font-family:monospace;color:#22c55e;'; pctSpan.textContent = '0%';
    var closeBtn = document.createElement('button'); closeBtn.style.cssText = 'background:none;border:1px solid #333840;color:#8b8f98;padding:5px 14px;border-radius:6px;cursor:pointer;font-size:12px;';
    closeBtn.textContent = 'Cerrar'; closeBtn.onclick = function() { overlay.remove(); };
    headRight.appendChild(pctSpan); headRight.appendChild(closeBtn);
    head.appendChild(headLeft); head.appendChild(headRight); modal.appendChild(head);
    // SLA countdown
    var slaBox = document.createElement('div'); slaBox.className = 'run-modal-sla-box';
    var slaLeft = document.createElement('div');
    var slaCd = document.createElement('div'); slaCd.className = 'run-modal-sla-countdown'; slaCd.id = 'modal-sla-cd-' + taskId; slaCd.textContent = '--:--:--';
    var slaLbl = document.createElement('div'); slaLbl.className = 'run-modal-sla-meta'; slaLbl.textContent = 'SLA tarea restante';
    slaLeft.appendChild(slaCd); slaLeft.appendChild(slaLbl);
    var slaRight = document.createElement('div'); slaRight.style.flex = '1';
    var slaEndTime = new Date(Date.now() + slaTarea * 60000);
    var endStr = slaEndTime.toLocaleString('es-ES', {day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'});
    var slaEnd = document.createElement('div'); slaEnd.className = 'run-modal-sla-end'; slaEnd.textContent = 'L\u00edmite: ' + endStr;
    var slaDur = document.createElement('div'); slaDur.className = 'run-modal-sla-meta';
    slaDur.textContent = 'Duraci\u00f3n: ' + Math.floor(slaTarea/60) + 'h ' + (slaTarea%60) + 'min';
    var slaBar = document.createElement('div'); slaBar.style.cssText = 'height:4px;background:#181b20;border-radius:2px;margin-top:6px;overflow:hidden;';
    var slaFill = document.createElement('div'); slaFill.id = 'modal-sla-bar-' + taskId;
    slaFill.style.cssText = 'height:100%;border-radius:2px;background:#ef4444;width:0%;transition:width 1s;';
    slaBar.appendChild(slaFill); slaRight.appendChild(slaEnd); slaRight.appendChild(slaDur); slaRight.appendChild(slaBar);
    slaBox.appendChild(slaLeft); slaBox.appendChild(slaRight); modal.appendChild(slaBox);
    var slaStart = Date.now(); var slaTotalMs = slaTarea * 60000;
    var miniTimer = setInterval(function() {
      var rem = slaTotalMs - (Date.now() - slaStart); var pct = Math.min(100, Math.round(((Date.now()-slaStart)/slaTotalMs)*100));
      var cd = document.getElementById('modal-sla-cd-' + taskId); var bar = document.getElementById('modal-sla-bar-' + taskId);
      if (!cd) { clearInterval(miniTimer); return; }
      if (rem <= 0) { cd.textContent = '00:00:00'; if(bar) bar.style.width='100%'; clearInterval(miniTimer); return; }
      var h=Math.floor(rem/3600000),m2=Math.floor((rem%3600000)/60000),s2=Math.floor((rem%60000)/1000);
      cd.textContent = (h<10?'0'+h:h)+':'+(m2<10?'0'+m2:m2)+':'+(s2<10?'0'+s2:s2);
      if(bar) bar.style.width = pct+'%';
    }, 1000);
    // Body
    var body = document.createElement('div'); body.style.padding = '14px 16px';
    if (task.id_tecnico) {
      var td = document.createElement('div'); td.style.cssText = 'display:flex;align-items:center;gap:10px;padding:8px 12px;background:rgba(34,197,94,.06);border:1px solid rgba(34,197,94,.2);border-radius:8px;margin-bottom:12px;';
      var av = document.createElement('div'); av.style.cssText = 'width:32px;height:32px;border-radius:50%;background:rgba(34,197,94,.2);color:#22c55e;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:11px;';
      av.textContent = (task.id_tecnico||'').substring(0,3);
      var ti2 = document.createElement('span'); ti2.style.fontSize = '12px';
      ti2.textContent = task.id_tecnico + (task.nombre_tecnico ? ' \u2014 ' + task.nombre_tecnico : '') + ' \u2014 Silo: ' + silo;
      td.appendChild(av); td.appendChild(ti2); body.appendChild(td);
    }
    if (cmdbItems.length > 0) {
      var ct = document.createElement('div'); ct.style.cssText = 'font-size:10px;font-weight:600;color:#8b8f98;text-transform:uppercase;margin:10px 0 6px;'; ct.textContent = 'Contexto infraestructura (CMDB + IA)';
      body.appendChild(ct);
      var grid = document.createElement('div'); grid.className = 'run-infra-grid';
      cmdbItems.forEach(function(item) {
        var cell = document.createElement('div'); cell.className = 'run-infra-item';
        var lbl = document.createElement('div'); lbl.className = 'run-infra-label'; lbl.textContent = item.campo || '';
        var val = document.createElement('div'); val.className = 'run-infra-val';
        if ((item.campo||'').toLowerCase().indexOf('ip') >= 0) val.classList.add('ip');
        else if ((item.campo||'').toLowerCase().indexOf('serv') >= 0) val.classList.add('host');
        if (item.source === 'IA') val.classList.add('suggest');
        val.textContent = item.valor || '';
        var src = document.createElement('span'); src.className = item.source==='CMDB'?'run-src-tag run-src-cmdb':'run-src-tag run-src-ia'; src.textContent = item.source||'IA';
        val.appendChild(src); cell.appendChild(lbl); cell.appendChild(val); grid.appendChild(cell);
      });
      body.appendChild(grid);
    }
    if (instrucciones.length > 0) {
      var st = document.createElement('div'); st.style.cssText = 'font-size:10px;font-weight:600;color:#8b8f98;text-transform:uppercase;margin:10px 0 6px;'; st.textContent = 'Instrucciones paso a paso';
      body.appendChild(st);
      instrucciones.forEach(function(inst, idx) {
        var step = document.createElement('div'); step.className = 'run-step';
        var num = document.createElement('div'); num.className = 'run-step-n'; num.textContent = String(idx+1);
        var cnt = document.createElement('div'); cnt.style.flex = '1';
        var stT = document.createElement('div'); stT.className = 'run-step-t'; stT.textContent = inst.titulo || ''; cnt.appendChild(stT);
        if (inst.detalle) { var det = document.createElement('div'); det.style.cssText = 'font-size:11px;color:#8b8f98;margin:2px 0;'; det.textContent = inst.detalle; cnt.appendChild(det); }
        (inst.comandos||[]).forEach(function(cmd) { var c = document.createElement('code'); c.className = 'run-cmd'; c.textContent = cmd; cnt.appendChild(c); });
        step.appendChild(num); step.appendChild(cnt); body.appendChild(step);
      });
    }
    if (checklist.length > 0) {
      var total = checklist.length;
      var chH = document.createElement('div'); chH.style.cssText = 'font-size:10px;font-weight:600;color:#8b8f98;text-transform:uppercase;margin:10px 0 6px;display:flex;justify-content:space-between;';
      var chL = document.createElement('span'); chL.textContent = 'Checklist';
      var chC = document.createElement('span'); chC.id = 'modal-chk-' + taskId; chC.style.color = '#22c55e'; chC.textContent = '(0/' + total + ')';
      chH.appendChild(chL); chH.appendChild(chC); body.appendChild(chH);
      checklist.forEach(function(chkText) {
        var chkDiv = document.createElement('div'); chkDiv.className = 'run-chk';
        var box = document.createElement('div'); box.className = 'run-chk-box';
        box.onclick = function() {
          box.classList.toggle('done'); box.textContent = box.classList.contains('done') ? '\u2713' : '';
          var tx = box.nextElementSibling; if(tx) tx.classList.toggle('done');
          var checked = modal.querySelectorAll('.run-chk-box.done').length;
          var p = Math.round((checked/total)*100);
          var pE = document.getElementById('modal-pct-' + taskId); if(pE) pE.textContent = p+'%';
          var cE = document.getElementById('modal-chk-' + taskId); if(cE) cE.textContent = '('+checked+'/'+total+')';
        };
        var txt = document.createElement('span'); txt.className = 'run-chk-text'; txt.textContent = chkText;
        chkDiv.appendChild(box); chkDiv.appendChild(txt); body.appendChild(chkDiv);
      });
    }
    modal.appendChild(body);
    var statusBar = document.createElement('div'); statusBar.className = 'run-status-bar';
    ['Backlog','En Progreso','En Revisi\u00f3n','Done'].forEach(function(st2) {
      var btn = document.createElement('div'); btn.className = 'run-status-btn';
      if (st2 === (task.columna||'Backlog')) btn.classList.add('current');
      btn.textContent = st2;
      btn.onclick = function() {
        statusBar.querySelectorAll('.run-status-btn').forEach(function(b){b.classList.remove('current');}); btn.classList.add('current');
        authFetch(API_BASE+'/kanban/tareas/'+taskId+'/mover',{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({columna:st2})}).catch(function(){});
        setTimeout(function() {
          var targetCard = document.querySelector('.build-kanban-card[data-task-id="' + taskId + '"]');
          if (!targetCard) {
            var allC = document.querySelectorAll('.build-kanban-card');
            allC.forEach(function(c) { if (c.dataset.taskId === taskId) targetCard = c; });
          }
          if (targetCard) {
            var colHeaders = document.querySelectorAll('.build-kanban-header');
            var colBodies = document.querySelectorAll('.build-kanban-body');
            colHeaders.forEach(function(h, idx) {
              if (h.textContent === st2 && colBodies[idx]) { targetCard.remove(); colBodies[idx].appendChild(targetCard); }
            });
          }
        }, 100);
      };
      statusBar.appendChild(btn);
    });
    modal.appendChild(statusBar);
    if (cmdbItems.length===0 && instrucciones.length===0 && checklist.length===0) {
      var w = document.createElement('div'); w.style.cssText = 'text-align:center;padding:30px;color:#8b8f98;font-style:italic;font-size:13px;';
      w.textContent = 'AG-012 a\u00fan no ha procesado esta tarjeta. Reintenta en unos segundos.';
      body.insertBefore(w, body.firstChild);
    }
    overlay.appendChild(modal); document.body.appendChild(overlay);
  });
}

function _buildPipelineBar(agentsUsed, activeAgent) {
  var allAgents = [
    {id:'AG-001', name:'AG-001 Dispatcher'},
    {id:'AG-002', name:'AG-002 Res. Manager'},
    {id:'AG-004', name:'AG-004 Buffer'}
  ];
  var html = '<div class="run-pipeline-bar">';
  allAgents.forEach(function(a, i) {
    if (i > 0) html += '<span class="arrow-sep">\u25b8</span>';
    var cls = 'agent-pill';
    if (activeAgent === a.id) cls += ' active';
    else if (agentsUsed.indexOf(a.id) >= 0) cls += ' done';
    else if (a.id === 'AG-004' && agentsUsed.indexOf('AG-004') < 0 && agentsUsed.length > 0) cls += ' skipped';
    else cls += ' waiting';
    var label = a.name;
    if (agentsUsed.indexOf(a.id) >= 0) label = '\u2713 ' + a.name;
    else if (a.id === 'AG-004' && agentsUsed.indexOf('AG-004') < 0 && agentsUsed.length > 0) label = a.name + ' (no requerido)';
    html += '<span class="' + cls + '">' + label + '</span>';
  });
  if (agentsUsed.length > 0) {
    html += '<span class="arrow-sep">\u25b8</span><span style="color:#22c55e;font-size:12px;font-weight:600;">\u2713 Completado</span>';
  }
  html += '</div>';
  return html;
}

// ═══ AGENT PIPELINE ICONS & HELPERS ═══
var AGENT_PIPELINE_ICONS = {};
AGENT_PIPELINE_ICONS['AG-001'] = '<svg viewBox="0 0 100 100" width="36" height="36" xmlns="http://www.w3.org/2000/svg"><path d="M50 5 L92 28 V72 L50 95 L8 72 V28 L50 5 Z" fill="none" stroke="currentColor" stroke-width="5"/><path d="M30 35 L45 50 V70 L55 70 V50 L70 35 Z" fill="currentColor"/><circle cx="50" cy="30" r="5" fill="currentColor"/><path d="M25 45 H35" stroke="currentColor" stroke-width="3"/><path d="M65 45 H75" stroke="currentColor" stroke-width="3"/></svg>';
AGENT_PIPELINE_ICONS['AG-002'] = '<svg viewBox="0 0 100 100" width="36" height="36" xmlns="http://www.w3.org/2000/svg"><path d="M50 5 L92 28 V72 L50 95 L8 72 V28 L50 5 Z" fill="none" stroke="currentColor" stroke-width="5"/><circle cx="35" cy="50" r="10" fill="none" stroke="currentColor" stroke-width="5"/><circle cx="65" cy="50" r="10" fill="none" stroke="currentColor" stroke-width="5"/><path d="M45 50 H55" stroke="currentColor" stroke-width="5" stroke-linecap="round"/><circle cx="50" cy="50" r="3" fill="currentColor"/></svg>';
AGENT_PIPELINE_ICONS['AG-004'] = '<svg viewBox="0 0 100 100" width="36" height="36" xmlns="http://www.w3.org/2000/svg"><path d="M50 5 L92 28 V72 L50 95 L8 72 V28 L50 5 Z" fill="none" stroke="currentColor" stroke-width="5"/><rect x="35" y="45" width="30" height="25" rx="2" fill="currentColor"/><path d="M40 45 V35 A10 10 0 0 1 60 35 V45" fill="none" stroke="currentColor" stroke-width="5" stroke-linecap="round"/><circle cx="50" cy="57" r="3" fill="#1a1d23"/></svg>';
AGENT_PIPELINE_ICONS['AG-005'] = '<svg viewBox="0 0 100 100" width="36" height="36" xmlns="http://www.w3.org/2000/svg"><path d="M50 5 L92 28 V72 L50 95 L8 72 V28 L50 5 Z" fill="none" stroke="currentColor" stroke-width="5"/><path d="M30 75 H70 L50 30 Z" fill="none" stroke="currentColor" stroke-width="5" stroke-linejoin="round"/><circle cx="50" cy="20" r="5" fill="currentColor"/><path d="M40 55 H60 M45 45 H55" stroke="currentColor" stroke-width="3"/></svg>';
AGENT_PIPELINE_ICONS['AG-006'] = '<svg viewBox="0 0 100 100" width="36" height="36" xmlns="http://www.w3.org/2000/svg"><path d="M50 5 L92 28 V72 L50 95 L8 72 V28 L50 5 Z" fill="none" stroke="currentColor" stroke-width="5"/><rect x="30" y="30" width="15" height="15" rx="1" fill="currentColor"/><rect x="30" y="50" width="15" height="15" rx="1" fill="currentColor" opacity="0.4"/><rect x="55" y="30" width="15" height="15" rx="1" fill="currentColor" opacity="0.4"/><rect x="55" y="50" width="15" height="15" rx="1" fill="currentColor" opacity="0.4"/><circle cx="75" cy="75" r="5" fill="currentColor"/></svg>';
AGENT_PIPELINE_ICONS['AG-007'] = '<svg viewBox="0 0 100 100" width="36" height="36" xmlns="http://www.w3.org/2000/svg"><path d="M50 5 L92 28 V72 L50 95 L8 72 V28 L50 5 Z" fill="none" stroke="currentColor" stroke-width="5"/><rect x="30" y="35" width="40" height="8" rx="2" fill="currentColor"/><rect x="30" y="50" width="25" height="8" rx="2" fill="currentColor"/><rect x="30" y="65" width="55" height="8" rx="2" fill="currentColor"/></svg>';
AGENT_PIPELINE_ICONS['AG-012'] = '<svg viewBox="0 0 100 100" width="36" height="36" xmlns="http://www.w3.org/2000/svg"><path d="M50 5 L92 28 V72 L50 95 L8 72 V28 L50 5 Z" fill="none" stroke="currentColor" stroke-width="5"/><circle cx="50" cy="45" r="15" fill="none" stroke="currentColor" stroke-width="4"/><path d="M50 30 V25" stroke="currentColor" stroke-width="3"/><path d="M50 60 V65" stroke="currentColor" stroke-width="3"/><path d="M35 45 H30" stroke="currentColor" stroke-width="3"/><path d="M65 45 H70" stroke="currentColor" stroke-width="3"/><circle cx="50" cy="45" r="3" fill="currentColor"/><path d="M50 45 L58 38" stroke="currentColor" stroke-width="2.5"/></svg>';

var AGENT_COLORS_MAP = {
  'AG-001':'#3b82f6','AG-002':'#a855f7','AG-003':'#f97316',
  'AG-004':'#06b6d4','AG-005':'#10b981','AG-006':'#eab308','AG-007':'#ec4899','AG-012':'#22c55e'
};
var AGENT_NAMES_MAP = {
  'AG-001':'Dispatcher','AG-002':'Resource Manager','AG-003':'Demand Forecaster',
  'AG-004':'Buffer Gatekeeper','AG-005':'Estratega','AG-006':'Resource Manager PMO','AG-007':'Planificador','AG-012':'Task Advisor'
};
var AGENT_SUBS_MAP = {
  'AG-001':'Triaje NLP \u00b7 ITIL 4','AG-002':'Matching T\u00e9cnico',
  'AG-003':'Prophet \u00b7 Predicci\u00f3n','AG-004':'Gobernanza RUN/BUILD',
  'AG-005':'PMBOK 7 \u00b7 Priorizaci\u00f3n','AG-006':'Asignaci\u00f3n \u00b7 Matching','AG-007':'WBS \u00b7 Gantt \u00b7 PMBOK','AG-012':'CMDB \u00b7 Instrucciones'
};

function createAnimatedPipeline(agentIds) {
  var bar = document.createElement('div');
  bar.className = 'pipeline-animated';
  var inp = document.createElement('span');
  inp.style.cssText = 'font-size:11px;color:#8b8f98;padding:4px 8px;border:1px solid #333840;border-radius:6px;white-space:nowrap;';
  inp.textContent = agentIds[0] === 'AG-001' ? 'ITIL 4 Input' : 'PMBOK Input';
  bar.appendChild(inp);
  agentIds.forEach(function(agId, i) {
    var arr = document.createElement('span');
    arr.className = 'pipeline-arrow';
    arr.id = 'arrow-' + agId;
    arr.textContent = '\u25b8';
    bar.appendChild(arr);
    var step = document.createElement('div');
    step.className = 'agent-step ' + (i === 0 ? 'active' : 'waiting');
    step.id = 'step-' + agId;
    step.style.setProperty('--agent-color', AGENT_COLORS_MAP[agId] || '#8b8f98');
    var iconDiv = document.createElement('div');
    iconDiv.className = 'agent-icon';
    iconDiv.style.color = AGENT_COLORS_MAP[agId] || '#8b8f98';
    iconDiv.innerHTML = AGENT_PIPELINE_ICONS[agId] || '';
    var infoDiv = document.createElement('div');
    infoDiv.className = 'agent-info';
    infoDiv.innerHTML = '<div class="agent-name">' + agId + ' \u2014 ' + (AGENT_NAMES_MAP[agId] || agId) + '</div><div class="agent-sub" id="sub-' + agId + '">' + (AGENT_SUBS_MAP[agId] || '') + '</div>';
    var statusDiv = document.createElement('div');
    statusDiv.className = 'agent-status';
    statusDiv.id = 'status-' + agId;
    step.appendChild(iconDiv);
    step.appendChild(infoDiv);
    step.appendChild(statusDiv);
    bar.appendChild(step);
  });
  var arrOut = document.createElement('span');
  arrOut.className = 'pipeline-arrow';
  arrOut.id = 'arrow-output';
  arrOut.textContent = '\u25b8';
  bar.appendChild(arrOut);
  var out = document.createElement('span');
  out.id = 'pipeline-output-label';
  out.style.cssText = 'font-size:12px;font-weight:600;color:#8b8f98;white-space:nowrap;';
  out.textContent = 'READY';
  bar.appendChild(out);
  return bar;
}

function setAgentState(agId, state, statusText) {
  var step = document.getElementById('step-' + agId);
  if (!step) return;
  step.className = 'agent-step ' + state;
  var st = document.getElementById('status-' + agId);
  if (st && statusText) { st.textContent = statusText; st.style.display = 'block'; }
  var sub = document.getElementById('sub-' + agId);
  if (sub) {
    if (state === 'active') {
      sub.innerHTML = (AGENT_SUBS_MAP[agId] || '') + '<span class="typing-dots"><span></span><span></span><span></span></span>';
    } else {
      sub.textContent = AGENT_SUBS_MAP[agId] || '';
    }
  }
  var arr = document.getElementById('arrow-' + agId);
  if (arr && (state === 'done' || state === 'active')) arr.className = 'pipeline-arrow active';
}

function setPipelineComplete(success) {
  var lbl = document.getElementById('pipeline-output-label');
  var arr = document.getElementById('arrow-output');
  if (lbl) { lbl.textContent = success ? '\u2713 Completado' : '\u2715 Error'; lbl.style.color = success ? '#22c55e' : '#ef4444'; }
  if (arr) arr.className = 'pipeline-arrow active';
}
// ═══ END AGENT PIPELINE HELPERS ═══

// ══════════════════ BUILD DASHBOARD VISUAL ══════════════════

async function executeBuildPipeline(text) {
  var execBtn = document.getElementById('build-exec-btn');
  var statusEl = document.getElementById('build-status-val');
  if (execBtn) execBtn.disabled = true;
  if (statusEl) { statusEl.textContent = 'Running'; statusEl.style.color = 'var(--blue)'; }

  var area = document.getElementById('build-pipeline-area');
  var idleEl = document.getElementById('build-pipeline-idle');
  if (idleEl) idleEl.style.display = 'none';
  var oldSteps = document.getElementById('build-steps');
  if (oldSteps) oldSteps.remove();

  var dashboard = document.createElement('div');
  dashboard.className = 'build-dashboard';
  dashboard.id = 'build-steps';
  area.appendChild(dashboard);

  var pipeline = createAnimatedPipeline(['AG-005', 'AG-006', 'AG-007']);
  dashboard.appendChild(pipeline);

  var progressArea = document.createElement('div');
  progressArea.id = 'build-progress';
  dashboard.appendChild(progressArea);

  var logContainer = document.createElement('div');
  var logTitle = document.createElement('div');
  logTitle.className = 'build-section-title';
  logTitle.textContent = 'Panel de actividad';
  var logBox = document.createElement('div');
  logBox.className = 'build-log';
  logBox.id = 'build-live-log';
  logContainer.appendChild(logTitle);
  logContainer.appendChild(logBox);
  dashboard.appendChild(logContainer);

  var sessionId = 'build-' + Date.now();
  var startTime = Date.now();
  function elapsed() {
    var s = Math.floor((Date.now() - startTime) / 1000);
    var m = Math.floor(s / 60); s = s % 60;
    return (m < 10 ? '0' + m : m) + ':' + (s < 10 ? '0' + s : s);
  }
  function addLog(agent, cls, msg, isTool) {
    var log = document.getElementById('build-live-log');
    if (!log) return;
    var entry = document.createElement('div');
    entry.className = 'build-log-entry';
    var timeSpan = document.createElement('span');
    timeSpan.className = 'build-log-time';
    timeSpan.textContent = elapsed();
    var agentSpan = document.createElement('span');
    agentSpan.className = 'build-log-agent ' + cls;
    agentSpan.textContent = agent;
    var msgSpan = document.createElement('span');
    if (isTool) msgSpan.className = 'build-log-tool';
    msgSpan.textContent = msg;
    entry.appendChild(timeSpan);
    entry.appendChild(agentSpan);
    entry.appendChild(msgSpan);
    log.appendChild(entry);
    log.scrollTop = log.scrollHeight;
  }

  function addPreview(title, color, content) {
    var wrapper = document.createElement('div');
    var titleEl = document.createElement('div');
    titleEl.className = 'build-section-title';
    titleEl.style.color = color;
    titleEl.textContent = title;
    var box = document.createElement('div');
    box.style.cssText = 'background:#22262e;border:1px solid #333840;border-left:3px solid ' + color + ';border-radius:8px;padding:12px;margin-bottom:12px;max-height:180px;overflow-y:auto;font-size:12px;color:#b0b4bc;white-space:pre-wrap;';
    box.textContent = content.substring(0, 2000);
    wrapper.appendChild(titleEl);
    wrapper.appendChild(box);
    progressArea.appendChild(wrapper);
  }

  try {
    addLog('AG-005', 'estratega', 'Recibido proyecto. Analizando con PMBOK 7...', false);
    addLog('AG-005', 'estratega', 'tool: decompose_pmbok()', true);

    var resp5 = await authFetch(API_BASE + '/agents/AG-005/invoke', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({message: text, session_id: sessionId})
    });
    var r5 = await resp5.json();
    if (!resp5.ok) throw new Error(r5.detail || 'AG-005 error');
    var result5 = r5.response || r5.result || '';

    setAgentState('AG-005', 'done', '\u2713');
    setAgentState('AG-006', 'active');
    addLog('AG-005', 'estratega', 'EDT generada. Pasando al Resource Manager PMO...', false);
    addPreview('AG-005 Estratega \u2014 EDT generada', '#10b981', result5);

    addLog('AG-006', 'resource', 'Buscando t\u00e9cnicos por skills...', false);
    addLog('AG-006', 'resource', 'tool: query_staff_by_skill()', true);

    var resp6 = await authFetch(API_BASE + '/agents/AG-006/invoke', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({message: 'Plan del Estratega:\n' + result5.substring(0, 1500), session_id: sessionId})
    });
    var r6 = await resp6.json();
    if (!resp6.ok) throw new Error(r6.detail || 'AG-006 error');
    var result6 = r6.response || r6.result || '';

    var hasCycle = result6.toLowerCase().indexOf('cycle_back') >= 0 || result6.indexOf('IMPOSIBLE') >= 0;
    if (hasCycle) {
      setAgentState('AG-006', 'fail', '\u21BA');
      addLog('AG-006', 'resource', 'CYCLE BACK: Ajuste de recursos necesario', false);
    } else {
      setAgentState('AG-006', 'done', '\u2713');
      addLog('AG-006', 'resource', 'Equipo formado. Pasando al Planificador...', false);
    }
    setAgentState('AG-007', 'active');
    addPreview('AG-006 Resource Manager PMO \u2014 ' + (hasCycle ? 'Cycle Back' : 'Equipo'), hasCycle ? '#ef4444' : '#eab308', result6);

    addLog('AG-007', 'planificador', 'Calculando ruta cr\u00edtica y paralelizaciones...', false);
    addLog('AG-007', 'planificador', 'tool: calc_critical_path()', true);

    var resp7 = await authFetch(API_BASE + '/agents/AG-007/invoke', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({message: 'PROYECTO:\n' + text.substring(0, 500) + '\n\nEDT:\n' + result5.substring(0, 1500) + '\n\nEQUIPO:\n' + result6.substring(0, 1000) + '\n\nINSTRUCCI\u00d3N: Usa calc_critical_path, generate_gantt_mermaid, create_kanban_cards fase 1, create_budget.', session_id: sessionId})
    });
    var r7 = await resp7.json();
    if (!resp7.ok) throw new Error(r7.detail || 'AG-007 error');
    var result7 = r7.response || r7.result || '';

    setAgentState('AG-007', 'done', '\u2713');
    setPipelineComplete(true);
    addLog('AG-007', 'planificador', 'Gantt generado con paralelizaci\u00f3n.', false);
    addLog('CHAIN', 'estratega', 'Pipeline BUILD completado en ' + elapsed(), false);

    var chainResult = {
      chain: 'BUILD', agents: ['AG-005', 'AG-006', 'AG-007'],
      result: result7, session_id: sessionId
    };

    try {
      var plResp = await authFetch(API_BASE + '/build/plans');
      var plans = await plResp.json();
      if (plans.length > 0) {
        chainResult.structured = { plan: {
          plan_id: plans[0].id, id_proyecto: plans[0].id_proyecto,
          nombre: plans[0].nombre, presupuesto: plans[0].presupuesto,
          duracion_semanas: plans[0].duracion_semanas,
          prioridad: plans[0].prioridad, plan_data: plans[0].plan_data || {}
        }};
      }
    } catch(ex) {}

    try {
      var tkResp = await authFetch(API_BASE + '/kanban/tareas');
      var allTk = await tkResp.json();
      var recent = allTk.filter(function(t) { return t.fecha_creacion && new Date(t.fecha_creacion) > new Date(Date.now() - 300000); });
      if (recent.length > 0 && chainResult.structured) {
        chainResult.structured.tasks = recent.map(function(t) {
          return {id: t.id, titulo: t.titulo, columna: t.columna || 'Backlog', id_tecnico: t.id_tecnico || ''};
        });
      }
    } catch(ex) {}

    // Fetch budget breakdown
    try {
      var budgetResp = await authFetch(API_BASE + '/presupuestos');
      var budgets = await budgetResp.json();
      if (budgets.length > 0 && chainResult.structured) {
        var lb = budgets[0];
        chainResult.structured.budget = {
          total_labor: lb.total_labor, total_capex: lb.total_capex,
          total_opex: lb.total_opex, total_rrhh: lb.total_rrhh,
          total_reservas: lb.total_reservas, bac_total: lb.bac_total,
          horas_internas: lb.horas_internas, tarifa_hora: lb.tarifa_hora_interna
        };
      }
    } catch(ex) {}

    progressArea.innerHTML = '';
    logContainer.remove();
    var data = _parseBuildResult(chainResult);
    _renderBuildDashboardContent(progressArea, data);
    dashboard.appendChild(logContainer);

  } catch(e) {
    addLog('ERROR', 'resource', e.message, false);
    setPipelineComplete(false);
  }

  if (execBtn) execBtn.disabled = false;
  if (statusEl) { statusEl.textContent = 'Idle'; statusEl.style.color = 'var(--yellow)'; }
}

function _parseBuildResult(chainResult) {
  var result = chainResult.result || '';
  var s = chainResult.structured || {};
  var plan = s.plan || {};
  var planData = plan.plan_data || {};

  var data = {
    project_id: plan.id_proyecto || '',
    project_name: plan.nombre || '',
    plan_id: plan.plan_id || '',
    duration_weeks: planData.duracion_total_semanas || plan.duracion_semanas || 0,
    duration_sequential: planData.duracion_secuencial_semanas || 0,
    saving_weeks: planData.ahorro_semanas || 0,
    budget: plan.presupuesto || 0,
    pm: planData.pm || '',
    priority: plan.prioridad || '',
    edt: [],
    team: [],
    gantt: [],
    kanban_tasks: [],
    cycle_back: false,
    blocked: false,
    agents_used: chainResult.agents || [],
    critical_path: planData.ruta_critica || []
  };

  // EDT from plan_data
  if (planData.edt && Array.isArray(planData.edt)) {
    planData.edt.forEach(function(pkg) {
      var totalHoras = 0;
      var subtareas = pkg.subtareas || [];
      subtareas.forEach(function(st) { totalHoras += (st.horas || 0); });
      data.edt.push({
        id: pkg.id || '',
        nombre: pkg.nombre || '',
        horas: totalHoras || pkg.horas || 0,
        responsable: pkg.responsable || '',
        subtareas: subtareas
      });
    });
  }

  // If no structured EDT, try to extract from Mermaid or text
  if (data.edt.length === 0 && planData.gantt_mermaid) {
    var mermaid = planData.gantt_mermaid;
    var sectionRegex = /section\s+(.+)/g;
    var match;
    var idx = 1;
    while ((match = sectionRegex.exec(mermaid)) !== null) {
      data.edt.push({id: idx + '.0', nombre: match[1].trim(), horas: 0, responsable: ''});
      idx++;
    }
  }

  // Fallback EDT from text if nothing structured
  if (data.edt.length === 0) {
    var edtLines = result.match(/\d+\.\d[^\n]+/g) || [];
    edtLines = edtLines.filter(function(line) {
      if (line.match(/,\s*after\s/)) return false;
      if (line.match(/,\s*\d{4}-\d{2}-\d{2}/)) return false;
      if (line.match(/,\s*\d+[dwm]\s*$/)) return false;
      if (line.match(/^\d+\.\d\s*,/)) return false;
      if (line.match(/→.*→.*→/)) return false;
      return true;
    });
    edtLines.forEach(function(line) {
      var m = line.match(/(\d+\.\d)\s*[-|:.]?\s*(.+)/);
      if (m) {
        var nombre = m[2].replace(/\*+/g, '').trim();
        var hoursM = nombre.match(/\((\d+)h?\)/);
        var hours = hoursM ? parseInt(hoursM[1]) : 0;
        nombre = nombre.replace(/\(\d+h?\)/, '').trim();
        if (nombre.length > 3 && nombre.length < 120) {
          data.edt.push({id: m[1], nombre: nombre, horas: hours});
        }
      }
    });
  }

  // Gantt data from EDT
  if (data.edt.length > 0) {
    var totalW = data.duration_weeks || 40;
    var numPkgs = data.edt.length;
    var totalHoras = data.edt.reduce(function(s2,p) { return s2 + (p.horas || 0); }, 0) || 1;
    var currentWeek = 0;
    data.edt.forEach(function(pkg, i) {
      var proportion = (pkg.horas || totalHoras/numPkgs) / totalHoras;
      var weeks = Math.max(2, Math.round(proportion * totalW));
      var isCrit = data.critical_path.indexOf(pkg.id) >= 0;
      var isParallel = false;
      if (pkg.subtareas) {
        pkg.subtareas.forEach(function(st) {
          if (st.paralela_con && st.paralela_con.length > 0) isParallel = true;
        });
      }
      var startWeek = currentWeek;
      if (isParallel && i > 0) {
        startWeek = Math.max(0, currentWeek - Math.round(weeks * 0.5));
      }
      data.gantt.push({
        id: pkg.id,
        nombre: pkg.nombre,
        startWeek: startWeek,
        weeks: weeks,
        isCrit: isCrit,
        isParallel: isParallel
      });
      currentWeek = startWeek + weeks;
    });
  }

  // Team from structured data
  if (s.team && Array.isArray(s.team)) {
    s.team.forEach(function(t) {
      data.team.push({
        id: t.id_recurso || t.id || '',
        nombre: t.nombre || '',
        nivel: t.nivel || '',
        silo: t.silo_especialidad || t.silo || '',
        carga: t.carga_actual || 0,
        skill: t.skill_principal || ''
      });
    });
  }

  // Kanban from structured data
  if (s.tasks && Array.isArray(s.tasks)) {
    s.tasks.forEach(function(t) {
      data.kanban_tasks.push({
        id: t.id || '',
        titulo: t.titulo || '',
        columna: t.columna || 'Backlog',
        tecnico: t.id_tecnico || ''
      });
    });
  }

  // Budget
  if (s.budget) {
    data.budget_breakdown = s.budget;
  } else {
    data.budget_breakdown = null;
  }

  // Detect problems from text as fallback
  if (result.toLowerCase().indexOf('cycle_back') >= 0 || result.indexOf('IMPOSIBLE') >= 0) data.cycle_back = true;
  if (result.indexOf('BLOQUEADO') >= 0 || result.indexOf('NO PLANIFICABLE') >= 0) data.blocked = true;

  // Duration fallback from text if not in structured
  if (!data.duration_weeks) {
    var durMatch = result.match(/(\d+)\s*semanas/);
    if (durMatch) data.duration_weeks = parseInt(durMatch[1]);
  }

  return data;
}

function _renderBuildDashboardContent(container, data) {
  var html = '';

  // 2. Project summary
  var prioClass = data.priority === 'Alta' || data.priority === 'Crítica' ? 'priority-alta' : data.priority === 'Media' ? 'priority-media' : '';
  var budgetStr = data.budget ? data.budget.toLocaleString('es-ES') + '€' : '—';
  html += '<div class="build-summary"><div class="build-summary-title">' + escHtml(data.project_name || 'Proyecto') + '</div>';
  html += '<div class="build-summary-grid">';
  html += '<div class="build-summary-item"><div class="bsi-label">Plan</div><div class="bsi-value">' + escHtml(data.plan_id || '—') + '</div></div>';
  html += '<div class="build-summary-item"><div class="bsi-label">Duración</div><div class="bsi-value duration">' + (data.duration_weeks || '—') + ' sem</div></div>';
  html += '<div class="build-summary-item"><div class="bsi-label">Presupuesto</div><div class="bsi-value budget">' + budgetStr + '</div></div>';
  html += '<div class="build-summary-item"><div class="bsi-label">Prioridad</div><div class="bsi-value ' + prioClass + '">' + escHtml(data.priority || '—') + '</div></div>';
  if (data.saving_weeks > 0) html += '<div class="build-summary-item"><div class="bsi-label">Ahorro</div><div class="bsi-value" style="color:#22c55e;">' + data.saving_weeks + ' sem</div></div>';
  if (data.duration_sequential > 0) html += '<div class="build-summary-item"><div class="bsi-label">Secuencial</div><div class="bsi-value" style="color:#8b8f98;">' + data.duration_sequential + ' sem</div></div>';
  html += '</div>';

  // Budget breakdown
  if (data.budget_breakdown) {
    var bb = data.budget_breakdown;
    html += '<div style="margin-top:10px;padding-top:10px;border-top:1px solid #333840;">';
    html += '<div style="font-size:10px;color:#8b8f98;text-transform:uppercase;margin-bottom:6px;">Desglose presupuestario</div>';
    html += '<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(100px,1fr));gap:6px;">';
    var items = [
      {l:'Labor',v:bb.total_labor,c:'#22c55e'},
      {l:'CAPEX',v:bb.total_capex,c:'#3b82f6'},
      {l:'OPEX',v:bb.total_opex,c:'#eab308'},
      {l:'RRHH',v:bb.total_rrhh,c:'#a855f7'},
      {l:'Reservas',v:bb.total_reservas,c:'#8b8f98'},
      {l:'BAC Total',v:bb.bac_total,c:'#22c55e'}
    ];
    items.forEach(function(it) {
      if (it.v) {
        html += '<div style="background:#181b20;border-radius:4px;padding:6px 8px;text-align:center;">';
        html += '<div style="font-size:9px;color:#8b8f98;">' + it.l + '</div>';
        html += '<div style="font-size:13px;font-weight:600;color:' + it.c + ';">' + Number(it.v).toLocaleString('es-ES') + '\u20ac</div>';
        html += '</div>';
      }
    });
    html += '</div></div>';
  }

  html += '</div>';

  // 3. Alert if cycle_back/blocked
  if (data.cycle_back || data.blocked) {
    var alertClass = data.blocked ? 'build-alert' : 'build-alert warning';
    html += '<div class="' + alertClass + '"><div class="build-alert-title">' + (data.blocked ? '✕ PROYECTO BLOQUEADO' : '⟲ AJUSTE DE RECURSOS NECESARIO') + '</div>';
    html += '<div class="build-alert-detail">' + (data.blocked ? 'No se puede planificar sin equipo formado.' : 'El Resource Manager necesita ajustar el equipo.') + '</div></div>';
  }

  // 4. Team
  if (data.team.length > 0) {
    html += '<div class="build-section-title">Equipo formado por AG-006 (' + data.team.length + ' miembros)</div>';
    html += '<div class="build-team">';
    data.team.forEach(function(t) {
      var initials = (t.nombre || '??').split(' ').map(function(w){return w[0];}).join('').substring(0,2).toUpperCase();
      html += '<div class="build-team-card"><div style="display:flex;align-items:center;gap:8px;">';
      html += '<div style="width:28px;height:28px;border-radius:50%;background:rgba(59,130,246,.2);color:#3b82f6;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:800;">' + initials + '</div>';
      html += '<div><div class="btc-name">' + escHtml(t.nombre) + '</div>';
      html += '<div class="btc-level">' + escHtml(t.id) + ' · ' + escHtml(t.nivel) + '</div></div></div></div>';
    });
    html += '</div>';
  }

  // 5. EDT
  if (data.edt.length > 0) {
    var totalHours = data.edt.reduce(function(s,p){return s+(p.horas||0);}, 0);
    html += '<div class="build-section-title">EDT/WBS — AG-005 Estratega</div>';
    html += '<div class="build-edt"><div class="build-edt-stats"><strong>' + data.edt.length + ' paquetes</strong>';
    if (totalHours > 0) html += ' | ' + totalHours + 'h estimadas';
    html += '</div>';
    data.edt.forEach(function(pkg) {
      var isCrit = data.critical_path.indexOf(pkg.id) >= 0;
      html += '<div class="build-edt-package"><div class="build-edt-pkg-header">';
      html += '<span style="color:' + (isCrit ? '#eab308' : '#e4e5e9') + ';">' + escHtml(pkg.id) + ' ' + escHtml(pkg.nombre) + '</span>';
      if (pkg.horas) html += '<span class="pkg-hours">(' + pkg.horas + 'h)</span>';
      html += '</div></div>';
    });
    html += '</div>';
  }

  // 6. Gantt
  if (data.gantt.length > 0 && !data.blocked) {
    var totalW = data.duration_weeks || 40;
    var seqW = data.duration_sequential || Math.round(totalW * 1.3);
    var saveW = data.saving_weeks || (seqW - totalW);
    var maxWeek = 0;
    data.gantt.forEach(function(g) { if (g.startWeek + g.weeks > maxWeek) maxWeek = g.startWeek + g.weeks; });
    if (maxWeek === 0) maxWeek = totalW;

    html += '<div class="build-section-title">Gantt con paralelización — AG-007</div>';
    html += '<div class="build-gantt">';
    html += '<div class="build-gantt-note">Tareas sin dependencias se ejecutan en paralelo. Proyecto compactado de ' + seqW + ' a ' + totalW + ' semanas.</div>';

    data.gantt.forEach(function(g) {
      var leftPct = Math.round((g.startWeek / maxWeek) * 100);
      var widthPct = Math.max(5, Math.round((g.weeks / maxWeek) * 100));
      var barClass = g.isCrit ? 'crit' : (g.isParallel ? 'parallel' : 'norm');
      var label = 'S' + (g.startWeek + 1) + '-' + (g.startWeek + g.weeks);
      html += '<div class="build-gantt-row">';
      html += '<div class="build-gantt-label">' + escHtml(g.id + ' ' + (g.nombre || '').substring(0, 20)) + '</div>';
      html += '<div class="build-gantt-track"><div class="build-gantt-bar ' + barClass + '" style="left:' + leftPct + '%;width:' + widthPct + '%;">' + label + '</div></div>';
      html += '</div>';
    });

    html += '<div class="build-gantt-legend"><span><span class="dot" style="background:#eab308"></span>Ruta crítica</span>';
    html += '<span><span class="dot" style="background:#3b82f6"></span>Con holgura</span>';
    html += '<span><span class="dot" style="background:#a78bfa"></span>Paralela</span>';
    html += '<span class="saving">' + totalW + ' sem (ahorro: ' + saveW + ' sem)</span></div>';
    html += '</div>';
  }

  // 7. Kanban
  if (data.kanban_tasks.length > 0) {
    var cols = {'Backlog':[],'En Progreso':[],'En Revisión':[],'Done':[]};
    data.kanban_tasks.forEach(function(t) { var c = cols[t.columna] ? t.columna : 'Backlog'; cols[c].push(t); });
    html += '<div class="build-section-title">Kanban (Fase 1)</div><div class="build-kanban">';
    ['Backlog','En Progreso','En Revisión','Done'].forEach(function(cn) {
      html += '<div class="build-kanban-col"><div class="build-kanban-header">' + cn + '</div><div class="build-kanban-body">';
      (cols[cn]||[]).forEach(function(t) {
        html += '<div class="build-kanban-card"><div class="bkc-title">' + escHtml((t.titulo||'').substring(0,35)) + '</div>';
        if (t.tecnico) html += '<div class="bkc-tech">' + escHtml(t.tecnico) + '</div>';
        html += '</div>';
      });
      html += '</div></div>';
    });
    html += '</div>';
  }

  // 8. Activity log
  html += '<div class="build-section-title">Panel de actividad</div><div class="build-log">';
  html += '<div class="build-log-entry"><span class="build-log-time">00:00</span><span class="build-log-agent estratega">AG-005</span><span>Pipeline BUILD iniciado</span></div>';
  html += '<div class="build-log-entry"><span class="build-log-time">00:02</span><span class="build-log-agent estratega">AG-005</span><span class="build-log-tool">tool: decompose_pmbok(' + data.edt.length + ' paquetes)</span></div>';
  html += '<div class="build-log-entry"><span class="build-log-time">00:05</span><span class="build-log-agent resource">AG-006</span><span>' + (data.team.length > 0 ? 'Equipo formado: ' + data.team.length + ' miembros' : 'Buscando recursos...') + '</span></div>';
  if (data.cycle_back) {
    html += '<div class="build-log-entry"><span class="build-log-time">00:07</span><span class="build-log-agent resource">AG-006</span><span class="build-log-warn">Cycle back: ajuste de recursos necesario</span></div>';
  }
  if (!data.blocked) {
    html += '<div class="build-log-entry"><span class="build-log-time">00:10</span><span class="build-log-agent planificador">AG-007</span><span class="build-log-tool">tool: calc_critical_path()</span></div>';
    html += '<div class="build-log-entry"><span class="build-log-time">00:12</span><span class="build-log-agent planificador">AG-007</span><span class="build-log-success">Gantt generado. ' + (data.duration_weeks || '?') + ' semanas optimizadas.</span></div>';
  } else {
    html += '<div class="build-log-entry"><span class="build-log-time">00:10</span><span class="build-log-agent planificador">AG-007</span><span class="build-log-error">BLOQUEADO: Sin equipo formado.</span></div>';
  }
  html += '<div class="build-log-entry"><span class="build-log-time">00:15</span><span class="build-log-agent estratega">CHAIN</span><span class="build-log-success">Pipeline BUILD completado</span></div>';
  html += '</div>';

  container.innerHTML = html;
}

async function executePipeline(mode) {
  var input = document.getElementById(mode+'-input');
  var text = input.value.trim();
  if (!text) { input.focus(); return; }

  if (mode === 'run') {
    return executeRunPipeline(text);
  }

  if (mode === 'build') {
    return executeBuildPipeline(text);
  }

  const agents = BUILD_AGENTS;
  const execBtn = document.getElementById(mode+'-exec-btn');
  const statusEl = document.getElementById(mode+'-status-val');
  const tasksEl = document.getElementById(mode+'-tasks');
  const histEl = document.getElementById(mode+'-hist');
  execBtn.disabled = true;
  statusEl.textContent = 'Running';
  statusEl.style.color = 'var(--blue)';

  const area = document.getElementById(mode+'-pipeline-area');
  // Hide idle flow diagram for RUN mode
  const idleEl = document.getElementById(mode+'-pipeline-idle');
  if (idleEl) idleEl.style.display = 'none';
  // Remove old steps if any, then create new
  const oldSteps = document.getElementById(mode+'-steps');
  if (oldSteps) oldSteps.remove();
  const stepsContainer = document.createElement('div');
  stepsContainer.className = 'pipeline-steps';
  stepsContainer.id = mode+'-steps';
  area.appendChild(stepsContainer);
  const stepsDiv = stepsContainer;

  agents.forEach((ag,i) => {
    const div = document.createElement('div');
    div.className = 'pipeline-step';
    div.id = mode+'-step-'+i;
    div.innerHTML = `
      <div class="step-header">
        <div class="agent-icon">${AGENT_ICONS[ag.id]}</div>
        <div class="step-info">
          <div class="step-name">${ag.id} — ${ag.name}</div>
          <div class="step-sub">${ag.sub}</div>
        </div>
        <span class="step-status status-pending" id="${mode}-step-status-${i}">Pendiente</span>
      </div>
      <div class="step-content" id="${mode}-step-content-${i}" style="display:none;">
        <div class="step-desc" id="${mode}-step-desc-${i}"></div>
        <div class="step-json-wrap">
          <button class="json-toggle-btn" onclick="toggleJson('${mode}-json-${i}')">
            <span class="arr">▶</span>&nbsp;Respuesta JSON completa
          </button>
          <pre class="json-pre" id="${mode}-json-${i}"></pre>
        </div>
      </div>`;
    stepsDiv.appendChild(div);
  });

  tasksEl.innerHTML = agents.map((ag,i)=>`<div class="task-item">
    <div style="display:flex;align-items:center;gap:6px;margin-bottom:4px;">
      <div style="width:22px;height:22px;flex-shrink:0;">${AGENT_ICONS[ag.id].replace('width:40px;height:40px;','width:22px;height:22px;')}</div>
      <div class="task-title" style="color:${ag.color};">${ag.id}: ${ag.name}</div>
    </div>
    <div class="task-meta"><span class="step-status status-pending" id="${mode}-task-${i}">Pendiente</span></div>
  </div>`).join('');

  let prevOutput = text;
  let prevFull = null;
  const timestamp = new Date().toLocaleTimeString('es-ES',{hour:'2-digit',minute:'2-digit'});

  for (let i=0; i<agents.length; i++) {
    const ag = agents[i];
    const stepEl = document.getElementById(mode+'-step-'+i);
    const statusBadge = document.getElementById(mode+'-step-status-'+i);
    const taskBadge = document.getElementById(mode+'-task-'+i);
    const contentEl = document.getElementById(mode+'-step-content-'+i);
    const descEl = document.getElementById(mode+'-step-desc-'+i);
    const jsonEl = document.getElementById(mode+'-json-'+i);

    stepEl.classList.add('running');
    statusBadge.textContent='Ejecutando...';
    statusBadge.className='step-status status-running';
    if(taskBadge){taskBadge.textContent='Ejecutando...';taskBadge.className='step-status status-running';}
    contentEl.style.display='block';
    descEl.innerHTML='<div class="typing-wrap"><div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div></div>';

    const question = i===0 ? text
      : `Entrada original: "${text}"\n\nSalida ${agents[i-1].id} (${agents[i-1].name}):\n${prevOutput}`;

    try {
      const resp = await callFlowise(ag.id, question);
      const textOut = resp.text || resp.answer || resp.output || JSON.stringify(resp);
      prevOutput = textOut;
      prevFull = resp;

      descEl.innerHTML = fmtMd(textOut);
      jsonEl.innerHTML = syntaxJson(resp);
    } catch(e) {
      descEl.innerHTML = `<div style="color:var(--red);font-size:12px;padding:4px 0;">⚠ ${escHtml(e.message)}</div>`;
      jsonEl.innerHTML = escHtml(e.message);
      prevOutput = 'Error en '+ag.id;
    }

    stepEl.classList.remove('running');
    statusBadge.textContent='✓ Completado';
    statusBadge.className='step-status status-done';
    stepEl.classList.add('done');
    if(taskBadge){taskBadge.textContent='✓';taskBadge.className='step-status status-done';}
  }

  pipelineHistory[mode].unshift({text:text.substring(0,50), time:timestamp, agents:agents.length});
  histEl.innerHTML = pipelineHistory[mode].slice(0,5).map(h=>`<div class="hist-item">
    <div style="font-size:12px;color:var(--text2);margin-bottom:2px;">${escHtml(h.text)}...</div>
    <div class="hist-time">${h.time} · ${h.agents} agentes</div>
  </div>`).join('');
  execBtn.disabled=false;
  statusEl.textContent='Idle';
  statusEl.style.color='var(--yellow)';
  // Update AI insight panels with simulated post-run data
  const totalAgents = agents.length;
  const confPct = (75 + Math.floor(Math.random()*20))+'%';
  const slaRisk = Math.floor(Math.random()*3);
  const auditCount = pipelineHistory[mode].length;
  const setEl = (id,v)=>{ const e=document.getElementById(id); if(e) e.textContent=v; };
  setEl(mode+'-ai-insights', totalAgents+' generados');
  setEl(mode+'-ai-conf', confPct);
  setEl(mode+'-sla-risk', slaRisk === 0 ? 'Ninguno' : slaRisk+' detectados');
  setEl(mode+'-sla-alert', slaRisk === 0 ? 'Verde' : slaRisk < 2 ? 'Amarillo' : 'Rojo');
  setEl(mode+'-kedb-conf', '0 activos');
  setEl(mode+'-kedb-res', totalAgents+' prop.');
  setEl(mode+'-res-util', (60+Math.floor(Math.random()*25))+'%');
  setEl(mode+'-res-opt', Math.random()>.5 ? 'Óptima' : 'Mejorable');
  setEl(mode+'-audit-count', auditCount+' entr.');
  setEl(mode+'-audit-last', timestamp);
}

function resetPipeline(mode) {
  document.getElementById(mode+'-input').value='';
  if (mode === 'run') {
    // Restore the visual flow diagram
    const idle = document.getElementById('run-pipeline-idle');
    if (idle) idle.style.display = '';
    // Remove any pipeline-steps that were added
    const steps = document.getElementById('run-steps');
    if (steps) steps.remove();
  } else {
    document.getElementById(mode+'-pipeline-area').innerHTML=`<div class="pipeline-idle"><div class="pipeline-idle-icon">⚙️</div><div class="pipeline-idle-title">Pipeline Inactivo</div><div class="pipeline-idle-sub">Ingresa un texto y ejecuta el pipeline para comenzar la cascada de agentes IA</div></div>`;
  }
  document.getElementById(mode+'-tasks').innerHTML='<div class="no-data"><div class="no-data-icon">🕐</div>No hay tareas activas</div>';
  document.getElementById(mode+'-status-val').textContent='Idle';
  document.getElementById(mode+'-status-val').style.color='var(--yellow)';
  document.getElementById(mode+'-exec-btn').disabled=false;
  // Reset ITSM form fields if run
  if (mode === 'run') {
    document.getElementById('itsm-ticket-id').textContent = '';
    document.getElementById('itsm-catalogo').value = '';
    document.getElementById('itsm-info-bar').style.display = 'none';
    document.getElementById('itsm-impacto').value = 'Medio';
    document.getElementById('itsm-urgencia').value = 'Media';
    itsmCalcPriority();
    // Reset SSE components
    document.getElementById('sse-sla-counter').style.display = 'none';
    document.getElementById('sse-tasks-area').style.display = 'none';
    document.getElementById('sse-tasks-list').innerHTML = '';
    document.getElementById('sse-kanban-mini').style.display = 'none';
    document.getElementById('sse-kb-backlog').innerHTML = '';
    document.getElementById('sse-kb-progress').innerHTML = '';
    document.getElementById('sse-kb-review').innerHTML = '';
    document.getElementById('sse-kb-done').innerHTML = '';
    document.getElementById('sse-log').style.display = 'none';
    document.getElementById('sse-log').innerHTML = '';
    if (typeof _sseTimer !== 'undefined' && _sseTimer) clearInterval(_sseTimer);
  }
}

// ── SSE RUN PIPELINE ──
var _sseTimer = null;
var _sseStartTime = null;
var _sseDeadline = null;

function executeRunSSE(text) {
  var execBtn = document.getElementById('run-exec-btn');
  var statusEl = document.getElementById('run-status-val');
  execBtn.disabled = true;
  statusEl.textContent = 'Running';
  statusEl.style.color = 'var(--blue)';

  // Setup pipeline steps UI
  var area = document.getElementById('run-pipeline-area');
  var idleEl = document.getElementById('run-pipeline-idle');
  if (idleEl) idleEl.style.display = 'none';
  var oldSteps = document.getElementById('run-steps');
  if (oldSteps) oldSteps.remove();

  var stepsDiv = document.createElement('div');
  stepsDiv.className = 'pipeline-steps';
  stepsDiv.id = 'run-steps';
  area.appendChild(stepsDiv);

  // Create step elements for AG-001, AG-002, AG-004
  var sseAgents = [
    {id:'AG-001', name:'Dispatcher', color:'#3b82f6', iconKey:'AG1'},
    {id:'AG-002', name:'Resource Manager', color:'#8b5cf6', iconKey:'AG2'},
    {id:'AG-004', name:'Buffer Gatekeeper', color:'#f59e0b', iconKey:'AG4'}
  ];

  sseAgents.forEach(function(ag, i) {
    var div = document.createElement('div');
    div.className = 'pipeline-step';
    div.id = 'sse-step-' + ag.id;
    var iconHtml = AGENT_ICONS[ag.iconKey] || '';
    div.innerHTML = '<div class="step-header">' +
      '<div class="agent-icon">' + iconHtml + '</div>' +
      '<div class="step-info"><div class="step-name">' + ag.id + ' &mdash; ' + ag.name + '</div>' +
      '<div class="step-sub" id="sse-step-sub-' + ag.id + '">Esperando...</div></div>' +
      '<span class="step-status status-pending" id="sse-status-' + ag.id + '">Pendiente</span></div>' +
      '<div class="step-content" id="sse-content-' + ag.id + '" style="display:none;"></div>';
    stepsDiv.appendChild(div);
    if (i < sseAgents.length - 1) {
      var arrow = document.createElement('div');
      arrow.style.cssText = 'text-align:center;color:var(--text3);font-size:16px;padding:4px 0;';
      arrow.textContent = '\u2193';
      stepsDiv.appendChild(arrow);
    }
  });

  // Reset SSE components
  document.getElementById('sse-tasks-area').style.display = 'none';
  document.getElementById('sse-tasks-list').innerHTML = '';
  document.getElementById('sse-kanban-mini').style.display = 'none';
  document.getElementById('sse-kb-backlog').innerHTML = '';
  document.getElementById('sse-kb-progress').innerHTML = '';
  document.getElementById('sse-kb-review').innerHTML = '';
  document.getElementById('sse-kb-done').innerHTML = '';
  var logEl = document.getElementById('sse-log');
  logEl.style.display = 'block';
  logEl.innerHTML = '';
  document.getElementById('sse-sla-counter').style.display = 'none';
  if (_sseTimer) clearInterval(_sseTimer);

  _sseStartTime = new Date();
  sseLog('SYSTEM', 'Pipeline RUN iniciado', '#39c5cf');

  // Connect SSE
  var token = AUTH_TOKEN || '';
  var url = API_BASE + '/agents/run/chain/stream?message=' + encodeURIComponent(text) + '&session_id=pipeline-' + Date.now() + '&token=' + encodeURIComponent(token);

  var es = new EventSource(url);

  es.onmessage = function(e) {
    try {
      var data = JSON.parse(e.data);
      handleSSEEvent(data);
    } catch(err) {
      console.error('SSE parse error:', err);
    }
  };

  es.onerror = function() {
    es.close();
    execBtn.disabled = false;
    statusEl.textContent = 'Idle';
    statusEl.style.color = 'var(--yellow)';
    sseLog('SYSTEM', 'Pipeline completado', '#3fb950');
  };
}

function handleSSEEvent(data) {
  var ev = data.event;

  if (ev === 'agent_start') {
    var step = document.getElementById('sse-step-' + data.agent_id);
    if (step) {
      step.classList.add('sse-working');
      var status = document.getElementById('sse-status-' + data.agent_id);
      if (status) { status.textContent = 'Ejecutando...'; status.className = 'step-status status-running'; }
      var sub = document.getElementById('sse-step-sub-' + data.agent_id);
      if (sub) sub.textContent = 'Procesando...';
    }
    sseLog(data.agent_name || data.agent_id, 'Iniciado', data.color || '#3b82f6');
  }

  else if (ev === 'agent_complete') {
    var step = document.getElementById('sse-step-' + data.agent_id);
    if (step) {
      step.classList.remove('sse-working');
      step.classList.add('sse-done');
      var status = document.getElementById('sse-status-' + data.agent_id);
      if (status) { status.textContent = '\u2713 Completado'; status.className = 'step-status status-done'; }
      var content = document.getElementById('sse-content-' + data.agent_id);
      if (content && data.response_preview) {
        content.style.display = 'block';
        content.innerHTML = '<div style="font-size:11px;color:var(--text2);padding:8px;max-height:150px;overflow-y:auto;">' + fmtMd(data.response_preview) + '</div>';
      }
    }
    sseLog(data.agent_id, '\u2713 Completado', '#3fb950');
  }

  else if (ev === 'agent_skip') {
    var step = document.getElementById('sse-step-' + data.agent_id);
    if (step) {
      step.classList.add('sse-skipped');
      var status = document.getElementById('sse-status-' + data.agent_id);
      if (status) { status.textContent = 'No requerido'; status.className = 'step-status'; status.style.color = '#484f58'; }
      var sub = document.getElementById('sse-step-sub-' + data.agent_id);
      if (sub) sub.textContent = data.reason || 'Saltado';
    }
    sseLog(data.agent_id, 'Saltado \u2014 ' + (data.reason || ''), '#484f58');
  }

  else if (ev === 'tool_call') {
    sseLog(data.agent_id, 'tool: ' + data.tool + '(' + (data.input || '').substring(0, 60) + ')', '#3fb950');
  }

  else if (ev === 'field_update') {
    if (data.field === 'priority') {
      var prioEl = document.getElementById('itsm-prio-calc');
      if (prioEl) {
        prioEl.textContent = data.value;
        var colors = {P1:'var(--red)',P2:'var(--orange)',P3:'var(--yellow)',P4:'var(--green)'};
        prioEl.style.color = colors[data.value] || 'var(--text)';
        prioEl.style.borderColor = colors[data.value] || 'var(--border)';
      }
    }
    if (data.field === 'ticket_id') {
      var ticketEl = document.getElementById('itsm-ticket-id');
      if (ticketEl) ticketEl.textContent = data.value;
    }
    sseLog('FIELD', data.field + ' = ' + data.value, '#39c5cf');
  }

  else if (ev === 'sla_started') {
    startSLACounter(data.priority, data.sla_hours, data.start, data.deadline);
  }

  else if (ev === 'task_created') {
    var tasksArea = document.getElementById('sse-tasks-area');
    tasksArea.style.display = 'block';
    var list = document.getElementById('sse-tasks-list');
    var card = document.createElement('div');
    card.className = 'sse-task-card';
    card.id = 'sse-task-' + data.task_id;
    card.innerHTML = '<div style="display:flex;justify-content:space-between;align-items:center;">' +
      '<div style="font-weight:600;font-size:12px;">' + escHtml(data.titulo) + '</div>' +
      '<span style="font-family:var(--mono);font-size:9px;color:var(--text3);">' + escHtml(data.task_id) + '</span></div>' +
      '<div class="tech-placeholder" id="sse-tech-' + data.task_id + '">' +
        '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg> Buscando t\u00e9cnico...' +
      '</div>';
    list.appendChild(card);
  }

  else if (ev === 'technician_assigned') {
    var techEl = document.getElementById('sse-tech-' + data.task_id);
    if (techEl) {
      var initials = (data.tecnico || '??').split(' ').map(function(w){return w[0];}).join('').substring(0,2).toUpperCase();
      techEl.className = 'tech-assigned';
      techEl.innerHTML = '<div style="width:24px;height:24px;border-radius:50%;background:#3fb950;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:800;color:#fff;">' + initials + '</div>' +
        '<span style="font-weight:600;">' + escHtml(data.tecnico) + '</span>' +
        '<span style="font-size:10px;color:var(--text3);">(' + escHtml(data.id_recurso) + ' \u00b7 ' + escHtml(data.nivel) + ')</span>';
    }
    sseLog('AG-002', 'Asignado: ' + data.tecnico + ' \u2192 ' + data.task_id, '#8b5cf6');
  }

  else if (ev === 'kanban_update') {
    var kbDiv = document.getElementById('sse-kanban-mini');
    kbDiv.style.display = 'grid';
    var tasks = data.tasks || [];
    tasks.forEach(function(t, i) {
      var col = i === 0 ? 'sse-kb-progress' : 'sse-kb-backlog';
      var colEl = document.getElementById(col);
      if (colEl) {
        var card = document.createElement('div');
        card.className = 'sse-kanban-card';
        card.textContent = (t.titulo || t.task_id || '').substring(0, 35);
        colEl.appendChild(card);
      }
    });
  }

  else if (ev === 'buffer_options') {
    sseLog('AG-004', 'Buffer: ' + (data.response || '').substring(0, 100), '#f59e0b');
  }

  else if (ev === 'chain_complete') {
    var execBtn = document.getElementById('run-exec-btn');
    var statusEl = document.getElementById('run-status-val');
    if (execBtn) execBtn.disabled = false;
    if (statusEl) { statusEl.textContent = 'Idle'; statusEl.style.color = 'var(--yellow)'; }
    sseLog('SYSTEM', 'Cadena completada: ' + (data.agents_used || []).join(' \u2192 '), '#3fb950');
  }

  else if (ev === 'error') {
    sseLog('ERROR', data.message || 'Error desconocido', '#f85149');
  }
}

function sseLog(agent, msg, color) {
  var logEl = document.getElementById('sse-log');
  if (!logEl) return;
  var elapsed = _sseStartTime ? Math.floor((Date.now() - _sseStartTime.getTime()) / 1000) : 0;
  var mm = String(Math.floor(elapsed / 60)).padStart(2, '0');
  var ss = String(elapsed % 60).padStart(2, '0');
  var line = document.createElement('div');
  line.className = 'log-line';
  line.innerHTML = '<span class="log-ts">' + mm + ':' + ss + '</span>' +
    '<span class="log-agent" style="color:' + (color || 'var(--text2)') + ';">' + escHtml(agent) + '</span>' +
    '<span>' + escHtml(msg) + '</span>';
  logEl.appendChild(line);
  logEl.scrollTop = logEl.scrollHeight;
}

function startSLACounter(priority, hours, startStr, deadlineStr) {
  var counter = document.getElementById('sse-sla-counter');
  counter.style.display = 'block';
  var colors = {P1:'#ef4444',P2:'#f59e0b',P3:'#eab308',P4:'#3fb950'};
  var c = colors[priority] || '#3fb950';
  document.getElementById('sse-sla-digits').style.color = c;
  document.getElementById('sse-sla-bar-fill').style.background = c;
  document.getElementById('sse-sla-label').textContent = 'SLA ' + priority + ' \u2014 ' + hours + 'h';
  document.getElementById('sse-sla-label').style.color = c;

  _sseDeadline = new Date(deadlineStr);
  var startDate = new Date(startStr);
  document.getElementById('sse-sla-start').textContent = 'Inicio: ' + startDate.toLocaleTimeString('es-ES');
  document.getElementById('sse-sla-end').textContent = 'L\u00edmite: ' + _sseDeadline.toLocaleTimeString('es-ES') + ' ' + _sseDeadline.toLocaleDateString('es-ES');

  var totalMs = hours * 3600000;
  if (_sseTimer) clearInterval(_sseTimer);
  _sseTimer = setInterval(function() {
    var now = new Date();
    var remaining = _sseDeadline.getTime() - now.getTime();
    if (remaining <= 0) {
      document.getElementById('sse-sla-digits').textContent = '00:00:00 EXPIRADO';
      document.getElementById('sse-sla-bar-fill').style.width = '100%';
      clearInterval(_sseTimer);
      return;
    }
    var h = Math.floor(remaining / 3600000);
    var m = Math.floor((remaining % 3600000) / 60000);
    var s = Math.floor((remaining % 60000) / 1000);
    document.getElementById('sse-sla-digits').textContent = String(h).padStart(2,'0') + ':' + String(m).padStart(2,'0') + ':' + String(s).padStart(2,'0');
    var elapsed = now.getTime() - startDate.getTime();
    var pct = Math.min(100, Math.round(elapsed / totalMs * 100));
    document.getElementById('sse-sla-bar-fill').style.width = pct + '%';
  }, 1000);
}

// ── CONFIG MODAL ──
const ALL_AGENTS_CFG = [...RUN_AGENTS,...BUILD_AGENTS];

async function openConfigModal() {
  showToast('Agentes IA nativos Claude — No requiere configuración Flowise');
}
function closeConfigModal(){ document.getElementById('config-modal').classList.remove('open'); }

async function saveConfig() {
  const config={};
  ALL_AGENTS_CFG.forEach(ag=>{
    const el=document.getElementById('cf-input-'+ag.id);
    if(el) config[ag.id]=el.value.trim();
  });
  try {
    await authFetch(`${API_BASE}/api/flowise/config`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({config})});
    showToast('✓ Chatflows guardados en el servidor');
  } catch(e){ showToast('⚠ Error guardando: '+e.message); return; }
  closeConfigModal();
}

async function fetchFlowiseFlows() {
  const btn=document.getElementById('fetch-btn');
  const container=document.getElementById('fetched-flows');
  btn.textContent='⏳ Cargando...';
  btn.disabled=true;
  container.style.display='block';
  container.innerHTML='<div style="padding:10px;color:var(--text2);font-size:12px;display:flex;align-items:center;gap:8px;"><span class="loading-spinner"></span>Conectando a Flowise...</div>';
  try {
    const resp=await authFetch(`${API_BASE}/api/flowise/chatflows`);
    if(!resp.ok){ const e=await resp.json(); throw new Error(e.detail||'HTTP '+resp.status); }
    const flows=await resp.json();
    if(!flows.length){
      container.innerHTML='<div style="padding:10px;color:var(--text2);font-size:12px;">No se encontraron chatflows</div>';
    } else {
      container.innerHTML='<div style="font-size:11px;color:var(--text2);padding:8px 12px 4px;font-weight:600;letter-spacing:.5px;text-transform:uppercase;">'+flows.length+' chatflows disponibles — click para copiar UUID</div>'+
        flows.map(f=>`<div class="fetched-item" onclick="pasteFlowId('${escHtml(f.id)}')">
          <div class="fetched-item-name">${escHtml(f.name||'Sin nombre')}</div>
          <div class="fetched-item-id">${escHtml(f.id)}</div>
        </div>`).join('');
    }
  } catch(e){
    container.innerHTML=`<div style="padding:10px;color:var(--red);font-size:12px;">⚠ ${escHtml(e.message)}</div>`;
  }
  btn.textContent='🔄 Obtener Chatflows';
  btn.disabled=false;
}

function pasteFlowId(id) {
  const focused=ALL_AGENTS_CFG.map(ag=>document.getElementById('cf-input-'+ag.id)).find(el=>el===document.activeElement);
  if(focused){ focused.value=id; showToast('ID pegado — pon el cursor en el campo destino y vuelve a hacer click'); }
  else { navigator.clipboard.writeText(id).catch(()=>{}); showToast('UUID copiado al portapapeles: '+id.substring(0,20)+'...'); }
}

let _toastTm=null;
function showToast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg; t.style.opacity='1';
  clearTimeout(_toastTm);
  _toastTm=setTimeout(()=>{t.style.opacity='0';},3000);
}

