  {cat:'Hardware',icon:'🔧',color:'#a8a29e',skills:['Hardware: Cambiar Disco','Hardware: Impresora en Red','Hardware: Limpieza Interna','Hardware: Inventario Activos','Hardware: Diagnóstico Fuente']},
  {cat:'Storage / SAP',icon:'💾',color:'#d97706',skills:['Storage: Mapa de Rutas','Storage: Asignación LUN','Storage: Snapshot','SAP: Transacción básica']},
  {cat:'Soporte / Tickets',icon:'🎫',color:'#fb923c',skills:['Ticket: Registro Incidencia','Ticket: Priorización','Ticket: Escalado Nivel','Ticket: Resolución y Cierre','Ticket: Comunicación Usuario','Doc: Escribir Documentación']},
];
const SLC = {Frontend:'#3b82f6',Backend:'#8b5cf6',Redes:'#6366f1',Windows:'#0ea5e9',BBDD:'#eab308',Seguridad:'#ef4444',DevOps:'#84cc16',QA:'#06b6d4',Soporte:'#fb923c'};

// shared state
let _tStep=1, _tNivel='', _tSilo='', _tSkills=[], _tEditMode=false, _tEditId='';
let _pStep=1, _pPrio='', _pSkills=[], _pEditMode=false, _pEditId='';

function fmOpen(id){ document.getElementById(id).classList.add('open'); document.body.style.overflow='hidden'; }
function fmClose(id){ document.getElementById(id).classList.remove('open'); document.body.style.overflow=''; }

// close on backdrop click
['fm-team','fm-proj'].forEach(id=>{
  document.getElementById(id).addEventListener('click', e=>{ if(e.target.id===id) fmClose(id); });
});

// ─── TEAM MODAL ─────────────────────────────────────────────
function openTeamForm(){
  _tEditMode=false; _tEditId='';
  _tStep=1; _tNivel=''; _tSilo=''; _tSkills=[];
  const nextNum = Math.max(...ALL_TEAM.map(t=>parseInt((t.fte||'FTE-0').replace('FTE-',''))||0), 150) + 1;
  document.getElementById('t-id').value = 'FTE-'+nextNum;
  document.getElementById('t-id').readOnly = false;
  document.getElementById('t-id').style.opacity = '';
  document.getElementById('t-nombre').value='';
  document.getElementById('t-estado').value='DISPONIBLE';
  document.querySelectorAll('#fm-team .nivel-card').forEach(c=>{ c.classList.remove('sel'); c.style.cssText=''; });
  document.querySelectorAll('#fm-team .silo-card').forEach(c=>{ c.classList.remove('sel'); c.style.cssText=''; });
  document.getElementById('tm-icon').textContent='🧑‍💻';
  document.getElementById('tm-title').textContent='Nuevo Técnico';
  document.getElementById('tm-sub').textContent='Registrar miembro en el equipo PMO';
  document.getElementById('ts-submit-btn').innerHTML='✅ Añadir al Equipo';
  tsSetStep(1); fmOpen('fm-team');
}

function openTeamEdit(fte){
  const t = ALL_TEAM.find(x=>x.fte===fte);
  if(!t){ showToast('❌ Técnico no encontrado'); return; }
  _tEditMode=true; _tEditId=fte;
  _tStep=1; _tNivel=t.nivel||''; _tSilo=t.silo||''; _tSkills=[...(t.tags||[])];
  // header
  document.getElementById('tm-icon').textContent='✏️';
  document.getElementById('tm-title').textContent='Editar Técnico';
  document.getElementById('tm-sub').textContent=t.name+' — '+fte;
  document.getElementById('ts-submit-btn').innerHTML='💾 Guardar Cambios';
  // fields
  const idEl = document.getElementById('t-id');
  idEl.value = fte; idEl.readOnly = true; idEl.style.opacity = '.55';
  document.getElementById('t-nombre').value = t.name;
  document.getElementById('t-estado').value = t.estado||'DISPONIBLE';
  // reset visual selectors first
  document.querySelectorAll('#fm-team .nivel-card').forEach(c=>{ c.classList.remove('sel'); c.style.cssText=''; });
  document.querySelectorAll('#fm-team .silo-card').forEach(c=>{ c.classList.remove('sel'); c.style.cssText=''; });
  // pre-select nivel
  document.querySelectorAll('#fm-team .nivel-card').forEach(el=>{
    const badge = el.querySelector('.nc-badge');
    if(badge && badge.textContent.trim()===_tNivel) selNivel(_tNivel, el);
  });
  // pre-select silo
  document.querySelectorAll('#fm-team .silo-card').forEach(el=>{
    const name = el.querySelector('.sc-name');
    if(name && name.textContent.trim()===_tSilo) selSilo(_tSilo, el);
  });
  tsSetStep(1); fmOpen('fm-team');
}

function tsSetStep(s){
  _tStep=s;
  document.querySelectorAll('#fm-team .fm-step').forEach(el=>el.classList.remove('active'));
  document.getElementById('ts-'+s).classList.add('active');
  [1,2,3].forEach(i=>{
    const d=document.getElementById('ts-dot-'+i);
    d.classList.remove('active','done');
    if(i<s) d.classList.add('done'); else if(i===s) d.classList.add('active');
  });
  document.getElementById('ts-back-btn').style.display = s>1 ? '' : 'none';
  document.getElementById('ts-next-btn').style.display = s<3 ? 'flex' : 'none';
  document.getElementById('ts-submit-btn').style.display = s===3 ? 'flex' : 'none';
  document.getElementById('ts-skill-count').style.display = s===2 ? '' : 'none';
  if(s===2){ renderSkillMatrix('ts-2-content', _tSkills, 'ts'); updateTsCount(); }
  if(s===3){ renderTeamPreview(); }
}

function tsNext(){
  if(_tStep===1){
    if(!document.getElementById('t-id').value.trim()){ showToast('⚠ Escribe el ID del técnico'); return; }
    if(!document.getElementById('t-nombre').value.trim()){ showToast('⚠ Escribe el nombre completo'); return; }
    if(!_tNivel){ showToast('⚠ Selecciona el nivel profesional'); return; }
    if(!_tSilo){ showToast('⚠ Selecciona el silo de especialidad'); return; }
  }
  if(_tStep<3) tsSetStep(_tStep+1);
}
function tsBack(){ if(_tStep>1) tsSetStep(_tStep-1); }

function selNivel(n, el){
  _tNivel=n;
  const colors={N1:'#f85149',N2:'#2d7ef7',N3:'#a5b4fc',N4:'#f59e0b'};
  const c=colors[n];
  document.querySelectorAll('#fm-team .nivel-card').forEach(e=>{ e.classList.remove('sel'); e.style.borderColor=''; e.style.background=''; });
  el.classList.add('sel'); el.style.borderColor=c; el.style.background=c+'20';
}
function selSilo(s, el){
  _tSilo=s;
  const c=SLC[s]||'#2d7ef7';
  document.querySelectorAll('#fm-team .silo-card').forEach(e=>{ e.classList.remove('sel'); e.style.borderColor=''; e.style.background=''; });
  el.classList.add('sel'); el.style.borderColor=c; el.style.background=c+'20';
}
function updateTsCount(){ document.getElementById('ts-skill-count').textContent=_tSkills.length+' skills seleccionadas'; }

function renderTeamPreview(){
  const nombre=document.getElementById('t-nombre').value.trim();
  const id=document.getElementById('t-id').value.trim();
  const estado=document.getElementById('t-estado').value;
  const col=SLC[_tSilo]||'#8b949e';
  const nColors={N1:'#f85149',N2:'#2d7ef7',N3:'#a5b4fc',N4:'#f59e0b'};
  const nc=nColors[_tNivel]||'#8b949e';
  const initials=(nombre.split(' ').slice(0,2).map(n=>n[0]||'').join('')).toUpperCase()||'?';
  const skHtml=_tSkills.length
    ? _tSkills.slice(0,14).map(s=>`<span class="skill-tag" style="border-color:${getSkillColor(s)}44;color:${getSkillColor(s)}">${escHtml(s.split(': ')[1]||s)}</span>`).join('')+(_tSkills.length>14?`<span class="skill-more">+${_tSkills.length-14} más</span>`:'')
    : '<span style="color:var(--text3);font-size:11px;font-style:italic;">Sin skills — puedes añadirlas después</span>';
  document.getElementById('ts-3-preview').innerHTML=`
    <div style="font-size:13px;color:var(--text2);margin-bottom:14px;">Revisa los datos antes de confirmar. El técnico quedará <strong style="color:var(--green);">registrado y disponible</strong> en el sistema.</div>
    <div class="preview-card" style="border-color:${col}44;">
      <div style="position:absolute;top:-30px;right:-30px;width:110px;height:110px;border-radius:50%;background:${col};opacity:.05;pointer-events:none;"></div>
      <div class="pc-top">
        <div class="pc-avatar" style="background:linear-gradient(135deg,${col},${col}99);">${escHtml(initials)}</div>
        <div style="flex:1">
          <div class="pc-name">${escHtml(nombre)||'Sin nombre'}</div>
          <div class="pc-id">${escHtml(id)}</div>
        </div>
        <div style="display:flex;flex-direction:column;align-items:flex-end;gap:5px;">
          <span class="nivel-badge ${_tNivel.toLowerCase()}">${_tNivel}</span>
          <span class="silo-badge" style="background:${col}22;color:${col};">${_tSilo}</span>
        </div>
      </div>
      <div class="pc-meta">
        <span style="font-size:11px;font-weight:700;padding:2px 10px;border-radius:20px;background:var(--green-bg);color:var(--green);">● ${estado}</span>
        <span style="font-size:11px;font-weight:700;padding:2px 10px;border-radius:20px;background:var(--blue-bg);color:var(--blue);font-family:var(--mono);">${_tSkills.length} skills</span>
      </div>
      <div class="pc-skills-title">Skills asignadas</div>
      <div class="pc-skills-wrap">${skHtml}</div>
    </div>`;
  // Show tasks panel in edit mode
  const tasksPanel = document.getElementById('ts-tasks-panel');
  if (_tEditMode && _tEditId) {
    const myTasks = _teamTaskMap[_tEditId] || [];
    const active = myTasks.filter(tk => tk.columna !== 'Completado');
    const completed = myTasks.filter(tk => tk.columna === 'Completado');
    const runActive = active.filter(tk => tk.tipo === 'RUN').length;
    const buildActive = active.filter(tk => tk.tipo === 'BUILD').length;
    const totalActive = active.length;
    tasksPanel.style.display = 'block';
    document.getElementById('ts-tasks-count').textContent = `(${active.length} activas, ${completed.length} completadas)`;
    document.getElementById('ts-pct-run').textContent = totalActive > 0 ? Math.round(runActive/totalActive*100) + '%' : '0%';
    document.getElementById('ts-pct-build').textContent = totalActive > 0 ? Math.round(buildActive/totalActive*100) + '%' : '0%';
    const list = document.getElementById('ts-tasks-list');
    if (myTasks.length === 0) {
      list.innerHTML = '<div style="text-align:center;padding:10px;color:var(--text3);font-size:11px;">Sin tareas asignadas</div>';
    } else {
      list.innerHTML = myTasks.map(tk => {
        const isRun = tk.tipo === 'RUN';
        const isDone = tk.columna === 'Completado';
        const link = tk.id_proyecto || tk.id_incidencia || '';
        const colIcon = {'Backlog':'📋','Análisis':'🔍','En Progreso':'⚡','Code Review':'👁','Testing':'🧪','Despliegue':'🚀','Bloqueado':'🚫','Completado':'✅'};
        return `<div style="background:var(--bg2);border:1px solid var(--border);border-radius:6px;padding:6px 10px;margin-bottom:4px;display:flex;align-items:center;gap:8px;${isDone?'opacity:.5;':''}border-left:3px solid ${isRun?'var(--blue)':'var(--green)'};">
          <span style="font-size:11px;">${colIcon[tk.columna]||'📋'}</span>
          <div style="flex:1;min-width:0;">
            <div style="font-size:11px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${escHtml(tk.titulo)}</div>
            <div style="font-size:9px;color:var(--text3);display:flex;gap:6px;">
              <span style="color:${isRun?'var(--blue)':'var(--green)'};">${tk.tipo}</span>
              <span>${tk.columna}</span>
              ${link?`<span style="color:var(--purple);">${link}</span>`:''}
              ${tk.horas_estimadas?`<span>⏱ ${tk.horas_estimadas}h</span>`:''}
            </div>
          </div>
          <span style="font-family:var(--mono);font-size:9px;color:var(--text3);">${tk.id}</span>
        </div>`;
      }).join('');
    }
  } else {
    tasksPanel.style.display = 'none';
  }
}

function getSkillColor(sk){
  for(const cat of SKILL_CATS){ if(cat.skills.includes(sk)) return cat.color; }
  return '#8b949e';
}

async function tsSubmit(){
  const btn=document.getElementById('ts-submit-btn');
  const originalHtml = btn.innerHTML;
  btn.disabled=true; btn.innerHTML='<span class="loading-spinner" style="width:13px;height:13px;border-width:2px;"></span> Guardando...';
  const nombre = document.getElementById('t-nombre').value.trim();
  const payload={
    id_recurso: document.getElementById('t-id').value.trim(),
    nombre, nivel: _tNivel, silo_especialidad: _tSilo,
    skills_json: _tSkills, skill_principal: _tSkills[0]||null,
    estado_run: document.getElementById('t-estado').value,
  };
  try {
    const url = _tEditMode ? API_BASE+'/team/tecnicos/'+encodeURIComponent(_tEditId) : API_BASE+'/team/tecnicos';
    const method = _tEditMode ? 'PUT' : 'POST';
    const res=await authFetch(url,{method,headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
    if(!res.ok){ const err=await res.json().catch(()=>{}); throw new Error(err?.detail||'Error al guardar'); }
    showToast(_tEditMode ? '💾 '+nombre+' actualizado correctamente' : '✅ '+nombre+' añadido al equipo');
    fmClose('fm-team'); ALL_TEAM=[]; loadTeam();
  } catch(e){ showToast('❌ '+e.message); btn.disabled=false; btn.innerHTML=originalHtml; }
}

// ─── PROJECT MODAL ───────────────────────────────────────────
function openProjForm(){
  _pEditMode=false; _pEditId='';
  _pStep=1; _pPrio=''; _pSkills=[];
  document.getElementById('p-nombre').value='';
  document.getElementById('p-perfil').value='';
  document.getElementById('p-estado').value='Standby';
  document.getElementById('p-horas').value=80;
  updateHoursSlider();
  document.querySelectorAll('#fm-proj .prio-card').forEach(c=>{ c.classList.remove('sel'); c.style.borderColor=''; c.style.background=''; });
  document.getElementById('pm-icon').textContent='📋';
  document.getElementById('pm-title').textContent='Nuevo Proyecto';
  document.getElementById('pm-sub').textContent='Registrar proyecto en la cartera BUILD';
  document.getElementById('ps-submit-btn').innerHTML='✅ Crear Proyecto';
  psSetStep(1); fmOpen('fm-proj');
}

function openProjEdit(id){
  const p = ALL_PROJECTS.find(x=>x.id===id);
  if(!p){ showToast('❌ Proyecto no encontrado'); return; }
  _pEditMode=true; _pEditId=id;
  _pStep=1; _pPrio=p.prio||''; _pSkills=[];
  // parse skills from "skill1, skill2, ..." string
  if(p.skill){ _pSkills = p.skill.split(',').map(s=>s.trim()).filter(s=>s.length>0); }
  // header
  document.getElementById('pm-icon').textContent='✏️';
  document.getElementById('pm-title').textContent='Editar Proyecto';
  document.getElementById('pm-sub').textContent=p.name.slice(0,50)+(p.name.length>50?'…':'');
  document.getElementById('ps-submit-btn').innerHTML='💾 Guardar Cambios';
  // fields
  document.getElementById('p-nombre').value = p.name;
  document.getElementById('p-perfil').value = '';
  document.getElementById('p-estado').value = p.estado||'Standby';
  document.getElementById('p-horas').value = p.horas||80;
  updateHoursSlider();
  // reset + pre-select prioridad
  document.querySelectorAll('#fm-proj .prio-card').forEach(c=>{ c.classList.remove('sel'); c.style.borderColor=''; c.style.background=''; });
  document.querySelectorAll('#fm-proj .prio-card').forEach(el=>{
    const nm = el.querySelector('.prio-name');
    if(nm){ const txt=nm.textContent.trim(); if(txt===_pPrio||txt.normalize('NFD').replace(/[\u0300-\u036f]/g,'')===_pPrio.normalize('NFD').replace(/[\u0300-\u036f]/g,'')) selPrio(_pPrio, el); }
  });
  psSetStep(1); fmOpen('fm-proj');
}

function psSetStep(s){
  _pStep=s;
  document.querySelectorAll('#fm-proj .fm-step').forEach(el=>el.classList.remove('active'));
  document.getElementById('ps-'+s).classList.add('active');
  [1,2].forEach(i=>{
    const d=document.getElementById('ps-dot-'+i);
    d.classList.remove('active','done');
    if(i<s) d.classList.add('done'); else if(i===s) d.classList.add('active');
  });
  document.getElementById('ps-back-btn').style.display = s>1 ? '' : 'none';
  document.getElementById('ps-next-btn').style.display = s<2 ? 'flex' : 'none';
  document.getElementById('ps-submit-btn').style.display = s===2 ? 'flex' : 'none';
  if(s===2){ renderSkillMatrix('ps-2-content', _pSkills, 'ps'); renderProjPreview(); }
}

function psNext(){
  if(!document.getElementById('p-nombre').value.trim()){ showToast('⚠ Escribe el nombre del proyecto'); return; }
  if(!_pPrio){ showToast('⚠ Selecciona la prioridad estratégica'); return; }
  psSetStep(2);
}
function psBack(){ if(_pStep>1) psSetStep(_pStep-1); }

function selPrio(p, el){
  _pPrio=p;
  const colors={'Crítica':'#f85149','Alta':'#f0883e','Media':'#d29922','Baja':'#3fb950'};
  const c=colors[p];
  document.querySelectorAll('#fm-proj .prio-card').forEach(e=>{ e.classList.remove('sel'); e.style.borderColor=''; e.style.background=''; });
  el.classList.add('sel'); el.style.borderColor=c; el.style.background=c+'20';
}

function updateHoursSlider(){
  const v=parseInt(document.getElementById('p-horas').value);
  const pct=((v-5)/(500-5)*100).toFixed(1);
  const col=v<60?'var(--green)':v<150?'var(--blue)':v<300?'var(--orange)':'var(--red)';
  document.getElementById('p-horas-val').textContent=v;
  document.getElementById('p-horas-val').style.color=col;
  const slider=document.getElementById('p-horas');
  slider.style.background=`linear-gradient(to right,${col} 0%,${col} ${pct}%,var(--border) ${pct}%,var(--border) 100%)`;
  const thumb=col==='var(--green)'?'#3fb950':col==='var(--blue)'?'#2d7ef7':col==='var(--orange)'?'#f0883e':'#f85149';
  slider.style.setProperty('--thumb-color', thumb);
  if(_pStep===2) renderProjPreview();
}

function renderProjPreview(){
  const nombre=document.getElementById('p-nombre').value.trim();
  const horas=document.getElementById('p-horas').value;
  const estado=document.getElementById('p-estado').value;
  const perfil=document.getElementById('p-perfil').value.trim();
  const prioColors={'Crítica':'#f85149','Alta':'#f0883e','Media':'#d29922','Baja':'#3fb950'};
  const pc=prioColors[_pPrio]||'var(--blue)';
  const skHtml=_pSkills.length
    ? _pSkills.slice(0,10).map(s=>`<span class="skill-tag" style="border-color:${getSkillColor(s)}44;color:${getSkillColor(s)};">${escHtml(s.split(': ')[1]||s)}</span>`).join('')+(_pSkills.length>10?`<span class="skill-more">+${_pSkills.length-10}</span>`:'')
    : '<span style="color:var(--text3);font-size:11px;font-style:italic;">Sin skills definidas</span>';
  document.getElementById('ps-3-preview').innerHTML=`
    <div class="preview-card" style="border-color:${pc}44;">
      <div style="position:absolute;top:-30px;right:-30px;width:110px;height:110px;border-radius:50%;background:${pc};opacity:.05;pointer-events:none;"></div>
      <div style="display:flex;align-items:flex-start;gap:12px;margin-bottom:12px;">
        <div style="width:42px;height:42px;border-radius:10px;background:${pc}22;border:1px solid ${pc}44;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;">📋</div>
        <div style="flex:1;min-width:0;">
          <div style="font-size:14px;font-weight:700;line-height:1.3;margin-bottom:6px;">${escHtml(nombre)||'Sin nombre'}</div>
          <div style="display:flex;gap:6px;flex-wrap:wrap;">
            <span style="font-size:11px;background:${pc}22;color:${pc};border-radius:20px;padding:2px 10px;font-weight:700;">${_pPrio||'—'}</span>
            <span style="font-size:11px;background:var(--bg3);border:1px solid var(--border);border-radius:20px;padding:2px 10px;color:var(--text2);">${estado}</span>
            <span style="font-size:11px;background:var(--bg3);border:1px solid var(--border);border-radius:20px;padding:2px 10px;font-family:var(--mono);color:var(--text2);">⏱ ${horas}h</span>
            ${perfil?`<span style="font-size:11px;background:var(--purple-bg);color:var(--purple);border-radius:20px;padding:2px 10px;">👤 ${escHtml(perfil)}</span>`:''}
          </div>
        </div>
      </div>
      <div class="pc-skills-title">Skills requeridas (${_pSkills.length})</div>
      <div class="pc-skills-wrap">${skHtml}</div>
    </div>`;
}

async function psSubmit(){
  const btn=document.getElementById('ps-submit-btn');
  const originalHtml = btn.innerHTML;
  btn.disabled=true; btn.innerHTML='<span class="loading-spinner" style="width:13px;height:13px;border-width:2px;"></span> Guardando...';
  const nombre = document.getElementById('p-nombre').value.trim();
  const payload={
    nombre, prioridad: _pPrio, prioridad_num: {'Crítica':1,'Alta':2,'Media':3,'Baja':4}[_pPrio]||3,
    estado: document.getElementById('p-estado').value,
    horas_estimadas: parseInt(document.getElementById('p-horas').value),
    skill_requerida: _pSkills.join(', '),
  };
  try {
    let url, method;
    if(_pEditMode){ url=API_BASE+'/cartera/proyectos'; method='PUT'; payload.id_proyecto=_pEditId; }
    else { url=API_BASE+'/proyectos/crear'; method='POST'; }
    const res=await authFetch(url,{method,headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
    if(!res.ok){ const err=await res.json().catch(()=>{}); throw new Error(err?.detail||'Error al guardar'); }
    showToast(_pEditMode ? '💾 Proyecto actualizado correctamente' : '✅ Proyecto "'+nombre.slice(0,25)+'..." creado');
    fmClose('fm-proj'); ALL_PROJECTS=[]; loadProjects();
  } catch(e){ showToast('❌ '+e.message); btn.disabled=false; btn.innerHTML=originalHtml; }
}

// ─── SKILLS MATRIX (shared) ─────────────────────────────────
function renderSkillMatrix(containerId, selected, prefix){
  document.getElementById(containerId).innerHTML = SKILL_CATS.map(cat=>{
    const selCount=cat.skills.filter(s=>selected.includes(s)).length;
    return `<div class="skill-cat-block">
      <div class="skill-cat-head" style="color:${cat.color}">
        <span style="font-size:14px">${cat.icon}</span>
        <span>${cat.cat}</span>
        <div class="skill-cat-line" style="background:${cat.color}"></div>
        <span class="skill-cat-cnt" style="color:${cat.color}">${selCount}/${cat.skills.length}</span>
      </div>
      <div class="skill-chips-grid">
        ${cat.skills.map(sk=>{
          const isSel=selected.includes(sk);
          const label=sk.split(': ')[1]||sk;
          return `<div class="sk-chip${isSel?' sel':''}" style="${isSel?`border-color:${cat.color};background:${cat.color};color:#fff;`:''}" onclick="toggleSkill('${sk.replace(/'/g,"\\'")}','${cat.color}','${prefix}',this)">${escHtml(label)}</div>`;
        }).join('')}
      </div>
    </div>`;
  }).join('');
}

function toggleSkill(sk, color, prefix, el){
  const arr = prefix==='ts' ? _tSkills : _pSkills;
  const idx = arr.indexOf(sk);
  if(idx>=0){
    arr.splice(idx,1);
    el.classList.remove('sel'); el.style.borderColor=''; el.style.background=''; el.style.color='';
  } else {
    arr.push(sk);
    el.classList.add('sel'); el.style.borderColor=color; el.style.background=color; el.style.color='#fff';
  }
  // update category counter
  const catEl = el.closest('.skill-cat-block');
  if(catEl){
    const catCnt=catEl.querySelector('.skill-cat-cnt');
    if(catCnt){ const chips=catEl.querySelectorAll('.sk-chip.sel'); catCnt.textContent=chips.length+'/'+catEl.querySelectorAll('.sk-chip').length; }
  }
  if(prefix==='ts'){ document.getElementById('ts-skill-count').textContent=_tSkills.length+' skills seleccionadas'; }
  else { document.getElementById('ps-skill-count').textContent=_pSkills.length+' skills'; renderProjPreview(); }
}

// ══════════════════ BUDGET MODULE ══════════════════
let ALL_BUDGETS = [], _bgtFiltered = [], _bgtEstadoFilter = '', _bgtSearch = '';
let _bgtEditMode = false, _bgtEditId = '';
let _bgtProveedores = []; // [{nombre,tipo,concepto,dias,tarifa,total}]

const fmtEur = v => {
  if(v===undefined||v===null) return '€ 0';
  const n = typeof v === 'string' ? parseFloat(v)||0 : (v||0);
  if(n>=1000000) return '€ '+(n/1000000).toFixed(2)+'M';
  if(n>=1000) return '€ '+(n/1000).toFixed(1)+'K';
  return '€ '+n.toLocaleString('es-ES',{minimumFractionDigits:0,maximumFractionDigits:0});
};
const fmtNum = v => {const n=parseFloat(v)||0; return n.toFixed(2);};

async function loadBudgets(){
  try {
    const r = await authFetch(API_BASE+'/presupuestos');
    ALL_BUDGETS = r.ok ? await r.json() : [];
  } catch(e){ ALL_BUDGETS=[]; }
  // Populate project dropdown in form
  const sel = document.getElementById('b-proyecto');
  if(sel && ALL_PROJECTS.length){
    sel.innerHTML = '<option value="">— Seleccionar proyecto —</option>' +
      ALL_PROJECTS.map(p=>`<option value="${escHtml(p.id)}" data-horas="${p.horas||0}">${escHtml(p.id.slice(0,35))} — ${escHtml((p.name||'').slice(0,40))}</option>`).join('');
  }
  applyBudgetFilters();
}

function applyBudgetFilters(){
  _bgtFiltered = ALL_BUDGETS.filter(b=>{
    const q = _bgtSearch.toLowerCase();
    const matchQ = !q || (b.id_presupuesto||'').toLowerCase().includes(q) ||
      (b.id_proyecto||'').toLowerCase().includes(q) ||
      (b.nombre_presupuesto||'').toLowerCase().includes(q) ||
      (b.responsable||'').toLowerCase().includes(q);
    const matchE = !_bgtEstadoFilter || b.estado === _bgtEstadoFilter;
    return matchQ && matchE;
  });
  renderBudgetTable();
  updateBudgetKpis();
}

function filterBudgets(q){ _bgtSearch=q; applyBudgetFilters(); }
function filterBgtEstado(e, el){
  _bgtEstadoFilter=e;
  document.querySelectorAll('#page-budget .filter-chip').forEach(c=>c.classList.remove('active'));
  el.classList.add('active');
  applyBudgetFilters();
}

function updateBudgetKpis(){
  const data = ALL_BUDGETS;
  const totalBac = data.reduce((s,b)=>s+(parseFloat(b.bac_total)||0),0);
  const totalLabor = data.reduce((s,b)=>s+(parseFloat(b.total_labor)||0),0);
  const totalOpex = data.reduce((s,b)=>s+(parseFloat(b.total_opex)||0),0);
  const totalCapex = data.reduce((s,b)=>s+(parseFloat(b.total_capex)||0),0);
  const totalProv = data.reduce((s,b)=>s+(parseFloat(b.total_proveedores)||0),0);
  const nAprobados = data.filter(b=>b.estado==='APROBADO').length;
  document.getElementById('bgt-kpi-bac').textContent = fmtEur(totalBac);
  document.getElementById('bgt-kpi-labor').textContent = fmtEur(totalLabor);
  document.getElementById('bgt-kpi-opex').textContent = fmtEur(totalOpex);
  document.getElementById('bgt-kpi-capex').textContent = fmtEur(totalCapex);
  document.getElementById('bgt-kpi-prov').textContent = fmtEur(totalProv);
  document.getElementById('bgt-kpi-count').textContent = data.length;
  document.getElementById('bgt-kpi-count-sub').textContent = nAprobados+' aprobados';
}

function renderBudgetTable(){
  const tbody = document.getElementById('budget-tbody');
  if(!_bgtFiltered.length){
    tbody.innerHTML=`<tr><td colspan="13" style="text-align:center;padding:48px;color:var(--text3);"><div style="font-size:28px;opacity:.2;margin-bottom:8px;">💰</div>No hay presupuestos${_bgtSearch||_bgtEstadoFilter?' que coincidan con el filtro':' registrados aún'}</td></tr>`;
    return;
  }
  const estadoCls = {BORRADOR:'bgt-borrador',EN_REVISION:'bgt-revision',APROBADO:'bgt-aprobado',CERRADO:'bgt-cerrado',RECHAZADO:'bgt-rechazado'};
  const estadoLabel = {BORRADOR:'Borrador',EN_REVISION:'En Revisión',APROBADO:'Aprobado',CERRADO:'Cerrado',RECHAZADO:'Rechazado'};
  tbody.innerHTML = _bgtFiltered.map(b=>{
    const bac = parseFloat(b.bac_total)||0;
    const bacCol = bac>500000?'var(--red)':bac>100000?'var(--orange)':'#10b981';
    return `<tr style="cursor:pointer;" onclick="openBudgetEdit('${escHtml(b.id_presupuesto)}')">
      <td><span style="font-family:var(--mono);font-size:11px;color:var(--text2);">${escHtml(b.id_presupuesto)}</span></td>
      <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${escHtml(b.id_proyecto)}">${escHtml((b.id_proyecto||'').slice(0,40))}</td>
      <td>${escHtml(b.responsable||'—')}</td>
      <td><span class="bgt-estado ${estadoCls[b.estado]||'bgt-borrador'}">${estadoLabel[b.estado]||b.estado}</span></td>
      <td style="text-align:right;"><span class="bgt-amount" style="color:#38bdf8;">${fmtEur(b.total_labor)}</span></td>
      <td style="text-align:right;"><span class="bgt-amount" style="color:#8b5cf6;">${fmtEur(b.total_proveedores)}</span></td>
      <td style="text-align:right;"><span class="bgt-amount" style="color:#fbbf24;">${fmtEur(b.total_opex)}</span></td>
      <td style="text-align:right;"><span class="bgt-amount" style="color:#f97316;">${fmtEur(b.total_capex)}</span></td>
      <td style="text-align:right;"><span class="bgt-amount" style="color:#f472b6;">${fmtEur(b.total_rrhh)}</span></td>
      <td style="text-align:right;"><span class="bgt-amount" style="color:#a3e635;">${fmtEur(b.total_reservas)}</span></td>
      <td style="text-align:right;"><span class="bgt-amount" style="color:${bacCol};font-size:13px;">${fmtEur(bac)}</span></td>
      <td><span style="font-family:var(--mono);font-size:11px;color:var(--text3);">v${b.version||1}</span></td>
      <td><div class="bgt-actions" onclick="event.stopPropagation()">
        <button class="bgt-btn-edit" onclick="openBudgetEdit('${escHtml(b.id_presupuesto)}')">✏️</button>
        <button class="bgt-btn-del" onclick="deleteBudget('${escHtml(b.id_presupuesto)}','${escHtml(b.nombre_presupuesto||b.id_presupuesto)}')">🗑</button>
      </div></td>
    </tr>`;
  }).join('');
}

// ── Form open / close ──
function openBudgetForm(){
  _bgtEditMode=false; _bgtEditId='';
  _bgtProveedores=[];
  resetBudgetForm();
  // generate ID
  const d = new Date(); const y=d.getFullYear(); const m=String(d.getMonth()+1).padStart(2,'0');
  const seq = String(ALL_BUDGETS.length+1).padStart(3,'0');
  document.getElementById('b-id').value = `PRES-${y}${m}-${seq}`;
  document.getElementById('b-id').readOnly = false;
  document.getElementById('b-id').style.opacity='1';
  document.getElementById('bgt-hdr-id').textContent = `PRES-${y}${m}-${seq}`;
  document.getElementById('bgt-hdr-title').textContent = 'Nuevo Presupuesto';
  document.getElementById('bgt-submit-btn').innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg> Crear Presupuesto';
  // populate project dropdown
  const sel = document.getElementById('b-proyecto');
  sel.innerHTML = '<option value="">— Seleccionar proyecto —</option>' +
    ALL_PROJECTS.map(p=>`<option value="${escHtml(p.id)}" data-horas="${p.horas||0}">${escHtml(p.id.slice(0,35))} — ${escHtml((p.name||'').slice(0,40))}</option>`).join('');
  bgtShowSection(1, document.querySelector('.fm-bgt-nav-item'));
  renderProveedores();
  bgtCalc();
  fmOpen('fm-budget');
}

function openBudgetEdit(id){
  const b = ALL_BUDGETS.find(x=>x.id_presupuesto===id);
  if(!b){ showToast('❌ Presupuesto no encontrado'); return; }
  _bgtEditMode=true; _bgtEditId=id;
  resetBudgetForm();
  // header
  document.getElementById('bgt-hdr-id').textContent = b.id_presupuesto;
  document.getElementById('bgt-hdr-title').textContent = b.nombre_presupuesto||'Editar Presupuesto';
  document.getElementById('bgt-submit-btn').innerHTML = '💾 Guardar Cambios';
  // parse proveedores
  let provArr = b.proveedores_externos||[];
  if(typeof provArr === 'string'){ try{ provArr=JSON.parse(provArr); }catch(e){ provArr=[]; } }
  _bgtProveedores = provArr.map(p=>({nombre:p.nombre||'',tipo:p.tipo||'Consultoría',concepto:p.concepto||'',dias:p.dias||0,tarifa:p.tarifa_dia||0,total:p.total||0}));
  // fill fields
  const fv = (id,v)=>{ const e=document.getElementById(id); if(e) e.value=v??''; };
  fv('b-id', b.id_presupuesto); document.getElementById('b-id').readOnly=true; document.getElementById('b-id').style.opacity='.55';
  fv('b-nombre', b.nombre_presupuesto);
  fv('b-responsable', b.responsable);
  fv('b-aprobado-por', b.aprobado_por||'');
  fv('b-fecha-inicio', b.fecha_inicio?String(b.fecha_inicio).slice(0,10):'');
  fv('b-fecha-fin', b.fecha_fin?String(b.fecha_fin).slice(0,10):'');
  fv('b-moneda', b.moneda||'EUR');
  fv('b-estado', b.estado||'BORRADOR');
  fv('b-version', b.version||1);
  fv('b-notas', b.notas||'');
  fv('b-horas', b.horas_internas||0);
  fv('b-tarifa', b.tarifa_hora_interna||85);
  fv('b-rrhh-rec', b.rrhh_reclutamiento||0);
  fv('b-rrhh-form', b.rrhh_formacion||0);
  fv('b-rrhh-admin', b.rrhh_hr_admin||0);
  fv('b-rrhh-viajes', b.rrhh_viajes_dietas||0);
  fv('b-rrhh-otros', b.rrhh_otros||0);
  fv('b-opex-lic', b.opex_licencias_sw||0);
  fv('b-opex-cloud', b.opex_cloud_infra||0);
  fv('b-opex-mant', b.opex_mantenimiento||0);
  fv('b-opex-cons', b.opex_consumibles||0);
  fv('b-opex-form', b.opex_formacion||0);
  fv('b-opex-otros', b.opex_otros||0);
  fv('b-capex-hw', b.capex_hardware||0);
  fv('b-capex-eq', b.capex_equipamiento||0);
  fv('b-capex-infra', b.capex_infraestructura||0);
  fv('b-capex-sw', b.capex_software||0);
  fv('b-capex-otros', b.capex_otros||0);
  fv('b-res-cont', b.reserva_contingencia_pct||10);
  fv('b-res-gest', b.reserva_gestion_pct||5);
  // set proyecto dropdown
  const sel = document.getElementById('b-proyecto');
  sel.innerHTML = '<option value="">— Seleccionar proyecto —</option>' +
    ALL_PROJECTS.map(p=>`<option value="${escHtml(p.id)}" data-horas="${p.horas||0}"${p.id===b.id_proyecto?' selected':''}>${escHtml(p.id.slice(0,35))} — ${escHtml((p.name||'').slice(0,40))}</option>`).join('');
  bgtUpdateEstadoBadge();
  bgtShowSection(1, document.querySelector('.fm-bgt-nav-item'));
  renderProveedores();
  bgtCalc();
  fmOpen('fm-budget');
}

function resetBudgetForm(){
  ['b-nombre','b-responsable','b-aprobado-por','b-notas'].forEach(id=>{ const e=document.getElementById(id); if(e) e.value=''; });
  ['b-horas','b-rrhh-rec','b-rrhh-form','b-rrhh-admin','b-rrhh-viajes','b-rrhh-otros',
   'b-opex-lic','b-opex-cloud','b-opex-mant','b-opex-cons','b-opex-form','b-opex-otros',
   'b-capex-hw','b-capex-eq','b-capex-infra','b-capex-sw','b-capex-otros'].forEach(id=>{ const e=document.getElementById(id); if(e) e.value=0; });
  const tf=document.getElementById('b-tarifa'); if(tf) tf.value=85;
  const rc=document.getElementById('b-res-cont'); if(rc) rc.value=10;
  const rg=document.getElementById('b-res-gest'); if(rg) rg.value=5;
  const ve=document.getElementById('b-version'); if(ve) ve.value=1;
  const me=document.getElementById('b-moneda'); if(me) me.value='EUR';
  const es=document.getElementById('b-estado'); if(es) es.value='BORRADOR';
  const fi=document.getElementById('b-fecha-inicio'); if(fi) fi.value='';
  const ff=document.getElementById('b-fecha-fin'); if(ff) ff.value='';
  bgtUpdateEstadoBadge();
}

function bgtAutoFillProject(){
  const sel = document.getElementById('b-proyecto');
  const opt = sel.options[sel.selectedIndex];
  if(opt){
    const horas = parseInt(opt.getAttribute('data-horas'))||0;
    if(horas>0){ document.getElementById('b-horas').value=horas; }
    // auto name
    const nameEl = document.getElementById('b-nombre');
    if(!nameEl.value && opt.value){
      const y=new Date().getFullYear();
      nameEl.value = 'Presupuesto — '+opt.text.slice(0,60).split('—')[1]?.trim() || 'Presupuesto '+opt.value;
    }
    bgtCalc();
  }
}

function bgtUpdateEstadoBadge(){
  const v=document.getElementById('b-estado')?.value||'BORRADOR';
  const badge=document.getElementById('bgt-hdr-estado');
  if(!badge) return;
  const cls={BORRADOR:'bgt-borrador',EN_REVISION:'bgt-revision',APROBADO:'bgt-aprobado',CERRADO:'bgt-cerrado',RECHAZADO:'bgt-rechazado'};
  const lbl={BORRADOR:'BORRADOR',EN_REVISION:'EN REVISIÓN',APROBADO:'APROBADO',CERRADO:'CERRADO',RECHAZADO:'RECHAZADO'};
  badge.className='fm-bgt-estado-badge '+(cls[v]||'bgt-borrador');
  badge.textContent=lbl[v]||v;
}

function bgtShowSection(n, el){
  document.querySelectorAll('.fm-bgt-section').forEach(s=>s.classList.remove('active'));
  const sec=document.getElementById('bgt-sec-'+n);
  if(sec) sec.classList.add('active');
  document.querySelectorAll('.fm-bgt-nav-item').forEach(e=>e.classList.remove('active'));
  if(el) el.classList.add('active');
  if(n===8) bgtUpdateResumen();
}

// ── Proveedores ──
function renderProveedores(){
  const tbody=document.getElementById('prov-tbody');
  if(!tbody) return;
  const tipos=['Consultoría','Desarrollo SW','Cloud/IaaS','Infraestructura','Licencias','Soporte/Mantenimiento','Auditoría','Formación','Seguridad','Otros'];
  tbody.innerHTML=_bgtProveedores.map((p,i)=>`<tr>
    <td><input class="prov-inp" placeholder="Nombre del proveedor" value="${escHtml(p.nombre)}" oninput="_bgtProveedores[${i}].nombre=this.value;bgtCalc()"></td>
    <td><select class="prov-sel" onchange="_bgtProveedores[${i}].tipo=this.value">${tipos.map(t=>`<option${t===p.tipo?' selected':''}>${t}</option>`).join('')}</select></td>
    <td><input class="prov-inp" placeholder="Concepto/alcance" value="${escHtml(p.concepto)}" oninput="_bgtProveedores[${i}].concepto=this.value;bgtCalc()"></td>
    <td><input class="prov-inp num" type="number" min="0" value="${p.dias}" oninput="_bgtProveedores[${i}].dias=parseFloat(this.value)||0;bgtProvCalcRow(${i})" style="width:50px;"></td>
    <td><input class="prov-inp num" type="number" min="0" value="${p.tarifa}" oninput="_bgtProveedores[${i}].tarifa=parseFloat(this.value)||0;bgtProvCalcRow(${i})" style="width:70px;"></td>
    <td class="prov-total" id="prov-total-${i}">${fmtEur(p.total)}</td>
    <td><button class="prov-del" onclick="removeProveedor(${i})">✕</button></td>
  </tr>`).join('');
}

function bgtProvCalcRow(i){
  const p=_bgtProveedores[i];
  p.total=Math.round(p.dias*p.tarifa*100)/100;
  const el=document.getElementById('prov-total-'+i);
  if(el) el.textContent=fmtEur(p.total);
  bgtCalc();
}

function addProveedor(){
  _bgtProveedores.push({nombre:'',tipo:'Consultoría',concepto:'',dias:0,tarifa:600,total:0});
  renderProveedores();
}
function removeProveedor(i){
  _bgtProveedores.splice(i,1);
  renderProveedores();
  bgtCalc();
}

// ── Live Calculation ──
function bgtCalc(){
  const gv = id=>parseFloat(document.getElementById(id)?.value)||0;
  const tl = Math.round(gv('b-horas')*gv('b-tarifa')*100)/100;
  const tp = Math.round(_bgtProveedores.reduce((s,p)=>s+p.total,0)*100)/100;
  const to = Math.round((gv('b-opex-lic')+gv('b-opex-cloud')+gv('b-opex-mant')+gv('b-opex-cons')+gv('b-opex-form')+gv('b-opex-otros'))*100)/100;
  const tc = Math.round((gv('b-capex-hw')+gv('b-capex-eq')+gv('b-capex-infra')+gv('b-capex-sw')+gv('b-capex-otros'))*100)/100;
  const tr = Math.round((gv('b-rrhh-rec')+gv('b-rrhh-form')+gv('b-rrhh-admin')+gv('b-rrhh-viajes')+gv('b-rrhh-otros'))*100)/100;
  const sub = tl+tp+to+tc+tr;
  const rcPct=gv('b-res-cont'), rgPct=gv('b-res-gest');
  const rc=Math.round(sub*rcPct/100*100)/100;
  const rg=Math.round(sub*rgPct/100*100)/100;
  const tres=rc+rg;
  const bac=Math.round((sub+tres)*100)/100;

  // Labor hero
  const setT=(id,v)=>{const e=document.getElementById(id);if(e)e.textContent=v;};
  setT('b-labor-display',fmtEur(tl));
  setT('b-labor-h',gv('b-horas').toFixed(0));
  setT('b-labor-t',gv('b-tarifa').toFixed(0));
  setT('b-labor-r',fmtEur(tl));
  // Prov total
  setT('b-prov-total-display',fmtEur(tp));
  // Reservas cards
  setT('b-res-cont-pct',rcPct.toFixed(1)+'%');
  setT('b-res-cont-amt',fmtEur(rc));
  setT('b-res-gest-pct',rgPct.toFixed(1)+'%');
  setT('b-res-gest-amt',fmtEur(rg));
  // BAC bar
  setT('bseg-labor',fmtEur(tl));
  setT('bseg-prov',fmtEur(tp));
  setT('bseg-opex',fmtEur(to));
  setT('bseg-capex',fmtEur(tc));
  setT('bseg-rrhh',fmtEur(tr));
  setT('bseg-res',fmtEur(tres));
  setT('bseg-bac',fmtEur(bac));
  setT('bgt-footer-bac','BAC: '+fmtEur(bac));
  // Nav amounts
  setT('bnav-labor',fmtEur(tl));
  setT('bnav-prov',fmtEur(tp));
  setT('bnav-rrhh',fmtEur(tr));
  setT('bnav-opex',fmtEur(to));
  setT('bnav-capex',fmtEur(tc));
  setT('bnav-res',fmtEur(tres));
  // Header ID live
  const idEl=document.getElementById('b-id');
  if(idEl&&idEl.value) setT('bgt-hdr-id',idEl.value);
  const nmEl=document.getElementById('b-nombre');
  if(nmEl&&nmEl.value) setT('bgt-hdr-title',nmEl.value.slice(0,60));
  return {tl,tp,to,tc,tr,tres,bac,sub,rc,rg,rcPct,rgPct};
}

function bgtUpdateResumen(){
  const {tl,tp,to,tc,tr,tres,bac,sub,rc,rg,rcPct,rgPct} = bgtCalc();
  const pct = v => bac>0?((v/bac)*100).toFixed(1)+'%':'0%';
  const row = (color,label,val,barW) => `<div class="resumen-row">
    <div class="resumen-dot" style="background:${color};"></div>
    <div class="resumen-label">${label}</div>
    <div class="resumen-bar-wrap"><div class="resumen-bar" style="background:${color};width:${Math.min(barW,100)}%;"></div></div>
    <div class="resumen-pct-col">${pct(val)}</div>
    <div class="resumen-amt" style="color:${color};">${fmtEur(val)}</div>
  </div>`;
  const breakdown = document.getElementById('b-resumen-breakdown');
  if(breakdown){
    breakdown.innerHTML =
      row('#38bdf8','Personal Interno (Labor FTE)',tl,bac>0?tl/bac*100:0)+
      row('#8b5cf6','Proveedores Externos',tp,bac>0?tp/bac*100:0)+
      row('#fbbf24','OPEX — Gastos Operacionales',to,bac>0?to/bac*100:0)+
      row('#f97316','CAPEX — Inversiones Capital',tc,bac>0?tc/bac*100:0)+
      row('#f472b6','RRHH &amp; Gestión Personal',tr,bac>0?tr/bac*100:0)+
      row('#a3e635','Reserva Contingencias ('+rcPct.toFixed(1)+'%)',rc,bac>0?rc/bac*100:0)+
      row('#22d3ee','Reserva Gestión ('+rgPct.toFixed(1)+'%)',rg,bac>0?rg/bac*100:0)+
      `<div class="resumen-row" style="background:rgba(16,185,129,.04);font-weight:700;"><div class="resumen-dot" style="background:#10b981;"></div><div class="resumen-label" style="color:var(--text);font-weight:700;">BAC — Budget at Completion</div><div class="resumen-bar-wrap"><div class="resumen-bar" style="background:#10b981;width:100%;"></div></div><div class="resumen-pct-col" style="color:#10b981;">100%</div><div class="resumen-amt" style="color:#10b981;font-size:14px;">${fmtEur(bac)}</div></div>`;
  }
  // Hero
  const setT=(id,v)=>{const e=document.getElementById(id);if(e)e.textContent=v;};
  setT('b-bac-hero',fmtEur(bac));
  const proj=document.getElementById('b-proyecto');
  const projTxt=proj?.options[proj.selectedIndex]?.text||'Sin proyecto';
  setT('b-bac-proyecto-name',projTxt.slice(0,60));
  const fi=document.getElementById('b-fecha-inicio')?.value||'—';
  const ff=document.getElementById('b-fecha-fin')?.value||'—';
  setT('b-bac-fecha','Período: '+fi+' → '+ff+' · v');
  setT('b-bac-ver',document.getElementById('b-version')?.value||'1');
  // PMBOK KPIs
  const horas=parseFloat(document.getElementById('b-horas')?.value)||0;
  setT('bkpi-labor-pct',pct(tl));
  setT('bkpi-opex-ratio',pct(to));
  setT('bkpi-capex-ratio',pct(tc));
  setT('bkpi-res-ratio',pct(tres));
  setT('bkpi-ext-ratio',pct(tp));
  setT('bkpi-hph',horas>0?fmtEur(bac/horas):'—');
}

// ── Save ──
async function bgtSave(){
  const gv = id=>parseFloat(document.getElementById(id)?.value)||0;
  const gs = id=>document.getElementById(id)?.value?.trim()||'';
  const id=gs('b-id'), proj=document.getElementById('b-proyecto')?.value||'', nombre=gs('b-nombre'), resp=gs('b-responsable');
  if(!id){ showToast('⚠ ID del presupuesto requerido'); bgtShowSection(1,document.querySelectorAll('.fm-bgt-nav-item')[0]); return; }
  if(!proj){ showToast('⚠ Selecciona un proyecto'); bgtShowSection(1,document.querySelectorAll('.fm-bgt-nav-item')[0]); return; }
  if(!nombre){ showToast('⚠ Nombre del presupuesto requerido'); bgtShowSection(1,document.querySelectorAll('.fm-bgt-nav-item')[0]); return; }
  if(!resp){ showToast('⚠ Responsable requerido'); bgtShowSection(1,document.querySelectorAll('.fm-bgt-nav-item')[0]); return; }

  const btn=document.getElementById('bgt-submit-btn');
  const origHtml=btn.innerHTML; btn.disabled=true; btn.innerHTML='<span class="loading-spinner"></span>Guardando…';

  const provData=_bgtProveedores.map(p=>({nombre:p.nombre,tipo:p.tipo,concepto:p.concepto,dias:p.dias,tarifa_dia:p.tarifa,total:p.total}));
  const payload={
    id_presupuesto:id, id_proyecto:proj, nombre_presupuesto:nombre,
    version:parseInt(document.getElementById('b-version')?.value)||1,
    estado:document.getElementById('b-estado')?.value||'BORRADOR',
    responsable:resp, fecha_inicio:gs('b-fecha-inicio')||null, fecha_fin:gs('b-fecha-fin')||null,
    moneda:gs('b-moneda')||'EUR', aprobado_por:gs('b-aprobado-por')||null, notas:gs('b-notas')||null,
    horas_internas:gv('b-horas'), tarifa_hora_interna:gv('b-tarifa'),
    proveedores_externos:provData,
    opex_licencias_sw:gv('b-opex-lic'),opex_cloud_infra:gv('b-opex-cloud'),opex_mantenimiento:gv('b-opex-mant'),opex_consumibles:gv('b-opex-cons'),opex_formacion:gv('b-opex-form'),opex_otros:gv('b-opex-otros'),
    capex_hardware:gv('b-capex-hw'),capex_equipamiento:gv('b-capex-eq'),capex_infraestructura:gv('b-capex-infra'),capex_software:gv('b-capex-sw'),capex_otros:gv('b-capex-otros'),
    rrhh_reclutamiento:gv('b-rrhh-rec'),rrhh_formacion:gv('b-rrhh-form'),rrhh_hr_admin:gv('b-rrhh-admin'),rrhh_viajes_dietas:gv('b-rrhh-viajes'),rrhh_otros:gv('b-rrhh-otros'),
    reserva_contingencia_pct:gv('b-res-cont'),reserva_gestion_pct:gv('b-res-gest'),
  };
  try {
    const url=_bgtEditMode?API_BASE+'/presupuestos/'+encodeURIComponent(_bgtEditId):API_BASE+'/presupuestos';
    const method=_bgtEditMode?'PUT':'POST';
    const res=await authFetch(url,{method,headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
    if(!res.ok){ const err=await res.json().catch(()=>{}); throw new Error(err?.detail||'Error al guardar'); }
    showToast(_bgtEditMode?'💾 Presupuesto actualizado':'✅ Presupuesto creado · BAC: '+fmtEur(payload.horas_internas*payload.tarifa_hora_interna));
    fmClose('fm-budget'); ALL_BUDGETS=[]; loadBudgets();
  } catch(e){ showToast('❌ '+e.message); btn.disabled=false; btn.innerHTML=origHtml; }
}

async function deleteBudget(id, nombre){
  if(!confirm(`¿Eliminar el presupuesto "${nombre}"?\n\nEsta acción no se puede deshacer.`)) return;
  try {
    const res=await authFetch(API_BASE+'/presupuestos/'+encodeURIComponent(id),{method:'DELETE'});
    if(!res.ok){ const err=await res.json().catch(()=>{}); throw new Error(err?.detail||'Error al eliminar'); }
    showToast('🗑 Presupuesto eliminado');
    ALL_BUDGETS=[]; loadBudgets();
  } catch(e){ showToast('❌ '+e.message); }
}

// ══════════════════ PMO GOVERNANCE — JS ══════════════════
let _govLoaded = false;
let ALL_PMS = [], ALL_GOV = [];
let _govDashVisible = false;
let _govCurrentView = 'pms';

function govView(view, el) {
  _govCurrentView = view;
  document.querySelectorAll('#page-governance .filter-chip').forEach(c=>c.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('gov-view-pms').style.display = view==='pms'?'':'none';
  document.getElementById('gov-view-scoring').style.display = view==='scoring'?'':'none';
  document.getElementById('gov-view-gates').style.display = view==='gates'?'':'none';
}

function toggleGovDashboard() {
  _govDashVisible = !_govDashVisible;
  document.getElementById('gov-dashboard').style.display = _govDashVisible ? 'block' : 'none';
  if (_govDashVisible) renderGovDashboard();
}

async function loadGovernance() {
  _govLoaded = true;
  try {
    const [pmRes, govRes, dashRes] = await Promise.all([
      authFetch(API_BASE + '/pmo/managers').then(r=>r.json()),
      authFetch(API_BASE + '/pmo/governance').then(r=>r.json()),
      authFetch(API_BASE + '/pmo/governance/dashboard').then(r=>r.json()),
    ]);
    ALL_PMS = pmRes; ALL_GOV = govRes;
    document.getElementById('gov-pm-count').textContent = ALL_PMS.length + ' PMs · ' + ALL_GOV.length + ' proyectos gobernados';
    renderGovPMs(ALL_PMS);
    renderGovScoring(ALL_GOV);
    renderGovGates(ALL_GOV);
    if (_govDashVisible) renderGovDashboard();
  } catch(e) { console.warn('Gov load error:', e); }
}

function renderGovScoring(gov) {
  const el = document.getElementById('gov-scoring-content');
  if (!gov.length) { el.innerHTML = '<div class="no-data">Sin datos de scoring</div>'; return; }
  el.innerHTML = gov.map(g => {
    const ts = g.total_score || 0;
    const tsColor = ts >= 7 ? 'var(--green)' : ts >= 5 ? 'var(--yellow)' : 'var(--red)';
    return `<div style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:10px;margin-bottom:6px;display:flex;align-items:center;gap:12px;">
      <div style="text-align:center;min-width:50px;">
        <div style="font-family:var(--mono);font-size:20px;font-weight:800;color:${tsColor};">${ts.toFixed?ts.toFixed(1):ts}</div>
        <div style="font-size:8px;color:var(--text3);text-transform:uppercase;">Score</div>
      </div>
      <div style="flex:1;">
        <div style="font-size:12px;font-weight:600;margin-bottom:3px;">${escHtml(g.nombre_proyecto||g.id_proyecto)}</div>
        <div style="display:flex;gap:8px;font-size:9px;">
          <span style="color:var(--text2);">PM: ${escHtml(g.pm_nombre||'—')}</span>
          <span class="gov-gate gov-gate-${(g.gate_status||'pending').toLowerCase()}">${g.current_gate||'G0'} · ${g.gate_status||'PENDING'}</span>
          <span style="color:var(--text3);">Compliance: ${g.compliance_pct||0}%</span>
        </div>
      </div>
      <div style="display:flex;gap:6px;">
        <div style="text-align:center;"><div style="font-family:var(--mono);font-size:11px;font-weight:700;color:#f59e0b;">${g.roi_score||0}</div><div style="font-size:7px;color:var(--text3);">ROI</div></div>
        <div style="text-align:center;"><div style="font-family:var(--mono);font-size:11px;font-weight:700;color:var(--red);">${g.risk_score||0}</div><div style="font-size:7px;color:var(--text3);">RISK</div></div>
        <div style="text-align:center;"><div style="font-family:var(--mono);font-size:11px;font-weight:700;color:var(--blue);">${g.capacity_score||0}</div><div style="font-size:7px;color:var(--text3);">CAP</div></div>
        <div style="text-align:center;"><div style="font-family:var(--mono);font-size:11px;font-weight:700;color:var(--green);">${g.strategic_value||0}</div><div style="font-size:7px;color:var(--text3);">VALOR</div></div>
      </div>
    </div>`;
  }).join('');
}

function renderGovGates(gov) {
  const el = document.getElementById('gov-gates-content');
  if (!gov.length) { el.innerHTML = '<div class="no-data">Sin datos de gates</div>'; return; }
  const gates = ['G0-IDEA','G1-ANALISIS','G2-PLANIF','G3-EJECUCION','G4-CIERRE','G5-BENEFICIO'];
  const gateColors = {'G0-IDEA':'#8b949e','G1-ANALISIS':'var(--blue)','G2-PLANIF':'#f59e0b','G3-EJECUCION':'var(--orange)','G4-CIERRE':'var(--green)','G5-BENEFICIO':'#a855f7'};
  el.innerHTML = `<div style="display:flex;gap:8px;overflow-x:auto;">` + gates.map(gate => {
    const items = gov.filter(g => g.current_gate === gate);
    return `<div style="min-width:180px;flex:1;background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:8px;">
      <div style="font-size:10px;font-weight:700;color:${gateColors[gate]||'var(--text2)'};margin-bottom:6px;display:flex;align-items:center;gap:4px;">
        <span style="width:8px;height:8px;border-radius:50%;background:${gateColors[gate]||'var(--text3)'};"></span>
        ${gate} <span style="font-family:var(--mono);color:var(--text3);font-size:9px;">(${items.length})</span>
      </div>
      ${items.length ? items.map(g => `<div style="background:var(--bg2);border:1px solid var(--border);border-radius:6px;padding:5px 8px;margin-bottom:4px;font-size:10px;">
        <div style="font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${escHtml((g.nombre_proyecto||g.id_proyecto).substring(0,30))}</div>
        <div style="font-size:8px;color:var(--text3);">${g.pm_nombre||'—'} · Score: ${(g.total_score||0).toFixed?g.total_score.toFixed(1):g.total_score}</div>
      </div>`).join('') : '<div style="font-size:9px;color:var(--text3);text-align:center;padding:8px;">Sin proyectos</div>'}
    </div>`;
  }).join('') + `</div>`;
}

async function renderGovDashboard() {
  try {
    const d = await authFetch(API_BASE + '/pmo/governance/dashboard').then(r=>r.json());
    // KPI cards
    document.getElementById('gov-pillar-kpis').innerHTML = [
      {v:d.total_pms||0,l:'Project Managers',c:'#f59e0b'},
      {v:d.total_proyectos_gobernados||0,l:'Proyectos Gobernados',c:'var(--blue)'},
      {v:(d.avg_scoring||0).toFixed(1)+'/10',l:'Scoring Promedio',c:d.avg_scoring>=7?'var(--green)':d.avg_scoring>=5?'var(--yellow)':'var(--red)'},
      {v:(d.avg_compliance||0).toFixed(0)+'%',l:'Compliance Medio',c:d.avg_compliance>=80?'var(--green)':'var(--orange)'},
    ].map(k=>`<div style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:8px;text-align:center;">
      <div style="font-family:var(--mono);font-size:20px;font-weight:800;color:${k.c};">${k.v}</div>
      <div style="font-size:9px;color:var(--text2);text-transform:uppercase;">${k.l}</div>
    </div>`).join('');
    // P1: Demanda
    const gateStatus = d.by_gate_status || {};
    document.getElementById('gov-p1-score').textContent = (d.avg_scoring||0).toFixed(1);
    document.getElementById('gov-p1-content').innerHTML = `
      <div style="display:flex;gap:8px;margin-top:4px;">
        ${Object.entries(gateStatus).map(([k,v])=>`<span class="gov-gate gov-gate-${k.toLowerCase()}">${k}: ${v}</span>`).join('')}
      </div>
      <div style="margin-top:6px;font-size:9px;color:var(--text3);">Marco de puntuación: ROI + Riesgo + Capacidad + Valor Estratégico = Score total /10</div>`;
    // P2: Capacidad
    const pctAsig = d.total_pms > 0 ? Math.round(d.pms_asignados / d.total_pms * 100) : 0;
    document.getElementById('gov-p2-score').textContent = pctAsig + '%';
    document.getElementById('gov-p2-content').innerHTML = `
      <div style="display:flex;gap:8px;font-size:10px;margin-top:4px;">
        <span style="color:var(--orange);">● Asignados: ${d.pms_asignados}</span>
        <span style="color:var(--red);">▲ Sobrecargados: ${d.pms_sobrecargados}</span>
        <span style="color:var(--green);">● Disponibles: ${d.total_pms - d.pms_asignados - d.pms_sobrecargados}</span>
      </div>
      <div class="gov-score-bar" style="margin-top:6px;"><div class="gov-score-fill" style="width:${pctAsig}%;background:${pctAsig>80?'var(--red)':pctAsig>50?'var(--orange)':'var(--green)'};"></div></div>`;
    // P3: Compliance
    document.getElementById('gov-p3-score').textContent = (d.avg_compliance||0).toFixed(0) + '%';
    const phases = d.by_gate_phase || {};
    document.getElementById('gov-p3-content').innerHTML = `
      <div style="display:flex;gap:4px;flex-wrap:wrap;margin-top:4px;">
        ${Object.entries(phases).map(([k,v])=>`<span style="font-size:8px;padding:1px 5px;border-radius:3px;background:var(--bg2);color:var(--text2);font-family:var(--mono);">${k}: ${v}</span>`).join('')}
      </div>
      <div class="gov-score-bar" style="margin-top:6px;"><div class="gov-score-fill" style="width:${d.avg_compliance||0}%;background:${(d.avg_compliance||0)>=80?'var(--green)':'var(--orange)'};"></div></div>`;
    // P4: Change Management
    document.getElementById('gov-p4-score').textContent = (d.change_approval_rate||0).toFixed(0) + '%';
    document.getElementById('gov-p4-content').innerHTML = `
      <div style="display:flex;gap:12px;font-size:10px;margin-top:4px;">
        <div><span style="color:var(--text3);">Solicitudes:</span> <strong style="color:var(--text);">${d.total_change_requests||0}</strong></div>
        <div><span style="color:var(--text3);">Tasa aprobación:</span> <strong style="color:${(d.change_approval_rate||0)>=70?'var(--green)':'var(--orange)'};">${(d.change_approval_rate||0).toFixed(0)}%</strong></div>
      </div>
      <div class="gov-score-bar" style="margin-top:6px;"><div class="gov-score-fill" style="width:${d.change_approval_rate||0}%;background:#a855f7;"></div></div>`;
  } catch(e) { console.warn('Gov dashboard error:', e); }
}

function filterGov(val) {
  if (!val) { renderGovPMs(ALL_PMS); return; }
  const v = val.toLowerCase();
  renderGovPMs(ALL_PMS.filter(p => p.nombre.toLowerCase().includes(v) || p.id_pm.toLowerCase().includes(v) || (p.especialidad||'').toLowerCase().includes(v) || (p.certificaciones||[]).join(' ').toLowerCase().includes(v)));
}

// ── PM Form (multi-step) ──
let _pmEditMode = false, _pmStep = 1, _pmNivel = '', _pmEsp = '', _pmSkills = [], _pmCerts = [];

const PM_CERT_OPTIONS = ['PMP','PRINCE2','PMI-ACP','ITIL v4','Scrum Master','SAFe Agilist','TOGAF','COBIT','ISO 27001 LA','CRISC','CISM','AWS Solutions Architect','Azure Solutions','Six Sigma GB','Six Sigma BB','Lean IT','DORA Specialist'];

const PM_SKILL_CATS = [
  {cat:'Liderazgo & Estrategia',icon:'🎯',color:'#f59e0b',skills:['Liderazgo de Equipos','Visión Estratégica','Negociación con Stakeholders','Toma de Decisiones','Gestión de Conflictos','Mentoring & Coaching']},
  {cat:'Planificación & Ejecución',icon:'📋',color:'var(--blue)',skills:['WBS & Cronogramas','Gestión de Alcance','Estimación de Esfuerzo','Critical Path Method','Earned Value Management','Agile/Scrum Framework']},
  {cat:'Riesgo & Compliance',icon:'🛡',color:'var(--red)',skills:['Gestión de Riesgos','Risk Register & Mitigation','Compliance Regulatorio','DORA/BCE Reporting','Auditoría de Proyectos','Business Continuity']},
  {cat:'Financiero & Recursos',icon:'💰',color:'var(--green)',skills:['Gestión Presupuestaria','ROI & Business Case','Resource Capacity Planning','Vendor Management','Contract Negotiation','Cost-Benefit Analysis']},
  {cat:'Comunicación & Cambio',icon:'📢',color:'#a855f7',skills:['Comunicación Ejecutiva','Change Management','Reporting & Dashboards','Gestión de Expectativas','Workshop Facilitation','Knowledge Transfer']},
  {cat:'Técnico & Dominio',icon:'⚙️',color:'var(--cyan)',skills:['Arquitectura IT (alto nivel)','Cloud & Infraestructura','Seguridad & Compliance IT','Data & Analytics Strategy','DevOps & CI/CD Awareness','ITSM & ITIL Practices']},
];

function pmSelNivel(n, el) {
  _pmNivel = n;
  document.querySelectorAll('#fm-pm .nivel-card').forEach(c => { c.classList.remove('sel'); c.style.cssText=''; });
  el.classList.add('sel');
  const colors = {'PM-Jr':'#8b949e','PM-Sr':'#2d7ef7','PM-Lead':'#f59e0b','PM-Dir':'#a855f7'};
  el.style.borderColor = colors[n]; el.style.background = colors[n]+'15';
}

function pmSelEsp(e, el) {
  _pmEsp = e;
  document.querySelectorAll('#fm-pm .silo-card').forEach(c => { c.classList.remove('sel'); c.style.cssText=''; });
  el.classList.add('sel');
  el.style.borderColor = '#f59e0b'; el.style.background = 'rgba(245,158,11,.12)';
}

function pmSetStep(s) {
  _pmStep = s;
  document.querySelectorAll('#fm-pm .fm-step').forEach(el=>el.classList.remove('active'));
  document.getElementById('pm-s'+s).classList.add('active');
  [1,2,3].forEach(i => {
    const d = document.getElementById('pm-dot-'+i);
    d.classList.remove('active','done');
    if (i<s) d.classList.add('done'); else if (i===s) d.classList.add('active');
  });
  document.getElementById('pm-back-btn').style.display = s>1?'':'none';
  document.getElementById('pm-next-btn').style.display = s<3?'flex':'none';
  document.getElementById('pm-submit-btn').style.display = s===3?'flex':'none';
  document.getElementById('pm-skill-count').style.display = s===2?'':'none';
  if (s===2) renderPMSkillsStep();
  if (s===3) renderPMPreview();
}

function pmStepNext() {
  if (_pmStep===1) {
    if (!document.getElementById('pm-nombre').value.trim()) { showToast('El nombre es obligatorio'); return; }
    if (!_pmNivel) { showToast('Selecciona un nivel'); return; }
    if (!_pmEsp) { showToast('Selecciona una especialidad'); return; }
  }
  pmSetStep(_pmStep + 1);
}
function pmStepBack() { pmSetStep(_pmStep - 1); }

function renderPMSkillsStep() {
  // Certs grid
  const certsGrid = document.getElementById('pm-certs-grid');
  certsGrid.innerHTML = PM_CERT_OPTIONS.map(c => {
    const sel = _pmCerts.includes(c);
    return `<div class="sk-chip${sel?' sel':''}" style="${sel?'border-color:#f59e0b;background:#f59e0b;color:#fff;':''}" onclick="pmToggleCert('${c}',this)">${c}</div>`;
  }).join('');
  // Skills grid
  const skillsGrid = document.getElementById('pm-skills-grid');
  skillsGrid.innerHTML = PM_SKILL_CATS.map(cat => {
    const selCount = cat.skills.filter(s=>_pmSkills.includes(s)).length;
    return `<div class="skill-cat-block">
      <div class="skill-cat-head" style="color:${cat.color}">
        <span style="font-size:14px">${cat.icon}</span><span>${cat.cat}</span>
        <div class="skill-cat-line" style="background:${cat.color}"></div>
        <span class="skill-cat-cnt" style="color:${cat.color}">${selCount}/${cat.skills.length}</span>
      </div>
      <div class="skill-chips-grid">
        ${cat.skills.map(sk => {
          const isSel = _pmSkills.includes(sk);
          return `<div class="sk-chip${isSel?' sel':''}" style="${isSel?`border-color:${cat.color};background:${cat.color};color:#fff;`:''}" onclick="pmToggleSkill('${sk.replace(/'/g,"\\'")}','${cat.color}',this)">${sk}</div>`;
        }).join('')}
      </div>
    </div>`;
  }).join('');
  updatePMSkillCount();
}

function pmToggleCert(c, el) {
  const idx = _pmCerts.indexOf(c);
  if (idx>=0) { _pmCerts.splice(idx,1); el.classList.remove('sel'); el.style.cssText=''; }
  else { _pmCerts.push(c); el.classList.add('sel'); el.style.borderColor='#f59e0b'; el.style.background='#f59e0b'; el.style.color='#fff'; }
  updatePMSkillCount();
}

function pmToggleSkill(sk, color, el) {
  const idx = _pmSkills.indexOf(sk);
  if (idx>=0) { _pmSkills.splice(idx,1); el.classList.remove('sel'); el.style.cssText=''; }
  else { _pmSkills.push(sk); el.classList.add('sel'); el.style.borderColor=color; el.style.background=color; el.style.color='#fff'; }
  const catEl = el.closest('.skill-cat-block');
  if (catEl) { const cnt=catEl.querySelector('.skill-cat-cnt'); if(cnt) cnt.textContent=catEl.querySelectorAll('.sk-chip.sel').length+'/'+catEl.querySelectorAll('.sk-chip').length; }
  updatePMSkillCount();
}

function updatePMSkillCount() {
  document.getElementById('pm-skill-count').textContent = _pmSkills.length + ' skills · ' + _pmCerts.length + ' certs';
}

function renderPMPreview() {
  const nombre = document.getElementById('pm-nombre').value.trim();
  const id = document.getElementById('pm-id').value.trim();
  const estado = document.getElementById('pm-estado').value;
  const nColors = {'PM-Jr':'#8b949e','PM-Sr':'#2d7ef7','PM-Lead':'#f59e0b','PM-Dir':'#a855f7'};
  const nc = nColors[_pmNivel]||'#8b949e';
  const initials = (nombre.split(' ').slice(0,2).map(n=>n[0]||'').join('')).toUpperCase()||'?';
  const certsHtml = _pmCerts.length ? _pmCerts.map(c=>`<span style="display:inline-block;font-size:10px;padding:1px 6px;border-radius:3px;background:rgba(245,158,11,.15);color:#f59e0b;margin:1px;">${c}</span>`).join('') : '<span style="color:var(--text3);font-size:11px;">Sin certificaciones</span>';
  const skillsHtml = _pmSkills.length ? _pmSkills.map(s=>`<span class="skill-tag">${s}</span>`).join('') : '<span style="color:var(--text3);font-size:11px;">Sin skills</span>';
  document.getElementById('pm-preview').innerHTML = `
    <div style="font-size:13px;color:var(--text2);margin-bottom:14px;">Revisa los datos antes de confirmar.</div>
    <div class="preview-card" style="border-color:${nc}44;">
      <div class="pc-top">
        <div class="pc-avatar" style="background:linear-gradient(135deg,${nc},${nc}99);">${escHtml(initials)}</div>
        <div style="flex:1"><div class="pc-name">${escHtml(nombre)||'Sin nombre'}</div><div class="pc-id">${escHtml(id)}</div></div>
        <div style="display:flex;flex-direction:column;align-items:flex-end;gap:5px;">
          <span style="font-size:11px;font-weight:700;color:${nc};padding:2px 8px;border-radius:4px;background:${nc}22;">${_pmNivel}</span>
          <span style="font-size:11px;font-weight:600;color:var(--text2);padding:2px 8px;border-radius:4px;background:var(--bg3);">${_pmEsp}</span>
        </div>
      </div>
      <div class="pc-meta" style="margin-top:10px;">
        <span style="font-size:11px;font-weight:700;padding:2px 10px;border-radius:20px;background:var(--green-bg);color:var(--green);">● ${estado}</span>
        <span style="font-size:11px;font-weight:700;padding:2px 10px;border-radius:20px;background:rgba(245,158,11,.15);color:#f59e0b;font-family:var(--mono);">Máx ${document.getElementById('pm-max').value} proyectos</span>
        <span style="font-size:11px;font-weight:700;padding:2px 10px;border-radius:20px;background:var(--blue-bg);color:var(--blue);font-family:var(--mono);">${_pmSkills.length} skills</span>
      </div>
      <div style="margin-top:10px;"><div style="font-size:10px;font-weight:700;color:var(--text2);margin-bottom:4px;">CERTIFICACIONES</div>${certsHtml}</div>
      <div style="margin-top:10px;"><div style="font-size:10px;font-weight:700;color:var(--text2);margin-bottom:4px;">SKILLS PM</div><div style="display:flex;flex-wrap:wrap;gap:2px;">${skillsHtml}</div></div>
    </div>`;
  // Show projects if editing
  if (_pmEditMode) {
    const myProjs = ALL_GOV.filter(g=>g.id_pm===document.getElementById('pm-edit-id').value);
    const panel = document.getElementById('pm-projects-panel');
    if (myProjs.length) {
      panel.style.display = 'block';
      document.getElementById('pm-projects-list').innerHTML = myProjs.map(g => {
        const gateClass = 'gov-gate-'+(g.gate_status||'pending').toLowerCase();
        return `<div style="background:var(--bg2);border:1px solid var(--border);border-radius:5px;padding:4px 8px;margin-bottom:3px;display:flex;align-items:center;gap:6px;">
          <span style="font-family:var(--mono);font-size:9px;color:var(--text3);">${g.id_proyecto}</span>
          <span style="font-size:10px;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${escHtml((g.nombre_proyecto||'').substring(0,40))}</span>
          <span class="gov-gate ${gateClass}">${g.current_gate}</span>
        </div>`;
      }).join('');
    } else { panel.style.display = 'none'; }
  } else { document.getElementById('pm-projects-panel').style.display = 'none'; }
}

function openPMForm() {
  _pmEditMode = false; _pmStep=1; _pmNivel=''; _pmEsp=''; _pmSkills=[]; _pmCerts=[];
  document.getElementById('pm-icon').textContent = '👔';
  document.getElementById('pm-form-title').textContent = 'Nuevo Project Manager';
  document.getElementById('pm-form-sub').textContent = 'Registrar PM en la PMO Governance';
  document.getElementById('pm-btn-text').textContent = '✅ Añadir PM';
  document.getElementById('pm-edit-id').value = '';
  const nextNum = ALL_PMS.length > 0 ? Math.max(...ALL_PMS.map(p=>parseInt(p.id_pm.replace('PM-',''))||0)) + 1 : 1;
  document.getElementById('pm-id').value = 'PM-' + String(nextNum).padStart(3,'0');
  document.getElementById('pm-id').readOnly = false; document.getElementById('pm-id').style.opacity = '';
  document.getElementById('pm-nombre').value = '';
  document.getElementById('pm-estado').value = 'DISPONIBLE';
  document.getElementById('pm-email').value = '';
  document.getElementById('pm-telefono').value = '';
  document.getElementById('pm-max').value = '3';
  document.getElementById('pm-exito').value = '100';
  document.querySelectorAll('#fm-pm .nivel-card').forEach(c=>{ c.classList.remove('sel'); c.style.cssText=''; });
  document.querySelectorAll('#fm-pm .silo-card').forEach(c=>{ c.classList.remove('sel'); c.style.cssText=''; });
  pmSetStep(1); fmOpen('fm-pm');
}

function openPMEdit(id) {
  const p = ALL_PMS.find(x=>x.id_pm===id);
  if (!p) return;
  _pmEditMode = true; _pmStep=1;
  _pmNivel = p.nivel || '';
  _pmEsp = p.especialidad || '';
  _pmSkills = [...(Array.isArray(p.skills_json) ? p.skills_json : [])];
  _pmCerts = [...(Array.isArray(p.certificaciones) ? p.certificaciones : [])];
  document.getElementById('pm-icon').textContent = '✏️';
  document.getElementById('pm-form-title').textContent = 'Editar PM';
  document.getElementById('pm-form-sub').textContent = p.nombre + ' — ' + p.id_pm;
  document.getElementById('pm-btn-text').textContent = '💾 Guardar Cambios';
  document.getElementById('pm-edit-id').value = p.id_pm;
  const idEl = document.getElementById('pm-id');
  idEl.value = p.id_pm; idEl.readOnly = true; idEl.style.opacity = '.55';
  document.getElementById('pm-nombre').value = p.nombre;
  document.getElementById('pm-estado').value = p.estado;
  document.getElementById('pm-email').value = p.email || '';
  document.getElementById('pm-telefono').value = p.telefono || '';
  document.getElementById('pm-max').value = p.max_proyectos || 3;
  document.getElementById('pm-exito').value = p.tasa_exito || 100;
  // Pre-select nivel
  document.querySelectorAll('#fm-pm .nivel-card').forEach(el => {
    el.classList.remove('sel'); el.style.cssText = '';
    const badge = el.querySelector('.nc-badge');
    if (badge && badge.textContent.trim() === _pmNivel.replace('PM-','')) pmSelNivel(_pmNivel, el);
  });
  // Pre-select especialidad
  document.querySelectorAll('#fm-pm .silo-card').forEach(el => {
    el.classList.remove('sel'); el.style.cssText = '';
    const name = el.querySelector('.sc-name');
    if (name && (_pmEsp.startsWith(name.textContent.trim()) || name.textContent.trim().startsWith(_pmEsp.substring(0,8)))) pmSelEsp(_pmEsp, el);
  });
  pmSetStep(1); fmOpen('fm-pm');
}

async function savePM() {
  const nombre = document.getElementById('pm-nombre').value.trim();
  if (!nombre) { showToast('El nombre es obligatorio'); return; }
  const btn = document.getElementById('pm-submit-btn');
  btn.disabled = true; const orig = btn.innerHTML;
  btn.innerHTML = '<span class="loading-spinner" style="width:13px;height:13px;border-width:2px;"></span> Guardando...';
  const payload = {
    nombre,
    nivel: _pmNivel,
    especialidad: _pmEsp,
    estado: document.getElementById('pm-estado').value,
    max_proyectos: parseInt(document.getElementById('pm-max').value) || 3,
    email: document.getElementById('pm-email').value.trim() || null,
    telefono: document.getElementById('pm-telefono').value.trim() || null,
    certificaciones: _pmCerts,
    skills_json: _pmSkills,
    skill_principal: _pmSkills[0] || null,
  };
  const editId = document.getElementById('pm-edit-id').value;
  try {
    let url, method;
    if (_pmEditMode) { url = API_BASE + '/pmo/managers/' + editId; method = 'PUT'; }
    else { payload.id_pm = document.getElementById('pm-id').value.trim(); url = API_BASE + '/pmo/managers'; method = 'POST'; }
    const res = await authFetch(url, {method, headers:{'Content-Type':'application/json'}, body:JSON.stringify(payload)});
    if (!res.ok) { const err = await res.json().catch(()=>{}); throw new Error(err?.detail||'Error'); }
    showToast(_pmEditMode ? '💾 PM actualizado' : '✅ PM añadido a la PMO');
    fmClose('fm-pm'); _govLoaded = false; loadGovernance();
  } catch(e) { showToast('❌ '+e.message); }
  btn.disabled = false; btn.innerHTML = orig;
}

// Make gov table rows clickable
function renderGovPMs(pms) {
  const tbody = document.getElementById('gov-tbody');
  if (!pms.length) { tbody.innerHTML = '<tr><td colspan="11" class="no-data">Sin PMs</td></tr>'; return; }
  const projByPm = {};
  ALL_GOV.forEach(g => { if(g.id_pm) projByPm[g.id_pm] = (projByPm[g.id_pm]||0)+1; });
  tbody.innerHTML = pms.map(p => {
    const initials = p.nombre.split(' ').slice(0,2).map(n=>n[0]).join('');
    const col = AV_COLORS[Math.abs(hashCode(p.nombre)) % AV_COLORS.length];
    const nColors = {'PM-Jr':'#8b949e','PM-Sr':'var(--blue)','PM-Lead':'#f59e0b','PM-Dir':'#a855f7'};
    const nc = nColors[p.nivel]||'#8b949e';
    const eColors = {DISPONIBLE:'var(--green)',ASIGNADO:'var(--orange)',SOBRECARGADO:'var(--red)',BAJA:'var(--red)',VACACIONES:'#8b949e'};
    const eIcons = {DISPONIBLE:'●',ASIGNADO:'●',SOBRECARGADO:'▲',BAJA:'✕',VACACIONES:'◌'};
    const proj = projByPm[p.id_pm] || p.proyectos_activos || 0;
    const maxP = p.max_proyectos || 3;
    const cargaPct = Math.min(100, Math.round(proj / maxP * 100));
    const certs = p.certificaciones || [];
    const certsHtml = certs.slice(0,2).map(c=>`<span style="font-size:8px;padding:0 3px;border-radius:2px;background:rgba(245,158,11,.15);color:#f59e0b;">${c}</span>`).join(' ')+(certs.length>2?`<span style="font-size:8px;color:var(--text3);">+${certs.length-2}</span>`:'');
    return `<tr style="cursor:pointer;" onclick="openPMEdit('${escHtml(p.id_pm)}')" title="Click para editar">
      <td><div style="display:flex;align-items:center;gap:6px;"><div class="avatar" style="background:${col};width:24px;height:24px;font-size:10px;">${escHtml(initials)}</div><span style="font-weight:500;font-size:11px;">${escHtml(p.nombre)}</span></div></td>
      <td><span class="fte-code" style="font-size:10px;">${escHtml(p.id_pm)}</span></td>
      <td><span style="font-size:10px;font-weight:600;color:${nc};">${escHtml(p.nivel)}</span></td>
      <td><span style="font-size:9px;color:var(--text2);">${escHtml(p.especialidad)}</span></td>
      <td style="text-align:center;"><span style="font-family:var(--mono);font-size:12px;font-weight:700;color:${proj>maxP?'var(--red)':proj>=maxP?'var(--orange)':'var(--green)'};">${proj}/${maxP}</span></td>
      <td><div style="display:flex;align-items:center;gap:4px;"><div style="width:40px;height:6px;border-radius:3px;background:var(--bg);overflow:hidden;"><div style="width:${cargaPct}%;height:100%;background:${cargaPct>80?'var(--red)':cargaPct>50?'var(--orange)':'var(--green)'};border-radius:3px;"></div></div><span style="font-family:var(--mono);font-size:9px;color:var(--text2);">${cargaPct}%</span></div></td>
      <td>${certsHtml||'<span style="font-size:9px;color:var(--text3);">—</span>'}</td>
      <td><span style="font-family:var(--mono);font-size:10px;color:${(p.tasa_exito||100)>=90?'var(--green)':'var(--orange)'};">${p.tasa_exito||100}%</span></td>
      <td><span style="font-size:10px;font-weight:600;color:${eColors[p.estado]||'var(--text2)'};">${eIcons[p.estado]||'●'} ${escHtml(p.estado)}</span></td>
      <td style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><span style="font-size:9px;color:var(--text2);">${escHtml(p.email||'')}</span></td>
      <td><span style="font-size:9px;color:var(--text2);font-family:var(--mono);">${escHtml(p.telefono||'')}</span></td>
    </tr>`;
  }).join('');
  // Update footer
  const asig = pms.filter(p=>p.estado==='ASIGNADO').length;
  const sobre = pms.filter(p=>p.estado==='SOBRECARGADO').length;
  const disp = pms.filter(p=>p.estado==='DISPONIBLE').length;
  const totalProj = Object.values(projByPm).reduce((s,v)=>s+v,0);
  document.getElementById('gov-footer-info').textContent = `${pms.length} PMs · ${asig} asignados · ${sobre} sobrecargados · ${disp} disponibles · ${totalProj} proyectos gestionados`;
}

// Enable drag-reorder for gov and proj tables
['gov-thead-row','proj-thead-row'].forEach(rowId => {
  const row = document.getElementById(rowId);
  if (!row) return;
  let dragTh = null;
  row.addEventListener('dragstart', e => {
    dragTh = e.target.closest('th');
    if (dragTh) { e.dataTransfer.effectAllowed='move'; dragTh.style.opacity='.4'; }
  });
  row.addEventListener('dragover', e => { e.preventDefault(); });
  row.addEventListener('drop', e => {
    e.preventDefault();
    const target = e.target.closest('th');
    if (dragTh && target && dragTh !== target) {
      const ths = [...row.children];
      const fromIdx = ths.indexOf(dragTh), toIdx = ths.indexOf(target);
      if (fromIdx < toIdx) target.after(dragTh); else target.before(dragTh);
      const tbodyId = rowId === 'gov-thead-row' ? 'gov-tbody' : 'proj-tbody';
      document.querySelectorAll('#'+tbodyId+' tr').forEach(tr => {
        const cells = [...tr.children];
        if (cells[fromIdx] && cells[toIdx]) {
          if (fromIdx < toIdx) cells[toIdx].after(cells[fromIdx]); else cells[toIdx].before(cells[fromIdx]);
        }
      });
    }
  });
  row.addEventListener('dragend', () => { if(dragTh) dragTh.style.opacity=''; dragTh=null; });
});

// ══════════════════ WAR ROOM COGNITIVO — JS ══════════════════

let _wrLoaded = false;
let WR_ALERTS = [], WR_AUDITS = [], WR_POSTMORTEMS = [], WR_SIMS = [], WR_SESSIONS = [], WR_METRICS = [];
let _wrCurrentAgent = 'AG-008';
let _wrSessionId = null;
let _wrChatHistory = [];

const WR_AGENT_INFO = {
  'AG-001':{name:'Dispatcher ITIL',color:'#2d7ef7',temp:0.1,desc:'Triaje ITIL 4 (P1-P4)'},
  'AG-002':{name:'Resource Manager RUN',color:'#2563eb',temp:0.1,desc:'Matching cognitivo de técnicos'},
  'AG-003':{name:'Demand Forecaster',color:'#0891b2',temp:0.3,desc:'Predicción Prophet 3 días'},
  'AG-004':{name:'Buffer Gatekeeper',color:'#0e7490',temp:0.1,desc:'Pausa BUILD por riesgo P1'},
  'AG-005':{name:'Estratega PMO',color:'#3fb950',temp:0.4,desc:'Gobernanza predictiva portafolio'},
  'AG-006':{name:'Resource Manager BUILD',color:'#059669',temp:0.1,desc:'Asignación atómica proyecto↔recurso'},
  'AG-007':{name:'Planificador PMBOK',color:'#047857',temp:0.5,desc:'WBS + Gantt + PMBOK 7'},
  'AG-008':{name:'Compliance Auditor',color:'#7c3aed',temp:0.2,desc:'Auditoría normativa continua'},
  'AG-009':{name:'Post-Mortem Engine',color:'#9333ea',temp:0.4,desc:'5 Whys + Ishikawa automatizado'},
  'AG-010':{name:'Scenario Simulator',color:'#a855f7',temp:0.7,desc:'Simulación What-If'},
  'AG-012':{name:'Alert Correlator',color:'#c084fc',temp:0.1,desc:'Correlación inteligente de alertas'},
};

function wrShowSection(id, el) {
  document.querySelectorAll('.wr-section').forEach(s=>s.classList.remove('active'));
  document.querySelectorAll('.wr-nav-item').forEach(n=>n.classList.remove('active'));
  document.getElementById('wr-sec-'+id).classList.add('active');
  el.classList.add('active');
}

async function loadWarRoom() {
  _wrLoaded = true;
  _wrSessionId = 'WR-' + Date.now();
  await Promise.all([
    wrLoadDashboard(),
    wrLoadAlerts(),
    wrLoadCompliance(),
    wrLoadPostMortems(),
    wrLoadSimulations(),
    wrLoadSessions(),
    wrLoadMetrics(),
  ]);
}

// ── Dashboard ──
async function wrLoadDashboard() {
  try {
    const r = await authFetch('/cognitive/warroom/dashboard');
    const d = await r.json();
    document.getElementById('wr-kpi-alertas').textContent = d.alertas_activas || 0;
    document.getElementById('wr-kpi-compliance').textContent = d.auditorias_pendientes || 0;
    document.getElementById('wr-kpi-postmortem').textContent = d.postmortems_pendientes || 0;
    document.getElementById('wr-kpi-sims').textContent = d.simulaciones_semana || 0;
    // Update badge
    const badge = document.getElementById('wr-alert-count');
    if (d.alertas_criticas > 0) {
      badge.textContent = d.alertas_criticas;
      badge.style.display = 'flex';
    }
    const navBadge = document.getElementById('wr-nav-alerts-badge');
    if (d.alertas_activas > 0) {
      navBadge.textContent = d.alertas_activas;
      navBadge.style.display = 'inline';
    }
    // Semáforo
    const runDot = document.getElementById('wr-sem-run');
    const buildDot = document.getElementById('wr-sem-build');
    if (d.alertas_criticas > 0) {
      runDot.className = 'wr-sem-dot red';
      document.getElementById('wr-sem-run-text').textContent = `${d.alertas_criticas} alertas críticas activas`;
    } else if (d.alertas_activas > 2) {
      runDot.className = 'wr-sem-dot yellow';
      document.getElementById('wr-sem-run-text').textContent = 'Tensión — alertas pendientes';
    } else {
      runDot.className = 'wr-sem-dot green';
      document.getElementById('wr-sem-run-text').textContent = 'Operación normal';
    }
    if (d.auditorias_pendientes > 3) {
      buildDot.className = 'wr-sem-dot yellow';
      document.getElementById('wr-sem-build-text').textContent = `${d.auditorias_pendientes} hallazgos pendientes`;
    } else {
      buildDot.className = 'wr-sem-dot green';
      document.getElementById('wr-sem-build-text').textContent = 'Compliance OK';
    }
  } catch(e) { console.warn('WR dashboard error:', e); }
  wrLoadTimeline();
}

async function wrLoadTimeline() {
  const feed = document.getElementById('wr-timeline-feed');
  try {
    const [alertsR, auditsR] = await Promise.all([
      authFetch('/cognitive/alerts?limit=5').then(r=>r.json()),
      authFetch('/cognitive/audits?limit=5').then(r=>r.json()),
    ]);
    const events = [];
    alertsR.forEach(a => events.push({time:a.created_at, icon:'🔔', text:`AG-012 → Alerta ${a.severity}: ${a.title}`, color:a.severity==='CRITICAL'?'var(--red)':a.severity==='HIGH'?'var(--orange)':'var(--yellow)'}));
    auditsR.forEach(a => events.push({time:a.created_at, icon:'🛡', text:`AG-008 → ${a.audit_type}: ${a.finding.substring(0,80)}...`, color:'#a855f7'}));
    events.sort((a,b) => new Date(b.time) - new Date(a.time));
    if (events.length === 0) {
      feed.innerHTML = '<div class="no-data">Sin actividad reciente. Ejecuta el seed de datos.</div>';
      return;
    }
    feed.innerHTML = events.slice(0,8).map(e => {
      const t = new Date(e.time);
      const ts = t.toLocaleTimeString('es-ES',{hour:'2-digit',minute:'2-digit'});
      return `<div class="wr-timeline-item">
        <div class="wr-timeline-time">${ts} — ${t.toLocaleDateString('es-ES')}</div>
        <div class="wr-timeline-text" style="color:${e.color}">${e.text}</div>
      </div>`;
    }).join('');
  } catch(e) {
    feed.innerHTML = '<div class="no-data">Error cargando timeline</div>';
  }
}

// ── Alertas ──
async function wrLoadAlerts() {
  try {
    const r = await authFetch('/cognitive/alerts?limit=50');
    WR_ALERTS = await r.json();
    wrRenderAlerts(WR_ALERTS);
  } catch(e) { console.warn('WR alerts error:', e); }
}

let _wrAlertFilter = 'ALL';
function wrFilterAlerts(sev, el) {
  _wrAlertFilter = sev;
  document.querySelectorAll('#wr-alert-filters .wr-filter-chip').forEach(c=>c.classList.remove('active'));
  el.classList.add('active');
  const filtered = sev === 'ALL' ? WR_ALERTS : WR_ALERTS.filter(a=>a.severity===sev);
  wrRenderAlerts(filtered);
}

function wrRenderAlerts(alerts) {
  const feed = document.getElementById('wr-alerts-feed');
  if (!alerts.length) { feed.innerHTML = '<div class="no-data">Sin alertas</div>'; return; }
  feed.innerHTML = alerts.map(a => {
    const sev = a.severity.toLowerCase();
    const ts = new Date(a.created_at).toLocaleString('es-ES',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'});
    return `<div class="wr-alert-card ${sev}">
      <span class="wr-alert-sev wr-sev-${sev}">${a.severity}</span>
      <div class="wr-alert-body">
        <div class="wr-alert-title">${a.title}</div>
        <div class="wr-alert-desc">${a.description.substring(0,150)}</div>
        <div class="wr-alert-meta">
          <span>${a.alert_type}</span>
          <span>·</span>
          <span>${a.source_agent}</span>
          <span>·</span>
          <span>${ts}</span>
          <span>·</span>
          <span style="color:${a.status==='ACTIVE'?'var(--red)':a.status==='ACKNOWLEDGED'?'var(--yellow)':'var(--green)'};font-weight:600;">${a.status}</span>
        </div>
      </div>
      <div class="wr-alert-actions">
        ${a.status==='ACTIVE'?`<button class="wr-btn-sm wr-btn-ack" onclick="wrAckAlert('${a.id}')">ACK</button>`:''}
        ${a.status!=='RESOLVED'?`<button class="wr-btn-sm wr-btn-resolve" onclick="wrResolveAlert('${a.id}')">Resolver</button>`:''}
      </div>
    </div>`;
  }).join('');
}

async function wrAckAlert(id) {
  try {
    await authFetch(`/cognitive/alerts/${id}/acknowledge`, {method:'PUT'});
    showToast('Alerta reconocida');
    wrLoadAlerts();
    wrLoadDashboard();
  } catch(e) { showToast('Error: '+e.message); }
}
async function wrResolveAlert(id) {
  try {
    await authFetch(`/cognitive/alerts/${id}/resolve`, {method:'PUT'});
    showToast('Alerta resuelta');
    wrLoadAlerts();
    wrLoadDashboard();
  } catch(e) { showToast('Error: '+e.message); }
}

// ── Compliance ──
async function wrLoadCompliance() {
  try {
    const [dashboard, audits] = await Promise.all([
      authFetch('/cognitive/compliance/dashboard').then(r=>r.json()),
      authFetch('/cognitive/audits?limit=50').then(r=>r.json()),
    ]);
    WR_AUDITS = audits;
    // KPIs
    const kpis = document.getElementById('wr-compliance-kpis');
    kpis.innerHTML = `
      <div class="wr-kpi"><div class="wr-kpi-val" style="color:var(--red);">${dashboard.critical_open||0}</div><div class="wr-kpi-label">Critical Abiertos</div></div>
      <div class="wr-kpi"><div class="wr-kpi-val" style="color:var(--yellow);">${dashboard.open||0}</div><div class="wr-kpi-label">Total Abiertos</div></div>
      <div class="wr-kpi"><div class="wr-kpi-val" style="color:var(--green);">${dashboard.total||0}</div><div class="wr-kpi-label">Total Hallazgos</div></div>
    `;
    wrRenderAudits(audits);
  } catch(e) { console.warn('WR compliance error:', e); }
}

function wrFilterAudits(type, el) {
  document.querySelectorAll('#wr-sec-compliance .wr-filter-chip').forEach(c=>c.classList.remove('active'));
  el.classList.add('active');
  const filtered = type === 'ALL' ? WR_AUDITS : WR_AUDITS.filter(a=>a.audit_type===type);
  wrRenderAudits(filtered);
}

function wrRenderAudits(audits) {
  const feed = document.getElementById('wr-compliance-feed');
  if (!audits.length) { feed.innerHTML = '<div class="no-data">Sin hallazgos de compliance</div>'; return; }
  feed.innerHTML = audits.map(a => {
    const sev = a.severity.toLowerCase();
    const ts = new Date(a.created_at).toLocaleString('es-ES',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'});
    return `<div class="wr-compliance-card" style="border-left:3px solid ${sev==='critical'?'var(--red)':sev==='high'?'var(--orange)':sev==='medium'?'var(--yellow)':'var(--green)'};">
      <div class="wr-compliance-hdr">
        <span class="wr-compliance-type">${a.audit_type}</span>
        <span class="wr-alert-sev wr-sev-${sev}">${a.severity}</span>
        <span class="wr-compliance-entity">${a.entity_type}: ${a.entity_id}</span>
        <span style="margin-left:auto;font-size:10px;color:${a.status==='OPEN'?'var(--red)':'var(--green)'};">${a.status}</span>
      </div>
      <div style="font-size:12px;margin-bottom:6px;line-height:1.4;">${a.finding}</div>
      ${a.recommendation?`<div style="font-size:11px;color:var(--text2);padding:6px 10px;background:var(--bg2);border-radius:6px;border-left:2px solid #a855f7;">💡 ${a.recommendation}</div>`:''}
      <div style="font-size:10px;color:var(--text3);margin-top:6px;">${ts} · ${a.created_by||'AG-008'}${a.assignee?' · Asignado: '+a.assignee:''}</div>
    </div>`;
  }).join('');
}

// ── Post-Mortem ──
async function wrLoadPostMortems() {
  try {
    const r = await authFetch('/cognitive/postmortem?limit=50');
    WR_POSTMORTEMS = await r.json();
    wrRenderPostMortems(WR_POSTMORTEMS);
  } catch(e) { console.warn('WR postmortem error:', e); }
}

function wrRenderPostMortems(pms) {
  const feed = document.getElementById('wr-postmortem-feed');
  if (!pms.length) { feed.innerHTML = '<div class="no-data">Sin informes post-mortem</div>'; return; }
  feed.innerHTML = pms.map(pm => {
    const statusCls = pm.review_status==='DRAFT'?'wr-pm-draft':pm.review_status==='REVIEW'?'wr-pm-review':'wr-pm-approved';
    const ts = new Date(pm.created_at).toLocaleDateString('es-ES');
    const timeline = (typeof pm.timeline === 'string' ? JSON.parse(pm.timeline) : pm.timeline) || [];
    const corrective = (typeof pm.corrective_actions === 'string' ? JSON.parse(pm.corrective_actions) : pm.corrective_actions) || [];
    const lessons = pm.lessons_learned || [];
    return `<div class="wr-pm-card">
      <div class="wr-pm-hdr">
        <span class="wr-alert-sev wr-sev-${pm.incident_priority==='P1'?'critical':'high'}">${pm.incident_priority}</span>
        <div class="wr-pm-title">${pm.title}</div>
        <span class="wr-pm-status ${statusCls}">${pm.review_status}</span>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:10px;">
        <div style="background:var(--bg2);border-radius:6px;padding:8px;text-align:center;">
          <div style="font-family:var(--mono);font-size:18px;font-weight:800;color:var(--orange);">${pm.mttr_minutes||'--'}</div>
          <div style="font-size:9px;color:var(--text2);text-transform:uppercase;">MTTR (min)</div>
        </div>
        <div style="background:var(--bg2);border-radius:6px;padding:8px;text-align:center;">
          <div style="font-family:var(--mono);font-size:18px;font-weight:800;color:var(--blue);">${pm.mtta_minutes||'--'}</div>
          <div style="font-size:9px;color:var(--text2);text-transform:uppercase;">MTTA (min)</div>
        </div>
        <div style="background:var(--bg2);border-radius:6px;padding:8px;text-align:center;">
          <div style="font-family:var(--mono);font-size:18px;font-weight:800;color:${pm.sla_breached?'var(--red)':'var(--green)'};">${pm.sla_breached?'SÍ':'NO'}</div>
          <div style="font-size:9px;color:var(--text2);text-transform:uppercase;">SLA Breach</div>
        </div>
      </div>
      <div style="margin-bottom:8px;">
        <span style="font-size:10px;font-weight:700;color:var(--text2);text-transform:uppercase;">Root Cause:</span>
        <span style="font-size:10px;padding:1px 6px;border-radius:3px;background:var(--orange-bg);color:var(--orange);font-weight:600;margin-left:4px;">${pm.root_cause_category||'N/A'}</span>
      </div>
      <div style="font-size:12px;line-height:1.4;margin-bottom:8px;color:var(--text2);">${pm.root_cause}</div>
      ${timeline.length?`<div style="margin-top:8px;"><div style="font-size:10px;font-weight:700;color:var(--text2);margin-bottom:4px;text-transform:uppercase;">Timeline</div>${timeline.map(t=>`<div style="font-size:11px;padding:3px 0;border-bottom:1px solid var(--border2);"><span style="font-family:var(--mono);color:var(--text3);margin-right:6px;">${t.time||''}</span>${t.event||t.description||''}</div>`).join('')}</div>`:''}
      ${corrective.length?`<div style="margin-top:8px;"><div style="font-size:10px;font-weight:700;color:var(--text2);margin-bottom:4px;text-transform:uppercase;">Acciones Correctivas</div>${corrective.map(c=>`<div style="font-size:11px;padding:3px 0;color:var(--text2);">• ${typeof c==='string'?c:c.action||JSON.stringify(c)}</div>`).join('')}</div>`:''}
      ${lessons.length?`<div style="margin-top:8px;"><div style="font-size:10px;font-weight:700;color:var(--text2);margin-bottom:4px;text-transform:uppercase;">Lecciones Aprendidas</div>${lessons.map(l=>`<div style="font-size:11px;padding:3px 0;color:#a855f7;">💡 ${l}</div>`).join('')}</div>`:''}
      <div style="display:flex;gap:6px;margin-top:10px;">
        <span style="font-size:10px;color:var(--text3);">📅 ${ts}</span>
        <span style="font-size:10px;color:var(--text3);">· ${pm.incident_id}</span>
        ${pm.review_status==='DRAFT'?`<button class="wr-btn-sm wr-btn-ack" onclick="wrApprovePostMortem('${pm.id}')" style="margin-left:auto;">Aprobar</button>`:''}
      </div>
    </div>`;
  }).join('');
}

async function wrApprovePostMortem(id) {
  try {
    await authFetch(`/cognitive/postmortem/${id}/approve?approved_by=Jose Antonio Martinez Victoria`, {method:'PUT'});
    showToast('Post-mortem aprobado');
    wrLoadPostMortems();
  } catch(e) { showToast('Error: '+e.message); }
}

// ── Simulaciones ──
async function wrLoadSimulations() {
  try {
    const r = await authFetch('/cognitive/simulation?limit=20');
    WR_SIMS = await r.json();
    wrRenderSimHistory(WR_SIMS);
  } catch(e) { console.warn('WR sim error:', e); }
}

function wrRenderSimHistory(sims) {
  const feed = document.getElementById('wr-sim-history');
  if (!sims.length) { feed.innerHTML = '<div class="no-data">Sin simulaciones previas</div>'; return; }
  feed.innerHTML = sims.map(s => {
    const result = typeof s.simulation_result === 'string' ? JSON.parse(s.simulation_result) : s.simulation_result;
    const kpi = typeof s.kpi_deltas === 'string' ? JSON.parse(s.kpi_deltas) : s.kpi_deltas || {};
    const ts = new Date(s.created_at).toLocaleString('es-ES');
    const recs = s.recommendations || [];
    return `<div class="wr-compliance-card" style="border-left:3px solid ${s.risk_score>70?'var(--red)':s.risk_score>40?'var(--yellow)':'var(--green)'};">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
        <span style="padding:2px 8px;border-radius:4px;font-size:10px;font-weight:700;background:var(--purple-bg);color:#a855f7;font-family:var(--mono);">${s.scenario_type}</span>
        <span style="font-size:13px;font-weight:600;flex:1;">${s.simulation_name}</span>
        <span style="font-family:var(--mono);font-size:14px;font-weight:800;color:${s.risk_score>70?'var(--red)':s.risk_score>40?'var(--yellow)':'var(--green)'};">Risk: ${s.risk_score}</span>
      </div>
      ${Object.keys(kpi).length?`<div style="display:flex;gap:12px;margin-bottom:8px;">${Object.entries(kpi).map(([k,v])=>`<div style="font-size:10px;"><span style="color:var(--text3);">${k}:</span> <span style="font-family:var(--mono);font-weight:700;">${v}</span></div>`).join('')}</div>`:''}
      ${recs.length?`<div style="margin-top:6px;">${recs.slice(0,3).map(r=>`<div style="font-size:11px;color:var(--text2);padding:2px 0;">→ ${r}</div>`).join('')}</div>`:''}
      <div style="font-size:10px;color:var(--text3);margin-top:6px;">Confianza: ${Math.round(s.confidence_level*100)}% · ${ts}</div>
    </div>`;
  }).join('');
}

async function wrRunSimulation() {
  const type = document.getElementById('wr-sim-type').value;
  const name = document.getElementById('wr-sim-name').value;
  const desc = document.getElementById('wr-sim-desc').value;
  if (!name) { showToast('Introduce un nombre para la simulación'); return; }
  showToast('Ejecutando simulación...');
  // Generate simulation locally with realistic data
  const risk = Math.round(20 + Math.random() * 60);
  const conf = +(0.5 + Math.random() * 0.4).toFixed(2);
  const payload = {
    simulation_name: name,
    scenario_type: type,
    input_params: {description: desc, type: type},
    baseline_snapshot: {projects: 46, technicians: 150, active_alerts: parseInt(document.getElementById('wr-kpi-alertas').textContent)||0},
    simulation_result: {
      best_case: {risk: Math.max(5,risk-25), sla_impact: '+'+Math.round(Math.random()*5)+'%', cost_delta: '€0', timeline_delta: '0d', burnout_risk: Math.round(risk*0.4)},
      base_case: {risk: risk, sla_impact: '-'+Math.round(Math.random()*8+2)+'%', cost_delta: '-€'+Math.round(Math.random()*15+3)+'K', timeline_delta: '+'+Math.round(Math.random()*5+1)+'d', burnout_risk: Math.round(risk*0.7)},
      worst_case: {risk: Math.min(98,risk+20), sla_impact: '-'+Math.round(Math.random()*15+8)+'%', cost_delta: '-€'+Math.round(Math.random()*30+10)+'K', timeline_delta: '+'+Math.round(Math.random()*12+5)+'d', burnout_risk: Math.min(95,Math.round(risk*1.1))},
    },
    risk_score: risk,
    confidence_level: conf,
    recommendations: [
      'Asignar recurso backup antes de ejecutar el cambio',
      'Activar freeze preventivo si la predicción supera 25 incidencias',
      'Notificar al PM del proyecto afectado sobre impacto estimado',
      'Revisar capacidad del pool de técnicos N3+',
    ],
    affected_projects: ['PRJ0034','PRJ0035','PRJ0036'],
    affected_resources: ['FTE-082','FTE-091'],
    kpi_deltas: {sla_impact: '-5%', cost_delta: '-€8K', timeline_delta: '+3d', burnout_risk: Math.round(risk*0.7), capacity: Math.round(60+Math.random()*25)+'%'},
  };
  try {
    const r = await authFetch('/cognitive/simulation/run', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(payload)});
    if (!r.ok) throw new Error('Error en simulación');
    const sim = await r.json();
    showToast('Simulación completada — Risk Score: ' + risk);
    // Show results
    const result = payload.simulation_result;
    document.getElementById('wr-sim-results').style.display = 'block';
    document.getElementById('wr-sim-cases').innerHTML = ['best','base','worst'].map(c => {
      const d = result[c+'_case'];
      const label = c==='best'?'MEJOR CASO':c==='base'?'CASO BASE':'PEOR CASO';
      const color = c==='best'?'var(--green)':c==='base'?'var(--yellow)':'var(--red)';
      return `<div class="wr-sim-case ${c}">
        <div class="wr-sim-case-title" style="color:${color};">${label}</div>
        <div class="wr-sim-metric"><span>Risk Score</span><span class="wr-sim-metric-val" style="color:${color};">${d.risk}</span></div>
        <div class="wr-sim-metric"><span>SLA Impact</span><span class="wr-sim-metric-val">${d.sla_impact}</span></div>
        <div class="wr-sim-metric"><span>Coste</span><span class="wr-sim-metric-val">${d.cost_delta}</span></div>
        <div class="wr-sim-metric"><span>Timeline</span><span class="wr-sim-metric-val">${d.timeline_delta}</span></div>
        <div class="wr-sim-metric"><span>Burnout</span><span class="wr-sim-metric-val">${d.burnout_risk}</span></div>
      </div>`;
    }).join('');
    document.getElementById('wr-sim-recommendations').innerHTML = `
      <div style="background:var(--bg3);border:1px solid var(--border);border-radius:10px;padding:14px;border-left:3px solid #a855f7;">
        <div style="font-size:11px;font-weight:700;color:#a855f7;text-transform:uppercase;margin-bottom:6px;">Recomendaciones</div>
        ${payload.recommendations.map((r,i)=>`<div style="font-size:12px;padding:3px 0;color:var(--text2);">${i+1}. ${r}</div>`).join('')}
      </div>`;
    wrLoadSimulations();
  } catch(e) { showToast('Error: '+e.message); }
}

// ── Sesiones ──
async function wrLoadSessions() {
  try {
    const r = await authFetch('/cognitive/warroom/sessions');
    WR_SESSIONS = await r.json();
    wrRenderSessions(WR_SESSIONS);
  } catch(e) { console.warn('WR sessions error:', e); }
}

function wrRenderSessions(sessions) {
  const feed = document.getElementById('wr-sessions-feed');
  if (!sessions.length) { feed.innerHTML = '<div class="no-data">Sin sesiones de crisis</div>'; return; }
  feed.innerHTML = sessions.map(s => {
    const ts = new Date(s.started_at).toLocaleString('es-ES');
    const participants = typeof s.participants === 'string' ? JSON.parse(s.participants) : s.participants || [];
    return `<div class="wr-session-card">
      <div class="wr-session-hdr">
        <span class="wr-session-type">${s.session_type}</span>
        <span style="font-size:13px;font-weight:700;flex:1;">${s.session_name}</span>
        <span class="wr-pm-status ${s.status==='ACTIVE'?'wr-session-active':'wr-pm-draft'}">${s.status}</span>
      </div>
      ${participants.length?`<div style="display:flex;gap:4px;margin-bottom:6px;">${participants.map(p=>`<span style="font-size:10px;padding:1px 6px;border-radius:3px;background:var(--purple-bg);color:#a855f7;">${p}</span>`).join('')}</div>`:''}
      ${s.summary?`<div style="font-size:11px;color:var(--text2);margin-bottom:4px;">${s.summary}</div>`:''}
      <div style="font-size:10px;color:var(--text3);">📅 ${ts}${s.closed_at?' · Cerrada: '+new Date(s.closed_at).toLocaleString('es-ES'):''}</div>
    </div>`;
  }).join('');
}

async function wrCreateSession() {
  const name = prompt('Nombre de la sesión de crisis:');
  if (!name) return;
  try {
    const r = await authFetch('/cognitive/warroom/sessions', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({session_name:name, session_type:'AD_HOC', participants:['AG-008','AG-012'], context:{}}),
    });
    if (!r.ok) throw new Error('Error creando sesión');
    showToast('Sesión creada');
    wrLoadSessions();
  } catch(e) { showToast('Error: '+e.message); }
}

// ── Métricas ──
async function wrLoadMetrics() {
  try {
    const r = await authFetch('/cognitive/metrics/agents');
    WR_METRICS = await r.json();
    wrRenderMetrics(WR_METRICS);
  } catch(e) { console.warn('WR metrics error:', e); }
}

function wrRenderMetrics(metrics) {
  const grid = document.getElementById('wr-metrics-grid');
  // Group by agent_id
  const byAgent = {};
  metrics.forEach(m => {
    if (!byAgent[m.agent_id]) byAgent[m.agent_id] = m;
  });
  const agents = Object.keys(WR_AGENT_INFO);
  if (Object.keys(byAgent).length === 0) {
    // Show all agents with placeholder data
    grid.innerHTML = agents.map(id => {
      const info = WR_AGENT_INFO[id];
      return `<div class="wr-metric-card">
        <div class="wr-metric-card-hdr">
          <div class="wr-metric-agent-av" style="background:${info.color};">${id.replace('AG-','')}</div>
          <div><div style="font-size:12px;font-weight:700;">${id}</div><div style="font-size:10px;color:var(--text2);">${info.name}</div></div>
        </div>
        <div class="wr-metric-vals">
          <div><div class="wr-metric-v" style="color:var(--blue);">--</div><div class="wr-metric-l">Invocaciones</div></div>
          <div><div class="wr-metric-v" style="color:var(--green);">--</div><div class="wr-metric-l">Latencia (ms)</div></div>
          <div><div class="wr-metric-v" style="color:var(--yellow);">--</div><div class="wr-metric-l">Tokens</div></div>
          <div><div class="wr-metric-v" style="color:var(--purple);">--</div><div class="wr-metric-l">Éxito %</div></div>
        </div>
      </div>`;
    }).join('');
    return;
  }
  grid.innerHTML = agents.map(id => {
    const info = WR_AGENT_INFO[id];
    const m = byAgent[id] || {};
    return `<div class="wr-metric-card">
      <div class="wr-metric-card-hdr">
        <div class="wr-metric-agent-av" style="background:${info.color};">${id.replace('AG-','')}</div>
        <div><div style="font-size:12px;font-weight:700;">${id}</div><div style="font-size:10px;color:var(--text2);">${info.name}</div></div>
      </div>
      <div class="wr-metric-vals">
        <div><div class="wr-metric-v" style="color:var(--blue);">${m.total_invocations||0}</div><div class="wr-metric-l">Invocaciones</div></div>
        <div><div class="wr-metric-v" style="color:var(--green);">${Math.round(m.avg_latency_ms||0)}</div><div class="wr-metric-l">Latencia (ms)</div></div>
        <div><div class="wr-metric-v" style="color:var(--yellow);">${m.total_tokens_consumed?Math.round(m.total_tokens_consumed/1000)+'K':'0'}</div><div class="wr-metric-l">Tokens</div></div>
        <div><div class="wr-metric-v" style="color:${(m.success_rate||100)>=95?'var(--green)':'var(--red)'};">${m.success_rate||100}%</div><div class="wr-metric-l">Éxito</div></div>
      </div>
    </div>`;
  }).join('');
}

// ── Chat Multi-Agente ──
function wrSelectAgent(agentId, el) {
  _wrCurrentAgent = agentId;
  document.querySelectorAll('.wr-agent-item').forEach(i=>i.classList.remove('active'));
  el.classList.add('active');
  const info = WR_AGENT_INFO[agentId];
  document.getElementById('wr-chat-av').style.background = info.color;
  document.getElementById('wr-chat-av').textContent = agentId.replace('AG-0','').replace('AG-','');
  document.getElementById('wr-chat-agent-name').textContent = agentId + ' ' + info.name;
  document.getElementById('wr-chat-agent-sub').textContent = `Temp: ${info.temp} · ${info.desc}`;
  // Clear chat for new agent
  _wrChatHistory = [];
  document.getElementById('wr-chat-messages').innerHTML = `
    <div style="text-align:center;padding:20px;color:var(--text3);font-size:12px;">
      Conversación con <strong style="color:${info.color};">${agentId} ${info.name}</strong><br>
      Escribe tu mensaje para comenzar.
    </div>`;
}

async function wrSendChat() {
  const input = document.getElementById('wr-chat-input');
  const msg = input.value.trim();
  if (!msg) return;
  input.value = '';
  const messages = document.getElementById('wr-chat-messages');
  // Remove placeholder
  if (messages.querySelector('div[style*="text-align:center"]')) messages.innerHTML = '';
  // Add user bubble
  const now = new Date().toLocaleTimeString('es-ES',{hour:'2-digit',minute:'2-digit'});
  messages.innerHTML += `<div class="wr-chat-bubble wr-bubble-user">${escapeHtml(msg)}<div class="wr-bubble-meta">${now}</div></div>`;
  messages.scrollTop = messages.scrollHeight;
  // Add typing indicator
  const typingId = 'typing-'+Date.now();
  messages.innerHTML += `<div class="wr-chat-bubble wr-bubble-assistant" id="${typingId}" style="color:var(--text3);font-style:italic;">Pensando...</div>`;
  messages.scrollTop = messages.scrollHeight;

  try {
    const r = await authFetch('/cognitive/chat', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({session_id: _wrSessionId, agent_id: _wrCurrentAgent, message: msg}),
    });
    const data = await r.json();
    const typing = document.getElementById(typingId);
    if (typing) {
      const info = WR_AGENT_INFO[_wrCurrentAgent];
      typing.id = '';
      typing.style.color = '';
      typing.style.fontStyle = '';
      typing.innerHTML = `${formatChatResponse(data.response)}<div class="wr-bubble-meta">${_wrCurrentAgent} · ${data.model} · ${data.latency_ms}ms · ${data.tokens_used} tokens</div>`;
    }
    messages.scrollTop = messages.scrollHeight;
  } catch(e) {
    const typing = document.getElementById(typingId);
    if (typing) { typing.textContent = 'Error: '+e.message; typing.style.color='var(--red)'; }
  }
}

function escapeHtml(t) {
  return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}
function formatChatResponse(text) {
  // Basic markdown-like formatting
  return text.replace(/\n/g,'<br>').replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>').replace(/`(.*?)`/g,'<code style="background:var(--bg);padding:1px 4px;border-radius:3px;font-family:var(--mono);font-size:12px;">$1</code>');
}

// ══════════════════ DOCUMENTACIÓN — JS ══════════════════
let _docsLoaded = false, ALL_DOCS = [], _docSearch = '', _docEditMode = false;

async function loadDocs() {
  _docsLoaded = true;
  const silo = document.getElementById('doc-filter-silo').value;
  const tipo = document.getElementById('doc-filter-tipo').value;
  const depto = document.getElementById('doc-filter-depto').value;
  let url = API_BASE + '/documentacion?limit=200';
  if (silo) url += '&silo=' + silo;
  if (tipo) url += '&tipo=' + tipo;
  if (depto) url += '&departamento=' + depto;
  if (_docSearch) url += '&search=' + encodeURIComponent(_docSearch);
  try {
    const r = await authFetch(url).then(r=>r.json());
    ALL_DOCS = r.docs || [];
    document.getElementById('docs-count').textContent = r.total + ' documentos';
    renderDocs(ALL_DOCS);
    loadDocDeptos();
  } catch(e) { console.warn(e); }
}

function filterDocs(val) { _docSearch = val; loadDocs(); }
function filterDocsApply() { loadDocs(); }
function toggleDocStats() {
  const el = document.getElementById('docs-stats');
  el.style.display = el.style.display === 'none' ? 'block' : 'none';
  if (el.style.display !== 'none') loadDocStats();
}

async function loadDocStats() {
  try {
    const s = await authFetch(API_BASE+'/documentacion/stats').then(r=>r.json());
    document.getElementById('docs-kpis').innerHTML = [
      {v:s.total||0,l:'Total Docs',c:'#0ea5e9'},
      {v:s.by_silo?.BUILD||0,l:'BUILD',c:'var(--green)'},
      {v:s.by_silo?.RUN||0,l:'RUN',c:'var(--blue)'},
      {v:s.by_silo?.TRANSVERSAL||0,l:'TRANSVERSAL',c:'var(--purple)'},
    ].map(k=>`<div style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:8px;text-align:center;"><div style="font-family:var(--mono);font-size:20px;font-weight:800;color:${k.c};">${k.v}</div><div style="font-size:9px;color:var(--text2);text-transform:uppercase;">${k.l}</div></div>`).join('');
    const tipoColors = {proyecto:'var(--green)',incidencia:'var(--blue)',gobernanza:'var(--purple)',formacion:'var(--yellow)',herramienta:'var(--orange)',plantilla:'#0ea5e9'};
    document.getElementById('docs-breakdown').innerHTML = Object.entries(s.by_tipo||{}).map(([t,c])=>`<div style="background:var(--bg3);border:1px solid var(--border);border-radius:6px;padding:6px 10px;display:flex;align-items:center;gap:6px;"><span style="width:8px;height:8px;border-radius:50%;background:${tipoColors[t]||'var(--text3)'};"></span><span style="font-size:10px;color:var(--text2);flex:1;">${t}</span><span style="font-family:var(--mono);font-size:12px;font-weight:700;">${c}</span></div>`).join('');
  } catch(e) {}
}

function renderDocs(docs) {
  const grid = document.getElementById('docs-grid');
  if (!docs.length) { grid.innerHTML = '<div class="no-data" style="grid-column:1/-1;">Sin documentos. Registra el primero con el botón "+ Documento".</div>'; return; }
  const fileIcons = {pdf:'📕',docx:'📘',xlsx:'📗',pptx:'📙',md:'📝',txt:'📄',csv:'📊',json:'⚙️'};
  grid.innerHTML = docs.map(d => {
    const ext = (d.archivo_tipo || d.archivo_nombre?.split('.').pop() || '').toLowerCase();
    const icon = fileIcons[ext] || '📎';
    const tags = (d.tags || []).slice(0,3).map(t=>`<span class="doc-tag">${escHtml(t)}</span>`).join('');
    const ts = d.fecha_creacion ? new Date(d.fecha_creacion).toLocaleDateString('es-ES') : '';
    const size = d.archivo_size ? (d.archivo_size > 1048576 ? (d.archivo_size/1048576).toFixed(1)+'MB' : (d.archivo_size/1024).toFixed(0)+'KB') : '';
    return `<div class="doc-card doc-silo-${(d.silo||'build').toLowerCase()}" onclick="openDocDetail(${d.id})">
      <div style="display:flex;align-items:flex-start;gap:10px;">
        <span style="font-size:24px;line-height:1;">${icon}</span>
        <div style="flex:1;min-width:0;">
          <div style="font-size:12px;font-weight:600;margin-bottom:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${escHtml(d.titulo)}</div>
          <div style="display:flex;gap:4px;flex-wrap:wrap;margin-bottom:4px;">
            <span class="doc-type-badge doc-type-${d.tipo}">${d.tipo}</span>
            <span style="font-size:9px;padding:1px 5px;border-radius:3px;background:var(--bg2);color:var(--text3);">${d.silo}</span>
            ${d.departamento?`<span style="font-size:9px;color:var(--text3);">${d.departamento}</span>`:''}
          </div>
          ${d.descripcion?`<div style="font-size:10px;color:var(--text2);line-height:1.3;margin-bottom:4px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">${escHtml(d.descripcion)}</div>`:''}
          <div style="display:flex;gap:3px;flex-wrap:wrap;">${tags}</div>
        </div>
      </div>
      <div style="display:flex;align-items:center;gap:8px;margin-top:8px;padding-top:6px;border-top:1px solid var(--border2);font-size:9px;color:var(--text3);">
        <span>${ts}</span>
        ${size?`<span>· ${size}</span>`:''}
        ${d.creado_por?`<span>· ${d.creado_por.split(' ')[0]}</span>`:''}
        ${d.proyecto_id?`<span style="color:var(--green);">· ${d.proyecto_id}</span>`:''}
        ${d.drive_share_url?`<a href="${d.drive_share_url}" target="_blank" onclick="event.stopPropagation()" style="margin-left:auto;color:#0ea5e9;font-weight:600;text-decoration:none;">↗ Drive</a>`:''}
        <button onclick="event.stopPropagation();deleteDoc(${d.id},'${escHtml(d.titulo).replace(/'/g,"\\'")}')" style="margin-left:${d.drive_share_url?'4px':'auto'};background:var(--red-bg);border:1px solid rgba(248,81,73,.3);color:var(--red);border-radius:3px;padding:1px 6px;font-size:8px;font-weight:600;cursor:pointer;">✕</button>
      </div>
    </div>`;
  }).join('');
}

function openDocDetail(id) {
  const d = ALL_DOCS.find(x=>x.id===id);
  if (!d) return;
  _docEditMode = true;
  document.getElementById('doc-form-title').textContent = 'Editar: ' + d.titulo;
  document.getElementById('doc-edit-id').value = d.id;
  document.getElementById('doc-titulo').value = d.titulo;
  document.getElementById('doc-desc').value = d.descripcion || '';
  document.getElementById('doc-tipo').value = d.tipo;
  document.getElementById('doc-silo').value = d.silo;
  docSiloChanged();
  setTimeout(()=>{ document.getElementById('doc-depto').value = d.departamento || ''; }, 50);
  document.getElementById('doc-tags').value = (d.tags||[]).join(', ');
  document.getElementById('doc-creador').value = d.creado_por || '';
  document.getElementById('doc-drive-url').value = d.drive_share_url || '';
  document.getElementById('doc-btn-save').textContent = 'Guardar Cambios';
  fmOpen('fm-doc');
}

function openDocForm() {
  _docEditMode = false;
  document.getElementById('doc-form-title').textContent = 'Nuevo Documento';
  document.getElementById('doc-edit-id').value = '';
  document.getElementById('doc-titulo').value = '';
  document.getElementById('doc-desc').value = '';
  document.getElementById('doc-tipo').value = 'proyecto';
  document.getElementById('doc-silo').value = 'BUILD';
  document.getElementById('doc-tags').value = '';
  document.getElementById('doc-creador').value = 'Jose Antonio Martinez';
  document.getElementById('doc-drive-url').value = '';
  document.getElementById('doc-file-info').style.display = 'none';
  document.getElementById('doc-btn-save').textContent = 'Registrar Documento';
  docSiloChanged();
  loadDocProjects();
  fmOpen('fm-doc');
}

function docSiloChanged() {
  const silo = document.getElementById('doc-silo').value;
  const deptos = {BUILD:['IT_Development','IT_Architecture','PMO_BUILD','QA','DevOps'],RUN:['IT_Operations','IT_Support','IT_Security','PMO_RUN','NOC'],TRANSVERSAL:['Gobernanza_General','RRHH','Formacion','Legal','Compliance']};
  const sel = document.getElementById('doc-depto');
  sel.innerHTML = '<option value="">— Seleccionar —</option>' + (deptos[silo]||[]).map(d=>`<option value="${d}">${d}</option>`).join('');
}

async function loadDocDeptos() {
  const sel = document.getElementById('doc-filter-depto');
  if (sel.options.length > 1) return;
  try {
    const data = await authFetch(API_BASE+'/documentacion/departamentos').then(r=>r.json());
    data.forEach(g => g.departamentos.forEach(d => {
      const opt = document.createElement('option');
      opt.value = d; opt.textContent = g.silo + ' / ' + d;
      sel.appendChild(opt);
    }));
  } catch(e) {}
}

async function loadDocProjects() {
  const sel = document.getElementById('doc-proyecto');
  if (sel.options.length > 1) return;
  try {
    const data = await authFetch(API_BASE+'/cartera/proyectos').then(r=>r.json());
    data.forEach(p => { const o = document.createElement('option'); o.value=p.id_proyecto; o.textContent=p.id_proyecto+' — '+(p.nombre_proyecto||'').substring(0,40); sel.appendChild(o); });
  } catch(e) {}
}

function docFileSelected(input) {
  const file = input.files[0];
  if (!file) return;
  const info = document.getElementById('doc-file-info');
  info.style.display = 'block';
  info.textContent = file.name + ' (' + (file.size/1024).toFixed(0) + 'KB)';
  if (!document.getElementById('doc-titulo').value) document.getElementById('doc-titulo').value = file.name.replace(/\.[^.]+$/,'');
}
function docHandleDrop(e) {
  const file = e.dataTransfer.files[0];
  if (file) { document.getElementById('doc-file-input').files = e.dataTransfer.files; docFileSelected(document.getElementById('doc-file-input')); }
}

async function saveDoc() {
  const titulo = document.getElementById('doc-titulo').value.trim();
  if (!titulo) { showToast('El título es obligatorio'); return; }
  const tagsRaw = document.getElementById('doc-tags').value;
  const file = document.getElementById('doc-file-input').files[0];
  const payload = {
    titulo, descripcion: document.getElementById('doc-desc').value.trim() || null,
    tipo: document.getElementById('doc-tipo').value, silo: document.getElementById('doc-silo').value,
    departamento: document.getElementById('doc-depto').value || null,
    proyecto_id: document.getElementById('doc-proyecto').value || null,
    tags: tagsRaw ? tagsRaw.split(',').map(t=>t.trim()).filter(Boolean) : [],
    creado_por: document.getElementById('doc-creador').value.trim() || null,
    drive_share_url: document.getElementById('doc-drive-url').value.trim() || null,
    archivo_nombre: file ? file.name : null,
    archivo_size: file ? file.size : 0,
    archivo_tipo: file ? file.name.split('.').pop() : null,
    mime_type: file ? file.type : null,
  };
  const editId = document.getElementById('doc-edit-id').value;
  try {
    const url = _docEditMode ? API_BASE+'/documentacion/'+editId : API_BASE+'/documentacion';
    const method = _docEditMode ? 'PUT' : 'POST';
    const r = await authFetch(url, {method, headers:{'Content-Type':'application/json'}, body:JSON.stringify(payload)});
    if (!r.ok) throw new Error((await r.json().catch(()=>{}))?.detail||'Error');
    showToast(_docEditMode ? 'Documento actualizado' : 'Documento registrado');
    fmClose('fm-doc'); loadDocs();
  } catch(e) { showToast('Error: '+e.message); }
}

async function deleteDoc(id, titulo) {
  if (!confirm('¿Eliminar el documento?\n\n"'+titulo+'"\n\nEl archivo en Google Drive NO se eliminará.')) return;
  try {
    await authFetch(API_BASE+'/documentacion/'+id, {method:'DELETE'});
    showToast('Documento eliminado');
    loadDocs();
  } catch(e) { showToast('Error: '+e.message); }
}

// ══════════════════ CMDB — JS ══════════════════
var _cmdbActivos = [];
var CRIT_COLORS = {CRITICA:'#ef4444',ALTA:'#f59e0b',MEDIA:'#3b82f6',BAJA:'#6b7280'};
var CAPA_COLORS = {INFRAESTRUCTURA:'#3b82f6',APLICACION:'#8b5cf6',RED:'#10b981',SEGURIDAD:'#ef4444',NEGOCIO:'#f59e0b',SOPORTE:'#6b7280'};
var ESTADO_COLORS = {OPERATIVO:'#3fb950',DEGRADADO:'#f59e0b',MANTENIMIENTO:'#f0883e',RETIRADO:'#6b7280',PLANIFICADO:'#3b82f6',DISCOVERY:'#39c5cf',DESPLEGANDO:'#a855f7'};

function cmdbShowSection(id, el) {
  document.querySelectorAll('#page-cmdb .dev-section').forEach(function(s){s.classList.remove('active');});
  document.querySelectorAll('#page-cmdb .dev-nav-item').forEach(function(n){n.classList.remove('active');});
  document.getElementById('cmdb-sec-'+id).classList.add('active');
  el.classList.add('active');
  if (id==='dashboard') loadCmdbDashboard();
  if (id==='inventario') loadCmdbInventario();
  if (id==='dependencias') loadCmdbDependencias();
  if (id==='vlans') loadCmdbVlans();
  if (id==='ips') loadCmdbIps();
  if (id==='software') loadCmdbSoftware();
  if (id==='costes') loadCmdbCostes();
  if (id==='compliance') loadCmdbCompliance();
}

// ── CMDB CRUD: Create/Edit/Delete Activo ──
function showCreateActivo() {
  var html = '<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;font-size:13px;">';
  html += '<div class="login-field"><label>'+t('cmdb.code')+' *</label><input type="text" id="ca-codigo" placeholder="SRV-PRO-XXX" style="text-transform:uppercase;"></div>';
  html += '<div class="login-field"><label>'+t('common.name')+' *</label><input type="text" id="ca-nombre" placeholder="Nombre del activo"></div>';
  html += '<div class="login-field"><label>'+t('cmdb.layer')+' *</label><select id="ca-capa" style="width:100%;padding:8px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:6px;"><option>INFRAESTRUCTURA</option><option>APLICACION</option><option>RED</option><option>SEGURIDAD</option><option>NEGOCIO</option><option>SOPORTE</option></select></div>';
  html += '<div class="login-field"><label>'+t('common.type')+' *</label><input type="text" id="ca-tipo" placeholder="Servidor Físico, Base de Datos..."></div>';
  html += '<div class="login-field"><label>'+t('cmdb.criticality')+'</label><select id="ca-crit" style="width:100%;padding:8px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:6px;"><option>MEDIA</option><option>CRITICA</option><option>ALTA</option><option>BAJA</option></select></div>';
  html += '<div class="login-field"><label>'+t('cmdb.environment')+'</label><select id="ca-entorno" style="width:100%;padding:8px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:6px;"><option>PRODUCCION</option><option>PREPRODUCCION</option><option>DESARROLLO</option><option>STAGING</option><option>DR</option><option>LAB</option></select></div>';
  html += '<div class="login-field"><label>Estado</label><select id="ca-estado" style="width:100%;padding:8px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:6px;"><option>OPERATIVO</option><option>PLANIFICADO</option><option>DESPLEGANDO</option><option>DEGRADADO</option><option>MANTENIMIENTO</option><option>RETIRADO</option><option>DISCOVERY</option></select></div>';
  html += '<div class="login-field"><label>'+t('cmdb.location')+'</label><input type="text" id="ca-ubic" placeholder="CPD Madrid..."></div>';
  html += '<div class="login-field"><label>'+t('cmdb.owner')+'</label><input type="text" id="ca-owner" placeholder="Departamento/Área"></div>';
  html += '<div class="login-field"><label>'+t('cmdb.responsible')+'</label><input type="text" id="ca-resp" placeholder="Nombre del responsable"></div>';
  html += '<div class="login-field"><label>'+t('cmdb.provider')+'</label><input type="text" id="ca-prov" placeholder="Dell, Microsoft..."></div>';
  html += '<div class="login-field"><label>'+t('cmdb.monthly_cost')+'</label><input type="number" id="ca-coste" value="0"></div>';
  html += '<div class="login-field"><label>'+t('cmdb.project')+'</label><select id="ca-proy" style="width:100%;padding:8px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:6px;" onfocus="loadProjectSelect(\'ca-proy\')"><option value="">-- Sin proyecto --</option></select></div>';
  html += '<div class="login-field"><label>'+t('cmdb.notes')+'</label><input type="text" id="ca-notas" placeholder="Notas adicionales..."></div>';
  html += '</div>';
  html += '<div style="display:flex;gap:8px;margin-top:14px;justify-content:flex-end;">';
  html += '<button onclick="document.getElementById(\'simple-modal-overlay\').remove()" style="background:var(--bg3);border:1px solid var(--border);color:var(--text2);border-radius:6px;padding:8px 20px;font-size:13px;cursor:pointer;">'+t('common.cancel')+'</button>';
  html += '<button onclick="doCreateActivo()" style="background:linear-gradient(135deg,#f59e0b,#d97706);border:none;color:#fff;border-radius:6px;padding:8px 20px;font-size:13px;font-weight:700;cursor:pointer;">'+t('common.create')+'</button>';
  html += '</div>';
  showSimpleModal(t('cmdb.new_asset'), html);
}

async function doCreateActivo() {
  var body = {
    codigo: (document.getElementById('ca-codigo').value||'').trim().toUpperCase(),
    nombre: document.getElementById('ca-nombre').value.trim(),
    capa: document.getElementById('ca-capa').value,
    tipo: document.getElementById('ca-tipo').value.trim(),
    criticidad: document.getElementById('ca-crit').value,
    entorno: document.getElementById('ca-entorno').value,
    estado_ciclo: document.getElementById('ca-estado').value,
    ubicacion: document.getElementById('ca-ubic').value.trim()||null,
    propietario: document.getElementById('ca-owner').value.trim()||null,
    responsable_tecnico: document.getElementById('ca-resp').value.trim()||null,
    proveedor: document.getElementById('ca-prov').value.trim()||null,
    coste_mensual: parseFloat(document.getElementById('ca-coste').value)||0,
    id_proyecto: document.getElementById('ca-proy').value.trim()||null,
    notas: document.getElementById('ca-notas').value.trim()||null,
  };
  if (!body.codigo||!body.nombre||!body.tipo) { alert('Código, Nombre y Tipo son obligatorios'); return; }
  try {
    var r = await authFetch(API_BASE+'/cmdb/activos',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
    var d = await r.json();
    if (!r.ok) { alert('Error: '+(d.detail||'Error')); return; }
    document.getElementById('simple-modal-overlay').remove();
    showToast('Activo '+body.codigo+' '+t('misc.created'));
    loadCmdbDashboard();
  } catch(e) { alert('Error: '+e.message); }
}

async function showEditActivo(id) {
  try {
    var data = await authFetch(API_BASE+'/cmdb/activos/'+id).then(function(r){return r.json();});
    var a = data.activo;
    var mkSel = function(id,opts,val) {
      return '<select id="'+id+'" style="width:100%;padding:8px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:6px;">'+opts.map(function(o){return '<option'+(o===val?' selected':'')+'>'+o+'</option>';}).join('')+'</select>';
    };
    var html = '<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;font-size:13px;">';
    html += '<div class="login-field"><label>'+t('cmdb.code')+'</label><input type="text" disabled value="'+escHtml(a.codigo)+'" style="opacity:.6;"></div>';
    html += '<div class="login-field"><label>'+t('common.name')+'</label><input type="text" id="ea-nombre" value="'+escHtml(a.nombre||'')+'"></div>';
    html += '<div class="login-field"><label>'+t('cmdb.layer')+'</label>'+mkSel('ea-capa',['INFRAESTRUCTURA','APLICACION','RED','SEGURIDAD','NEGOCIO','SOPORTE'],a.capa)+'</div>';
    html += '<div class="login-field"><label>'+t('common.type')+'</label><input type="text" id="ea-tipo" value="'+escHtml(a.tipo||'')+'"></div>';
    html += '<div class="login-field"><label>'+t('cmdb.criticality')+'</label>'+mkSel('ea-crit',['CRITICA','ALTA','MEDIA','BAJA'],a.criticidad)+'</div>';
    html += '<div class="login-field"><label>'+t('cmdb.environment')+'</label>'+mkSel('ea-entorno',['PRODUCCION','PREPRODUCCION','DESARROLLO','STAGING','DR','LAB'],a.entorno)+'</div>';
    html += '<div class="login-field"><label>'+t('cmdb.lifecycle')+'</label>'+mkSel('ea-estado',['OPERATIVO','PLANIFICADO','DESPLEGANDO','DEGRADADO','MANTENIMIENTO','RETIRADO','DISCOVERY'],a.estado_ciclo)+'</div>';
    html += '<div class="login-field"><label>'+t('cmdb.location')+'</label><input type="text" id="ea-ubic" value="'+escHtml(a.ubicacion||'')+'"></div>';
    html += '<div class="login-field"><label>'+t('cmdb.owner')+'</label><input type="text" id="ea-owner" value="'+escHtml(a.propietario||'')+'"></div>';
    html += '<div class="login-field"><label>'+t('cmdb.responsible')+'</label><input type="text" id="ea-resp" value="'+escHtml(a.responsable_tecnico||'')+'"></div>';
    html += '<div class="login-field"><label>'+t('cmdb.provider')+'</label><input type="text" id="ea-prov" value="'+escHtml(a.proveedor||'')+'"></div>';
    html += '<div class="login-field"><label>'+t('cmdb.monthly_cost')+'</label><input type="number" id="ea-coste" value="'+(a.coste_mensual||0)+'"></div>';
    html += '<div class="login-field"><label>'+t('cmdb.project')+'</label><select id="ea-proy" style="width:100%;padding:8px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:6px;" onfocus="loadProjectSelect(\'ea-proy\',\''+escHtml(a.id_proyecto||'')+'\')"><option value="">-- Sin proyecto --</option>'+(a.id_proyecto?'<option value="'+escHtml(a.id_proyecto)+'" selected>'+escHtml(a.id_proyecto)+'</option>':'')+'</select></div>';
    html += '<div class="login-field"><label>'+t('cmdb.notes')+'</label><input type="text" id="ea-notas" value="'+escHtml(a.notas||'')+'"></div>';
    html += '</div>';
    html += '<div style="display:flex;gap:8px;margin-top:14px;justify-content:space-between;">';
    html += '<button onclick="doDeleteActivo('+id+',\''+escHtml(a.codigo)+'\')" style="background:var(--red-bg);border:1px solid rgba(248,81,73,.2);color:var(--red);border-radius:6px;padding:8px 14px;font-size:12px;font-weight:600;cursor:pointer;">'+t('common.delete')+'</button>';
    html += '<div style="display:flex;gap:8px;">';
    html += '<button onclick="document.getElementById(\'simple-modal-overlay\').remove()" style="background:var(--bg3);border:1px solid var(--border);color:var(--text2);border-radius:6px;padding:8px 20px;font-size:13px;cursor:pointer;">'+t('common.cancel')+'</button>';
    html += '<button onclick="doEditActivo('+id+')" style="background:linear-gradient(135deg,#2563eb,#3b82f6);border:none;color:#fff;border-radius:6px;padding:8px 20px;font-size:13px;font-weight:700;cursor:pointer;">'+t('common.save')+'</button>';
    html += '</div></div>';
    showSimpleModal(t('cmdb.edit_asset')+': '+a.codigo+' — '+a.nombre, html);
  } catch(e) { alert('Error: '+e.message); }
}

async function doEditActivo(id) {
  var body = {
    nombre: document.getElementById('ea-nombre').value.trim(),
    capa: document.getElementById('ea-capa').value,
    tipo: document.getElementById('ea-tipo').value.trim(),
    criticidad: document.getElementById('ea-crit').value,
    entorno: document.getElementById('ea-entorno').value,
    estado_ciclo: document.getElementById('ea-estado').value,
    ubicacion: document.getElementById('ea-ubic').value.trim()||null,
    propietario: document.getElementById('ea-owner').value.trim()||null,
    responsable_tecnico: document.getElementById('ea-resp').value.trim()||null,
    proveedor: document.getElementById('ea-prov').value.trim()||null,
    coste_mensual: parseFloat(document.getElementById('ea-coste').value)||0,
    id_proyecto: document.getElementById('ea-proy').value.trim()||null,
    notas: document.getElementById('ea-notas').value.trim()||null,
  };
  try {
    var r = await authFetch(API_BASE+'/cmdb/activos/'+id,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
    if (!r.ok) { var d = await r.json(); alert('Error: '+(d.detail||'Error')); return; }
    document.getElementById('simple-modal-overlay').remove();
    showToast('Activo '+t('misc.updated'));
    loadCmdbDashboard();
  } catch(e) { alert('Error: '+e.message); }
}

async function doDeleteActivo(id, codigo) {
  if (!confirm(t('misc.confirm_retire')+' "'+codigo+'"?')) return;
  try {
    await authFetch(API_BASE+'/cmdb/activos/'+id,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({estado_ciclo:'RETIRADO'})});
    document.getElementById('simple-modal-overlay').remove();
    showToast('Activo '+codigo+' marcado como RETIRADO');
    loadCmdbDashboard();
  } catch(e) { alert('Error: '+e.message); }
}

// ── Load projects into a select dropdown ──
async function loadProjectSelect(selectId, currentVal) {
  var sel = document.getElementById(selectId);
  if (!sel || sel.options.length > 2) return;
  try {
    var projs = await authFetch(API_BASE+'/cartera/proyectos').then(function(r){return r.json();});
    sel.innerHTML = '<option value="">-- Sin proyecto --</option>';
    projs.forEach(function(p) {
      var opt = document.createElement('option');
      opt.value = p.id_proyecto;
      opt.textContent = p.id_proyecto + ' — ' + (p.nombre_proyecto||'').substring(0,50);
      if (currentVal && p.id_proyecto === currentVal) opt.selected = true;
      sel.appendChild(opt);
    });
  } catch(e) { console.warn('Error loading projects:', e); }
}

// ── Load CMDB assets into a select dropdown ──
async function loadCmdbSelect(selectId, isMultiple) {
  var sel = document.getElementById(selectId);
  if (!sel || sel.options.length > 2) return;
  try {
    var data = await authFetch(API_BASE+'/cmdb/activos?limit=500').then(function(r){return r.json();});
    var activos = data.activos||[];
    sel.innerHTML = isMultiple ? '' : '<option value="">-- Seleccionar activo CMDB --</option>';
    activos.forEach(function(a) {
      var opt = document.createElement('option');
      opt.value = a.codigo;
      opt.textContent = a.codigo + ' — ' + a.nombre + ' [' + a.capa + ']';
      sel.appendChild(opt);
    });
  } catch(e) { console.warn('Error loading CMDB select:', e); }
}

async function loadCmdbDashboard() {
  var el = document.getElementById('cmdb-dash');
  try {
    var d = await authFetch(API_BASE+'/cmdb/dashboard').then(function(r){return r.json();});
    var html = '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;"><div style="font-size:16px;font-weight:800;display:flex;align-items:center;gap:8px;"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="1.8"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>'+t('cmdb.title')+'</div><button onclick="showCreateActivo()" style="background:linear-gradient(135deg,#f59e0b,#d97706);border:none;color:#fff;border-radius:6px;padding:8px 16px;font-size:12px;font-weight:700;cursor:pointer;">'+t('cmdb.new_asset')+'</button></div>';
    // KPIs
    html += '<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px;">';
    html += _cmdbKpi(t('cmdb.total_assets'), d.total_activos, '#3b82f6');
    html += _cmdbKpi(t('cmdb.critical'), d.activos_criticos, '#ef4444');
    html += _cmdbKpi(t('cmdb.infra_cost'), '€'+Math.round(d.coste_mensual_infra).toLocaleString(), '#f59e0b');
    html += _cmdbKpi(t('cmdb.sw_cost'), '€'+Math.round(d.coste_anual_software).toLocaleString(), '#8b5cf6');
    html += _cmdbKpi('VLANs', d.total_vlans, '#10b981');
    html += _cmdbKpi(t('cmdb.relations'), d.total_relaciones, '#39c5cf');
    html += _cmdbKpi('Software', d.total_software, '#f778ba');
    html += _cmdbKpi(t('cmdb.obsolete_sw'), d.software_obsoleto, d.software_obsoleto>0?'#ef4444':'#3fb950');
    html += '</div>';
    // By capa
    html += '<div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">';
    html += '<div style="background:var(--bg3);border:1px solid var(--border);border-radius:10px;padding:14px;"><div style="font-size:13px;font-weight:700;margin-bottom:10px;">'+t('cmdb.by_layer')+'</div>';
    Object.entries(d.by_capa).forEach(function(e){
      var pct = Math.round(e[1]/d.total_activos*100);
      var c = CAPA_COLORS[e[0]]||'#6b7280';
      html += '<div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;"><span style="font-size:11px;width:120px;color:'+c+';font-weight:600;">'+e[0]+'</span><div style="flex:1;height:8px;background:var(--bg4);border-radius:4px;overflow:hidden;"><div style="width:'+pct+'%;height:100%;background:'+c+';border-radius:4px;"></div></div><span style="font-size:11px;font-weight:700;width:30px;text-align:right;">'+e[1]+'</span></div>';
    });
    html += '</div>';
    html += '<div style="background:var(--bg3);border:1px solid var(--border);border-radius:10px;padding:14px;"><div style="font-size:13px;font-weight:700;margin-bottom:10px;">'+t('cmdb.by_criticality')+'</div>';
    ['CRITICA','ALTA','MEDIA','BAJA'].forEach(function(k){
      var v = d.by_criticidad[k]||0; var pct = Math.round(v/d.total_activos*100); var c = CRIT_COLORS[k];
      html += '<div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;"><span style="font-size:11px;width:80px;color:'+c+';font-weight:600;">'+k+'</span><div style="flex:1;height:8px;background:var(--bg4);border-radius:4px;overflow:hidden;"><div style="width:'+pct+'%;height:100%;background:'+c+';border-radius:4px;"></div></div><span style="font-size:11px;font-weight:700;width:30px;text-align:right;">'+v+'</span></div>';
    });
    html += '</div></div>';
    // Inventario below dashboard
    html += '<div style="margin-top:16px;" id="cmdb-dash-inv">'+t('common.loading')+'</div>';
    el.innerHTML = html;
    // Load inventory table below
    var invData = await authFetch(API_BASE+'/cmdb/activos?limit=300').then(function(r){return r.json();});
    _cmdbActivos = invData.activos||[];
    var invEl = document.getElementById('cmdb-dash-inv');
    if (invEl) {
      var ih = '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;flex-wrap:wrap;gap:6px;">';
      ih += '<div style="font-size:13px;font-weight:700;">'+t('cmdb.full_inventory')+' ('+invData.total+' '+t('misc.assets')+')</div>';
      ih += '<div style="display:flex;gap:3px;flex-wrap:wrap;">';
      ['TODOS','INFRAESTRUCTURA','APLICACION','RED','SEGURIDAD','NEGOCIO','SOPORTE'].forEach(function(c){
        ih += '<button onclick="cmdbFilterCapa(\''+c+'\')" style="padding:2px 8px;border-radius:4px;font-size:9px;font-weight:700;cursor:pointer;background:'+(CAPA_COLORS[c]||'var(--bg3)')+'18;border:1px solid '+(CAPA_COLORS[c]||'var(--border)')+'33;color:'+(CAPA_COLORS[c]||'var(--text2)')+';">'+c+'</button>';
      });
      ih += '</div></div>';
      ih += '<div id="cmdb-inv-table">' + _renderCmdbTable(_cmdbActivos) + '</div>';
      invEl.innerHTML = ih;
    }
  } catch(e) { el.innerHTML = '<div style="color:var(--red);">Error: '+escHtml(e.message)+'</div>'; }
}

function _cmdbKpi(label, val, color) {
  return '<div style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:12px;"><div style="font-size:10px;color:var(--text3);text-transform:uppercase;font-weight:600;">'+label+'</div><div style="font-size:20px;font-weight:800;color:'+color+';">'+val+'</div></div>';
}

async function loadCmdbInventario() {
  var el = document.getElementById('cmdb-inv');
  try {
    var data = await authFetch(API_BASE+'/cmdb/activos?limit=300').then(function(r){return r.json();});
    var activos = data.activos||[];
    var html = '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;flex-wrap:wrap;gap:8px;">';
    html += '<div style="font-size:14px;font-weight:700;">Inventario de Configuration Items ('+data.total+')</div>';
    html += '<div style="display:flex;gap:4px;flex-wrap:wrap;">';
    ['TODOS','INFRAESTRUCTURA','APLICACION','RED','SEGURIDAD','NEGOCIO','SOPORTE'].forEach(function(c){
      html += '<button onclick="cmdbFilterCapa(\''+c+'\')" class="filter-chip" data-capa="'+c+'" style="font-size:10px;padding:3px 10px;">'+c+'</button>';
    });
    html += '</div></div>';
    html += '<div style="overflow-x:auto;max-height:calc(100vh - 200px);overflow-y:auto;" id="cmdb-inv-table">';
    html += _renderCmdbTable(activos);
    html += '</div>';
    el.innerHTML = html;
    // Store for filtering
    window._cmdbActivos = activos;
  } catch(e) { el.innerHTML = '<div style="color:var(--red);">Error: '+escHtml(e.message)+'</div>'; }
}

function _renderCmdbTable(activos) {
  var html = '<table class="data-table" style="width:100%;font-size:11px;"><thead><tr>';
  html += '<th>'+t('cmdb.code')+'</th><th>'+t('common.name')+'</th><th>'+t('cmdb.layer')+'</th><th>'+t('common.type')+'</th><th>'+t('common.status')+'</th><th>'+t('cmdb.criticality')+'</th><th>'+t('cmdb.environment')+'</th><th>'+t('cmdb.location')+'</th><th>'+t('cmdb.project')+'</th><th>€/'+t('misc.of')+'</th>';
  html += '</tr></thead><tbody>';
  activos.forEach(function(a){
    var cc = CRIT_COLORS[a.criticidad]||'#6b7280';
    var ec = ESTADO_COLORS[a.estado_ciclo]||'#6b7280';
    var lc = CAPA_COLORS[a.capa]||'#6b7280';
    html += '<tr onclick="cmdbShowDetalle('+a.id_activo+')" style="cursor:pointer;" onmouseenter="this.style.background=\'rgba(45,126,247,.06)\'" onmouseleave="this.style.background=\'\'">';
    html += '<td style="font-family:var(--mono);font-weight:600;color:var(--cyan);white-space:nowrap;">'+escHtml(a.codigo)+'</td>';
    html += '<td style="font-weight:600;max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">'+escHtml(a.nombre)+'</td>';
    html += '<td><span style="padding:1px 6px;border-radius:3px;font-size:9px;font-weight:700;background:'+lc+'18;color:'+lc+';">'+escHtml(a.capa)+'</span></td>';
    html += '<td style="font-size:10px;">'+escHtml(a.tipo)+'</td>';
    html += '<td><span style="padding:1px 6px;border-radius:3px;font-size:9px;font-weight:700;background:'+ec+'18;color:'+ec+';">'+escHtml(a.estado_ciclo)+'</span></td>';
    html += '<td><span style="padding:1px 6px;border-radius:3px;font-size:9px;font-weight:700;background:'+cc+'18;color:'+cc+';">'+escHtml(a.criticidad)+'</span></td>';
    html += '<td style="font-size:10px;">'+escHtml(a.entorno)+'</td>';
    html += '<td style="font-size:10px;">'+escHtml(a.ubicacion||'-')+'</td>';
    html += '<td style="font-size:9px;font-family:var(--mono);color:var(--text3);max-width:80px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">'+escHtml(a.id_proyecto||'-')+'</td>';
    html += '<td style="font-family:var(--mono);font-size:10px;">€'+Math.round(a.coste_mensual||0)+'</td>';
    html += '</tr>';
  });
  html += '</tbody></table>';
  return html;
}

function cmdbFilterCapa(capa) {
  if (!window._cmdbActivos) return;
  var filtered = capa==='TODOS' ? window._cmdbActivos : window._cmdbActivos.filter(function(a){return a.capa===capa;});
  document.getElementById('cmdb-inv-table').innerHTML = _renderCmdbTable(filtered);
}

async function cmdbShowDetalle(id) {
  try {
    var d = await authFetch(API_BASE+'/cmdb/activos/'+id).then(function(r){return r.json();});
    var a = d.activo;
    var html = '<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;font-size:12px;">';
    html += '<div><strong>Código:</strong> <span style="font-family:var(--mono);color:var(--cyan);">'+escHtml(a.codigo)+'</span></div>';
    html += '<div><strong>Capa:</strong> <span style="color:'+(CAPA_COLORS[a.capa]||'')+';">'+escHtml(a.capa)+'</span></div>';
    html += '<div><strong>Tipo:</strong> '+escHtml(a.tipo)+'</div>';
    html += '<div><strong>Criticidad:</strong> <span style="color:'+(CRIT_COLORS[a.criticidad]||'')+';font-weight:700;">'+escHtml(a.criticidad)+'</span></div>';
    html += '<div><strong>Estado:</strong> <span style="color:'+(ESTADO_COLORS[a.estado_ciclo]||'')+';font-weight:700;">'+escHtml(a.estado_ciclo)+'</span></div>';
    html += '<div><strong>Entorno:</strong> '+escHtml(a.entorno)+'</div>';
    html += '<div><strong>Ubicación:</strong> '+escHtml(a.ubicacion||'-')+'</div>';
    html += '<div><strong>Propietario:</strong> '+escHtml(a.propietario||'-')+'</div>';
    html += '<div><strong>Responsable:</strong> '+escHtml(a.responsable_tecnico||'-')+'</div>';
    html += '<div><strong>Proveedor:</strong> '+escHtml(a.proveedor||'-')+'</div>';
    html += '<div><strong>Coste/mes:</strong> €'+Math.round(a.coste_mensual||0)+'</div>';
    html += '<div><strong>Proyecto:</strong> '+escHtml(a.id_proyecto||'Sin asignar')+'</div>';
    html += '</div>';
    if (a.especificaciones && Object.keys(a.especificaciones).length) {
      html += '<div style="margin-top:12px;"><strong>Especificaciones:</strong><div style="background:var(--bg3);border:1px solid var(--border);border-radius:6px;padding:8px;margin-top:4px;font-family:var(--mono);font-size:11px;max-height:120px;overflow-y:auto;">';
      Object.entries(a.especificaciones).forEach(function(e){
        html += '<div><span style="color:var(--cyan);">'+escHtml(e[0])+'</span>: '+escHtml(String(e[1]))+'</div>';
      });
      html += '</div></div>';
    }
    // Dependencias
    if (d.dependencias.length) {
      html += '<div style="margin-top:12px;"><strong>Dependencias ('+d.dependencias.length+'):</strong><div style="display:flex;flex-wrap:wrap;gap:4px;margin-top:4px;">';
      d.dependencias.forEach(function(dep){
        var isOrigen = dep.origen_codigo===a.codigo;
        var other = isOrigen ? dep.destino_nombre+' ('+dep.destino_codigo+')' : dep.origen_nombre+' ('+dep.origen_codigo+')';
        var arrow = isOrigen ? '→' : '←';
        var c = CRIT_COLORS[dep.criticidad]||'#6b7280';
        html += '<span style="padding:3px 8px;border-radius:4px;font-size:10px;background:'+c+'15;border:1px solid '+c+'25;color:'+c+';">'+escHtml(dep.tipo_relacion)+' '+arrow+' '+escHtml(other)+'</span>';
      });
      html += '</div></div>';
    }
    // IPs
    if (d.ips.length) {
      html += '<div style="margin-top:12px;"><strong>IPs Asignadas:</strong><div style="display:flex;flex-wrap:wrap;gap:4px;margin-top:4px;">';
      d.ips.forEach(function(ip){
        html += '<span style="padding:3px 8px;border-radius:4px;font-size:10px;background:var(--cyan)15;border:1px solid var(--cyan)25;color:var(--cyan);font-family:var(--mono);">'+escHtml(ip.direccion_ip)+(ip.vlan_nombre?' (VLAN: '+escHtml(ip.vlan_nombre)+')':'')+'</span>';
      });
      html += '</div></div>';
    }
    // Software
    if (d.software.length) {
      html += '<div style="margin-top:12px;"><strong>Software Instalado:</strong><div style="display:flex;flex-wrap:wrap;gap:4px;margin-top:4px;">';
      d.software.forEach(function(sw){
        html += '<span style="padding:3px 8px;border-radius:4px;font-size:10px;background:var(--purple-bg);border:1px solid rgba(168,85,247,.2);color:#a855f7;">'+escHtml(sw.nombre)+' '+escHtml(sw.version_instalada||sw.version||'')+'</span>';
      });
      html += '</div></div>';
    }
    // Action buttons
    html += '<div style="display:flex;gap:8px;margin-top:14px;flex-wrap:wrap;">';
    html += '<button onclick="cmdbShowImpacto('+id+')" style="background:linear-gradient(135deg,#ef4444,#dc2626);border:none;color:#fff;border-radius:6px;padding:8px 16px;font-size:12px;font-weight:700;cursor:pointer;">Simulación de Impacto</button>';
    html += '<button onclick="document.getElementById(\'simple-modal-overlay\').remove();showEditActivo('+id+')" style="background:linear-gradient(135deg,#2563eb,#3b82f6);border:none;color:#fff;border-radius:6px;padding:8px 16px;font-size:12px;font-weight:700;cursor:pointer;">Editar Activo</button>';
    html += '<button onclick="doDeleteActivo('+id+',\''+escHtml(a.codigo)+'\')" style="background:var(--red-bg);border:1px solid rgba(248,81,73,.2);color:var(--red);border-radius:6px;padding:8px 16px;font-size:12px;font-weight:600;cursor:pointer;">Retirar</button>';
    html += '</div>';
    showSimpleModal(a.nombre, html);
  } catch(e) { alert('Error: '+e.message); }
}

async function cmdbShowImpacto(id) {
  try {
    var d = await authFetch(API_BASE+'/cmdb/impacto/'+id).then(function(r){return r.json();});
    var html = '<div style="margin-bottom:12px;padding:10px;background:var(--red-bg);border:1px solid rgba(248,81,73,.2);border-radius:8px;">';
    html += '<div style="font-weight:700;color:var(--red);">Si "'+escHtml(d.origen.nombre)+'" falla → '+d.total_afectados+' activos afectados</div></div>';
    if (d.impacto.length) {
      html += '<div style="max-height:40vh;overflow-y:auto;">';
      d.impacto.forEach(function(a){
        var c = CRIT_COLORS[a.criticidad]||'#6b7280';
        html += '<div style="display:flex;align-items:center;gap:8px;padding:6px 10px;margin-bottom:4px;background:var(--bg3);border-radius:6px;border-left:3px solid '+c+';">';
        html += '<span style="font-family:var(--mono);font-size:10px;color:var(--cyan);width:100px;">'+escHtml(a.codigo)+'</span>';
        html += '<span style="flex:1;font-size:12px;font-weight:600;">'+escHtml(a.nombre)+'</span>';
        html += '<span style="padding:1px 6px;border-radius:3px;font-size:9px;font-weight:700;background:'+c+'18;color:'+c+';">'+escHtml(a.criticidad)+'</span>';
        html += '<span style="font-size:10px;color:var(--text3);">Nivel '+a.depth+'</span>';
        html += '</div>';
      });
      html += '</div>';
    } else {
      html += '<div style="text-align:center;color:var(--text3);padding:20px;">Ningún activo depende directamente de este CI</div>';
    }
    showSimpleModal('Impacto en Cascada', html);
  } catch(e) { alert('Error: '+e.message); }
}

async function loadCmdbDependencias() {
  var el = document.getElementById('cmdb-deps');
  try {
    var rels = await authFetch(API_BASE+'/cmdb/relaciones').then(function(r){return r.json();});
    var html = '<div style="font-size:14px;font-weight:700;margin-bottom:12px;">Mapa de Dependencias — Diagrama ('+rels.length+' relaciones)</div>';
    var relColors = {DEPENDE_DE:'#ef4444',EJECUTA_EN:'#3b82f6',CONECTA_A:'#10b981',PROTEGE_A:'#8b5cf6',RESPALDA_A:'#f59e0b',MONITORIZA:'#39c5cf',PARTE_DE:'#6366f1',SIRVE_A:'#f778ba'};
    // Leyenda
    html += '<div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:14px;">';
    Object.entries(relColors).forEach(function(e){
      html += '<span style="display:flex;align-items:center;gap:4px;font-size:10px;"><span style="width:14px;height:3px;background:'+e[1]+';border-radius:2px;display:inline-block;"></span><span style="color:'+e[1]+';font-weight:600;">'+e[0].replace(/_/g,' ')+'</span></span>';
    });
    html += '</div>';
    // Diagram: group by destination (what things depend on)
    var byDest = {};
    rels.forEach(function(r) {
      var key = r.destino_codigo;
      if (!byDest[key]) byDest[key] = {nombre:r.destino_nombre,capa:r.destino_capa,deps:[]};
      byDest[key].deps.push(r);
    });
    // Sort by number of dependents (most depended-on first)
    var sorted = Object.entries(byDest).sort(function(a,b){return b[1].deps.length - a[1].deps.length;});
    html += '<div style="max-height:calc(100vh - 240px);overflow-y:auto;">';
    sorted.forEach(function(entry) {
      var code = entry[0], info = entry[1];
      var lc = CAPA_COLORS[info.capa]||'#6b7280';
      html += '<div style="margin-bottom:16px;background:var(--bg3);border:1px solid var(--border);border-radius:10px;padding:14px;">';
      // Center node
      html += '<div style="display:flex;align-items:center;justify-content:center;margin-bottom:12px;">';
      html += '<div style="padding:8px 20px;background:'+lc+'18;border:2px solid '+lc+';border-radius:10px;text-align:center;">';
      html += '<div style="font-size:13px;font-weight:800;color:'+lc+';">'+escHtml(code)+'</div>';
      html += '<div style="font-size:10px;color:var(--text2);max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">'+escHtml(info.nombre)+'</div>';
      html += '</div></div>';
      // Dependents radiating out
      html += '<div style="display:flex;flex-wrap:wrap;gap:6px;justify-content:center;">';
      info.deps.forEach(function(r) {
        var rc = relColors[r.tipo_relacion]||'#6b7280';
        var olc = CAPA_COLORS[r.origen_capa]||'#6b7280';
        html += '<div style="display:flex;align-items:center;gap:4px;">';
        html += '<div style="padding:4px 10px;border-radius:6px;background:'+olc+'12;border:1px solid '+olc+'30;text-align:center;">';
        html += '<div style="font-size:10px;font-weight:700;color:'+olc+';">'+escHtml(r.origen_codigo)+'</div>';
        html += '</div>';
        html += '<div style="width:30px;height:2px;background:'+rc+';position:relative;"><div style="position:absolute;right:-2px;top:-3px;width:0;height:0;border-left:6px solid '+rc+';border-top:4px solid transparent;border-bottom:4px solid transparent;"></div></div>';
        html += '</div>';
      });
      html += '</div></div>';
    });
    html += '</div>';
    el.innerHTML = html;
  } catch(e) { el.innerHTML = '<div style="color:var(--red);">Error: '+escHtml(e.message)+'</div>'; }
}

async function loadCmdbVlans() {
  var el = document.getElementById('cmdb-vlans');
  try {
    var vlans = await authFetch(API_BASE+'/cmdb/vlans').then(function(r){return r.json();});
    var html = '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">';
    html += '<div style="font-size:14px;font-weight:700;">VLANs ('+vlans.length+')</div>';
    html += '<button onclick="showCreateVlan()" style="background:linear-gradient(135deg,#10b981,#059669);border:none;color:#fff;border-radius:6px;padding:8px 16px;font-size:12px;font-weight:700;cursor:pointer;">+ Nueva VLAN</button>';
    html += '</div>';
    html += '<table class="data-table" style="width:100%;font-size:11px;"><thead><tr>';
    html += '<th>VLAN ID</th><th>Nombre</th><th>Subred</th><th>Gateway</th><th>Entorno</th><th>Ubicación</th><th>Propósito</th><th>IPs Total</th><th>IPs Usadas</th></tr></thead><tbody>';
    vlans.forEach(function(v){
      var pct = v.total_ips>0 ? Math.round((v.ips_asignadas||0)/v.total_ips*100) : 0;
      var uc = pct>80?'#ef4444':pct>50?'#f59e0b':'#3fb950';
      html += '<tr onclick="showVlanDetail('+v.id_vlan+')" style="cursor:pointer;" onmouseenter="this.style.background=\'rgba(45,126,247,.06)\'" onmouseleave="this.style.background=\'\'">';
      html += '<td style="font-family:var(--mono);font-weight:700;color:#39c5cf;">'+v.vlan_id+'</td>';
      html += '<td style="font-weight:600;">'+escHtml(v.nombre)+'</td>';
      html += '<td style="font-family:var(--mono);font-size:10px;">'+escHtml(v.subred)+'</td>';
      html += '<td style="font-family:var(--mono);font-size:10px;">'+escHtml(v.gateway||'-')+'</td>';
      html += '<td>'+escHtml(v.entorno)+'</td>';
      html += '<td style="font-size:10px;">'+escHtml(v.ubicacion||'-')+'</td>';
      html += '<td style="font-size:10px;">'+escHtml(v.proposito||'-')+'</td>';
      html += '<td>'+v.total_ips+'</td>';
      html += '<td><span style="color:'+uc+';font-weight:700;">'+(v.ips_asignadas||0)+'</span> <span style="font-size:9px;color:var(--text3);">('+pct+'%)</span></td>';
      html += '</tr>';
    });
    html += '</tbody></table>';
    el.innerHTML = html;
    window._cmdbVlans = vlans;
  } catch(e) { el.innerHTML = '<div style="color:var(--red);">Error: '+escHtml(e.message)+'</div>'; }
}

function showCreateVlan() {
  var html = '<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;font-size:13px;">';
  html += '<div class="login-field"><label>VLAN ID *</label><input type="number" id="cv-vlan-id" placeholder="100"></div>';
  html += '<div class="login-field"><label>Nombre *</label><input type="text" id="cv-nombre" placeholder="VLAN nombre"></div>';
  html += '<div class="login-field"><label>Subred *</label><input type="text" id="cv-subred" placeholder="10.0.100.0/24"></div>';
  html += '<div class="login-field"><label>Gateway</label><input type="text" id="cv-gateway" placeholder="10.0.100.1"></div>';
  html += '<div class="login-field"><label>Entorno</label><select id="cv-entorno" style="width:100%;padding:8px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:6px;"><option>PRODUCCION</option><option>PREPRODUCCION</option><option>DESARROLLO</option><option>STAGING</option><option>DR</option><option>LAB</option></select></div>';
  html += '<div class="login-field"><label>Ubicación</label><input type="text" id="cv-ubic" placeholder="CPD Madrid"></div>';
  html += '<div class="login-field"><label>Propósito</label><input type="text" id="cv-proposito" placeholder="Servidores producción"></div>';
  html += '<div class="login-field"><label>Total IPs</label><input type="number" id="cv-total-ips" value="254"></div>';
  html += '</div>';
  html += '<div style="display:flex;gap:8px;margin-top:14px;justify-content:flex-end;">';
  html += '<button onclick="document.getElementById(\'simple-modal-overlay\').remove()" style="background:var(--bg3);border:1px solid var(--border);color:var(--text2);border-radius:6px;padding:8px 20px;font-size:13px;cursor:pointer;">Cancelar</button>';
  html += '<button onclick="doCreateVlan()" style="background:linear-gradient(135deg,#10b981,#059669);border:none;color:#fff;border-radius:6px;padding:8px 20px;font-size:13px;font-weight:700;cursor:pointer;">Crear VLAN</button>';
  html += '</div>';
  showSimpleModal('Nueva VLAN', html);
}

async function doCreateVlan() {
  var body = {
    vlan_id: parseInt(document.getElementById('cv-vlan-id').value)||0,
    nombre: document.getElementById('cv-nombre').value.trim(),
    subred: document.getElementById('cv-subred').value.trim(),
    gateway: document.getElementById('cv-gateway').value.trim()||null,
    entorno: document.getElementById('cv-entorno').value,
    ubicacion: document.getElementById('cv-ubic').value.trim()||null,
    proposito: document.getElementById('cv-proposito').value.trim()||null,
    total_ips: parseInt(document.getElementById('cv-total-ips').value)||254,
  };
  if (!body.vlan_id||!body.nombre||!body.subred) { alert('VLAN ID, Nombre y Subred son obligatorios'); return; }
  try {
    var r = await authFetch(API_BASE+'/cmdb/vlans',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
    var d = await r.json();
    if (!r.ok) { alert('Error: '+(d.detail||'Error')); return; }
    document.getElementById('simple-modal-overlay').remove();
    showToast('VLAN '+body.vlan_id+' creada');
    loadCmdbVlans();
  } catch(e) { alert('Error: '+e.message); }
}

function showVlanDetail(idVlan) {
  var v = (window._cmdbVlans||[]).find(function(x){return x.id_vlan===idVlan;});
  if (!v) return;
  var pct = v.total_ips>0 ? Math.round((v.ips_asignadas||0)/v.total_ips*100) : 0;
  var html = '<div style="font-size:13px;line-height:2;">';
  html += '<div><strong>VLAN ID:</strong> <span style="color:#39c5cf;font-family:var(--mono);font-weight:700;">'+v.vlan_id+'</span></div>';
  html += '<div><strong>Nombre:</strong> '+escHtml(v.nombre)+'</div>';
  html += '<div><strong>Subred:</strong> <span style="font-family:var(--mono);">'+escHtml(v.subred)+'</span></div>';
  html += '<div><strong>Gateway:</strong> <span style="font-family:var(--mono);">'+escHtml(v.gateway||'-')+'</span></div>';
  html += '<div><strong>Entorno:</strong> '+escHtml(v.entorno)+'</div>';
  html += '<div><strong>Ubicación:</strong> '+escHtml(v.ubicacion||'-')+'</div>';
  html += '<div><strong>Propósito:</strong> '+escHtml(v.proposito||'-')+'</div>';
  html += '<div><strong>IPs:</strong> '+(v.ips_asignadas||0)+' / '+v.total_ips+' ('+pct+'%)</div>';
  html += '</div>';
  html += '<div style="display:flex;gap:8px;margin-top:14px;justify-content:space-between;">';
  html += '<button onclick="doDeleteVlan('+v.id_vlan+',\''+escHtml(v.nombre)+'\')" style="background:var(--red-bg);border:1px solid rgba(248,81,73,.2);color:var(--red);border-radius:6px;padding:8px 14px;font-size:12px;font-weight:600;cursor:pointer;">Eliminar</button>';
  html += '<div style="display:flex;gap:8px;">';
  html += '<button onclick="document.getElementById(\'simple-modal-overlay\').remove()" style="background:var(--bg3);border:1px solid var(--border);color:var(--text2);border-radius:6px;padding:8px 20px;font-size:13px;cursor:pointer;">Cerrar</button>';
  html += '<button onclick="showEditVlan('+v.id_vlan+')" style="background:linear-gradient(135deg,#2563eb,#3b82f6);border:none;color:#fff;border-radius:6px;padding:8px 20px;font-size:13px;font-weight:700;cursor:pointer;">Editar</button>';
  html += '</div></div>';
  showSimpleModal('VLAN '+v.vlan_id+' — '+escHtml(v.nombre), html);
}

function showEditVlan(idVlan) {
  var v = (window._cmdbVlans||[]).find(function(x){return x.id_vlan===idVlan;});
  if (!v) return;
  var mkSel = function(id,opts,val) {
    return '<select id="'+id+'" style="width:100%;padding:8px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:6px;">'+opts.map(function(o){return '<option'+(o===val?' selected':'')+'>'+o+'</option>';}).join('')+'</select>';
  };
  var html = '<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;font-size:13px;">';
  html += '<div class="login-field"><label>VLAN ID</label><input type="number" id="ev-vlan-id" value="'+v.vlan_id+'"></div>';
  html += '<div class="login-field"><label>Nombre</label><input type="text" id="ev-nombre" value="'+escHtml(v.nombre||'')+'"></div>';
  html += '<div class="login-field"><label>Subred</label><input type="text" id="ev-subred" value="'+escHtml(v.subred||'')+'"></div>';
  html += '<div class="login-field"><label>Gateway</label><input type="text" id="ev-gateway" value="'+escHtml(v.gateway||'')+'"></div>';
  html += '<div class="login-field"><label>Entorno</label>'+mkSel('ev-entorno',['PRODUCCION','PREPRODUCCION','DESARROLLO','STAGING','DR','LAB'],v.entorno)+'</div>';
  html += '<div class="login-field"><label>Ubicación</label><input type="text" id="ev-ubic" value="'+escHtml(v.ubicacion||'')+'"></div>';
  html += '<div class="login-field"><label>Propósito</label><input type="text" id="ev-proposito" value="'+escHtml(v.proposito||'')+'"></div>';
  html += '<div class="login-field"><label>Total IPs</label><input type="number" id="ev-total-ips" value="'+(v.total_ips||254)+'"></div>';
  html += '</div>';
  html += '<div style="display:flex;gap:8px;margin-top:14px;justify-content:flex-end;">';
  html += '<button onclick="document.getElementById(\'simple-modal-overlay\').remove()" style="background:var(--bg3);border:1px solid var(--border);color:var(--text2);border-radius:6px;padding:8px 20px;font-size:13px;cursor:pointer;">Cancelar</button>';
  html += '<button onclick="doEditVlan('+v.id_vlan+')" style="background:linear-gradient(135deg,#2563eb,#3b82f6);border:none;color:#fff;border-radius:6px;padding:8px 20px;font-size:13px;font-weight:700;cursor:pointer;">Guardar</button>';
  html += '</div>';
  showSimpleModal('Editar VLAN '+v.vlan_id, html);
}

async function doEditVlan(idVlan) {
  var body = {
    vlan_id: parseInt(document.getElementById('ev-vlan-id').value)||0,
    nombre: document.getElementById('ev-nombre').value.trim(),
    subred: document.getElementById('ev-subred').value.trim(),
    gateway: document.getElementById('ev-gateway').value.trim()||null,
    entorno: document.getElementById('ev-entorno').value,
    ubicacion: document.getElementById('ev-ubic').value.trim()||null,
    proposito: document.getElementById('ev-proposito').value.trim()||null,
    total_ips: parseInt(document.getElementById('ev-total-ips').value)||254,
  };
  try {
    var r = await authFetch(API_BASE+'/cmdb/vlans/'+idVlan,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
    if (!r.ok) { var d = await r.json(); alert('Error: '+(d.detail||'Error')); return; }
    document.getElementById('simple-modal-overlay').remove();
    showToast('VLAN actualizada');
    loadCmdbVlans();
  } catch(e) { alert('Error: '+e.message); }
}

async function doDeleteVlan(idVlan, nombre) {
  if (!confirm('¿Eliminar la VLAN "'+nombre+'"? Se eliminarán también las IPs asociadas.')) return;
  try {
    var r = await authFetch(API_BASE+'/cmdb/vlans/'+idVlan,{method:'DELETE'});
    if (!r.ok) { var d = await r.json(); alert('Error: '+(d.detail||'Error')); return; }
    document.getElementById('simple-modal-overlay').remove();
    showToast('VLAN '+nombre+' eliminada');
    loadCmdbVlans();
  } catch(e) { alert('Error: '+e.message); }
}

async function loadCmdbIps() {
  var el = document.getElementById('cmdb-ips');
  try {
    var data = await authFetch(API_BASE+'/cmdb/ips?limit=300').then(function(r){return r.json();});
    var ips = data.ips||[];
    var html = '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">';
    html += '<div style="font-size:14px;font-weight:700;">Registro de IPs ('+data.total+')</div>';
    html += '<button onclick="showCreateIp()" style="background:linear-gradient(135deg,#39c5cf,#0891b2);border:none;color:#fff;border-radius:6px;padding:8px 16px;font-size:12px;font-weight:700;cursor:pointer;">+ Nueva IP</button>';
    html += '</div>';
    if (ips.length===0) {
      html += '<div style="text-align:center;padding:40px;color:var(--text3);">No hay IPs registradas.</div>';
    } else {
      html += '<table class="data-table" style="width:100%;font-size:11px;"><thead><tr>';
      html += '<th>IP</th><th>Hostname</th><th>VLAN</th><th>Activo</th><th>Tipo</th><th>Estado</th><th>MAC</th></tr></thead><tbody>';
      ips.forEach(function(ip){
        html += '<tr onclick="showIpDetail('+ip.id_ip+')" style="cursor:pointer;" onmouseenter="this.style.background=\'rgba(45,126,247,.06)\'" onmouseleave="this.style.background=\'\'">';
        html += '<td style="font-family:var(--mono);font-weight:600;color:var(--cyan);">'+escHtml(ip.direccion_ip)+'</td>';
        html += '<td>'+escHtml(ip.hostname||'-')+'</td>';
        html += '<td>'+(ip.vlan_nombre?escHtml(ip.vlan_nombre)+' ('+ip.vlan_num+')':'-')+'</td>';
        html += '<td>'+(ip.activo_nombre?escHtml(ip.activo_codigo)+' - '+escHtml(ip.activo_nombre):'-')+'</td>';
        html += '<td>'+escHtml(ip.tipo)+'</td><td>'+escHtml(ip.estado)+'</td>';
        html += '<td style="font-family:var(--mono);font-size:10px;">'+escHtml(ip.mac_address||'-')+'</td></tr>';
      });
      html += '</tbody></table>';
    }
    el.innerHTML = html;
    window._cmdbIps = ips;
  } catch(e) { el.innerHTML = '<div style="color:var(--red);">Error: '+escHtml(e.message)+'</div>'; }
}

async function loadCmdbSelectById(selectId, currentVal) {
  var sel = document.getElementById(selectId);
  if (!sel || sel.options.length > 2) return;
  try {
    var data = await authFetch(API_BASE+'/cmdb/activos?limit=500').then(function(r){return r.json();});
    var activos = data.activos||[];
    sel.innerHTML = '<option value="">-- Sin activo --</option>';
    activos.forEach(function(a) {
      var opt = document.createElement('option');
      opt.value = a.id_activo;
      opt.textContent = a.codigo + ' — ' + a.nombre;
      if (currentVal && a.id_activo == currentVal) opt.selected = true;
      sel.appendChild(opt);
    });
  } catch(e) { console.warn('Error loading CMDB select by ID:', e); }
}

async function loadVlanSelect(selectId, currentVal) {
  var sel = document.getElementById(selectId);
  if (!sel || sel.options.length > 2) return;
  try {
    var vlans = await authFetch(API_BASE+'/cmdb/vlans').then(function(r){return r.json();});
    sel.innerHTML = '<option value="">-- Sin VLAN --</option>';
    vlans.forEach(function(v) {
      var opt = document.createElement('option');
      opt.value = v.id_vlan;
      opt.textContent = 'VLAN ' + v.vlan_id + ' — ' + v.nombre + ' (' + v.subred + ')';
      if (currentVal && v.id_vlan == currentVal) opt.selected = true;
      sel.appendChild(opt);
    });
  } catch(e) { console.warn('Error loading VLAN select:', e); }
}

function showCreateIp() {
  var html = '<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;font-size:13px;">';
  html += '<div class="login-field"><label>Dirección IP *</label><input type="text" id="ci-ip" placeholder="10.0.100.10"></div>';
  html += '<div class="login-field"><label>Hostname</label><input type="text" id="ci-hostname" placeholder="srv-prod-01"></div>';
  html += '<div class="login-field"><label>VLAN</label><select id="ci-vlan" style="width:100%;padding:8px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:6px;" onfocus="loadVlanSelect(\'ci-vlan\')"><option value="">-- Sin VLAN --</option></select></div>';
  html += '<div class="login-field"><label>Activo CMDB</label><select id="ci-activo" style="width:100%;padding:8px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:6px;" onfocus="loadCmdbSelectById(\'ci-activo\')"><option value="">-- Sin activo --</option></select></div>';
  html += '<div class="login-field"><label>Tipo</label><select id="ci-tipo" style="width:100%;padding:8px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:6px;"><option>ESTATICA</option><option>DHCP</option><option>RESERVADA</option><option>VIRTUAL</option></select></div>';
  html += '<div class="login-field"><label>Estado</label><select id="ci-estado" style="width:100%;padding:8px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:6px;"><option>ASIGNADA</option><option>DISPONIBLE</option><option>RESERVADA</option><option>CONFLICTO</option></select></div>';
  html += '<div class="login-field"><label>MAC Address</label><input type="text" id="ci-mac" placeholder="AA:BB:CC:DD:EE:FF"></div>';
  html += '<div class="login-field"><label>Notas</label><input type="text" id="ci-notas" placeholder="Notas..."></div>';
  html += '</div>';
  html += '<div style="display:flex;gap:8px;margin-top:14px;justify-content:flex-end;">';
  html += '<button onclick="document.getElementById(\'simple-modal-overlay\').remove()" style="background:var(--bg3);border:1px solid var(--border);color:var(--text2);border-radius:6px;padding:8px 20px;font-size:13px;cursor:pointer;">Cancelar</button>';
  html += '<button onclick="doCreateIp()" style="background:linear-gradient(135deg,#39c5cf,#0891b2);border:none;color:#fff;border-radius:6px;padding:8px 20px;font-size:13px;font-weight:700;cursor:pointer;">Crear IP</button>';
  html += '</div>';
  showSimpleModal('Nueva IP', html);
}

async function doCreateIp() {
  var body = {
    direccion_ip: document.getElementById('ci-ip').value.trim(),
    hostname: document.getElementById('ci-hostname').value.trim()||null,
    id_vlan: parseInt(document.getElementById('ci-vlan').value)||null,
    id_activo: parseInt(document.getElementById('ci-activo').value)||null,
    tipo: document.getElementById('ci-tipo').value,
    estado: document.getElementById('ci-estado').value,
    mac_address: document.getElementById('ci-mac').value.trim()||null,
    notas: document.getElementById('ci-notas').value.trim()||null,
  };
  if (!body.direccion_ip) { alert('Dirección IP es obligatoria'); return; }
  try {
    var r = await authFetch(API_BASE+'/cmdb/ips',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
    var d = await r.json();
    if (!r.ok) { alert('Error: '+(d.detail||'Error')); return; }
    document.getElementById('simple-modal-overlay').remove();
    showToast('IP '+body.direccion_ip+' creada');
    loadCmdbIps();
  } catch(e) { alert('Error: '+e.message); }
}

function showIpDetail(idIp) {
  var ip = (window._cmdbIps||[]).find(function(x){return x.id_ip===idIp;});
  if (!ip) return;
  var html = '<div style="font-size:13px;line-height:2;">';
  html += '<div><strong>IP:</strong> <span style="color:var(--cyan);font-family:var(--mono);font-weight:700;">'+escHtml(ip.direccion_ip)+'</span></div>';
  html += '<div><strong>Hostname:</strong> '+escHtml(ip.hostname||'-')+'</div>';
  html += '<div><strong>VLAN:</strong> '+(ip.vlan_nombre?escHtml(ip.vlan_nombre)+' ('+ip.vlan_num+')':'-')+'</div>';
  html += '<div><strong>Activo:</strong> '+(ip.activo_nombre?escHtml(ip.activo_codigo)+' - '+escHtml(ip.activo_nombre):'-')+'</div>';
  html += '<div><strong>Tipo:</strong> '+escHtml(ip.tipo)+'</div>';
  html += '<div><strong>Estado:</strong> '+escHtml(ip.estado)+'</div>';
  html += '<div><strong>MAC:</strong> <span style="font-family:var(--mono);">'+escHtml(ip.mac_address||'-')+'</span></div>';
  html += '<div><strong>Notas:</strong> '+escHtml(ip.notas||'-')+'</div>';
  html += '</div>';
  html += '<div style="display:flex;gap:8px;margin-top:14px;justify-content:space-between;">';
  html += '<button onclick="doDeleteIp('+ip.id_ip+',\''+escHtml(ip.direccion_ip)+'\')" style="background:var(--red-bg);border:1px solid rgba(248,81,73,.2);color:var(--red);border-radius:6px;padding:8px 14px;font-size:12px;font-weight:600;cursor:pointer;">Eliminar</button>';
  html += '<div style="display:flex;gap:8px;">';
  html += '<button onclick="document.getElementById(\'simple-modal-overlay\').remove()" style="background:var(--bg3);border:1px solid var(--border);color:var(--text2);border-radius:6px;padding:8px 20px;font-size:13px;cursor:pointer;">Cerrar</button>';
  html += '<button onclick="showEditIp('+ip.id_ip+')" style="background:linear-gradient(135deg,#2563eb,#3b82f6);border:none;color:#fff;border-radius:6px;padding:8px 20px;font-size:13px;font-weight:700;cursor:pointer;">Editar</button>';
  html += '</div></div>';
  showSimpleModal('IP '+escHtml(ip.direccion_ip), html);
}

function showEditIp(idIp) {
  var ip = (window._cmdbIps||[]).find(function(x){return x.id_ip===idIp;});
  if (!ip) return;
  var mkSel = function(id,opts,val) {
    return '<select id="'+id+'" style="width:100%;padding:8px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:6px;">'+opts.map(function(o){return '<option'+(o===val?' selected':'')+'>'+o+'</option>';}).join('')+'</select>';
  };
  var html = '<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;font-size:13px;">';
  html += '<div class="login-field"><label>Dirección IP</label><input type="text" id="ei-ip" value="'+escHtml(ip.direccion_ip||'')+'"></div>';
  html += '<div class="login-field"><label>Hostname</label><input type="text" id="ei-hostname" value="'+escHtml(ip.hostname||'')+'"></div>';
  html += '<div class="login-field"><label>VLAN</label><select id="ei-vlan" style="width:100%;padding:8px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:6px;" onfocus="loadVlanSelect(\'ei-vlan\','+JSON.stringify(ip.id_vlan)+')"><option value="">-- Sin VLAN --</option>'+(ip.id_vlan?'<option value="'+ip.id_vlan+'" selected>'+(ip.vlan_nombre?escHtml(ip.vlan_nombre):'VLAN '+ip.id_vlan)+'</option>':'')+'</select></div>';
  html += '<div class="login-field"><label>Activo CMDB</label><select id="ei-activo" style="width:100%;padding:8px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:6px;" onfocus="loadCmdbSelectById(\'ei-activo\','+JSON.stringify(ip.id_activo)+')"><option value="">-- Sin activo --</option>'+(ip.id_activo?'<option value="'+ip.id_activo+'" selected>'+escHtml(ip.activo_codigo||'')+' — '+escHtml(ip.activo_nombre||'')+'</option>':'')+'</select></div>';
  html += '<div class="login-field"><label>Tipo</label>'+mkSel('ei-tipo',['ESTATICA','DHCP','RESERVADA','VIRTUAL'],ip.tipo)+'</div>';
  html += '<div class="login-field"><label>Estado</label>'+mkSel('ei-estado',['ASIGNADA','DISPONIBLE','RESERVADA','CONFLICTO'],ip.estado)+'</div>';
  html += '<div class="login-field"><label>MAC Address</label><input type="text" id="ei-mac" value="'+escHtml(ip.mac_address||'')+'"></div>';
  html += '<div class="login-field"><label>Notas</label><input type="text" id="ei-notas" value="'+escHtml(ip.notas||'')+'"></div>';
  html += '</div>';
  html += '<div style="display:flex;gap:8px;margin-top:14px;justify-content:flex-end;">';
  html += '<button onclick="document.getElementById(\'simple-modal-overlay\').remove()" style="background:var(--bg3);border:1px solid var(--border);color:var(--text2);border-radius:6px;padding:8px 20px;font-size:13px;cursor:pointer;">Cancelar</button>';
  html += '<button onclick="doEditIp('+ip.id_ip+')" style="background:linear-gradient(135deg,#2563eb,#3b82f6);border:none;color:#fff;border-radius:6px;padding:8px 20px;font-size:13px;font-weight:700;cursor:pointer;">Guardar</button>';
  html += '</div>';
  showSimpleModal('Editar IP '+escHtml(ip.direccion_ip), html);
}

async function doEditIp(idIp) {
  var body = {
    direccion_ip: document.getElementById('ei-ip').value.trim(),
    hostname: document.getElementById('ei-hostname').value.trim()||null,
    id_vlan: parseInt(document.getElementById('ei-vlan').value)||null,
    id_activo: parseInt(document.getElementById('ei-activo').value)||null,
    tipo: document.getElementById('ei-tipo').value,
    estado: document.getElementById('ei-estado').value,
    mac_address: document.getElementById('ei-mac').value.trim()||null,
    notas: document.getElementById('ei-notas').value.trim()||null,
  };
  try {
    var r = await authFetch(API_BASE+'/cmdb/ips/'+idIp,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
    if (!r.ok) { var d = await r.json(); alert('Error: '+(d.detail||'Error')); return; }
    document.getElementById('simple-modal-overlay').remove();
    showToast('IP actualizada');
    loadCmdbIps();
  } catch(e) { alert('Error: '+e.message); }
}

async function doDeleteIp(idIp, ipAddr) {
  if (!confirm('¿Eliminar la IP "'+ipAddr+'"?')) return;
  try {
    var r = await authFetch(API_BASE+'/cmdb/ips/'+idIp,{method:'DELETE'});
    if (!r.ok) { var d = await r.json(); alert('Error: '+(d.detail||'Error')); return; }
    document.getElementById('simple-modal-overlay').remove();
    showToast('IP '+ipAddr+' eliminada');
    loadCmdbIps();
  } catch(e) { alert('Error: '+e.message); }
}

async function loadCmdbSoftware() {
  var el = document.getElementById('cmdb-soft');
  try {
    var soft = await authFetch(API_BASE+'/cmdb/software').then(function(r){return r.json();});
    var html = '<div style="font-size:14px;font-weight:700;margin-bottom:12px;">Software & Licencias ('+soft.length+')</div>';
    var totalCoste = soft.reduce(function(s,sw){return s+(sw.coste_anual||0);},0);
    html += '<div style="margin-bottom:12px;padding:10px;background:var(--bg3);border-radius:8px;font-size:12px;">Coste anual total: <strong style="color:var(--orange);">€'+Math.round(totalCoste).toLocaleString()+'</strong></div>';
    html += '<table class="data-table" style="width:100%;font-size:11px;"><thead><tr>';
    html += '<th>Software</th><th>Versión</th><th>Editor</th><th>Licencia</th><th>Usadas/Total</th><th>Coste/año</th><th>Estado</th><th>Crítico</th></tr></thead><tbody>';
    soft.forEach(function(s){
      var ec = s.estado==='ACTIVO'?'#3fb950':s.estado==='OBSOLETO'?'#ef4444':'#f59e0b';
      var usage = s.num_licencias>0?Math.round(s.licencias_usadas/s.num_licencias*100):0;
      var uc = usage>90?'#ef4444':usage>70?'#f59e0b':'#3fb950';
      html += '<tr><td style="font-weight:600;">'+escHtml(s.nombre)+'</td>';
      html += '<td style="font-family:var(--mono);font-size:10px;">'+escHtml(s.version||'-')+'</td>';
      html += '<td style="font-size:10px;">'+escHtml(s.editor||'-')+'</td>';
      html += '<td><span style="padding:1px 6px;border-radius:3px;font-size:9px;font-weight:600;background:var(--bg4);">'+escHtml(s.tipo_licencia||'-')+'</span></td>';
      html += '<td>'+(s.num_licencias>0?'<span style="color:'+uc+';font-weight:600;">'+s.licencias_usadas+'/'+s.num_licencias+'</span>':'<span style="color:var(--text3);">∞</span>')+'</td>';
      html += '<td style="font-family:var(--mono);">€'+Math.round(s.coste_anual||0).toLocaleString()+'</td>';
      html += '<td><span style="color:'+ec+';font-weight:700;font-size:10px;">'+escHtml(s.estado)+'</span></td>';
      html += '<td>'+(s.critico_negocio?'<span style="color:var(--red);font-weight:700;">SI</span>':'<span style="color:var(--text3);">No</span>')+'</td></tr>';
    });
    html += '</tbody></table>';
    el.innerHTML = html;
  } catch(e) { el.innerHTML = '<div style="color:var(--red);">Error: '+escHtml(e.message)+'</div>'; }
}

async function loadCmdbCostes() {
  var el = document.getElementById('cmdb-costes');
  try {
    var costes = await authFetch(API_BASE+'/cmdb/costes').then(function(r){return r.json();});
    var dash = await authFetch(API_BASE+'/cmdb/costes/dashboard').then(function(r){return r.json();});
    var totalAnual = dash.total_capex + dash.total_opex;
    var topProv = '';
    var topProvKeys = Object.keys(dash.top_proveedores||{});
    if (topProvKeys.length>0) topProv = topProvKeys[0];

    var html = '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">';
    html += '<div style="font-size:16px;font-weight:800;display:flex;align-items:center;gap:8px;"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="1.8"><rect x="2" y="4" width="20" height="14" rx="2"/><path d="M12 12m-3 0a3 3 0 1 0 6 0a3 3 0 1 0-6 0"/></svg>Costes & Budget</div>';
    html += '<button onclick="showCreateCoste()" style="background:linear-gradient(135deg,#f59e0b,#d97706);border:none;color:#fff;border-radius:6px;padding:8px 16px;font-size:12px;font-weight:700;cursor:pointer;">+ Nuevo Coste</button>';
    html += '</div>';

    // KPIs
    html += '<div style="display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin-bottom:16px;">';
    html += _cmdbKpi('Total CAPEX', '\u20AC'+Math.round(dash.total_capex).toLocaleString(), '#3b82f6');
    html += _cmdbKpi('Total OPEX', '\u20AC'+Math.round(dash.total_opex).toLocaleString(), '#8b5cf6');
    html += _cmdbKpi('Burn Rate/mes', '\u20AC'+Math.round(dash.burn_rate_mensual).toLocaleString(), '#ef4444');
    html += _cmdbKpi('Total Anual', '\u20AC'+Math.round(totalAnual).toLocaleString(), '#f59e0b');
    html += _cmdbKpi('Top Proveedor', escHtml(topProv)||'-', '#10b981');
    html += '</div>';

    // Charts: By Category + CAPEX vs OPEX
    html += '<div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:16px;">';
    // By category chart
    html += '<div style="background:var(--bg3);border:1px solid var(--border);border-radius:10px;padding:14px;"><div style="font-size:13px;font-weight:700;margin-bottom:10px;">Por Categor\u00EDa</div>';
    var catColors = {'HARDWARE':'#3b82f6','SOFTWARE':'#8b5cf6','CLOUD':'#06b6d4','LICENCIAS':'#f59e0b','MANTENIMIENTO':'#10b981','SOPORTE':'#f778ba','RRHH':'#ef4444','CONSULTORIA':'#d97706','FORMACION':'#a5b4fc','OTROS':'#6b7280'};
    var maxCat = 1;
    Object.values(dash.by_categoria||{}).forEach(function(v){if(v>maxCat)maxCat=v;});
    Object.entries(dash.by_categoria||{}).forEach(function(e){
      var pct = Math.round(e[1]/maxCat*100);
      var c = catColors[e[0]]||'#6b7280';
      html += '<div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;"><span style="font-size:10px;width:110px;color:'+c+';font-weight:600;">'+e[0]+'</span><div style="flex:1;height:8px;background:var(--bg4);border-radius:4px;overflow:hidden;"><div style="width:'+pct+'%;height:100%;background:'+c+';border-radius:4px;"></div></div><span style="font-size:10px;font-weight:700;width:70px;text-align:right;">\u20AC'+Math.round(e[1]).toLocaleString()+'</span></div>';
    });
    html += '</div>';
    // CAPEX vs OPEX chart
    html += '<div style="background:var(--bg3);border:1px solid var(--border);border-radius:10px;padding:14px;"><div style="font-size:13px;font-weight:700;margin-bottom:10px;">CAPEX vs OPEX</div>';
    var maxCO = Math.max(dash.total_capex, dash.total_opex, 1);
    html += '<div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;"><span style="font-size:11px;width:60px;color:#3b82f6;font-weight:600;">CAPEX</span><div style="flex:1;height:14px;background:var(--bg4);border-radius:4px;overflow:hidden;"><div style="width:'+Math.round(dash.total_capex/maxCO*100)+'%;height:100%;background:#3b82f6;border-radius:4px;"></div></div><span style="font-size:11px;font-weight:700;width:90px;text-align:right;">\u20AC'+Math.round(dash.total_capex).toLocaleString()+'</span></div>';
    html += '<div style="display:flex;align-items:center;gap:8px;margin-bottom:16px;"><span style="font-size:11px;width:60px;color:#8b5cf6;font-weight:600;">OPEX</span><div style="flex:1;height:14px;background:var(--bg4);border-radius:4px;overflow:hidden;"><div style="width:'+Math.round(dash.total_opex/maxCO*100)+'%;height:100%;background:#8b5cf6;border-radius:4px;"></div></div><span style="font-size:11px;font-weight:700;width:90px;text-align:right;">\u20AC'+Math.round(dash.total_opex).toLocaleString()+'</span></div>';
    // Top assets
    if (dash.top_assets && dash.top_assets.length) {
      html += '<div style="font-size:12px;font-weight:700;margin-bottom:8px;margin-top:8px;">Top 10 Activos m\u00E1s Costosos</div>';
      var maxAsset = dash.top_assets[0].total||1;
      dash.top_assets.forEach(function(a){
        var pctA = Math.round(a.total/maxAsset*100);
        html += '<div style="display:flex;align-items:center;gap:6px;margin-bottom:4px;"><span style="font-size:9px;width:100px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:var(--cyan);" title="'+escHtml(a.nombre)+'">'+escHtml(a.codigo)+'</span><div style="flex:1;height:6px;background:var(--bg4);border-radius:3px;overflow:hidden;"><div style="width:'+pctA+'%;height:100%;background:#f59e0b;border-radius:3px;"></div></div><span style="font-size:9px;font-weight:700;width:65px;text-align:right;">\u20AC'+Math.round(a.total).toLocaleString()+'</span></div>';
      });
    }
    html += '</div></div>';

    // Full table
    html += '<div style="font-size:13px;font-weight:700;margin-bottom:8px;">Detalle de Costes ('+costes.length+')</div>';
    html += '<div style="overflow-x:auto;max-height:calc(100vh - 460px);overflow-y:auto;">';
    html += '<table class="data-table" style="width:100%;font-size:11px;"><thead><tr>';
    html += '<th>Concepto</th><th>Activo</th><th>Categor\u00EDa</th><th>Tipo</th><th>Importe</th><th>Periodicidad</th><th>Proveedor</th><th>Proyecto</th><th>Centro Coste</th></tr></thead><tbody>';
    costes.forEach(function(co){
      var tc = co.tipo==='CAPEX'?'#3b82f6':'#8b5cf6';
      var cc = catColors[co.categoria]||'#6b7280';
      html += '<tr onclick="showCosteDetail('+co.id_coste+')" style="cursor:pointer;" onmouseenter="this.style.background=\'rgba(45,126,247,.06)\'" onmouseleave="this.style.background=\'\'">';
      html += '<td style="font-weight:600;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">'+escHtml(co.concepto)+'</td>';
      html += '<td style="font-size:10px;">'+(co.activo_nombre?escHtml(co.activo_codigo)+' - '+escHtml(co.activo_nombre):'-')+'</td>';
      html += '<td><span style="padding:1px 6px;border-radius:3px;font-size:9px;font-weight:700;background:'+cc+'18;color:'+cc+';">'+escHtml(co.categoria)+'</span></td>';
      html += '<td><span style="padding:1px 6px;border-radius:3px;font-size:9px;font-weight:700;background:'+tc+'18;color:'+tc+';">'+escHtml(co.tipo)+'</span></td>';
      html += '<td style="font-family:var(--mono);font-weight:600;">\u20AC'+parseFloat(co.importe||0).toLocaleString()+'</td>';
      html += '<td style="font-size:10px;">'+escHtml(co.periodicidad)+'</td>';
      html += '<td style="font-size:10px;">'+escHtml(co.proveedor||'-')+'</td>';
      html += '<td style="font-size:9px;font-family:var(--mono);color:var(--text3);">'+escHtml(co.id_proyecto||'-')+'</td>';
      html += '<td style="font-size:10px;">'+escHtml(co.centro_coste||'-')+'</td>';
      html += '</tr>';
    });
    html += '</tbody></table></div>';
    el.innerHTML = html;
    window._cmdbCostes = costes;
  } catch(e) { el.innerHTML = '<div style="color:var(--red);">Error: '+escHtml(e.message)+'</div>'; }
}

function showCreateCoste() {
  var html = '<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;font-size:13px;">';
  html += '<div class="login-field" style="grid-column:span 2;"><label>Concepto *</label><input type="text" id="cc-concepto" placeholder="Descripci\u00F3n del coste"></div>';
  html += '<div class="login-field"><label>Activo CMDB</label><select id="cc-activo" style="width:100%;padding:8px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:6px;" onfocus="loadCmdbSelectById(\'cc-activo\')"><option value="">-- Sin activo --</option></select></div>';
  html += '<div class="login-field"><label>Categor\u00EDa *</label><select id="cc-cat" style="width:100%;padding:8px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:6px;"><option>HARDWARE</option><option>SOFTWARE</option><option>CLOUD</option><option>LICENCIAS</option><option>MANTENIMIENTO</option><option>SOPORTE</option><option>RRHH</option><option>CONSULTORIA</option><option>FORMACION</option><option>OTROS</option></select></div>';
  html += '<div class="login-field"><label>Tipo *</label><select id="cc-tipo" style="width:100%;padding:8px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:6px;"><option>CAPEX</option><option>OPEX</option></select></div>';
  html += '<div class="login-field"><label>Importe (\u20AC) *</label><input type="number" id="cc-importe" step="0.01" placeholder="0.00"></div>';
  html += '<div class="login-field"><label>Periodicidad</label><select id="cc-period" style="width:100%;padding:8px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:6px;"><option>MENSUAL</option><option>UNICO</option><option>TRIMESTRAL</option><option>ANUAL</option></select></div>';
  html += '<div class="login-field"><label>Proveedor</label><input type="text" id="cc-prov" placeholder="Nombre proveedor"></div>';
  html += '<div class="login-field"><label>Centro de Coste</label><input type="text" id="cc-centro" placeholder="IT-INFRA"></div>';
  html += '<div class="login-field"><label>Proyecto</label><select id="cc-proy" style="width:100%;padding:8px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:6px;" onfocus="loadProjectSelect(\'cc-proy\')"><option value="">-- Sin proyecto --</option></select></div>';
  html += '<div class="login-field"><label>Fecha Inicio</label><input type="date" id="cc-finicio" style="width:100%;padding:8px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:6px;"></div>';
  html += '<div class="login-field"><label>Fecha Fin</label><input type="date" id="cc-ffin" style="width:100%;padding:8px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:6px;"></div>';
  html += '<div class="login-field" style="grid-column:span 2;"><label>Notas</label><input type="text" id="cc-notas" placeholder="Notas adicionales..."></div>';
  html += '</div>';
  html += '<div style="display:flex;gap:8px;margin-top:14px;justify-content:flex-end;">';
  html += '<button onclick="document.getElementById(\'simple-modal-overlay\').remove()" style="background:var(--bg3);border:1px solid var(--border);color:var(--text2);border-radius:6px;padding:8px 20px;font-size:13px;cursor:pointer;">Cancelar</button>';
  html += '<button onclick="doCreateCoste()" style="background:linear-gradient(135deg,#f59e0b,#d97706);border:none;color:#fff;border-radius:6px;padding:8px 20px;font-size:13px;font-weight:700;cursor:pointer;">Crear Coste</button>';
  html += '</div>';
  showSimpleModal('Nuevo Coste', html);
}

async function doCreateCoste() {
  var body = {
    concepto: document.getElementById('cc-concepto').value.trim(),
    id_activo: parseInt(document.getElementById('cc-activo').value)||null,
    categoria: document.getElementById('cc-cat').value,
    tipo: document.getElementById('cc-tipo').value,
    importe: parseFloat(document.getElementById('cc-importe').value)||0,
    periodicidad: document.getElementById('cc-period').value,
    proveedor: document.getElementById('cc-prov').value.trim()||null,
    centro_coste: document.getElementById('cc-centro').value.trim()||null,
    id_proyecto: document.getElementById('cc-proy').value.trim()||null,
    fecha_inicio: document.getElementById('cc-finicio').value||null,
    fecha_fin: document.getElementById('cc-ffin').value||null,
    notas: document.getElementById('cc-notas').value.trim()||null,
  };
  if (!body.concepto||!body.importe) { alert('Concepto e Importe son obligatorios'); return; }
  try {
    var r = await authFetch(API_BASE+'/cmdb/costes',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
    var d = await r.json();
    if (!r.ok) { alert('Error: '+(d.detail||'Error')); return; }
    document.getElementById('simple-modal-overlay').remove();
    showToast('Coste creado');
    loadCmdbCostes();
  } catch(e) { alert('Error: '+e.message); }
}

function showCosteDetail(idCoste) {
  var co = (window._cmdbCostes||[]).find(function(x){return x.id_coste===idCoste;});
  if (!co) return;
  var html = '<div style="font-size:13px;line-height:2;">';
  html += '<div><strong>Concepto:</strong> '+escHtml(co.concepto)+'</div>';
  html += '<div><strong>Activo:</strong> '+(co.activo_nombre?escHtml(co.activo_codigo)+' - '+escHtml(co.activo_nombre):'-')+'</div>';
  html += '<div><strong>Categor\u00EDa:</strong> '+escHtml(co.categoria)+'</div>';
  html += '<div><strong>Tipo:</strong> <span style="font-weight:700;color:'+(co.tipo==='CAPEX'?'#3b82f6':'#8b5cf6')+';">'+escHtml(co.tipo)+'</span></div>';
  html += '<div><strong>Importe:</strong> <span style="font-family:var(--mono);font-weight:700;color:#f59e0b;">\u20AC'+parseFloat(co.importe||0).toLocaleString()+'</span></div>';
  html += '<div><strong>Periodicidad:</strong> '+escHtml(co.periodicidad)+'</div>';
  html += '<div><strong>Proveedor:</strong> '+escHtml(co.proveedor||'-')+'</div>';
  html += '<div><strong>Centro Coste:</strong> '+escHtml(co.centro_coste||'-')+'</div>';
  html += '<div><strong>Proyecto:</strong> '+escHtml(co.id_proyecto||'-')+'</div>';
  html += '<div><strong>Fecha Inicio:</strong> '+escHtml(co.fecha_inicio||'-')+'</div>';
  html += '<div><strong>Fecha Fin:</strong> '+escHtml(co.fecha_fin||'-')+'</div>';
  html += '<div><strong>Notas:</strong> '+escHtml(co.notas||'-')+'</div>';
  html += '</div>';
  html += '<div style="display:flex;gap:8px;margin-top:14px;justify-content:space-between;">';
  html += '<button onclick="doDeleteCoste('+co.id_coste+',\''+escHtml(co.concepto).replace(/'/g,"\\'")+'\')" style="background:var(--red-bg);border:1px solid rgba(248,81,73,.2);color:var(--red);border-radius:6px;padding:8px 14px;font-size:12px;font-weight:600;cursor:pointer;">Eliminar</button>';
  html += '<div style="display:flex;gap:8px;">';
  html += '<button onclick="document.getElementById(\'simple-modal-overlay\').remove()" style="background:var(--bg3);border:1px solid var(--border);color:var(--text2);border-radius:6px;padding:8px 20px;font-size:13px;cursor:pointer;">Cerrar</button>';
  html += '<button onclick="showEditCoste('+co.id_coste+')" style="background:linear-gradient(135deg,#2563eb,#3b82f6);border:none;color:#fff;border-radius:6px;padding:8px 20px;font-size:13px;font-weight:700;cursor:pointer;">Editar</button>';
  html += '</div></div>';
  showSimpleModal('Coste: '+escHtml(co.concepto), html);
}

function showEditCoste(idCoste) {
  var co = (window._cmdbCostes||[]).find(function(x){return x.id_coste===idCoste;});
  if (!co) return;
  var mkSel = function(id,opts,val) {
    return '<select id="'+id+'" style="width:100%;padding:8px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:6px;">'+opts.map(function(o){return '<option'+(o===val?' selected':'')+'>'+o+'</option>';}).join('')+'</select>';
  };
  var html = '<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;font-size:13px;">';
  html += '<div class="login-field" style="grid-column:span 2;"><label>Concepto</label><input type="text" id="ec-concepto" value="'+escHtml(co.concepto||'')+'"></div>';
  html += '<div class="login-field"><label>Activo CMDB</label><select id="ec-activo" style="width:100%;padding:8px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:6px;" onfocus="loadCmdbSelectById(\'ec-activo\','+JSON.stringify(co.id_activo)+')"><option value="">-- Sin activo --</option>'+(co.id_activo?'<option value="'+co.id_activo+'" selected>'+escHtml(co.activo_codigo||'')+' \u2014 '+escHtml(co.activo_nombre||'')+'</option>':'')+'</select></div>';
  html += '<div class="login-field"><label>Categor\u00EDa</label>'+mkSel('ec-cat',['HARDWARE','SOFTWARE','CLOUD','LICENCIAS','MANTENIMIENTO','SOPORTE','RRHH','CONSULTORIA','FORMACION','OTROS'],co.categoria)+'</div>';
  html += '<div class="login-field"><label>Tipo</label>'+mkSel('ec-tipo',['CAPEX','OPEX'],co.tipo)+'</div>';
  html += '<div class="login-field"><label>Importe (\u20AC)</label><input type="number" id="ec-importe" step="0.01" value="'+(co.importe||0)+'"></div>';
  html += '<div class="login-field"><label>Periodicidad</label>'+mkSel('ec-period',['UNICO','MENSUAL','TRIMESTRAL','ANUAL'],co.periodicidad)+'</div>';
  html += '<div class="login-field"><label>Proveedor</label><input type="text" id="ec-prov" value="'+escHtml(co.proveedor||'')+'"></div>';
  html += '<div class="login-field"><label>Centro de Coste</label><input type="text" id="ec-centro" value="'+escHtml(co.centro_coste||'')+'"></div>';
  html += '<div class="login-field"><label>Proyecto</label><select id="ec-proy" style="width:100%;padding:8px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:6px;" onfocus="loadProjectSelect(\'ec-proy\',\''+escHtml(co.id_proyecto||'')+'\')"><option value="">-- Sin proyecto --</option>'+(co.id_proyecto?'<option value="'+escHtml(co.id_proyecto)+'" selected>'+escHtml(co.id_proyecto)+'</option>':'')+'</select></div>';
  html += '<div class="login-field"><label>Fecha Inicio</label><input type="date" id="ec-finicio" value="'+(co.fecha_inicio||'')+'" style="width:100%;padding:8px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:6px;"></div>';
  html += '<div class="login-field"><label>Fecha Fin</label><input type="date" id="ec-ffin" value="'+(co.fecha_fin||'')+'" style="width:100%;padding:8px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:6px;"></div>';
  html += '<div class="login-field" style="grid-column:span 2;"><label>Notas</label><input type="text" id="ec-notas" value="'+escHtml(co.notas||'')+'"></div>';
  html += '</div>';
  html += '<div style="display:flex;gap:8px;margin-top:14px;justify-content:flex-end;">';
  html += '<button onclick="document.getElementById(\'simple-modal-overlay\').remove()" style="background:var(--bg3);border:1px solid var(--border);color:var(--text2);border-radius:6px;padding:8px 20px;font-size:13px;cursor:pointer;">Cancelar</button>';
  html += '<button onclick="doEditCoste('+co.id_coste+')" style="background:linear-gradient(135deg,#2563eb,#3b82f6);border:none;color:#fff;border-radius:6px;padding:8px 20px;font-size:13px;font-weight:700;cursor:pointer;">Guardar</button>';
  html += '</div>';
  showSimpleModal('Editar Coste', html);
}

async function doEditCoste(idCoste) {
  var body = {
    concepto: document.getElementById('ec-concepto').value.trim(),
    id_activo: parseInt(document.getElementById('ec-activo').value)||null,
    categoria: document.getElementById('ec-cat').value,
    tipo: document.getElementById('ec-tipo').value,
    importe: parseFloat(document.getElementById('ec-importe').value)||0,
    periodicidad: document.getElementById('ec-period').value,
    proveedor: document.getElementById('ec-prov').value.trim()||null,
    centro_coste: document.getElementById('ec-centro').value.trim()||null,
    id_proyecto: document.getElementById('ec-proy').value.trim()||null,
    fecha_inicio: document.getElementById('ec-finicio').value||null,
    fecha_fin: document.getElementById('ec-ffin').value||null,
    notas: document.getElementById('ec-notas').value.trim()||null,
  };
  try {
    var r = await authFetch(API_BASE+'/cmdb/costes/'+idCoste,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
    if (!r.ok) { var d = await r.json(); alert('Error: '+(d.detail||'Error')); return; }
    document.getElementById('simple-modal-overlay').remove();
    showToast('Coste actualizado');
    loadCmdbCostes();
  } catch(e) { alert('Error: '+e.message); }
}

async function doDeleteCoste(idCoste, concepto) {
  if (!confirm('\u00BFEliminar el coste "'+concepto+'"?')) return;
  try {
    var r = await authFetch(API_BASE+'/cmdb/costes/'+idCoste,{method:'DELETE'});
    if (!r.ok) { var d = await r.json(); alert('Error: '+(d.detail||'Error')); return; }
    document.getElementById('simple-modal-overlay').remove();
    showToast('Coste eliminado');
    loadCmdbCostes();
  } catch(e) { alert('Error: '+e.message); }
}

async function loadCmdbCompliance() {
  var el = document.getElementById('cmdb-comp');
  try {
    var d = await authFetch(API_BASE+'/cmdb/compliance').then(function(r){return r.json();});
    var html = '<div style="font-size:14px;font-weight:700;margin-bottom:14px;display:flex;align-items:center;gap:8px;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>Panel de Salud & Cumplimiento</div>';
    // KPIs
    html += '<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px;">';
    html += _cmdbKpi('SW Obsoleto', d.software_obsoleto.length, d.software_obsoleto.length>0?'#ef4444':'#3fb950');
    html += _cmdbKpi('Sin Responsable', d.activos_sin_responsable, d.activos_sin_responsable>0?'#f59e0b':'#3fb950');
    html += _cmdbKpi('Sin Proyecto', d.activos_sin_proyecto, d.activos_sin_proyecto>0?'#f59e0b':'#3fb950');
    html += '</div>';
    // Degradados
    if (d.activos_degradados.length) {
      html += '<div style="margin-bottom:14px;padding:12px;background:var(--orange-bg);border:1px solid rgba(240,136,62,.2);border-radius:8px;"><div style="font-weight:700;color:var(--orange);margin-bottom:6px;">Activos Degradados / En Mantenimiento</div>';
      d.activos_degradados.forEach(function(a){
        html += '<div style="font-size:12px;">'+escHtml(a.codigo)+' — '+escHtml(a.nombre)+' <span style="color:var(--orange);font-weight:600;">['+escHtml(a.estado_ciclo)+']</span></div>';
      });
      html += '</div>';
    }
    // Certificados
    if (d.certificados.length) {
      html += '<div style="margin-bottom:14px;padding:12px;background:var(--bg3);border:1px solid var(--border);border-radius:8px;"><div style="font-weight:700;margin-bottom:6px;">Certificados SSL/TLS</div>';
      d.certificados.forEach(function(c){
        var exp = c.expira||'N/A';
        var isExpiring = exp!=='N/A' && new Date(exp) < new Date(Date.now()+90*86400000);
        html += '<div style="font-size:12px;display:flex;align-items:center;gap:8px;">'+escHtml(c.codigo)+' — '+escHtml(c.nombre)+' → Expira: <span style="font-weight:700;color:'+(isExpiring?'var(--red)':'var(--green)')+';">'+exp+'</span></div>';
      });
      html += '</div>';
    }
    el.innerHTML = html;
  } catch(e) { el.innerHTML = '<div style="color:var(--red);">Error: '+escHtml(e.message)+'</div>'; }
}

// ══════════════════ DEV TOOLS — JS ══════════════════
let _devLoaded = false;

function devShowSection(id, el) {
  document.querySelectorAll('.dev-section').forEach(s=>s.classList.remove('active'));
  document.querySelectorAll('.dev-nav-item').forEach(n=>n.classList.remove('active'));
  document.getElementById('dev-sec-'+id).classList.add('active');
  el.classList.add('active');
  if (id==='db' && !_devLoaded) loadDevTables();
  if (id==='files') loadDevFiles();
  if (id==='api') loadDevAPI();
  if (id==='context') loadDevContext();
  if (id==='dbloader') { /* nothing to auto-load */ }
  if (id==='rbac-users') loadRbacUsers();
  if (id==='rbac-roles') loadRbacRolesPanel();
  if (id==='rbac-audit') loadRbacAudit();
  if (id==='rbac-org') loadRbacOrg();
}

async function loadDevTables() {
  _devLoaded = true;
  try {
    const tables = await authFetch(API_BASE+'/dev/tables').then(r=>r.json());
    const el = document.getElementById('dev-tables-list');
    el.innerHTML = tables.map(t => `
      <div style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:10px;cursor:pointer;transition:all .15s;" onclick="devOpenTable('${t.table_name}')" onmouseover="this.style.borderColor='#ef4444'" onmouseout="this.style.borderColor=''">
        <div style="font-size:12px;font-weight:700;color:#ef4444;margin-bottom:4px;">${t.table_name}</div>
        <div style="display:flex;gap:8px;font-size:10px;color:var(--text3);">
          <span>${t.row_count||0} rows</span>
          <span>${t.col_count} cols</span>
          <span>${t.size}</span>
        </div>
      </div>
    `).join('');
  } catch(e) { console.warn(e); }
}

async function devOpenTable(name) {
  const detail = document.getElementById('dev-table-detail');
  detail.style.display = 'block';
  detail.innerHTML = '<div class="no-data"><span class="loading-spinner"></span> Cargando...</div>';
  try {
    const [schema, data] = await Promise.all([
      authFetch(API_BASE+'/dev/tables/'+name+'/schema').then(r=>r.json()),
      authFetch(API_BASE+'/dev/tables/'+name+'/data?limit=20').then(r=>r.json()),
    ]);
    let html = `<div style="font-size:13px;font-weight:700;margin-bottom:8px;color:#ef4444;">${name} <span style="color:var(--text3);font-weight:400;">(${data.total} rows)</span></div>`;
    // Schema
    html += `<div style="margin-bottom:10px;"><div style="font-size:11px;font-weight:600;margin-bottom:4px;">Columnas</div><table class="dev-result-table"><tr><th>Columna</th><th>Tipo</th><th>Nullable</th><th>Default</th></tr>`;
    schema.columns.forEach(c => {
      html += `<tr><td style="font-weight:600;color:var(--text);">${c.column_name}</td><td>${c.data_type}${c.character_maximum_length?'('+c.character_maximum_length+')':''}</td><td>${c.is_nullable}</td><td style="font-size:9px;">${c.column_default||'—'}</td></tr>`;
    });
    html += '</table></div>';
    // Data preview
    if (data.rows.length) {
      const cols = Object.keys(data.rows[0]);
      html += `<div style="font-size:11px;font-weight:600;margin-bottom:4px;">Datos (primeras ${data.rows.length} filas)</div><div style="overflow-x:auto;"><table class="dev-result-table"><tr>${cols.map(c=>'<th>'+c+'</th>').join('')}</tr>`;
      data.rows.forEach(r => { html += '<tr>'+cols.map(c=>'<td>'+escHtml(String(r[c]??'')).substring(0,50)+'</td>').join('')+'</tr>'; });
      html += '</table></div>';
    }
    detail.innerHTML = html;
  } catch(e) { detail.innerHTML = '<div style="color:var(--red);">Error: '+e.message+'</div>'; }
}

async function devRunSQL() {
  const sql = document.getElementById('dev-sql-input').value.trim();
  if (!sql) return;
  const isWrite = !sql.toUpperCase().startsWith('SELECT') && !sql.toUpperCase().startsWith('WITH');
  if (isWrite && !confirm('⚠ ATENCIÓN: Esta sentencia MODIFICARÁ datos en producción.\n\n'+sql.substring(0,200)+'\n\n¿Estás seguro?')) return;
  document.getElementById('dev-sql-status').textContent = 'Ejecutando...';
  try {
    const r = await authFetch(API_BASE+'/dev/sql', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({sql})});
    const data = await r.json();
    if (!r.ok) throw new Error(data.detail||'Error SQL');
    const el = document.getElementById('dev-sql-result');
    if (data.type==='query' && data.rows.length) {
      const cols = Object.keys(data.rows[0]);
      el.innerHTML = `<div style="font-size:10px;color:var(--green);margin-bottom:4px;">✓ ${data.count} filas devueltas</div><div style="overflow-x:auto;"><table class="dev-result-table"><tr>${cols.map(c=>'<th>'+c+'</th>').join('')}</tr>${data.rows.map(r=>'<tr>'+cols.map(c=>'<td>'+escHtml(String(r[c]??'')).substring(0,80)+'</td>').join('')+'</tr>').join('')}</table></div>`;
    } else if (data.type==='execute') {
      el.innerHTML = `<div style="color:var(--green);font-size:12px;">✓ ${data.result}</div>`;
    } else {
      el.innerHTML = `<div style="color:var(--text3);font-size:11px;">Sin resultados</div>`;
    }
    document.getElementById('dev-sql-status').textContent = '✓ OK';
  } catch(e) {
    document.getElementById('dev-sql-result').innerHTML = `<div style="color:var(--red);font-size:12px;">✕ ${escHtml(e.message)}</div>`;
    document.getElementById('dev-sql-status').textContent = '✕ Error';
  }
}

async function loadDevFiles() {
  try {
    const files = await authFetch(API_BASE+'/dev/files').then(r=>r.json());
    document.getElementById('dev-files-list').innerHTML = files.map(f => `
      <div style="display:flex;align-items:center;gap:8px;padding:4px 8px;border-radius:4px;cursor:pointer;font-size:11px;transition:all .15s;" onclick="devViewFile('${f.path}')" onmouseover="this.style.background='var(--bg3)'" onmouseout="this.style.background=''">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="${f.path.endsWith('.py')?'#3b82f6':f.path.endsWith('.sql')?'#f59e0b':'var(--text3)'}" stroke-width="1.8"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/></svg>
        <span style="flex:1;font-family:var(--mono);">${f.path}</span>
        <span style="color:var(--text3);font-size:9px;">${f.lines} lines · ${(f.size/1024).toFixed(1)}KB</span>
      </div>
    `).join('');
  } catch(e) {}
}

async function devViewFile(path) {
  const viewer = document.getElementById('dev-file-viewer');
  viewer.style.display = 'block';
  try {
    const data = await authFetch(API_BASE+'/dev/files/'+path).then(r=>r.json());
    viewer.innerHTML = `<div style="display:flex;align-items:center;gap:6px;margin-bottom:6px;"><span style="font-size:12px;font-weight:700;font-family:var(--mono);color:#ef4444;">${data.path}</span><span style="font-size:10px;color:var(--text3);">${(data.size/1024).toFixed(1)}KB</span></div><pre style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:10px;font-size:11px;overflow:auto;max-height:60vh;line-height:1.5;white-space:pre-wrap;"><code>${escHtml(data.content)}</code></pre>`;
  } catch(e) { viewer.innerHTML = '<div style="color:var(--red);">Error: '+e.message+'</div>'; }
}

async function loadDevAPI() {
  try {
    const ctx = await authFetch(API_BASE+'/dev/context').then(r=>r.json());
    const methods = {GET:'var(--green)',POST:'var(--blue)',PUT:'var(--orange)',DELETE:'var(--red)'};
    document.getElementById('dev-api-list').innerHTML = `<div style="font-size:11px;color:var(--text3);margin-bottom:8px;">${ctx.endpoints.length} endpoints en ${ctx.total_tables} tablas</div>` +
      ctx.endpoints.map(e => `
        <div style="display:flex;align-items:center;gap:8px;padding:4px 8px;border-radius:4px;font-size:11px;border-bottom:1px solid var(--border2);">
          <span style="font-family:var(--mono);font-size:10px;font-weight:700;color:${methods[e.method]||'var(--text)'};width:45px;">${e.method}</span>
          <span style="font-family:var(--mono);flex:1;">${e.path}</span>
          <span style="font-size:9px;color:var(--text3);">${e.file}</span>
        </div>
      `).join('');
  } catch(e) {}
}

let _devContextMd = '';
async function loadDevContext() {
  const el = document.getElementById('dev-context-content');
  el.innerHTML = '<span class="loading-spinner"></span> Generando contexto técnico...';
  try {
    const ctx = await authFetch(API_BASE+'/dev/context').then(r=>r.json());
    let md = `# Cognitive PMO — Contexto Técnico Completo\n`;
    md += `**Generado:** ${new Date().toLocaleString('es-ES')} | **Versión:** ${ctx.version} | **Autor:** ${ctx.author}\n\n`;
    md += `## ESTADO ACTUAL\n- **Frontend:** SPA vanilla JS (${ctx.total_endpoints} endpoints)\n- **Backend:** FastAPI + asyncpg\n- **Base de datos:** PostgreSQL con ${ctx.total_tables} tablas\n- **Agentes IA:** 7 en Flowise + 4 War Room (Claude Sonnet 4)\n- **Infraestructura:** Docker Compose en NasJose 192.168.1.49\n\n`;
    md += `## ARQUITECTURA\n### Servicios\n`;
    ctx.services.forEach(s => { md += `- **${s.name}**: Puerto ${s.port} (${s.tech})\n`; });
    md += `\n## ESQUEMA DE BASE DE DATOS\n`;
    ctx.tables.forEach(t => {
      md += `\n### ${t.name} (${t.rows} filas)\n\`\`\`sql\nCREATE TABLE ${t.name} (\n`;
      t.columns.forEach((c,i) => { md += `  ${c.column_name} ${c.data_type}${c.is_nullable==='NO'?' NOT NULL':''}${c.column_default?' DEFAULT '+c.column_default:''}${i<t.columns.length-1?',':''}\n`; });
      md += `);\n\`\`\`\n`;
    });
    md += `\n## API ENDPOINTS (${ctx.endpoints.length})\n`;
    ctx.endpoints.forEach(e => { md += `- \`${e.method} ${e.path}\` — ${e.file}\n`; });
    md += `\n## DECISIONES DE DISEÑO\n- SPA monolítica en vanilla JS para máximo rendimiento y zero-build\n- asyncpg pool para alta concurrencia\n- JSONB para datos flexibles (skills, proveedores, plan_data)\n- Sub-app FastAPI para War Room (mount /cognitive)\n- Auto-sync estado técnico via kanban_tareas\n- Buffer persistente en PostgreSQL para planes RUN/BUILD\n- Mermaid para rendering visual de Gantt\n- Theme claro/oscuro con CSS variables\n- Drag-and-drop para reorden de pestañas y columnas\n`;
    _devContextMd = md;
    el.innerHTML = fmtMd(md);
  } catch(e) { el.innerHTML = '<div style="color:var(--red);">Error: '+e.message+'</div>'; }
}

function devCopyContext() {
  if (!_devContextMd) { showToast('Genera el contexto primero'); return; }
  navigator.clipboard.writeText(_devContextMd).then(()=>showToast('Contexto copiado al portapapeles'));
}

function devDownloadContext() {
  if (!_devContextMd) { showToast('Genera el contexto primero'); return; }
  const html = `<!DOCTYPE html><html><head><meta charset="utf-8"><title>Cognitive PMO — Contexto Técnico</title><style>body{font-family:Arial,sans-serif;max-width:900px;margin:0 auto;padding:40px;color:#222;font-size:13px;line-height:1.6;}h1{color:#dc2626;border-bottom:3px solid #dc2626;padding-bottom:10px;}h2{color:#0369a1;margin-top:30px;border-bottom:1px solid #ddd;padding-bottom:5px;}h3{color:#92400e;font-size:14px;}pre{background:#f8fafc;border:1px solid #e2e8f0;border-radius:6px;padding:12px;font-size:11px;overflow-x:auto;}code{font-family:monospace;font-size:11px;}.footer{margin-top:40px;border-top:2px solid #dc2626;padding-top:10px;font-size:10px;color:#888;text-align:center;}</style></head><body>${fmtMd(_devContextMd)}<div class="footer">Cognitive PMO · Contexto Técnico · ${new Date().toLocaleDateString('es-ES')}</div></body></html>`;
  const w = window.open('','_blank');
  w.document.write(html); w.document.close();
  w.onload = () => setTimeout(()=>w.print(), 500);
}

let _clipySessionId = 'clipy-' + Date.now();
const CLIPY_AVATAR_SMALL = `<svg viewBox="0 0 100 100" width="24" height="24" style="flex-shrink:0;margin-top:2px;"><path d="M35 85 L35 30 Q35 15 50 15 Q65 15 65 30 L65 70 Q65 80 55 80 Q45 80 45 70 L45 35" fill="none" stroke="#3b82f6" stroke-width="8" stroke-linecap="round"/><ellipse cx="43" cy="38" rx="3.5" ry="4" fill="white"/><ellipse cx="57" cy="38" rx="3.5" ry="4" fill="white"/><circle cx="44" cy="38" r="2" fill="#1e293b"/><circle cx="58" cy="38" r="2" fill="#1e293b"/><path d="M44 48 Q50 54 56 48" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"/></svg>`;

async function devSendChat() {
  const input = document.getElementById('dev-chat-input');
  const msg = input.value.trim();
  if (!msg) return;
  input.value = '';
  const messages = document.getElementById('dev-chat-messages');
  const now = new Date().toLocaleTimeString('es-ES',{hour:'2-digit',minute:'2-digit'});
  // User bubble
  messages.innerHTML += `<div style="display:flex;gap:8px;justify-content:flex-end;margin-bottom:8px;">
    <div style="background:var(--blue-bg);border:1px solid rgba(45,126,247,.2);border-radius:10px;padding:8px 12px;font-size:12px;max-width:75%;border-bottom-right-radius:4px;line-height:1.5;">${escHtml(msg)}<div style="font-size:9px;color:var(--text3);margin-top:3px;">${now}</div></div>
  </div>`;
  messages.scrollTop = messages.scrollHeight;
  // Clipy typing
  const typingId = 'clipy-t-'+Date.now();
  messages.innerHTML += `<div id="${typingId}" style="display:flex;gap:8px;align-items:flex-start;margin-bottom:8px;">
    ${CLIPY_AVATAR_SMALL}
    <div style="background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:8px 12px;font-size:12px;max-width:80%;border-top-left-radius:4px;line-height:1.5;">
      <div class="typing-wrap"><div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div></div>
    </div>
  </div>`;
  messages.scrollTop = messages.scrollHeight;
  // Build TECHNICAL-ONLY context (no business data)
  let contextStr = '[CONTEXTO TÉCNICO - Solo estructura, NO datos de negocio]\n';
  contextStr += 'Stack: FastAPI+asyncpg, SPA vanilla JS, PostgreSQL 15, Docker Compose\n';
  contextStr += 'Servidor: NasJose 192.168.1.49 | API:8088 | Frontend:3030 | Flowise:3000 | PG:5432\n';
  contextStr += 'Frontend: index.html ~6500 líneas | Backend: main.py ~1300 líneas + war_room_api.py ~800 líneas\n';
  try {
    const ctx = await authFetch(API_BASE+'/dev/context').then(r=>r.json());
    contextStr += `Tablas (solo nombres): ${ctx.tables.map(t=>t.name).join(', ')}\n`;
    contextStr += `Endpoints: ${ctx.total_endpoints} totales\n`;
  } catch(e) {}
  try {
    const payload = {
      session_id: _clipySessionId,
      agent_id: 'CLIPY',
      message: contextStr + '\n[PREGUNTA DEL DESARROLLADOR]\n' + msg,
    };
    const r = await authFetch(API_BASE+'/cognitive/chat', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
    const data = await r.json();
    const typing = document.getElementById(typingId);
    if (typing) {
      const inner = typing.querySelector('div:last-child');
      if (inner) {
        inner.innerHTML = `${fmtMd(data.response)}<div style="font-size:9px;color:var(--text3);margin-top:4px;display:flex;gap:8px;align-items:center;">
          <span style="color:#3b82f6;font-weight:600;">Clipy</span>
          <span>${data.model||'claude'}</span>
          <span>${data.latency_ms||0}ms</span>
          <span>${data.tokens_used||0} tokens</span>
        </div>`;
      }
    }
  } catch(e) {
    const typing = document.getElementById(typingId);
    if (typing) {
      const inner = typing.querySelector('div:last-child');
      if (inner) { inner.innerHTML = `<span style="color:var(--red);">Ups, algo ha fallado: ${escHtml(e.message)}. ¿Tienes la ANTHROPIC_API_KEY configurada?</span>`; }
    }
  }
  messages.scrollTop = messages.scrollHeight;
}

// ── THEME TOGGLE ──
function toggleTheme() {
  const root = document.documentElement;
  const isLight = root.classList.toggle('light');
  const btn = document.getElementById('theme-toggle');
  btn.textContent = isLight ? '☀️' : '🌙';
  btn.title = isLight ? 'Cambiar a modo oscuro' : 'Cambiar a modo claro';
  localStorage.setItem('pmo-theme', isLight ? 'light' : 'dark');
}
if (localStorage.getItem('pmo-theme') === 'light') {
  document.documentElement.classList.add('light');
  const tb = document.getElementById('theme-toggle');
  if (tb) tb.textContent = '☀️';
}

// ── NAV TAB DRAG REORDER ──
(function initTabDrag() {
  const container = document.querySelector('.nav-tabs');
  if (!container) return;
  let dragTab = null;
  container.addEventListener('dragstart', e => {
    dragTab = e.target.closest('.nav-tab');
    if (dragTab) { e.dataTransfer.effectAllowed = 'move'; dragTab.classList.add('dragging'); }
  });
  container.addEventListener('dragover', e => {
    e.preventDefault();
    const target = e.target.closest('.nav-tab');
    if (!target || target === dragTab) return;
    const rect = target.getBoundingClientRect();
    const mid = rect.left + rect.width / 2;
    if (e.clientX < mid) target.before(dragTab);
    else target.after(dragTab);
  });
  container.addEventListener('dragend', () => {
    if (dragTab) dragTab.classList.remove('dragging');
    dragTab = null;
    const order = [...container.querySelectorAll('.nav-tab')].map(t => {
      const cls = [...t.classList].filter(c => c !== 'nav-tab' && c !== 'active' && c !== 'dragging');
      return cls[0] || '';
    }).filter(Boolean);
    localStorage.setItem('pmo-tab-order', JSON.stringify(order));
  });
  const saved = localStorage.getItem('pmo-tab-order');
  if (saved) {
    try {
      JSON.parse(saved).forEach(cls => {
        const tab = container.querySelector('.nav-tab.' + cls);
        if (tab) container.appendChild(tab);
      });
    } catch(e) {}
  }
})();

// ═══════════════════════════════════════════════════════════════
// RBAC MANAGEMENT - USERS, ROLES, AUDIT, ORG
// ═══════════════════════════════════════════════════════════════

// ══════════════════ DATABASE LOADER ══════════════════

function dbloaderHandleDrop(e) {
  var files = e.dataTransfer.files;
  if (files.length > 0) dbloaderUpload(files[0]);
}

async function dbloaderUpload(file) {
  if (!file) return;
  if (!file.name.endsWith('.sql')) {
    showToast('Solo se permiten archivos .sql');
    return;
  }

  var infoEl = document.getElementById('dbloader-info');
  infoEl.style.display = 'block';
  infoEl.innerHTML = '<div style="padding:14px;background:var(--bg3);border:1px solid var(--border);border-radius:8px;"><div style="display:flex;align-items:center;gap:8px;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="1.8" class="spin"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg> Subiendo ' + escHtml(file.name) + '...</div></div>';

  var formData = new FormData();
  formData.append('file', file);

  try {
    var r = await authFetch(API_BASE + '/dev/upload-database-file', {
      method: 'POST',
      body: formData
    });
    var data = await r.json();
    if (!r.ok) { showToast('Error: ' + (data.detail || 'Upload failed')); return; }

    infoEl.innerHTML = '<div style="padding:14px;background:var(--bg3);border:1px solid var(--border);border-radius:8px;">' +
      '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">' +
        '<div style="font-weight:700;font-size:14px;color:var(--green);display:flex;align-items:center;gap:6px;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3fb950" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> Archivo subido correctamente</div>' +
        '<span style="font-size:11px;color:var(--text3);">' + escHtml(data.uploaded_at) + '</span>' +
      '</div>' +
      '<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;">' +
        '<div style="background:var(--bg4);border-radius:6px;padding:8px;text-align:center;"><div style="font-size:10px;color:var(--text3);">Archivo</div><div style="font-size:12px;font-weight:700;">' + escHtml(data.filename) + '</div></div>' +
        '<div style="background:var(--bg4);border-radius:6px;padding:8px;text-align:center;"><div style="font-size:10px;color:var(--text3);">Tamano</div><div style="font-size:12px;font-weight:700;">' + data.size_mb + ' MB</div></div>' +
        '<div style="background:var(--bg4);border-radius:6px;padding:8px;text-align:center;"><div style="font-size:10px;color:var(--text3);">Lineas</div><div style="font-size:12px;font-weight:700;">' + data.lines.toLocaleString() + '</div></div>' +
        '<div style="background:var(--bg4);border-radius:6px;padding:8px;text-align:center;"><div style="font-size:10px;color:var(--text3);">INSERT</div><div style="font-size:12px;font-weight:700;color:var(--blue);">' + data.insert_statements + '</div></div>' +
        '<div style="background:var(--bg4);border-radius:6px;padding:8px;text-align:center;"><div style="font-size:10px;color:var(--text3);">CREATE</div><div style="font-size:12px;font-weight:700;color:var(--green);">' + data.create_statements + '</div></div>' +
      '</div>' +
      '<div style="display:flex;gap:8px;margin-top:12px;">' +
        '<button onclick="dbloaderPreview()" style="background:var(--blue-bg);border:1px solid rgba(45,126,247,.2);color:var(--blue);border-radius:6px;padding:8px 16px;font-size:12px;font-weight:600;cursor:pointer;">Preview</button>' +
        '<button onclick="dbloaderConfirmLoad()" style="background:linear-gradient(135deg,#3fb950,#2da44e);border:none;color:#fff;border-radius:6px;padding:8px 16px;font-size:12px;font-weight:700;cursor:pointer;">Cargar en Base de Datos</button>' +
      '</div>' +
    '</div>';

  } catch(e) {
    infoEl.innerHTML = '<div style="padding:14px;background:var(--red-bg);border:1px solid rgba(248,81,73,.2);border-radius:8px;color:var(--red);">Error: ' + escHtml(e.message) + '</div>';
  }
}

async function dbloaderPreview() {
  var el = document.getElementById('dbloader-preview');
  el.style.display = 'block';
  el.innerHTML = '<div style="color:var(--text3);">Loading preview...</div>';
  try {
    var data = await authFetch(API_BASE + '/dev/preview-database-file').then(function(r){return r.json();});
    el.innerHTML = '<div style="margin-top:10px;"><div style="font-size:12px;font-weight:700;margin-bottom:6px;">Preview (primeras 100 lineas):</div>' +
      '<pre style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:10px;font-size:10px;font-family:var(--mono);max-height:300px;overflow:auto;white-space:pre-wrap;">' +
      escHtml(data.preview.join('\n')) + '</pre></div>';
  } catch(e) {
    el.innerHTML = '<div style="color:var(--red);">Error loading preview</div>';
  }
}

function dbloaderConfirmLoad() {
  if (!confirm('ATENCION: Esto cargara el archivo SQL en la base de datos.\n\nLos datos existentes pueden ser sobrescritos.\nEl usuario admin/admin se preservara.\n\nContinuar?')) return;
  if (!confirm('Estas SEGURO? Esta operacion no se puede deshacer.')) return;
  dbloaderExecute();
}

async function dbloaderExecute() {
  var progEl = document.getElementById('dbloader-progress');
  var resultsEl = document.getElementById('dbloader-results');
  progEl.style.display = 'block';
  resultsEl.style.display = 'none';

  progEl.innerHTML = '<div style="padding:14px;background:var(--bg3);border:1px solid var(--border);border-radius:8px;">' +
    '<div style="font-weight:700;margin-bottom:8px;display:flex;align-items:center;gap:6px;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="2" class="spin"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg> Ejecutando SQL...</div>' +
    '<div style="height:8px;background:var(--bg4);border-radius:4px;overflow:hidden;"><div id="dbloader-bar" style="height:100%;background:var(--blue);border-radius:4px;width:0%;transition:width .3s;"></div></div>' +
    '<div id="dbloader-status" style="font-size:11px;color:var(--text3);margin-top:4px;">Iniciando...</div></div>';

  try {
    var r = await authFetch(API_BASE + '/dev/load-database-content', {method: 'POST'});
    var data = await r.json();

    progEl.style.display = 'none';
    resultsEl.style.display = 'block';

    var isOk = data.status === 'completed';
    resultsEl.innerHTML = '<div style="padding:14px;background:' + (isOk ? 'rgba(63,185,80,.08)' : 'var(--red-bg)') + ';border:1px solid ' + (isOk ? 'rgba(63,185,80,.2)' : 'rgba(248,81,73,.2)') + ';border-radius:8px;">' +
      '<div style="font-weight:700;font-size:14px;color:' + (isOk ? 'var(--green)' : 'var(--red)') + ';margin-bottom:10px;">' + (isOk ? 'Carga completada' : 'Error en la carga') + '</div>' +
      '<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:10px;">' +
        '<div style="background:var(--bg3);border-radius:6px;padding:8px;text-align:center;"><div style="font-size:10px;color:var(--text3);">Exitosos</div><div style="font-size:18px;font-weight:800;color:var(--green);">' + data.statements_ok + '</div></div>' +
        '<div style="background:var(--bg3);border-radius:6px;padding:8px;text-align:center;"><div style="font-size:10px;color:var(--text3);">Errores</div><div style="font-size:18px;font-weight:800;color:' + (data.statements_error > 0 ? 'var(--red)' : 'var(--green)') + ';">' + data.statements_error + '</div></div>' +
        '<div style="background:var(--bg3);border-radius:6px;padding:8px;text-align:center;"><div style="font-size:10px;color:var(--text3);">Duracion</div><div style="font-size:12px;font-weight:700;">' + (data.started && data.finished ? Math.round((new Date(data.finished) - new Date(data.started))/1000) + 's' : '-') + '</div></div>' +
      '</div>' +
      (data.errors && data.errors.length > 0 ? '<div style="margin-top:8px;"><div style="font-size:11px;font-weight:700;color:var(--red);margin-bottom:4px;">Errores (primeros 20):</div><pre style="background:var(--bg3);border-radius:6px;padding:8px;font-size:10px;max-height:200px;overflow:auto;">' + escHtml(data.errors.map(function(e){return e.error;}).join('\n')) + '</pre></div>' : '') +
      '<div style="margin-top:10px;padding:8px;background:var(--green-bg);border-radius:6px;font-size:12px;color:var(--green);font-weight:600;">Usuario admin/admin preservado y verificado</div>' +
    '</div>';

    showToast(isOk ? 'Base de datos cargada correctamente' : 'Carga con errores');
  } catch(e) {
    progEl.innerHTML = '<div style="color:var(--red);padding:14px;">Error: ' + escHtml(e.message) + '</div>';
  }
}

// ══════════════════ RBAC ══════════════════

let _rbacUsers = [];
let _rbacRoles = [];

async function loadRbacUsers() {
  try {
    const [usersRes, rolesRes] = await Promise.all([
      authFetch(API_BASE+'/rbac/usuarios?limit=500').then(r=>r.json()),
      authFetch(API_BASE+'/rbac/roles').then(r=>r.json()),
    ]);
    _rbacUsers = usersRes.usuarios || [];
    _rbacRoles = rolesRes || [];
    renderRbacStats();
    renderRbacUsers(_rbacUsers);
    populateRoleFilter();
  } catch(e) {
    document.getElementById('rbac-users-tbody').innerHTML = '<tr><td colspan="8" style="text-align:center;color:var(--red);">Error: '+escHtml(e.message)+'</td></tr>';
  }
}

function renderRbacStats() {
  const total = _rbacUsers.length;
  const activos = _rbacUsers.filter(u=>u.activo).length;
  const conLogin = _rbacUsers.filter(u=>u.ultimo_login).length;
  const roles = new Set(_rbacUsers.map(u=>u.role_code)).size;
  document.getElementById('rbac-stats').innerHTML =
    '<div style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:12px 14px;"><div style="font-size:10px;color:var(--text3);text-transform:uppercase;font-weight:600;">'+t('rbac.total_users')+'</div><div style="font-size:22px;font-weight:800;color:var(--blue);">'+total+'</div></div>'+
    '<div style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:12px 14px;"><div style="font-size:10px;color:var(--text3);text-transform:uppercase;font-weight:600;">'+t('rbac.active')+'</div><div style="font-size:22px;font-weight:800;color:var(--green);">'+activos+'</div></div>'+
    '<div style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:12px 14px;"><div style="font-size:10px;color:var(--text3);text-transform:uppercase;font-weight:600;">'+t('rbac.logged_in')+'</div><div style="font-size:22px;font-weight:800;color:var(--orange);">'+conLogin+'</div></div>'+
    '<div style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:12px 14px;"><div style="font-size:10px;color:var(--text3);text-transform:uppercase;font-weight:600;">'+t('rbac.roles_used')+'</div><div style="font-size:22px;font-weight:800;color:var(--purple);">'+roles+'</div></div>';
}

function renderRbacUsers(users) {
  const tbody = document.getElementById('rbac-users-tbody');
  if (!users.length) {
    tbody.innerHTML = '<tr><td colspan="8" class="no-data">No se encontraron usuarios</td></tr>';
    return;
  }
  tbody.innerHTML = users.map((u,i) => {
    const initials = (u.nombre_completo||'?').split(' ').map(w=>w[0]).join('').substring(0,2).toUpperCase();
    const roleColor = u.role_color || '#6B7280';
    const loginDate = u.ultimo_login ? new Date(u.ultimo_login).toLocaleDateString(LANG==='en'?'en-US':'es-ES',{day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'}) : '<span style="color:var(--text3);">'+t('rbac.never')+'</span>';
    return '<tr>'+
      '<td style="color:var(--text3);">'+(i+1)+'</td>'+
      '<td><div style="display:flex;align-items:center;gap:8px;">'+
        '<div style="width:28px;height:28px;border-radius:50%;background:'+roleColor+';display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:800;color:#fff;flex-shrink:0;">'+initials+'</div>'+
        '<div><div style="font-weight:600;">'+escHtml(u.nombre_completo)+'</div>'+
        (u.id_recurso ? '<span style="font-size:10px;color:var(--cyan);font-family:var(--mono);">'+escHtml(u.id_recurso)+'</span>' : '')+
        (u.id_directivo ? '<span style="font-size:10px;color:var(--orange);font-family:var(--mono);">'+escHtml(u.id_directivo)+'</span>' : '')+
        '</div></div></td>'+
      '<td style="font-family:var(--mono);font-size:11px;">'+escHtml(u.email)+'</td>'+
      '<td><span style="padding:2px 8px;border-radius:4px;font-size:10px;font-weight:700;background:'+roleColor+'22;color:'+roleColor+';">'+escHtml(u.role_code)+'</span></td>'+
      '<td style="font-size:11px;">'+escHtml(u.departamento||'-')+'</td>'+
      '<td style="font-size:11px;">'+loginDate+'</td>'+
      '<td>'+(u.activo ? '<span style="color:var(--green);font-weight:700;font-size:11px;">'+t('common.active')+'</span>' : '<span style="color:var(--red);font-weight:700;font-size:11px;">'+t('common.inactive')+'</span>')+'</td>'+
      '<td><div style="display:flex;gap:4px;">'+
        '<button onclick="showEditUserForm('+u.id_usuario+')" style="background:var(--blue-bg);border:1px solid rgba(45,126,247,.2);color:var(--blue);border-radius:4px;padding:3px 8px;font-size:10px;font-weight:600;cursor:pointer;" title="'+t('common.edit')+'">'+t('common.edit')+'</button>'+
        '<button onclick="resetUserPass('+u.id_usuario+',\''+escHtml(u.nombre_completo)+'\')" style="background:var(--orange-bg);border:1px solid rgba(240,136,62,.2);color:var(--orange);border-radius:4px;padding:3px 8px;font-size:10px;font-weight:600;cursor:pointer;" title="Reset Pass">'+t('rbac.reset_pass')+'</button>'+
      '</div></td>'+
    '</tr>';
  }).join('');
}

function populateRoleFilter() {
  const sel = document.getElementById('rbac-role-filter');
  sel.innerHTML = '<option value="">'+t('rbac.all_roles')+'</option>';
  _rbacRoles.forEach(r => {
    sel.innerHTML += '<option value="'+escHtml(r.code)+'">'+escHtml(r.code)+' ('+r.total_usuarios+')</option>';
  });
}

function filterRbacUsers(val) {
  const q = val.toLowerCase();
  const roleFilter = document.getElementById('rbac-role-filter').value;
  const filtered = _rbacUsers.filter(u => {
    const matchText = !q || (u.nombre_completo||'').toLowerCase().includes(q) || (u.email||'').toLowerCase().includes(q) || (u.departamento||'').toLowerCase().includes(q);
    const matchRole = !roleFilter || u.role_code === roleFilter;
    return matchText && matchRole;
  });
  renderRbacUsers(filtered);
}

function filterRbacByRole(val) {
  filterRbacUsers(document.getElementById('rbac-search').value);
}

// ── Create User Form ──
function showCreateUserForm() {
  const roleOpts = _rbacRoles.map(r => '<option value="'+escHtml(r.code)+'">'+escHtml(r.code)+' - '+escHtml(r.nombre)+'</option>').join('');
  const html = '<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">'+
    '<div class="login-field"><label>Nombre Completo *</label><input type="text" id="nu-nombre" placeholder="Nombre Apellido1 Apellido2"></div>'+
    '<div class="login-field"><label>Email *</label><input type="text" id="nu-email" placeholder="nombre@cognitivepmo.com"></div>'+
    '<div class="login-field"><label>Rol *</label><select id="nu-role" style="width:100%;padding:10px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:8px;font-size:13px;">'+roleOpts+'</select></div>'+
    '<div class="login-field"><label>Contraseña</label><input type="text" id="nu-pass" value="12345" placeholder="12345"></div>'+
    '<div class="login-field"><label>Departamento</label><input type="text" id="nu-dept" placeholder="Ej: Backend, Soporte..."></div>'+
    '<div class="login-field"><label>Cargo</label><input type="text" id="nu-cargo" placeholder="Ej: Técnico N2 - Backend"></div>'+
    '<div class="login-field"><label>ID Recurso (FTE)</label><input type="text" id="nu-recurso" placeholder="FTE-XXX (opcional)"></div>'+
    '<div class="login-field"><label>ID Directivo</label><input type="text" id="nu-directivo" placeholder="DIR-XXX (opcional)"></div>'+
  '</div>'+
  '<div style="display:flex;gap:8px;margin-top:16px;justify-content:flex-end;">'+
    '<button onclick="document.getElementById(\'simple-modal-overlay\').remove()" style="background:var(--bg3);border:1px solid var(--border);color:var(--text2);border-radius:6px;padding:8px 20px;font-size:13px;cursor:pointer;">Cancelar</button>'+
    '<button onclick="doCreateUser()" style="background:linear-gradient(135deg,#f59e0b,#d97706);border:none;color:#fff;border-radius:6px;padding:8px 20px;font-size:13px;font-weight:700;cursor:pointer;">Crear Usuario</button>'+
  '</div>';
  showSimpleModal('Crear Nuevo Usuario', html);
}

async function doCreateUser() {
  const body = {
    nombre_completo: document.getElementById('nu-nombre').value.trim(),
    email: document.getElementById('nu-email').value.trim(),
    role_code: document.getElementById('nu-role').value,
    password: document.getElementById('nu-pass').value || '12345',
    departamento: document.getElementById('nu-dept').value.trim() || null,
    cargo: document.getElementById('nu-cargo').value.trim() || null,
    id_recurso: document.getElementById('nu-recurso').value.trim() || null,
    id_directivo: document.getElementById('nu-directivo').value.trim() || null,
  };
  if (!body.nombre_completo || !body.email) { alert('Nombre y Email son obligatorios'); return; }
  try {
    const r = await authFetch(API_BASE+'/rbac/usuarios', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(body)});
    const data = await r.json();
    if (!r.ok) { alert('Error: '+(data.detail||'Error desconocido')); return; }
    document.getElementById('simple-modal-overlay').remove();
    showToast('Usuario creado: '+body.email);
    loadRbacUsers();
  } catch(e) { alert('Error: '+e.message); }
}

// ── Edit User Form ──
function showEditUserForm(userId) {
  const user = _rbacUsers.find(u => u.id_usuario === userId);
  if (!user) return;
  const roleOpts = _rbacRoles.map(r => '<option value="'+escHtml(r.code)+'"'+(r.code===user.role_code?' selected':'')+'>'+escHtml(r.code)+' - '+escHtml(r.nombre)+'</option>').join('');
  const html = '<div style="margin-bottom:14px;padding:10px;background:var(--bg3);border-radius:8px;display:flex;align-items:center;gap:10px;">'+
    '<div style="width:36px;height:36px;border-radius:50%;background:'+(user.role_color||'var(--blue)')+';display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:800;color:#fff;">'+(user.nombre_completo||'?').split(' ').map(w=>w[0]).join('').substring(0,2).toUpperCase()+'</div>'+
    '<div><div style="font-weight:700;">'+escHtml(user.nombre_completo)+'</div><div style="font-size:11px;color:var(--text2);font-family:var(--mono);">'+escHtml(user.email)+'</div></div>'+
  '</div>'+
  '<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">'+
    '<div class="login-field"><label>Nombre Completo</label><input type="text" id="eu-nombre" value="'+escHtml(user.nombre_completo||'')+'"></div>'+
    '<div class="login-field"><label>Rol</label><select id="eu-role" style="width:100%;padding:10px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:8px;font-size:13px;">'+roleOpts+'</select></div>'+
    '<div class="login-field"><label>Departamento</label><input type="text" id="eu-dept" value="'+escHtml(user.departamento||'')+'"></div>'+
    '<div class="login-field"><label>Cargo</label><input type="text" id="eu-cargo" value="'+escHtml(user.cargo||'')+'"></div>'+
    '<div class="login-field" style="grid-column:1/-1;"><label>Estado</label><select id="eu-activo" style="width:100%;padding:10px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:8px;font-size:13px;">'+
      '<option value="true"'+(user.activo?' selected':'')+'>Activo</option>'+
      '<option value="false"'+(!user.activo?' selected':'')+'>Inactivo</option>'+
    '</select></div>'+
  '</div>'+
  '<div style="display:flex;gap:8px;margin-top:16px;justify-content:flex-end;">'+
    '<button onclick="document.getElementById(\'simple-modal-overlay\').remove()" style="background:var(--bg3);border:1px solid var(--border);color:var(--text2);border-radius:6px;padding:8px 20px;font-size:13px;cursor:pointer;">Cancelar</button>'+
    '<button onclick="doEditUser('+userId+')" style="background:linear-gradient(135deg,#2563eb,#3b82f6);border:none;color:#fff;border-radius:6px;padding:8px 20px;font-size:13px;font-weight:700;cursor:pointer;">Guardar Cambios</button>'+
  '</div>';
  showSimpleModal('Editar Usuario #'+userId, html);
}

async function doEditUser(userId) {
  const body = {
    nombre_completo: document.getElementById('eu-nombre').value.trim() || null,
    role_code: document.getElementById('eu-role').value || null,
    departamento: document.getElementById('eu-dept').value.trim() || null,
    cargo: document.getElementById('eu-cargo').value.trim() || null,
    activo: document.getElementById('eu-activo').value === 'true',
  };
  try {
    const r = await authFetch(API_BASE+'/rbac/usuarios/'+userId, {method:'PUT', headers:{'Content-Type':'application/json'}, body:JSON.stringify(body)});
    const data = await r.json();
    if (!r.ok) { alert('Error: '+(data.detail||'Error')); return; }
    document.getElementById('simple-modal-overlay').remove();
    showToast('Usuario actualizado');
    loadRbacUsers();
  } catch(e) { alert('Error: '+e.message); }
}

// ── Reset Password ──
async function resetUserPass(userId, nombre) {
  if (!confirm(t('misc.confirm_reset')+' "'+nombre+'" '+t('misc.to_default'))) return;
  try {
    const r = await authFetch(API_BASE+'/rbac/usuarios/'+userId+'/reset-password', {method:'POST'});
    if (!r.ok) { const d = await r.json(); alert('Error: '+(d.detail||'Error')); return; }
    showToast(t('misc.password_reset')+' ('+nombre+')');
  } catch(e) { alert('Error: '+e.message); }
}

// ═══════════════════════════════════════════════════════════════
// RBAC ROLES & PERMISOS MANAGEMENT
// ═══════════════════════════════════════════════════════════════

var _allPermisos = [];
var _accionColors = {ver:'var(--green)',crear:'var(--blue)',editar:'var(--orange)',eliminar:'var(--red)',aprobar:'var(--purple)',exportar:'var(--cyan)',ejecutar:'var(--pink)',admin:'var(--red)'};

async function loadRbacRolesPanel() {
  try {
    var res = await Promise.all([
      authFetch(API_BASE+'/rbac/roles').then(function(r){return r.json();}),
      authFetch(API_BASE+'/rbac/permisos').then(function(r){return r.json();}),
    ]);
    _rbacRoles = res[0] || [];
    _allPermisos = res[1] || [];
    renderRolesCards();
  } catch(e) {
    document.getElementById('rbac-roles-list').innerHTML = '<div style="color:var(--red);">Error: '+escHtml(e.message)+'</div>';
  }
}

function renderRolesCards() {
  var container = document.getElementById('rbac-roles-list');
  container.innerHTML = _rbacRoles.map(function(r) {
    var color = r.color || '#6B7280';
    return '<div style="background:var(--bg3);border:1px solid var(--border);border-radius:10px;padding:14px;border-left:4px solid '+color+';cursor:pointer;transition:border-color .15s;" onclick="openRoleEditor('+r.id_role+')" onmouseenter="this.style.borderColor=\''+color+'\'" onmouseleave="this.style.borderColor=\'var(--border)\'">'+
      '<div style="display:flex;align-items:center;gap:10px;margin-bottom:6px;">'+
        '<div style="width:36px;height:36px;border-radius:8px;background:'+color+'22;display:flex;align-items:center;justify-content:center;flex-shrink:0;">'+
          '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="'+color+'" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>'+
        '</div>'+
        '<div style="flex:1;min-width:0;"><div style="font-weight:700;font-size:13px;">'+escHtml(r.nombre)+'</div>'+
          '<div style="font-family:var(--mono);font-size:10px;color:'+color+';font-weight:600;">'+escHtml(r.code)+'</div></div>'+
        '<div style="text-align:right;">'+
          '<div style="font-size:18px;font-weight:800;color:var(--blue);">'+r.total_permisos+'</div>'+
          '<div style="font-size:9px;color:var(--text3);text-transform:uppercase;">permisos</div>'+
        '</div>'+
      '</div>'+
      '<div style="font-size:11px;color:var(--text2);margin-bottom:8px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">'+escHtml(r.descripcion||'Sin descripción')+'</div>'+
      '<div style="display:flex;align-items:center;gap:6px;">'+
        '<span style="font-size:10px;color:var(--green);font-weight:600;">'+r.total_usuarios+' usuarios</span>'+
        (r.activo?'':'<span style="font-size:10px;color:var(--red);font-weight:600;">INACTIVO</span>')+
      '</div>'+
    '</div>';
  }).join('');
}

// ── Unified Role Editor (datos + permisos visual) ──
async function openRoleEditor(roleId) {
  var role = _rbacRoles.find(function(r){ return r.id_role === roleId; });
  if (!role) return;
  var color = role.color || '#6B7280';

  // Fetch assigned permisos
  var assigned;
  try {
    assigned = await authFetch(API_BASE+'/rbac/roles/'+roleId+'/permisos').then(function(r){return r.json();});
  } catch(e) { alert('Error cargando permisos'); return; }
  var assignedIds = new Set(assigned.map(function(p){ return p.id_permiso; }));

  // Group permisos by module
  var grouped = {};
  _allPermisos.forEach(function(p) {
    if (!grouped[p.modulo]) grouped[p.modulo] = [];
    grouped[p.modulo].push(p);
  });

  // Build HTML
  var html = '';

  // ── Role header info ──
  html += '<div style="display:flex;gap:12px;margin-bottom:16px;flex-wrap:wrap;">';
  html += '<div style="flex:1;min-width:200px;"><label style="font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;display:block;margin-bottom:4px;">Nombre</label><input type="text" id="er-nombre" value="'+escHtml(role.nombre||'')+'" style="width:100%;padding:8px 10px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:6px;font-size:13px;"></div>';
  html += '<div style="flex:1;min-width:200px;"><label style="font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;display:block;margin-bottom:4px;">Descripción</label><input type="text" id="er-desc" value="'+escHtml(role.descripcion||'')+'" style="width:100%;padding:8px 10px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:6px;font-size:13px;"></div>';
  html += '<div style="width:60px;"><label style="font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;display:block;margin-bottom:4px;">Color</label><input type="color" id="er-color" value="'+(role.color||'#6B7280')+'" style="width:44px;height:34px;border:1px solid var(--border);border-radius:6px;cursor:pointer;"></div>';
  html += '</div>';

  // ── Quick actions ──
  html += '<div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;">';
  html += '<span style="font-size:12px;font-weight:700;color:var(--text);">Permisos</span>';
  html += '<span style="font-size:11px;color:var(--text2);" id="rp-count">'+assignedIds.size+' de '+_allPermisos.length+'</span>';
  html += '<div style="margin-left:auto;display:flex;gap:4px;">';
  html += '<button onclick="rpSelectAll(true)" style="background:var(--green-bg);border:1px solid rgba(63,185,80,.2);color:var(--green);border-radius:4px;padding:3px 10px;font-size:10px;font-weight:700;cursor:pointer;">Marcar todos</button>';
  html += '<button onclick="rpSelectAll(false)" style="background:var(--red-bg);border:1px solid rgba(248,81,73,.2);color:var(--red);border-radius:4px;padding:3px 10px;font-size:10px;font-weight:700;cursor:pointer;">Desmarcar todos</button>';
  html += '</div></div>';

  // ── Permisos grid (same visual as "Mis Permisos") ──
  html += '<div style="max-height:50vh;overflow-y:auto;padding-right:4px;">';
  var modulos = Object.keys(grouped).sort();
  modulos.forEach(function(mod) {
    var perms = grouped[mod];
    var checkedCount = perms.filter(function(p){ return assignedIds.has(p.id_permiso); }).length;
    html += '<div style="margin-bottom:12px;">';
    html += '<div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;cursor:pointer;" onclick="rpToggleModule(\''+mod+'\')">';
    html += '<input type="checkbox" id="rp-mod-'+mod+'"'+(checkedCount===perms.length?' checked':'')+' style="accent-color:var(--blue);cursor:pointer;width:14px;height:14px;" onclick="event.stopPropagation();rpToggleModule(\''+mod+'\')">';
    html += '<span style="font-size:12px;font-weight:700;color:var(--blue);text-transform:uppercase;letter-spacing:1px;">'+escHtml(mod)+'</span>';
    html += '<span style="font-size:10px;color:var(--text3);">'+checkedCount+'/'+perms.length+'</span>';
    html += '</div>';
    html += '<div style="display:flex;flex-wrap:wrap;gap:4px;padding-left:22px;">';
    perms.forEach(function(p) {
      var checked = assignedIds.has(p.id_permiso);
      var c = _accionColors[p.accion] || 'var(--text2)';
      html += '<label style="display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:4px;font-size:11px;font-weight:600;cursor:pointer;background:'+c+'18;color:'+c+';opacity:'+(checked?'1':'.35')+';transition:opacity .15s;" title="'+escHtml(p.descripcion||p.code)+'">';
      html += '<input type="checkbox" class="rp-check" data-id="'+p.id_permiso+'" data-modulo="'+mod+'"'+(checked?' checked':'')+' style="accent-color:'+c+';cursor:pointer;width:12px;height:12px;" onchange="rpUpdateBadge(this)">';
      html += escHtml(p.accion);
      html += '</label>';
    });
    html += '</div></div>';
  });
  html += '</div>';

  // ── Footer buttons ──
  html += '<div style="display:flex;gap:8px;margin-top:14px;justify-content:space-between;align-items:center;">';
  if (role.total_usuarios === 0) {
    html += '<button onclick="deleteRole('+roleId+',\''+escHtml(role.code)+'\')" style="background:var(--red-bg);border:1px solid rgba(248,81,73,.2);color:var(--red);border-radius:6px;padding:8px 14px;font-size:12px;font-weight:600;cursor:pointer;">Eliminar Rol</button>';
  } else {
    html += '<span style="font-size:11px;color:var(--text3);">'+role.total_usuarios+' usuarios asignados</span>';
  }
  html += '<div style="display:flex;gap:8px;">';
  html += '<button onclick="document.getElementById(\'simple-modal-overlay\').remove()" style="background:var(--bg3);border:1px solid var(--border);color:var(--text2);border-radius:6px;padding:8px 20px;font-size:13px;cursor:pointer;">Cancelar</button>';
  html += '<button onclick="doSaveRole('+roleId+')" style="background:linear-gradient(135deg,#7c3aed,#a855f7);border:none;color:#fff;border-radius:6px;padding:8px 20px;font-size:13px;font-weight:700;cursor:pointer;">Guardar Todo</button>';
  html += '</div></div>';

  showSimpleModal(role.code+' — '+role.nombre, html);

  // Live counter update
  document.querySelectorAll('.rp-check').forEach(function(cb) {
    cb.addEventListener('change', rpUpdateCount);
  });
}

function rpUpdateBadge(cb) {
  var label = cb.parentElement;
  label.style.opacity = cb.checked ? '1' : '.35';
  rpUpdateCount();
}

function rpUpdateCount() {
  var total = document.querySelectorAll('.rp-check').length;
  var checked = document.querySelectorAll('.rp-check:checked').length;
  var el = document.getElementById('rp-count');
  if (el) el.textContent = checked + ' de ' + total;
}

function rpToggleModule(mod) {
  var modCb = document.getElementById('rp-mod-'+mod);
  var newState = modCb ? modCb.checked : true;
  document.querySelectorAll('.rp-check[data-modulo="'+mod+'"]').forEach(function(cb) {
    cb.checked = newState;
    cb.parentElement.style.opacity = newState ? '1' : '.35';
  });
  rpUpdateCount();
}

function rpSelectAll(state) {
  document.querySelectorAll('.rp-check').forEach(function(cb) {
    cb.checked = state;
    cb.parentElement.style.opacity = state ? '1' : '.35';
  });
  document.querySelectorAll('[id^="rp-mod-"]').forEach(function(cb) { cb.checked = state; });
  rpUpdateCount();
}

async function doSaveRole(roleId) {
  // Save role data + permisos in one go
  var roleBody = {
    nombre: document.getElementById('er-nombre').value.trim() || null,
    descripcion: document.getElementById('er-desc').value.trim() || null,
    color: document.getElementById('er-color').value,
  };
  var ids = [];
  document.querySelectorAll('.rp-check:checked').forEach(function(cb) {
    ids.push(parseInt(cb.getAttribute('data-id')));
  });
  try {
    // Update role info
    await authFetch(API_BASE+'/rbac/roles/'+roleId, {method:'PUT', headers:{'Content-Type':'application/json'}, body:JSON.stringify(roleBody)});
    // Update permisos
    var r = await authFetch(API_BASE+'/rbac/roles/'+roleId+'/permisos', {
      method:'PUT', headers:{'Content-Type':'application/json'},
      body:JSON.stringify({permisos:ids}),
    });
    var data = await r.json();
    if (!r.ok) { alert('Error: '+(data.detail||'Error')); return; }
    document.getElementById('simple-modal-overlay').remove();
    showToast('Rol guardado con '+data.permisos_count+' permisos');
    loadRbacRolesPanel();
  } catch(e) { alert('Error: '+e.message); }
}

// ── Create Role ──
function showCreateRoleForm() {
  var html = '<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">'+
    '<div class="login-field"><label>Código (único) *</label><input type="text" id="nr-code" placeholder="Ej: PM_EXTERNO" style="text-transform:uppercase;"></div>'+
    '<div class="login-field"><label>Nombre *</label><input type="text" id="nr-nombre" placeholder="Ej: Project Manager Externo"></div>'+
    '<div class="login-field" style="grid-column:1/-1;"><label>Descripción</label><input type="text" id="nr-desc" placeholder="Descripción del rol..."></div>'+
    '<div class="login-field"><label>Color</label><input type="color" id="nr-color" value="#6B7280" style="width:50px;height:34px;border:1px solid var(--border);border-radius:6px;cursor:pointer;"></div>'+
  '</div>'+
  '<div style="display:flex;gap:8px;margin-top:16px;justify-content:flex-end;">'+
    '<button onclick="document.getElementById(\'simple-modal-overlay\').remove()" style="background:var(--bg3);border:1px solid var(--border);color:var(--text2);border-radius:6px;padding:8px 20px;font-size:13px;cursor:pointer;">Cancelar</button>'+
    '<button onclick="doCreateRole()" style="background:linear-gradient(135deg,#f59e0b,#d97706);border:none;color:#fff;border-radius:6px;padding:8px 20px;font-size:13px;font-weight:700;cursor:pointer;">Crear Rol</button>'+
  '</div>';
  showSimpleModal('Crear Nuevo Rol', html);
}

async function doCreateRole() {
  var body = {
    code: (document.getElementById('nr-code').value || '').trim().toUpperCase().replace(/\s+/g,'_'),
    nombre: document.getElementById('nr-nombre').value.trim(),
    descripcion: document.getElementById('nr-desc').value.trim() || null,
    color: document.getElementById('nr-color').value || '#6B7280',
  };
  if (!body.code || !body.nombre) { alert('Código y Nombre son obligatorios'); return; }
  try {
    var r = await authFetch(API_BASE+'/rbac/roles', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(body)});
    var data = await r.json();
    if (!r.ok) { alert('Error: '+(data.detail||'Error')); return; }
    document.getElementById('simple-modal-overlay').remove();
    showToast('Rol "'+body.code+'" creado — haz click para configurar permisos');
    loadRbacRolesPanel();
  } catch(e) { alert('Error: '+e.message); }
}

// ── Delete Role ──
async function deleteRole(roleId, code) {
  if (!confirm('¿Eliminar el rol "'+code+'"? Esta acción no se puede deshacer.')) return;
  try {
    var ov = document.getElementById('simple-modal-overlay');
    if (ov) ov.remove();
    var r = await authFetch(API_BASE+'/rbac/roles/'+roleId, {method:'DELETE'});
    if (!r.ok) { var d = await r.json(); alert('Error: '+(d.detail||'Error')); return; }
    showToast('Rol "'+code+'" eliminado');
    loadRbacRolesPanel();
  } catch(e) { alert('Error: '+e.message); }
}

// ── Audit Log ──
async function loadRbacAudit() {
  try {
    const data = await authFetch(API_BASE+'/rbac/audit?limit=200').then(r=>r.json());
    const logs = data.logs || [];
    const tbody = document.getElementById('rbac-audit-tbody');
    if (!logs.length) {
      tbody.innerHTML = '<tr><td colspan="7" class="no-data">Sin registros de auditoría</td></tr>';
      return;
    }
    tbody.innerHTML = logs.map(l => {
      const ts = l.timestamp ? new Date(l.timestamp).toLocaleString('es-ES') : '-';
      const resColor = l.resultado==='OK' ? 'var(--green)' : l.resultado==='DENEGADO' ? 'var(--red)' : 'var(--orange)';
      return '<tr>'+
        '<td style="font-family:var(--mono);font-size:11px;white-space:nowrap;">'+ts+'</td>'+
        '<td>'+escHtml(l.nombre_completo||l.email||'-')+'</td>'+
        '<td><span style="font-weight:600;">'+escHtml(l.accion||'-')+'</span></td>'+
        '<td>'+escHtml(l.modulo||'-')+'</td>'+
        '<td><span style="color:'+resColor+';font-weight:700;font-size:11px;">'+escHtml(l.resultado)+'</span></td>'+
        '<td style="font-family:var(--mono);font-size:11px;">'+escHtml(l.ip_address||'-')+'</td>'+
        '<td style="font-size:10px;max-width:200px;overflow:hidden;text-overflow:ellipsis;">'+escHtml(JSON.stringify(l.detalle||{}))+'</td>'+
      '</tr>';
    }).join('');
  } catch(e) {
    document.getElementById('rbac-audit-tbody').innerHTML = '<tr><td colspan="7" style="color:var(--red);">Error: '+escHtml(e.message)+'</td></tr>';
  }
}

// ── Organigrama ──
async function loadRbacOrg() {
  try {
    const data = await authFetch(API_BASE+'/directorio/organigrama').then(r=>r.json());
    const roots = data.organigrama || [];
    const container = document.getElementById('rbac-org-content');
    const levelColors = {'C-LEVEL':'#EF4444','VP':'#8B5CF6','DIRECTOR':'#2563EB','SUBDIRECTOR':'#0891B2','GERENTE':'#10B981','COORDINADOR':'#06B6D4','JEFE_EQUIPO':'#F59E0B'};

    function renderNode(node, depth) {
      const color = levelColors[node.nivel_organizativo] || '#6B7280';
      const indent = depth * 28;
      let html = '<div style="display:flex;align-items:center;gap:10px;padding:8px 12px;margin-left:'+indent+'px;border-left:2px solid '+color+'44;margin-bottom:2px;background:var(--bg3);border-radius:0 8px 8px 0;cursor:default;" title="'+escHtml(node.email)+'">';
      html += '<div style="width:32px;height:32px;border-radius:50%;background:'+color+';display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;color:#fff;flex-shrink:0;">'+(node.nombre_completo||'?').split(' ').map(w=>w[0]).join('').substring(0,2).toUpperCase()+'</div>';
      html += '<div style="flex:1;min-width:0;"><div style="font-weight:600;font-size:13px;">'+escHtml(node.nombre_completo)+'</div><div style="font-size:11px;color:var(--text2);">'+escHtml(node.cargo)+'</div></div>';
      html += '<span style="padding:2px 8px;border-radius:4px;font-size:9px;font-weight:700;background:'+color+'22;color:'+color+';white-space:nowrap;">'+escHtml(node.nivel_organizativo)+'</span>';
      html += '<span style="font-size:10px;color:var(--text3);font-family:var(--mono);">'+escHtml(node.email||'')+'</span>';
      html += '</div>';
      if (node.subordinados && node.subordinados.length) {
        node.subordinados.forEach(sub => { html += renderNode(sub, depth+1); });
      }
      return html;
    }

    container.innerHTML = '<div style="margin-bottom:10px;font-size:12px;color:var(--text2);">Total directivos: <strong style="color:var(--text);">'+data.total_directivos+'</strong></div>' +
      roots.map(r => renderNode(r, 0)).join('');
  } catch(e) {
    document.getElementById('rbac-org-content').innerHTML = '<div style="color:var(--red);">Error: '+escHtml(e.message)+'</div>';
  }
}

// ═══════════════════════════════════════════════════════════════
// FIRST LOGIN PASSWORD CHANGE
// ═══════════════════════════════════════════════════════════════

async function doChangeFirstPassword() {
  const newPass = document.getElementById('chpass-new').value;
  const confirm = document.getElementById('chpass-confirm').value;
  const errEl = document.getElementById('chpass-error');
  const btn = document.getElementById('chpass-btn');

  if (!newPass || newPass.length < 4) {
    errEl.textContent = t('chpass.min');
    errEl.classList.add('show');
    return;
  }
  if (newPass !== confirm) {
    errEl.textContent = t('chpass.mismatch');
    errEl.classList.add('show');
    return;
  }
  if (newPass === '12345') {
    errEl.textContent = t('chpass.same');
    errEl.classList.add('show');
    return;
  }
  errEl.classList.remove('show');
  btn.disabled = true;
  btn.textContent = t('chpass.changing');
  try {
    const r = await authFetch(API_BASE+'/auth/cambiar-password', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({password_actual:'12345', password_nueva:newPass}),
    });
    const data = await r.json();
    if (!r.ok) {
      errEl.textContent = data.detail || 'Error al cambiar contraseña';
      errEl.classList.add('show');
      btn.disabled = false;
      btn.textContent = t('chpass.btn');
      return;
    }
    // Update local data
    AUTH_USER.requiere_cambio_password = false;
    localStorage.setItem('pmo_user', JSON.stringify(AUTH_USER));
    // Hide change-pass screen, show app
    document.getElementById('change-pass-screen').style.display = 'none';
    document.getElementById('login-screen').style.display = 'none';
    updateTopbarUser();
    loadTeam(); loadProjects(); loadKanban(); loadBudgets();
    showToast(t('chpass.success'));
  } catch(e) {
    errEl.textContent = t('login.error.connection');
    errEl.classList.add('show');
  }
  btn.disabled = false;
  btn.textContent = t('chpass.btn');
}

// ── INIT ── apply saved language + check existing session
setLang(LANG);
checkExistingSession();
</script>
</body>
</html>
