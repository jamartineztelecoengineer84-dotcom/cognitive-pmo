<div class="statusbar">
  <div class="status-item">
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
    Gateway: 8099
    <span class="status-badge online">Online</span>
  </div>
  <div class="status-item">
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
    PostgreSQL 15
    <span class="status-badge online">Online</span>
  </div>
  <div class="status-item">
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
    Agents IA: Claude
    <span class="status-badge online">Online</span>
  </div>
  <div class="server-info">
    NasJose Server
    <span class="server-ip">192.168.1.49</span>
  </div>
</div>
<div class="page active" id="page-run">
  <div class="pipeline-layout">
    <div class="pipeline-main">
      <div class="panel">
        <div class="panel-header">
          <div class="panel-title" style="display:flex;align-items:center;gap:8px;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="1.8"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
            Registro de Incidencia ITSM
          </div>
          <div style="display:flex;gap:6px;align-items:center;">
            <span class="mode-badge mode-run">ITIL 4</span>
            <span style="font-size:9px;padding:2px 6px;border-radius:4px;background:var(--green-bg);color:var(--green);font-weight:600;" id="itsm-ticket-id"></span>
          </div>
        </div>
        <div style="padding:12px 14px;">
          <!-- Row 1: Catálogo + Canal -->
          <div style="display:grid;grid-template-columns:3fr 1fr;gap:8px;margin-bottom:8px;">
            <div class="sap-field" style="margin:0;">
              <label class="sap-label">📋 Tipo de Incidencia (Catálogo ITSM)</label>
              <select class="sap-input" id="itsm-catalogo" onchange="itsmCatalogoChanged()">
                <option value="">— Seleccionar del catálogo —</option>
              </select>
            </div>
            <div class="sap-field" style="margin:0;">
              <label class="sap-label">📡 Canal de Entrada</label>
              <select class="sap-input" id="itsm-canal">
                <option value="Portal ITSM">Portal ITSM</option>
                <option value="Teléfono">Teléfono</option>
                <option value="Email">Email</option>
                <option value="Chat">Chat</option>
                <option value="Monitorización">Monitorización</option>
                <option value="Presencial">Presencial</option>
              </select>
            </div>
          </div>
          <!-- Row 2: Auto-populated info bar -->
          <div id="itsm-info-bar" style="display:none;background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:8px 12px;margin-bottom:8px;">
            <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:center;">
              <div><span style="font-size:9px;color:var(--text3);text-transform:uppercase;">Complejidad</span><div style="font-size:12px;font-weight:700;" id="itsm-complejidad">—</div></div>
              <div><span style="font-size:9px;color:var(--text3);text-transform:uppercase;">Área</span><div style="font-size:12px;font-weight:700;" id="itsm-area-auto">—</div></div>
              <div><span style="font-size:9px;color:var(--text3);text-transform:uppercase;">SLA Objetivo</span><div style="font-size:12px;font-weight:700;font-family:var(--mono);" id="itsm-sla-obj">—</div></div>
              <div><span style="font-size:9px;color:var(--text3);text-transform:uppercase;">Nivel Mínimo</span><div style="font-size:12px;font-weight:700;" id="itsm-nivel-min">—</div></div>
              <div><span style="font-size:9px;color:var(--text3);text-transform:uppercase;">Skills Req.</span><div style="font-size:12px;font-weight:700;font-family:var(--mono);" id="itsm-skills-count">—</div></div>
              <div style="margin-left:auto;"><span style="font-size:9px;color:var(--text3);text-transform:uppercase;">Prioridad Sugerida</span><div style="font-size:16px;font-weight:800;font-family:var(--mono);" id="itsm-prio-sugerida">—</div></div>
            </div>
          </div>
          <!-- Row 3: Impact × Urgency Matrix -->
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:8px;margin-bottom:8px;">
            <div class="sap-field" style="margin:0;">
              <label class="sap-label">💥 Impacto</label>
              <select class="sap-input" id="itsm-impacto" onchange="itsmCalcPriority()">
                <option value="Crítico">1 — Crítico (Organización)</option>
                <option value="Alto">2 — Alto (Departamento)</option>
                <option value="Medio" selected>3 — Medio (Grupo)</option>
                <option value="Bajo">4 — Bajo (Individual)</option>
              </select>
            </div>
            <div class="sap-field" style="margin:0;">
              <label class="sap-label">⏱ Urgencia</label>
              <select class="sap-input" id="itsm-urgencia" onchange="itsmCalcPriority()">
                <option value="Crítica">1 — Crítica (Inmediata)</option>
                <option value="Alta">2 — Alta (&lt;2h)</option>
                <option value="Media" selected>3 — Media (&lt;8h)</option>
                <option value="Baja">4 — Baja (Planificable)</option>
              </select>
            </div>
            <div class="sap-field" style="margin:0;">
              <label class="sap-label">🎯 Prioridad Calculada</label>
              <div id="itsm-prio-calc" style="background:var(--bg2);border:1px solid var(--border);border-radius:6px;padding:7px 10px;font-family:var(--mono);font-size:16px;font-weight:800;text-align:center;color:var(--yellow);">P3</div>
            </div>
            <div class="sap-field" style="margin:0;">
              <label class="sap-label">⏰ SLA (horas)</label>
              <input class="sap-input mono" id="itsm-sla" type="number" min="0.5" step="0.5" value="24" style="text-align:center;font-weight:700;">
            </div>
          </div>
          <!-- Row 4: Description + Service + CI -->
          <div style="display:grid;grid-template-columns:2fr 1fr 1fr;gap:8px;margin-bottom:8px;">
            <div class="sap-field" style="margin:0;">
              <label class="sap-label">📝 Descripción Detallada</label>
              <textarea class="sap-textarea" id="run-input" placeholder="Describe el síntoma, contexto y cualquier detalle relevante para el diagnóstico..." style="min-height:52px;"></textarea>
            </div>
            <div>
              <div class="sap-field" style="margin:0 0 8px;">
                <label class="sap-label">🖥 Servicio Afectado</label>
                <select class="sap-input" id="itsm-servicio">
                  <option value="">— Seleccionar —</option>
                  <option value="Banca Online">Banca Online</option>
                  <option value="App Móvil">App Móvil</option>
                  <option value="Bizum">Bizum / Pagos</option>
                  <option value="SWIFT">SWIFT Alliance</option>
                  <option value="Red Oficinas">Red Oficinas</option>
                  <option value="Cajeros ATM">Cajeros ATM</option>
                  <option value="Core Bancario">Core Bancario</option>
                  <option value="Email/Ofimática">Email / Ofimática</option>
                  <option value="VPN">VPN Corporativa</option>
                  <option value="BBDD">Base de Datos</option>
                  <option value="Infraestructura">Infraestructura</option>
                  <option value="Seguridad">Seguridad Perimetral</option>
                </select>
              </div>
              <div class="sap-field" style="margin:0;">
                <label class="sap-label">👤 Reportado por</label>
                <input class="sap-input" id="itsm-reporter" placeholder="Nombre del reportante">
              </div>
            </div>
            <div>
              <div class="sap-field" style="margin:0 0 8px;">
                <label class="sap-label">🔧 CI Afectado (CMDB)</label>
                <select class="sap-input" id="itsm-ci" style="padding:6px 8px;"><option value="">Cargando activos CMDB...</option></select>
              </div>
              <div class="sap-field" style="margin:0;">
                <label class="sap-label">💼 Impacto de Negocio</label>
                <select class="sap-input" id="itsm-impacto-neg">
                  <option value="">— Evaluar —</option>
                  <option value="Pérdida financiera directa">Pérdida financiera directa</option>
                  <option value="Interrupción servicio cliente">Interrupción servicio cliente</option>
                  <option value="Riesgo regulatorio">Riesgo regulatorio (BCE/CNMV)</option>
                  <option value="Degradación rendimiento">Degradación rendimiento</option>
                  <option value="Impacto interno operativo">Impacto interno operativo</option>
                  <option value="Impacto cosmético">Impacto cosmético / menor</option>
                </select>
              </div>
            </div>
          </div>
          <!-- Buttons -->
          <div style="display:flex;gap:8px;align-items:center;">
            <button class="btn-exec" id="run-exec-btn" onclick="itsmSubmitAndPipeline()" style="flex:1;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:middle;margin-right:4px;"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              Registrar Incidencia + Ejecutar Pipeline IA
            </button>
            <button class="btn-reset" onclick="resetPipeline('run')" style="white-space:nowrap;">↺ Reset</button>
          </div>
        </div>
      </div>
      <div class="panel">
        <div class="panel-header">
          <div class="panel-title">Pipeline de Agentes IA</div>
          <button class="config-btn" onclick="showToast('Agentes IA nativos Claude — No requiere configuración')" style="opacity:.5;">⚙ Agentes IA</button>
        </div>
        <div class="pipeline-area" id="run-pipeline-area" style="border-style:solid;min-height:auto;padding:0;">
          <div id="run-pipeline-idle">
            <div style="padding:10px 14px;">
              <div style="display:flex;align-items:center;gap:6px;margin-bottom:8px;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
                <span style="font-size:12px;font-weight:700;">Cascada RUN — 4 Agentes IA</span>
                <span style="margin-left:auto;font-size:9px;padding:2px 6px;border-radius:8px;background:var(--bg3);border:1px solid var(--border);color:var(--text3);font-family:var(--mono);">READY</span>
              </div>
              <!-- Compact horizontal flow -->
              <div style="display:flex;align-items:center;gap:0;">
                <div style="display:flex;align-items:center;gap:4px;background:linear-gradient(135deg,rgba(59,130,246,.12),rgba(59,130,246,.05));border:1px solid rgba(59,130,246,.25);border-radius:14px;padding:3px 10px;flex-shrink:0;">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                  <span style="font-size:9px;font-weight:600;color:var(--blue);">ITSM Input</span>
                </div>
                <svg width="16" height="10" style="flex-shrink:0;"><line x1="0" y1="5" x2="10" y2="5" stroke="#30363d" stroke-width="1.5" stroke-dasharray="3,2"><animate attributeName="stroke-dashoffset" from="5" to="0" dur="0.8s" repeatCount="indefinite"/></line><polygon points="10,2 16,5 10,8" fill="#30363d"/></svg>
                <div style="background:var(--bg2);border:1px solid rgba(59,130,246,.25);border-radius:8px;padding:5px 7px;display:flex;align-items:center;gap:5px;flex:1;min-width:0;border-left:3px solid #3b82f6;">
                  <div style="width:22px;height:22px;flex-shrink:0;display:flex;align-items:center;justify-content:center;background:rgba(59,130,246,.1);border-radius:5px;" id="run-flow-icon-1"></div>
                  <div style="min-width:0;"><div style="font-size:9px;font-weight:700;color:#3b82f6;">AG-001 Dispatcher</div><div style="font-size:7px;color:var(--text3);">Triaje NLP · P1-P4</div></div>
                </div>
                <svg width="14" height="10" style="flex-shrink:0;"><line x1="0" y1="5" x2="8" y2="5" stroke="#30363d" stroke-width="1.5" stroke-dasharray="3,2"><animate attributeName="stroke-dashoffset" from="5" to="0" dur="0.8s" repeatCount="indefinite"/></line><polygon points="8,2 14,5 8,8" fill="#30363d"/></svg>
                <div style="background:var(--bg2);border:1px solid rgba(139,92,246,.25);border-radius:8px;padding:5px 7px;display:flex;align-items:center;gap:5px;flex:1;min-width:0;border-left:3px solid #8b5cf6;">
                  <div style="width:22px;height:22px;flex-shrink:0;display:flex;align-items:center;justify-content:center;background:rgba(139,92,246,.1);border-radius:5px;" id="run-flow-icon-2"></div>
                  <div style="min-width:0;"><div style="font-size:9px;font-weight:700;color:#8b5cf6;">AG-002 Resources</div><div style="font-size:7px;color:var(--text3);">Matching · 150 FTEs</div></div>
                </div>
                <svg width="14" height="10" style="flex-shrink:0;"><line x1="0" y1="5" x2="8" y2="5" stroke="#30363d" stroke-width="1.5" stroke-dasharray="3,2"><animate attributeName="stroke-dashoffset" from="5" to="0" dur="0.8s" repeatCount="indefinite"/></line><polygon points="8,2 14,5 8,8" fill="#30363d"/></svg>
                <div style="background:var(--bg2);border:1px solid rgba(249,115,22,.25);border-radius:8px;padding:5px 7px;display:flex;align-items:center;gap:5px;flex:1;min-width:0;border-left:3px solid #f97316;">
                  <div style="width:22px;height:22px;flex-shrink:0;display:flex;align-items:center;justify-content:center;background:rgba(249,115,22,.1);border-radius:5px;" id="run-flow-icon-3"></div>
                  <div style="min-width:0;"><div style="font-size:9px;font-weight:700;color:#f97316;">AG-003 Forecaster</div><div style="font-size:7px;color:var(--text3);">Prophet · Freeze</div></div>
                </div>
                <svg width="14" height="10" style="flex-shrink:0;"><line x1="0" y1="5" x2="8" y2="5" stroke="#30363d" stroke-width="1.5" stroke-dasharray="3,2"><animate attributeName="stroke-dashoffset" from="5" to="0" dur="0.8s" repeatCount="indefinite"/></line><polygon points="8,2 14,5 8,8" fill="#30363d"/></svg>
                <div style="background:var(--bg2);border:1px solid rgba(6,182,212,.25);border-radius:8px;padding:5px 7px;display:flex;align-items:center;gap:5px;flex:1;min-width:0;border-left:3px solid #06b6d4;">
                  <div style="width:22px;height:22px;flex-shrink:0;display:flex;align-items:center;justify-content:center;background:rgba(6,182,212,.1);border-radius:5px;" id="run-flow-icon-4"></div>
                  <div style="min-width:0;"><div style="font-size:9px;font-weight:700;color:#06b6d4;">AG-004 Gatekeeper</div><div style="font-size:7px;color:var(--text3);">Buffer · Freeze</div></div>
                </div>
                <svg width="16" height="10" style="flex-shrink:0;"><line x1="0" y1="5" x2="10" y2="5" stroke="#30363d" stroke-width="1.5" stroke-dasharray="3,2"><animate attributeName="stroke-dashoffset" from="5" to="0" dur="0.8s" repeatCount="indefinite"/></line><polygon points="10,2 16,5 10,8" fill="#30363d"/></svg>
                <div style="display:flex;align-items:center;gap:4px;background:linear-gradient(135deg,rgba(63,185,80,.12),rgba(63,185,80,.05));border:1px solid rgba(63,185,80,.25);border-radius:14px;padding:3px 10px;flex-shrink:0;">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                  <span style="font-size:9px;font-weight:600;color:var(--green);">Output</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <!-- SSE Real-time components (legacy - hidden, replaced by run-dashboard) -->
      <div style="margin:0 14px;display:none !important;">
        <div id="sse-sla-counter" class="sla-counter">
          <div style="display:flex;justify-content:space-between;font-size:10px;color:var(--text3);margin-bottom:4px;">
            <span id="sse-sla-start">--</span>
            <span style="font-weight:700;" id="sse-sla-label">SLA</span>
            <span id="sse-sla-end">--</span>
          </div>
          <div class="sla-digits" id="sse-sla-digits">--:--:--</div>
          <div class="sla-bar"><div class="sla-bar-fill" id="sse-sla-bar-fill" style="width:0%;background:#3fb950;"></div></div>
        </div>
        <div id="sse-tasks-area" style="display:none;margin-top:12px;">
          <div style="font-size:12px;font-weight:700;margin-bottom:6px;display:flex;align-items:center;gap:6px;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18"/></svg>
            Tareas de Resoluci&oacute;n
          </div>
          <div id="sse-tasks-list"></div>
        </div>
        <div id="sse-kanban-mini" class="sse-kanban-mini" style="display:none;">
          <div class="sse-kanban-col"><div class="sse-kanban-col-title">Backlog</div><div id="sse-kb-backlog"></div></div>
          <div class="sse-kanban-col"><div class="sse-kanban-col-title">En Progreso</div><div id="sse-kb-progress"></div></div>
          <div class="sse-kanban-col"><div class="sse-kanban-col-title">En Revisi&oacute;n</div><div id="sse-kb-review"></div></div>
          <div class="sse-kanban-col"><div class="sse-kanban-col-title">Done</div><div id="sse-kb-done"></div></div>
        </div>
        <div id="sse-log" class="sse-log"></div>
      </div>
      <!-- Buffer de Incidencias Registradas -->
      <div class="panel" style="margin:0 14px 14px;">
        <div class="panel-header" style="padding:8px 12px;">
          <div class="panel-title" style="font-size:12px;display:flex;align-items:center;gap:6px;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="1.8"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            Incidencias Registradas
            <span style="font-family:var(--mono);font-size:10px;color:var(--text3);" id="run-buffer-count">(0)</span>
          </div>
        </div>
        <div id="run-buffer-list" style="padding:8px;max-height:220px;overflow-y:auto;">
          <div style="font-size:10px;color:var(--text3);text-align:center;padding:8px;">Cargando incidencias...</div>
        </div>
      </div>
    </div>
    <div class="pipeline-sidebar">
      <div class="side-panel">
        <div class="side-title" style="display:flex;align-items:center;gap:7px;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/><circle cx="12" cy="12" r="10" fill="#fbbf24" fill-opacity=".08"/></svg>Task Monitoring</div>
        <div class="no-data" id="run-tasks"><div class="no-data-icon">🕐</div>No hay tareas activas</div>
      </div>
      <div class="side-panel">
        <div class="side-title" style="display:flex;align-items:center;gap:7px;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22d3ee" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>Historial Buffer</div>
        <div class="no-data" id="run-hist"><div class="no-data-icon">🕐</div>Sin ejecuciones previas</div>
      </div>
      <div class="side-panel">
        <div class="side-title" style="display:flex;align-items:center;gap:7px;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#a3e635" stroke-width="2" stroke-linecap="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>Estado del Sistema</div>
        <div class="sys-row"><span>Agentes Activos</span><span class="sys-val val-blue">4/4</span></div>
        <div class="sys-row"><span>Pipeline Status</span><span class="sys-val val-idle" id="run-status-val">Idle</span></div>
        <div class="sys-row"><span>Técnicos Staff</span><span class="sys-val">150</span></div>
      </div>
      <div class="side-panel">
        <div class="side-title" style="display:flex;align-items:center;gap:7px;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.663 17h4.673M12 3a6 6 0 0 1 6 6v1a2 2 0 0 0 2 2H4a2 2 0 0 0 2-2V9a6 6 0 0 1 6-6z" fill="#8b5cf6" fill-opacity=".1"/><path d="M12 17v4M8 21h8"/></svg>AI Insight Explorer</div>
        <div class="sys-row"><span>Insights Generados</span><span class="sys-val" style="color:#8b5cf6" id="run-ai-insights">—</span></div>
        <div class="sys-row"><span>Confianza NLP</span><span class="sys-val" style="color:#8b5cf6" id="run-ai-conf">—</span></div>
      </div>
      <div class="side-panel">
        <div class="side-title" style="display:flex;align-items:center;gap:7px;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.52 0 10-4.48 10-10S17.52 2 12 2 2 6.48 2 12s4.48 10 10 10z" fill="#f97316" fill-opacity=".1"/><path d="M12 6v6l4 2"/></svg>SLA Risk Forecaster</div>
        <div class="sys-row"><span>SLAs en Riesgo</span><span class="sys-val" style="color:#f97316" id="run-sla-risk">—</span></div>
        <div class="sys-row"><span>Nivel de Alerta</span><span class="sys-val" style="color:#f97316" id="run-sla-alert">—</span></div>
      </div>
      <div class="side-panel">
        <div class="side-title" style="display:flex;align-items:center;gap:7px;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#06b6d4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>KEDB Conflict Resolver</div>
        <div class="sys-row"><span>Conflictos Activos</span><span class="sys-val" style="color:#06b6d4" id="run-kedb-conf">—</span></div>
        <div class="sys-row"><span>Resoluciones Prop.</span><span class="sys-val" style="color:#06b6d4" id="run-kedb-res">—</span></div>
      </div>
      <div class="side-panel">
        <div class="side-title" style="display:flex;align-items:center;gap:7px;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" fill="#fbbf24" fill-opacity=".1"/></svg>Resource Efficiency</div>
        <div class="sys-row"><span>Utilización Media</span><span class="sys-val" style="color:#fbbf24" id="run-res-util">—</span></div>
        <div class="sys-row"><span>Carga Óptima</span><span class="sys-val" style="color:#fbbf24" id="run-res-opt">—</span></div>
      </div>
      <div class="side-panel">
        <div class="side-title" style="display:flex;align-items:center;gap:7px;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2" fill="#10b981" fill-opacity=".1"/><rect x="9" y="3" width="6" height="4" rx="2"/><line x1="9" y1="12" x2="15" y2="12"/><line x1="9" y1="16" x2="13" y2="16"/></svg>Buffer Audit Log</div>
        <div class="sys-row"><span>Entradas Hoy</span><span class="sys-val" style="color:#10b981" id="run-audit-count">—</span></div>
        <div class="sys-row"><span>Último Evento</span><span class="sys-val" style="color:#10b981;font-size:9px;" id="run-audit-last">—</span></div>
      </div>
    </div>
  </div>
</div>
<div class="page" id="page-build">
  <div class="pipeline-layout">
    <div class="pipeline-main">
      <div class="panel">
        <div class="panel-header">
          <div class="panel-title" style="display:flex;align-items:center;gap:8px;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="1.8"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
            Demanda de Proyecto PMBOK 7
          </div>
          <div style="display:flex;gap:6px;align-items:center;">
            <span class="mode-badge mode-build">PMBOK 7</span>
            <span style="font-size:9px;padding:2px 6px;border-radius:4px;background:var(--green-bg);color:var(--green);font-weight:600;" id="build-proj-id"></span>
          </div>
        </div>
        <div style="padding:10px 14px;overflow-y:auto;max-height:420px;">
          <!-- Nav steps -->
          <div style="display:flex;gap:4px;margin-bottom:10px;border-bottom:1px solid var(--border);padding-bottom:8px;" id="build-form-nav">
            <div class="filter-chip active" onclick="buildFormStep(1,this)" style="font-size:10px;">1. Business Case</div>
            <div class="filter-chip" onclick="buildFormStep(2,this)" style="font-size:10px;">2. Acta Constitución</div>
            <div class="filter-chip" onclick="buildFormStep(3,this)" style="font-size:10px;">3. Alcance & EDT</div>
            <div class="filter-chip" onclick="buildFormStep(4,this)" style="font-size:10px;">4. Riesgos & Costes</div>
            <div class="filter-chip" onclick="buildFormStep(5,this)" style="font-size:10px;">5. Interesados</div>
          </div>
          <!-- Step 1: Business Case -->
          <div class="build-form-step active" id="bf-step-1">
            <div style="display:grid;grid-template-columns:2fr 1fr;gap:8px;margin-bottom:8px;">
              <div class="sap-field" style="margin:0;"><label class="sap-label">📋 Nombre del Proyecto</label>
                <input class="sap-input" id="bf-nombre" placeholder="Ej: Implementación Plataforma OpenShift On-Premise"></div>
              <div class="sap-field" style="margin:0;"><label class="sap-label">👔 Director del Proyecto</label>
                <select class="sap-input" id="bf-pm"><option value="">— Seleccionar PM —</option></select></div>
            </div>
            <div class="sap-field" style="margin:0 0 8px;"><label class="sap-label">📝 Resumen Ejecutivo (Business Case)</label>
              <textarea class="sap-textarea" id="bf-resumen" placeholder="Resumen ejecutivo del caso de negocio: justificación, inversión solicitada, beneficios esperados..." style="min-height:50px;"></textarea></div>
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:8px;">
              <div class="sap-field" style="margin:0;"><label class="sap-label">💰 Presupuesto Total (€)</label>
                <input class="sap-input mono" id="bf-presupuesto" type="text" inputmode="numeric" placeholder="650000" style="text-align:right;"></div>
              <div class="sap-field" style="margin:0;"><label class="sap-label">📅 Duración (semanas)</label>
                <input class="sap-input mono" id="bf-duracion" type="text" inputmode="numeric" value="40" style="text-align:center;"></div>
              <div class="sap-field" style="margin:0;"><label class="sap-label">🎯 Prioridad Estratégica</label>
                <select class="sap-input" id="bf-prioridad">
                  <option value="Crítica">Crítica</option><option value="Alta" selected>Alta</option><option value="Media">Media</option><option value="Baja">Baja</option>
                </select></div>
            </div>
            <div class="sap-field" style="margin:0 0 8px;"><label class="sap-label">📊 Justificación / Razones del Proyecto</label>
              <textarea class="sap-textarea" id="bf-justificacion" placeholder="Problema de negocio, ineficiencia operativa, riesgo de cumplimiento, obsolescencia tecnológica..."></textarea></div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
              <div class="sap-field" style="margin:0;"><label class="sap-label">✅ Beneficios Esperados</label>
                <textarea class="sap-textarea" id="bf-beneficios" placeholder="Cuantitativos: reducción ciclo despliegue >70%&#10;Cualitativos: agilidad competitiva, seguridad..." style="min-height:45px;"></textarea></div>
              <div class="sap-field" style="margin:0;"><label class="sap-label">⚠ Contrabeneficios / Riesgos</label>
                <textarea class="sap-textarea" id="bf-contrabeneficios" placeholder="Inversión inicial elevada, resistencia cultural, complejidad técnica, curva de aprendizaje..." style="min-height:45px;"></textarea></div>
            </div>
          </div>
          <!-- Step 2: Acta de Constitución -->
          <div class="build-form-step" id="bf-step-2" style="display:none;">
            <div class="sap-field" style="margin:0 0 8px;"><label class="sap-label">📄 Descripción de Alto Nivel</label>
              <textarea class="sap-textarea" id="bf-descripcion" placeholder="Descripción general del proyecto, su propósito y los entregables principales esperados..."></textarea></div>
            <div class="sap-field" style="margin:0 0 8px;"><label class="sap-label">🎯 Objetivos SMART</label>
              <textarea class="sap-textarea" id="bf-objetivos" placeholder="Específico: Implementar 3 clústeres&#10;Medible: Reducir ciclo despliegue >70%&#10;Alcanzable: Dentro de presupuesto&#10;Relevante: Alineado con transformación digital&#10;Temporal: 40 semanas"></textarea></div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px;">
              <div class="sap-field" style="margin:0;"><label class="sap-label">📦 Entregables Principales</label>
                <textarea class="sap-textarea" id="bf-entregables" placeholder="E01: Entorno DESA operativo&#10;E02: Entorno PRE certificado&#10;E03: Entorno PRO en producción&#10;E04: App piloto migrada&#10;E05: Equipo formado&#10;E06: Documentación completa" style="min-height:80px;"></textarea></div>
              <div class="sap-field" style="margin:0;"><label class="sap-label">🏁 Hitos Principales</label>
                <textarea class="sap-textarea" id="bf-hitos" placeholder="S6: Diseño Arquitectura Aprobado&#10;S12: Hardware Recibido&#10;S25: PRE Construido&#10;S33: Certificación PRE&#10;S36: Go-Live App Piloto&#10;S40: Cierre Proyecto" style="min-height:80px;"></textarea></div>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
              <div class="sap-field" style="margin:0;"><label class="sap-label">👤 Patrocinador (Sponsor)</label>
                <input class="sap-input" id="bf-sponsor" placeholder="Nombre y cargo del sponsor"></div>
              <div class="sap-field" style="margin:0;"><label class="sap-label">✅ Criterios de Éxito / Salida</label>
                <input class="sap-input" id="bf-criterios" placeholder="Uptime >99.9%, UAT aprobada, hypercare 2 semanas OK"></div>
            </div>
          </div>
          <!-- Step 3: Alcance & EDT -->
          <div class="build-form-step" id="bf-step-3" style="display:none;">
            <div class="sap-field" style="margin:0 0 8px;"><label class="sap-label">📐 Alcance del Producto</label>
              <textarea class="sap-textarea" id="bf-alcance" placeholder="Descripción detallada del alcance: qué incluye y qué NO incluye el proyecto..."></textarea></div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px;">
              <div class="sap-field" style="margin:0;"><label class="sap-label">🚫 Exclusiones del Proyecto</label>
                <textarea class="sap-textarea" id="bf-exclusiones" placeholder="Migración de todas las aplicaciones&#10;Rearquitectura a microservicios&#10;Operación post-entrega"></textarea></div>
              <div class="sap-field" style="margin:0;"><label class="sap-label">⚠ Restricciones</label>
                <textarea class="sap-textarea" id="bf-restricciones" placeholder="Presupuesto: 650.411€ máx&#10;Plazo: 40 semanas&#10;Tecnología: On-premise&#10;Seguridad: PCI DSS, GDPR"></textarea></div>
            </div>
            <div class="sap-field" style="margin:0 0 8px;"><label class="sap-label">📋 EDT / WBS — Paquetes de Trabajo (uno por línea: ID | Nombre | Responsable)</label>
              <textarea class="sap-textarea" id="bf-edt" placeholder="1.0 | Planificación y Diseño | Arquitectura&#10;2.0 | Adquisición | JdP&#10;3.0 | Implementación DESA | UNIX&#10;4.0 | Implementación PRE | UNIX&#10;5.0 | Pruebas Certificación | QA&#10;6.0 | Implementación PRO | UNIX&#10;7.0 | Go-Live | Operaciones&#10;8.0 | Cierre | JdP" style="min-height:80px;"></textarea></div>
            <div class="sap-field" style="margin:0 0 8px;"><label class="sap-label">🖥 Activos CMDB Vinculados</label>
              <select class="sap-input" id="bf-cmdb-activos" multiple style="min-height:60px;padding:6px;"><option value="">Cargando activos CMDB...</option></select>
              <span style="font-size:10px;color:var(--text3);">Mantén Ctrl/Cmd para seleccionar varios activos</span></div>
            <div class="sap-field" style="margin:0;"><label class="sap-label">🧠 Asunciones del Proyecto</label>
              <textarea class="sap-textarea" id="bf-asunciones" placeholder="Recursos internos disponibles según planificación&#10;Hardware entregado en 10 semanas&#10;Colaboración activa del equipo de desarrollo"></textarea></div>
          </div>
          <!-- Step 4: Riesgos & Costes -->
          <div class="build-form-step" id="bf-step-4" style="display:none;">
            <div class="sap-field" style="margin:0 0 8px;"><label class="sap-label">⚡ Riesgos Principales (uno por línea: Desc | Prob 1-5 | Impacto 1-5 | Estrategia)</label>
              <textarea class="sap-textarea" id="bf-riesgos" placeholder="Retraso hardware | 3 | 5 | Mitigar&#10;Complejidad técnica instalación | 4 | 4 | Mitigar&#10;Resistencia cultural al cambio | 4 | 3 | Mitigar&#10;Vulnerabilidad en pentesting | 2 | 5 | Mitigar&#10;Falta disponibilidad personal | 3 | 3 | Mitigar" style="min-height:70px;"></textarea></div>
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:8px;">
              <div class="sap-field" style="margin:0;"><label class="sap-label">💰 CAPEX (Hardware, Infra)</label>
                <input class="sap-input mono" id="bf-capex" type="text" inputmode="numeric" placeholder="204000" style="text-align:right;"></div>
              <div class="sap-field" style="margin:0;"><label class="sap-label">💳 OPEX (Licencias, SW)</label>
                <input class="sap-input mono" id="bf-opex" type="text" inputmode="numeric" placeholder="152000" style="text-align:right;"></div>
              <div class="sap-field" style="margin:0;"><label class="sap-label">👥 Coste Personal Interno</label>
                <input class="sap-input mono" id="bf-personal" type="text" inputmode="numeric" placeholder="159575" style="text-align:right;"></div>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:8px;margin-bottom:8px;">
              <div class="sap-field" style="margin:0;"><label class="sap-label">🔧 Servicios Externos</label>
                <input class="sap-input mono" id="bf-servicios" type="text" inputmode="numeric" placeholder="50000" style="text-align:right;"></div>
              <div class="sap-field" style="margin:0;"><label class="sap-label">📊 Contingencia %</label>
                <input class="sap-input mono" id="bf-contingencia" type="text" inputmode="numeric" value="15" min="0" max="30" style="text-align:center;"></div>
              <div class="sap-field" style="margin:0;"><label class="sap-label">⏱ Horas Estimadas</label>
                <input class="sap-input mono" id="bf-horas" type="text" inputmode="numeric" placeholder="2455" style="text-align:center;"></div>
              <div class="sap-field" style="margin:0;"><label class="sap-label">💶 €/hora</label>
                <input class="sap-input mono" id="bf-tarifa" type="text" inputmode="numeric" value="65" style="text-align:center;"></div>
            </div>
            <div class="sap-field" style="margin:0;"><label class="sap-label">📈 VAN / TIR / Payback (opcional)</label>
              <input class="sap-input" id="bf-financiero" placeholder="VAN: -22.698€ (conservador) | TIR: 9.12% | Payback: 3.98 años"></div>
          </div>
          <!-- Step 5: Interesados & Calidad -->
          <div class="build-form-step" id="bf-step-5" style="display:none;">
            <div class="sap-field" style="margin:0 0 8px;"><label class="sap-label">👥 Interesados Clave (uno por línea: Nombre | Rol | Posición | Poder | Estrategia)</label>
              <textarea class="sap-textarea" id="bf-interesados" placeholder="CIO | Patrocinador | A favor | Alto | Gestionar de cerca&#10;CISO | Seguridad | Neutral | Alto | Mantener satisfecho&#10;CFO | Finanzas | Neutral | Alto | Mantener informado&#10;Jefa Desarrollo | Beneficiaria | A favor | Medio | Gestionar de cerca&#10;Jefe Operaciones | Resistencia | En contra | Medio | Mitigar" style="min-height:70px;"></textarea></div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px;">
              <div class="sap-field" style="margin:0;"><label class="sap-label">🏢 Área / Departamento Solicitante</label>
                <select class="sap-input" id="bf-area">
                  <option value="Infraestructura">Infraestructura</option><option value="Seguridad">Seguridad</option><option value="Desarrollo">Desarrollo</option>
                  <option value="Operaciones">Operaciones</option><option value="Datos & Analytics">Datos & Analytics</option><option value="Negocio">Negocio Digital</option>
                  <option value="Transformación">Transformación Digital</option><option value="Gobernanza">Gobernanza TI</option>
                </select></div>
              <div class="sap-field" style="margin:0;"><label class="sap-label">📋 Estándares de Calidad</label>
                <input class="sap-input" id="bf-calidad" placeholder="ISO 27001, PCI DSS, GDPR, ISO 9001"></div>
            </div>
            <div class="sap-field" style="margin:0 0 8px;"><label class="sap-label">📢 Plan de Comunicaciones (frecuencia y destinatarios)</label>
              <textarea class="sap-textarea" id="bf-comunicaciones" placeholder="Semanal: Reunión equipo (Acta)&#10;Mensual: Informe ejecutivo a Sponsor&#10;Por fase: Informe cierre fase&#10;Ad-hoc: Notificación riesgo crítico" style="min-height:50px;"></textarea></div>
            <textarea class="sap-textarea" id="build-input" placeholder="Notas adicionales para los agentes IA..." style="min-height:30px;display:none;"></textarea>
          </div>
          <!-- Action buttons -->
          <div style="display:flex;gap:8px;align-items:center;margin-top:10px;padding-top:8px;border-top:1px solid var(--border);">
            <button class="btn-exec" id="build-exec-btn" onclick="buildSubmitAndPipeline()" style="flex:1;background:linear-gradient(135deg,#059669,#10b981);">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:middle;margin-right:4px;"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              Registrar Proyecto + Ejecutar Pipeline IA
            </button>
            <button class="btn-reset" onclick="resetBuildForm()" style="white-space:nowrap;">↺ Reset</button>
          </div>
          <!-- buffer moved below pipeline -->
        </div>
      </div>
      <div class="panel">
        <div class="panel-header">
          <div class="panel-title">Pipeline de Agentes IA</div>
          <button class="config-btn" onclick="showToast('Agentes IA nativos Claude — No requiere configuración')" style="opacity:.5;">⚙ Agentes IA</button>
        </div>
        <div class="pipeline-area" id="build-pipeline-area" style="border-style:solid;min-height:auto;padding:0;">
          <div id="build-pipeline-idle">
            <div style="padding:10px 14px;">
              <div style="display:flex;align-items:center;gap:6px;margin-bottom:8px;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="1.8"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                <span style="font-size:12px;font-weight:700;">Cascada BUILD — 3 Agentes IA</span>
                <span style="margin-left:auto;font-size:9px;padding:2px 6px;border-radius:8px;background:var(--bg3);border:1px solid var(--border);color:var(--text3);font-family:var(--mono);">READY</span>
              </div>
              <!-- Compact horizontal flow -->
              <div style="display:flex;align-items:center;gap:0;">
                <!-- Entry -->
                <div style="display:flex;align-items:center;gap:4px;background:linear-gradient(135deg,rgba(16,185,129,.12),rgba(16,185,129,.05));border:1px solid rgba(16,185,129,.25);border-radius:14px;padding:3px 10px;flex-shrink:0;">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                  <span style="font-size:9px;font-weight:600;color:var(--green);">PMBOK Input</span>
                </div>
                <!-- Arrow -->
                <svg width="20" height="10" style="flex-shrink:0;"><line x1="0" y1="5" x2="14" y2="5" stroke="#30363d" stroke-width="1.5" stroke-dasharray="3,2"><animate attributeName="stroke-dashoffset" from="5" to="0" dur="0.8s" repeatCount="indefinite"/></line><polygon points="14,2 20,5 14,8" fill="#30363d"/></svg>
                <!-- AG-005 -->
                <div style="background:var(--bg2);border:1px solid rgba(16,185,129,.25);border-radius:8px;padding:6px 8px;display:flex;align-items:center;gap:6px;flex:1;min-width:0;border-left:3px solid #10b981;">
                  <div style="width:26px;height:26px;flex-shrink:0;display:flex;align-items:center;justify-content:center;background:rgba(16,185,129,.1);border-radius:6px;" id="build-flow-icon-1"></div>
                  <div style="min-width:0;"><div style="font-size:10px;font-weight:700;color:#10b981;">AG-005 Estratega</div><div style="font-size:8px;color:var(--text3);">PMBOK 7 · Priorización</div></div>
                </div>
                <!-- Arrow -->
                <svg width="20" height="10" style="flex-shrink:0;"><line x1="0" y1="5" x2="14" y2="5" stroke="#30363d" stroke-width="1.5" stroke-dasharray="3,2"><animate attributeName="stroke-dashoffset" from="5" to="0" dur="0.8s" repeatCount="indefinite"/></line><polygon points="14,2 20,5 14,8" fill="#30363d"/></svg>
                <!-- AG-006 -->
                <div style="background:var(--bg2);border:1px solid rgba(234,179,8,.25);border-radius:8px;padding:6px 8px;display:flex;align-items:center;gap:6px;flex:1;min-width:0;border-left:3px solid #eab308;">
                  <div style="width:26px;height:26px;flex-shrink:0;display:flex;align-items:center;justify-content:center;background:rgba(234,179,8,.1);border-radius:6px;" id="build-flow-icon-2"></div>
                  <div style="min-width:0;"><div style="font-size:10px;font-weight:700;color:#eab308;">AG-006 Resources</div><div style="font-size:8px;color:var(--text3);">Asignación · Matching</div></div>
                </div>
                <!-- Arrow -->
                <svg width="20" height="10" style="flex-shrink:0;"><line x1="0" y1="5" x2="14" y2="5" stroke="#30363d" stroke-width="1.5" stroke-dasharray="3,2"><animate attributeName="stroke-dashoffset" from="5" to="0" dur="0.8s" repeatCount="indefinite"/></line><polygon points="14,2 20,5 14,8" fill="#30363d"/></svg>
                <!-- AG-007 -->
                <div style="background:var(--bg2);border:1px solid rgba(236,72,153,.25);border-radius:8px;padding:6px 8px;display:flex;align-items:center;gap:6px;flex:1;min-width:0;border-left:3px solid #ec4899;">
                  <div style="width:26px;height:26px;flex-shrink:0;display:flex;align-items:center;justify-content:center;background:rgba(236,72,153,.1);border-radius:6px;" id="build-flow-icon-3"></div>
                  <div style="min-width:0;"><div style="font-size:10px;font-weight:700;color:#ec4899;">AG-007 Planificador</div><div style="font-size:8px;color:var(--text3);">WBS · Gantt · PMBOK</div></div>
                </div>
                <!-- Arrow -->
                <svg width="20" height="10" style="flex-shrink:0;"><line x1="0" y1="5" x2="14" y2="5" stroke="#30363d" stroke-width="1.5" stroke-dasharray="3,2"><animate attributeName="stroke-dashoffset" from="5" to="0" dur="0.8s" repeatCount="indefinite"/></line><polygon points="14,2 20,5 14,8" fill="#30363d"/></svg>
                <!-- Output -->
                <div style="display:flex;align-items:center;gap:4px;background:linear-gradient(135deg,rgba(63,185,80,.12),rgba(63,185,80,.05));border:1px solid rgba(63,185,80,.25);border-radius:14px;padding:3px 10px;flex-shrink:0;">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                  <span style="font-size:9px;font-weight:600;color:var(--green);">Output</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <!-- Buffer de Proyectos Registrados -->
      <div class="panel" style="margin:0 14px 14px;">
        <div class="panel-header" style="padding:8px 12px;">
          <div class="panel-title" style="font-size:12px;display:flex;align-items:center;gap:6px;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="1.8"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="2"/></svg>
            Proyectos Registrados
            <span style="font-family:var(--mono);font-size:10px;color:var(--text3);" id="build-buffer-count">(0)</span>
          </div>
        </div>
        <div id="build-buffer-list" style="padding:8px;max-height:180px;overflow-y:auto;">
          <div style="font-size:10px;color:var(--text3);text-align:center;padding:8px;">Sin proyectos registrados</div>
        </div>
      </div>
    </div>
    <div class="pipeline-sidebar">
      <div class="side-panel">
        <div class="side-title" style="display:flex;align-items:center;gap:7px;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/><circle cx="12" cy="12" r="10" fill="#fbbf24" fill-opacity=".08"/></svg>Task Monitoring</div>
        <div class="no-data" id="build-tasks"><div class="no-data-icon">🕐</div>No hay tareas activas</div>
      </div>
      <div class="side-panel">
        <div class="side-title" style="display:flex;align-items:center;gap:7px;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22d3ee" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>Historial Buffer</div>
        <div class="no-data" id="build-hist"><div class="no-data-icon">🕐</div>Sin ejecuciones previas</div>
      </div>
      <div class="side-panel">
        <div class="side-title" style="display:flex;align-items:center;gap:7px;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#a3e635" stroke-width="2" stroke-linecap="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>Estado del Sistema</div>
        <div class="sys-row"><span>Agentes Activos</span><span class="sys-val val-blue">3/3</span></div>
        <div class="sys-row"><span>Pipeline Status</span><span class="sys-val val-idle" id="build-status-val">Idle</span></div>
        <div class="sys-row"><span>Técnicos Staff</span><span class="sys-val">150</span></div>
      </div>
      <div class="side-panel">
        <div class="side-title" style="display:flex;align-items:center;gap:7px;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.663 17h4.673M12 3a6 6 0 0 1 6 6v1a2 2 0 0 0 2 2H4a2 2 0 0 0 2-2V9a6 6 0 0 1 6-6z" fill="#8b5cf6" fill-opacity=".1"/><path d="M12 17v4M8 21h8"/></svg>AI Insight Explorer</div>
        <div class="sys-row"><span>Insights Generados</span><span class="sys-val" style="color:#8b5cf6" id="build-ai-insights">—</span></div>
        <div class="sys-row"><span>Confianza NLP</span><span class="sys-val" style="color:#8b5cf6" id="build-ai-conf">—</span></div>
      </div>
      <div class="side-panel">
        <div class="side-title" style="display:flex;align-items:center;gap:7px;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.52 0 10-4.48 10-10S17.52 2 12 2 2 6.48 2 12s4.48 10 10 10z" fill="#f97316" fill-opacity=".1"/><path d="M12 6v6l4 2"/></svg>SLA Risk Forecaster</div>
        <div class="sys-row"><span>SLAs en Riesgo</span><span class="sys-val" style="color:#f97316" id="build-sla-risk">—</span></div>
        <div class="sys-row"><span>Nivel de Alerta</span><span class="sys-val" style="color:#f97316" id="build-sla-alert">—</span></div>
      </div>
      <div class="side-panel">
        <div class="side-title" style="display:flex;align-items:center;gap:7px;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#06b6d4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>KEDB Conflict Resolver</div>
        <div class="sys-row"><span>Conflictos Activos</span><span class="sys-val" style="color:#06b6d4" id="build-kedb-conf">—</span></div>
        <div class="sys-row"><span>Resoluciones Prop.</span><span class="sys-val" style="color:#06b6d4" id="build-kedb-res">—</span></div>
      </div>
      <div class="side-panel">
        <div class="side-title" style="display:flex;align-items:center;gap:7px;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" fill="#fbbf24" fill-opacity=".1"/></svg>Resource Efficiency</div>
        <div class="sys-row"><span>Utilización Media</span><span class="sys-val" style="color:#fbbf24" id="build-res-util">—</span></div>
        <div class="sys-row"><span>Carga Óptima</span><span class="sys-val" style="color:#fbbf24" id="build-res-opt">—</span></div>
      </div>
      <div class="side-panel">
        <div class="side-title" style="display:flex;align-items:center;gap:7px;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2" fill="#10b981" fill-opacity=".1"/><rect x="9" y="3" width="6" height="4" rx="2"/><line x1="9" y1="12" x2="15" y2="12"/><line x1="9" y1="16" x2="13" y2="16"/></svg>Buffer Audit Log</div>
        <div class="sys-row"><span>Entradas Hoy</span><span class="sys-val" style="color:#10b981" id="build-audit-count">—</span></div>
        <div class="sys-row"><span>Último Evento</span><span class="sys-val" style="color:#10b981;font-size:9px;" id="build-audit-last">—</span></div>
      </div>
    </div>
  </div>
</div>
<div class="page" id="page-team">
  <div class="team-page">
    <div class="team-header" style="padding:10px 20px 8px;">
      <div class="team-header-top" style="margin-bottom:8px;">
        <div class="page-title" style="display:flex;align-items:center;gap:10px;"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#38bdf8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0"><circle cx="9" cy="7" r="3.5"/><path d="M2 21v-1.5A5.5 5.5 0 0 1 7.5 14h3A5.5 5.5 0 0 1 16 19.5V21"/><circle cx="17.5" cy="6.5" r="2.5" opacity=".6"/><path d="M20 13.5h1.5A3.5 3.5 0 0 1 25 17v1" opacity=".6"/></svg> Directorio de Equipo <span style="font-size:11px;color:var(--text2);font-weight:400;" id="team-count">150 técnicos</span></div>
        <div style="display:flex;align-items:center;gap:6px;">
          <button onclick="toggleTeamDashboard()" style="background:var(--blue-bg);border:1px solid rgba(45,126,247,.3);color:var(--blue);border-radius:6px;padding:3px 10px;font-size:11px;font-weight:600;cursor:pointer;">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:middle;margin-right:3px;"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>Dashboard
          </button>
          <button class="btn-add-new" onclick="openTeamForm()" style="padding:3px 10px;font-size:11px;">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="vertical-align:middle;margin-right:2px;"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Técnico
          </button>
        </div>
      </div>
      <!-- ═══ DASHBOARD PANEL (COLLAPSIBLE) ═══ -->
      <div id="team-dashboard" style="display:none;margin-bottom:8px;">
        <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin-bottom:10px;" id="team-estado-badges"></div>
        <div style="display:grid;grid-template-columns:1fr 1fr 2fr;gap:8px;margin-bottom:10px;">
          <!-- Gauge: Ocupación Global -->
          <div style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:10px;text-align:center;">
            <div style="font-size:9px;font-weight:700;color:var(--text2);text-transform:uppercase;margin-bottom:4px;">Ocupación Global</div>
            <div style="position:relative;width:80px;height:50px;margin:0 auto;">
              <canvas id="team-gauge" width="80" height="50"></canvas>
              <div style="position:absolute;bottom:0;left:0;right:0;text-align:center;font-family:var(--mono);font-size:18px;font-weight:800;" id="team-gauge-pct">0%</div>
            </div>
            <div style="display:flex;justify-content:space-around;margin-top:6px;font-size:9px;">
              <span style="color:var(--orange);">Ocup: <strong id="td-ocupados">0</strong></span>
              <span style="color:var(--green);">Disp: <strong id="td-disponibles">0</strong></span>
              <span style="color:var(--text3);">Otros: <strong id="td-otros">0</strong></span>
            </div>
          </div>
          <!-- Gauge: % RUN vs BUILD -->
          <div style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:10px;text-align:center;">
            <div style="font-size:9px;font-weight:700;color:var(--text2);text-transform:uppercase;margin-bottom:4px;">Carga RUN vs BUILD</div>
            <div style="position:relative;width:80px;height:50px;margin:0 auto;">
              <canvas id="team-runbuild-gauge" width="80" height="50"></canvas>
            </div>
            <div style="display:flex;justify-content:space-around;margin-top:6px;font-size:9px;">
              <span style="color:var(--blue);"><strong id="td-pct-run">0%</strong> RUN</span>
              <span style="color:var(--green);"><strong id="td-pct-build">0%</strong> BUILD</span>
            </div>
          </div>
          <!-- Silo bars + Level badges -->
          <div style="background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:10px;">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
              <div style="font-size:9px;font-weight:700;color:var(--text2);text-transform:uppercase;">Ocupación por Silo</div>
              <div style="display:flex;gap:4px;">
                <div class="lvl-badge" style="padding:1px 6px;font-size:9px;">N1 <span class="lvl-num" id="cnt-n1">0</span></div>
                <div class="lvl-badge" style="padding:1px 6px;font-size:9px;">N2 <span class="lvl-num" id="cnt-n2">0</span></div>
                <div class="lvl-badge" style="padding:1px 6px;font-size:9px;">N3 <span class="lvl-num" id="cnt-n3">0</span></div>
                <div class="lvl-badge" style="padding:1px 6px;font-size:9px;">N4 <span class="lvl-num" id="cnt-n4">0</span></div>
              </div>
            </div>
            <div id="team-silo-bars"></div>
          </div>
        </div>
        <div style="text-align:right;"><span style="font-size:10px;color:var(--text3);cursor:pointer;" onclick="toggleTeamDashboard()">▲ Minimizar dashboard</span></div>
      </div>
      <div style="display:flex;gap:8px;margin-bottom:6px;">
        <input class="search-bar" placeholder="Buscar por nombre, FTE, proyecto..." oninput="filterTeam(this.value)" style="margin-bottom:0;flex:1;">
        <div class="filter-row" style="flex-wrap:nowrap;">
          <div class="filter-chip active" onclick="filterSilo('Todos',this)">Todos</div>
          <div class="filter-chip" onclick="filterSilo('Frontend',this)">Front</div>
          <div class="filter-chip" onclick="filterSilo('Soporte',this)">Sop</div>
          <div class="filter-chip" onclick="filterSilo('Redes',this)">Redes</div>
          <div class="filter-chip" onclick="filterSilo('Windows',this)">Win</div>
          <div class="filter-chip" onclick="filterSilo('Backend',this)">Back</div>
          <div class="filter-chip" onclick="filterSilo('QA',this)">QA</div>
          <div class="filter-chip" onclick="filterSilo('DevOps',this)">DevOps</div>
          <div class="filter-chip" onclick="filterSilo('Seguridad',this)">Sec</div>
          <div class="filter-chip" onclick="filterSilo('BBDD',this)">BBDD</div>
        </div>
      </div>
    </div>
    <div class="table-wrap">
      <table class="data-table" id="team-table" style="table-layout:fixed;">
        <thead><tr id="team-thead-row">
          <th style="width:160px;" class="tm-th-resizable" draggable="true" data-col="nombre">Nombre</th>
          <th style="width:60px;" class="tm-th-resizable" draggable="true" data-col="fte">FTE</th>
          <th style="width:65px;" class="tm-th-resizable" draggable="true" data-col="silo">Silo</th>
          <th style="width:38px;" class="tm-th-resizable" draggable="true" data-col="nivel">Nivel</th>
          <th style="width:55px;" class="tm-th-resizable" draggable="true" data-col="skills">Skills</th>
          <th style="width:38px;text-align:center;" class="tm-th-resizable" draggable="true" data-col="tareas">Tareas</th>
          <th style="width:100px;" class="tm-th-resizable" draggable="true" data-col="vinculacion">Vinculación</th>
          <th style="width:75px;" class="tm-th-resizable" draggable="true" data-col="carga">Carga</th>
          <th style="width:70px;" class="tm-th-resizable" draggable="true" data-col="estado">Estado</th>
          <th style="width:140px;" class="tm-th-resizable" draggable="true" data-col="email">Email</th>
          <th style="width:90px;" class="tm-th-resizable" draggable="true" data-col="telefono">Teléfono</th>
        </tr></thead>
        <tbody id="team-tbody"><tr><td colspan="11" style="text-align:center;padding:20px;color:var(--text2);"><span class="loading-spinner"></span>Cargando equipo...</td></tr></tbody>
      </table>
    </div>
    <!-- DISPONIBLES POR SILO (collapsible) -->
    <div id="team-disponibles-panel" style="display:none;border-top:1px solid var(--border);background:var(--bg2);padding:10px 20px;max-height:200px;overflow-y:auto;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
        <div style="font-size:12px;font-weight:700;display:flex;align-items:center;gap:6px;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="1.8"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
          Técnicos Disponibles por Silo
        </div>
        <span style="font-size:10px;color:var(--text3);cursor:pointer;" onclick="document.getElementById('team-disponibles-panel').style.display='none'">✕ Cerrar</span>
      </div>
      <div id="team-disponibles-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;"></div>
    </div>
    <div style="border-top:1px solid var(--border);background:var(--bg2);padding:4px 20px;display:flex;align-items:center;gap:12px;flex-shrink:0;">
      <button onclick="toggleDisponibles()" style="background:var(--green-bg);border:1px solid rgba(63,185,80,.3);color:var(--green);border-radius:5px;padding:3px 10px;font-size:10px;font-weight:600;cursor:pointer;">● Disponibles por Silo</button>
      <span style="font-size:10px;color:var(--text3);" id="team-footer-info"></span>
    </div>
    </div>
  </div>
</div>
<!-- ══════════════════ PAGE: PMO GOVERNANCE ══════════════════ -->
<div class="page" id="page-governance">
  <div class="gov-page">
    <div class="team-header" style="padding:10px 20px 8px;">
      <div class="team-header-top" style="margin-bottom:8px;">
        <div class="page-title" style="display:flex;align-items:center;gap:10px;">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
          PMO Governance <span style="font-size:11px;color:var(--text2);font-weight:400;" id="gov-pm-count">0 PMs</span>
        </div>
        <div style="display:flex;gap:6px;">
          <button onclick="toggleGovDashboard()" style="background:rgba(245,158,11,.15);border:1px solid rgba(245,158,11,.3);color:#f59e0b;border-radius:6px;padding:3px 10px;font-size:11px;font-weight:600;cursor:pointer;">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:middle;margin-right:3px;"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>4 Pilares
          </button>
          <button class="btn-add-new" onclick="openPMForm()" style="padding:3px 10px;font-size:11px;background:linear-gradient(135deg,#d97706,#f59e0b);border-color:#f59e0b;">+ PM</button>
          <div class="filter-chip active" onclick="govView('pms',this)" style="font-size:10px;">PMs</div>
          <div class="filter-chip" onclick="govView('scoring',this)" style="font-size:10px;">Scoring</div>
          <div class="filter-chip" onclick="govView('gates',this)" style="font-size:10px;">Gates</div>
        </div>
      </div>
      <!-- ═══ 4 PILLARS DASHBOARD (collapsible) ═══ -->
      <div id="gov-dashboard" style="display:none;margin-bottom:8px;">
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:8px;" id="gov-pillar-kpis"></div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px;">
          <!-- Pilar 1: Demanda y Priorización -->
          <div class="gov-pillar" style="border-left:3px solid #f59e0b;">
            <div class="gov-pillar-hdr"><div class="gov-pillar-icon" style="background:rgba(245,158,11,.15);"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="1.8"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg></div><div><div class="gov-pillar-title">Demanda y Priorización</div><div style="font-size:9px;color:var(--text2);">Scoring ROI vs Riesgo vs Capacidad vs Valor</div></div><div class="gov-pillar-badge" style="background:rgba(245,158,11,.15);color:#f59e0b;" id="gov-p1-score">0</div></div>
            <div id="gov-p1-content" style="font-size:10px;color:var(--text2);">Cargando...</div>
          </div>
          <!-- Pilar 2: Capacidad de Recursos -->
          <div class="gov-pillar" style="border-left:3px solid var(--blue);">
            <div class="gov-pillar-hdr"><div class="gov-pillar-icon" style="background:var(--blue-bg);"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="1.8"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg></div><div><div class="gov-pillar-title">Capacidad de Recursos</div><div style="font-size:9px;color:var(--text2);">Carga PM vs BAU vs Proyectos</div></div><div class="gov-pillar-badge" style="background:var(--blue-bg);color:var(--blue);" id="gov-p2-score">0%</div></div>
            <div id="gov-p2-content">Cargando...</div>
          </div>
          <!-- Pilar 3: Estándares y Cumplimiento -->
          <div class="gov-pillar" style="border-left:3px solid var(--green);">
            <div class="gov-pillar-hdr"><div class="gov-pillar-icon" style="background:var(--green-bg);"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div><div><div class="gov-pillar-title">Estándares y Cumplimiento</div><div style="font-size:9px;color:var(--text2);">Gating Reviews · Plantillas · Compliance</div></div><div class="gov-pillar-badge" style="background:var(--green-bg);color:var(--green);" id="gov-p3-score">0%</div></div>
            <div id="gov-p3-content">Cargando...</div>
          </div>
          <!-- Pilar 4: Gestión del Cambio -->
          <div class="gov-pillar" style="border-left:3px solid #a855f7;">
            <div class="gov-pillar-hdr"><div class="gov-pillar-icon" style="background:rgba(168,85,247,.15);"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#a855f7" stroke-width="1.8"><path d="M21 12a9 9 0 1 1-6.219-8.56"/><polyline points="21 3 21 9 15 9"/></svg></div><div><div class="gov-pillar-title">Gestión del Cambio</div><div style="font-size:9px;color:var(--text2);">Change Requests · Adopción · Comunicación</div></div><div class="gov-pillar-badge" style="background:rgba(168,85,247,.15);color:#a855f7;" id="gov-p4-score">0%</div></div>
            <div id="gov-p4-content">Cargando...</div>
          </div>
        </div>
        <div style="text-align:right;"><span style="font-size:10px;color:var(--text3);cursor:pointer;" onclick="toggleGovDashboard()">▲ Minimizar</span></div>
      </div>
      <div style="display:flex;gap:8px;margin-bottom:6px;">
        <input class="search-bar" placeholder="Buscar PM, proyecto, certificación..." oninput="filterGov(this.value)" style="margin-bottom:0;flex:1;">
      </div>
    </div>
    <!-- PM Table View -->
    <div class="table-wrap" id="gov-view-pms">
      <table class="data-table" id="gov-table" style="table-layout:fixed;">
        <thead><tr id="gov-thead-row">
          <th style="width:160px;" class="tm-th-resizable" draggable="true">Nombre</th>
          <th style="width:55px;" class="tm-th-resizable" draggable="true">ID</th>
          <th style="width:55px;" class="tm-th-resizable" draggable="true">Nivel</th>
          <th style="width:75px;" class="tm-th-resizable" draggable="true">Especialidad</th>
          <th style="width:50px;text-align:center;" class="tm-th-resizable" draggable="true">Proyectos</th>
          <th style="width:70px;" class="tm-th-resizable" draggable="true">Carga</th>
          <th style="width:90px;" class="tm-th-resizable" draggable="true">Certificaciones</th>
          <th style="width:55px;" class="tm-th-resizable" draggable="true">Éxito</th>
          <th style="width:75px;" class="tm-th-resizable" draggable="true">Estado</th>
          <th style="width:130px;" class="tm-th-resizable" draggable="true">Email</th>
          <th style="width:85px;" class="tm-th-resizable" draggable="true">Teléfono</th>
        </tr></thead>
        <tbody id="gov-tbody"><tr><td colspan="11" style="text-align:center;padding:20px;color:var(--text2);"><span class="loading-spinner"></span>Cargando PMs...</td></tr></tbody>
      </table>
    </div>
    <!-- Scoring View -->
    <div class="table-wrap" id="gov-view-scoring" style="display:none;">
      <div style="padding:16px;" id="gov-scoring-content"><div class="no-data">Cargando scoring...</div></div>
    </div>
    <!-- Gates View -->
    <div class="table-wrap" id="gov-view-gates" style="display:none;">
      <div style="padding:16px;" id="gov-gates-content"><div class="no-data">Cargando gates...</div></div>
    </div>
    <!-- Métricas footer -->
    <div style="border-top:1px solid var(--border);background:var(--bg2);padding:4px 20px;display:flex;align-items:center;gap:12px;flex-shrink:0;">
      <span style="font-size:10px;color:var(--text3);" id="gov-footer-info"></span>
    </div>
  </div>
</div>
<!-- MODAL: PM FORM (Multi-step like Team) -->
<div class="fm-overlay" id="fm-pm" onclick="if(event.target===this)fmClose('fm-pm')">
  <div class="fm-box">
    <div class="fm-header" style="border-bottom-color:rgba(245,158,11,.3);">
      <div class="fm-title">
        <span id="pm-icon" style="font-size:22px;">👔</span>
        <div>
          <div id="pm-form-title">Nuevo Project Manager</div>
          <div id="pm-form-sub" style="font-size:11px;color:var(--text2);font-weight:400;margin-top:1px;">Registrar PM en la PMO Governance</div>
        </div>
      </div>
      <button class="fm-close" onclick="fmClose('fm-pm')">✕</button>
    </div>
    <div class="fm-steps">
      <div class="fm-step-dot active" id="pm-dot-1"><div class="fsd-circle">1</div><div class="fsd-label">Identidad</div></div>
      <div class="fm-step-dot" id="pm-dot-2"><div class="fsd-circle">2</div><div class="fsd-label">Skills & Certs</div></div>
      <div class="fm-step-dot" id="pm-dot-3"><div class="fsd-circle">3</div><div class="fsd-label">Confirmar</div></div>
    </div>
    <div style="padding:18px;overflow-y:auto;max-height:60vh;">
      <input type="hidden" id="pm-edit-id">
      <!-- Step 1: Identidad -->
      <div class="fm-step active" id="pm-s1">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:12px;">
          <div class="fm-field" style="margin:0"><div class="fm-label">🪪 ID Project Manager</div>
            <input class="fm-input" id="pm-id" placeholder="PM-016" style="font-family:var(--mono);letter-spacing:.5px;"></div>
          <div class="fm-field" style="margin:0"><div class="fm-label">📊 Estado</div>
            <select class="fm-select" id="pm-estado">
              <option value="DISPONIBLE">🟢 DISPONIBLE</option>
              <option value="ASIGNADO">🟡 ASIGNADO</option>
              <option value="SOBRECARGADO">🔴 SOBRECARGADO</option>
              <option value="BAJA">❌ BAJA</option>
              <option value="VACACIONES">⚪ VACACIONES</option>
            </select></div>
        </div>
        <div class="fm-section-sep"></div>
        <div class="fm-field"><div class="fm-label">👤 Nombre Completo</div>
          <input class="fm-input" id="pm-nombre" placeholder="Ej: Elena Rodríguez Vega"></div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:4px;">
          <div class="fm-field" style="margin:0"><div class="fm-label">📧 Email Corporativo</div>
            <input class="fm-input" id="pm-email" placeholder="elena.rodriguez@bcc-bank.es"></div>
          <div class="fm-field" style="margin:0"><div class="fm-label">📱 Teléfono</div>
            <input class="fm-input" id="pm-telefono" placeholder="+34 6XXXXXXXX" style="font-family:var(--mono);"></div>
        </div>
        <div class="fm-section-sep"></div>
        <!-- Nivel PM -->
        <div class="fm-field"><div class="fm-label">🎯 Nivel Profesional</div>
          <div class="nivel-grid">
            <div class="nivel-card" onclick="pmSelNivel('PM-Jr',this)"><div class="nc-badge" style="color:#8b949e;">Jr</div><div style="font-size:11px;font-weight:600;color:var(--text2);">PM Junior</div><div class="nc-desc">0–2 años PM<br>Proyectos pequeños</div></div>
            <div class="nivel-card" onclick="pmSelNivel('PM-Sr',this)"><div class="nc-badge" style="color:var(--blue);">Sr</div><div style="font-size:11px;font-weight:600;color:var(--text2);">PM Senior</div><div class="nc-desc">2–5 años PM<br>Proyectos medios</div></div>
            <div class="nivel-card" onclick="pmSelNivel('PM-Lead',this)"><div class="nc-badge" style="color:#f59e0b;">Lead</div><div style="font-size:11px;font-weight:600;color:var(--text2);">PM Lead</div><div class="nc-desc">5–10 años PM<br>Programas y portfolio</div></div>
            <div class="nivel-card" onclick="pmSelNivel('PM-Dir',this)"><div class="nc-badge" style="color:#a855f7;">Dir</div><div style="font-size:11px;font-weight:600;color:var(--text2);">PM Director</div><div class="nc-desc">10+ años PM<br>Estrategia PMO</div></div>
          </div>
        </div>
        <!-- Especialidad -->
        <div class="fm-field" style="margin-bottom:0"><div class="fm-label">🏢 Especialidad de Proyectos</div>
          <div class="silo-grid">
            <div class="silo-card" onclick="pmSelEsp('Infraestructura',this)"><div class="sc-icon">🏗️</div><div class="sc-name">Infraestructura</div></div>
            <div class="silo-card" onclick="pmSelEsp('Seguridad',this)"><div class="sc-icon">🔒</div><div class="sc-name">Seguridad</div></div>
            <div class="silo-card" onclick="pmSelEsp('Aplicaciones',this)"><div class="sc-icon">⚙️</div><div class="sc-name">Aplicaciones</div></div>
            <div class="silo-card" onclick="pmSelEsp('Data & Analytics',this)"><div class="sc-icon">📊</div><div class="sc-name">Data & Analytics</div></div>
            <div class="silo-card" onclick="pmSelEsp('Gobernanza',this)"><div class="sc-icon">🏛️</div><div class="sc-name">Gobernanza</div></div>
            <div class="silo-card" onclick="pmSelEsp('Transformación Digital',this)"><div class="sc-icon">🚀</div><div class="sc-name">Transformación</div></div>
          </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:12px;">
          <div class="fm-field" style="margin:0"><div class="fm-label">📂 Máx. Proyectos Simultáneos</div>
            <input class="fm-input" id="pm-max" type="number" min="1" max="10" value="3" style="font-family:var(--mono);font-weight:700;text-align:center;"></div>
          <div class="fm-field" style="margin:0"><div class="fm-label">✅ Tasa de Éxito (%)</div>
            <input class="fm-input" id="pm-exito" type="number" min="0" max="100" step="0.1" value="100" style="font-family:var(--mono);font-weight:700;text-align:center;"></div>
        </div>
      </div>
      <!-- Step 2: Skills & Certificaciones -->
      <div class="fm-step" id="pm-s2">
        <div style="font-size:13px;color:var(--text2);margin-bottom:10px;">Selecciona las skills del PM y sus certificaciones profesionales.</div>
        <div style="font-size:12px;font-weight:700;margin-bottom:8px;">🎓 Certificaciones</div>
        <div id="pm-certs-grid" style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:16px;"></div>
        <div class="fm-section-sep"></div>
        <div style="font-size:12px;font-weight:700;margin-bottom:8px;">🧠 Skills de Project Management</div>
        <div id="pm-skills-grid"></div>
      </div>
      <!-- Step 3: Confirmar -->
      <div class="fm-step" id="pm-s3">
        <div id="pm-preview"></div>
        <div id="pm-projects-panel" style="display:none;margin-top:14px;background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:10px;">
          <div style="font-size:11px;font-weight:700;color:#f59e0b;margin-bottom:6px;">📋 Proyectos Asignados</div>
          <div id="pm-projects-list" style="max-height:160px;overflow-y:auto;"></div>
        </div>
      </div>
    </div>
    <div class="fm-footer">
      <button class="btn-fm-back" id="pm-back-btn" onclick="pmStepBack()" style="display:none">← Atrás</button>
      <div style="display:flex;align-items:center;gap:10px;">
        <span class="fm-skill-counter" id="pm-skill-count" style="display:none">0 skills</span>
        <button class="btn-fm-next" id="pm-next-btn" onclick="pmStepNext()" style="background:linear-gradient(135deg,#d97706,#f59e0b);border-color:#f59e0b;">Siguiente →</button>
        <button class="btn-fm-submit" id="pm-submit-btn" onclick="savePM()" style="display:none;background:linear-gradient(135deg,#d97706,#f59e0b);border-color:#f59e0b;">
          <span id="pm-btn-text">✅ Añadir PM</span>
        </button>
      </div>
    </div>
  </div>
</div>
<div class="page" id="page-projects">
  <div class="projects-page">
    <div class="proj-header">
      <div class="proj-header-top">
        <div style="display:flex;align-items:center;gap:12px;">
          <div class="page-title" style="display:flex;align-items:center;gap:10px;"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4 3 9 3s9-1.34 9-3"/><ellipse cx="12" cy="5" rx="9" ry="3" fill="#94a3b8" fill-opacity=".1"/></svg> Base de Datos de Proyectos <span style="font-size:12px;color:var(--text2);font-weight:400;" id="proj-count">46 proyectos</span></div>
          <button class="btn-add-new" onclick="openProjForm()">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Nuevo Proyecto
          </button>
        </div>
        <div class="stat-chips">
          <div class="stat-chip"><span class="stat-chip-val" id="cnt-backlog">12</span><span class="stat-chip-label">Backlog</span></div>
          <div class="stat-chip"><span class="stat-chip-val" id="cnt-plan">16</span><span class="stat-chip-label">Planificado</span></div>
          <div class="stat-chip"><span class="stat-chip-val" id="cnt-prog">16</span><span class="stat-chip-label">En Progreso</span></div>
          <div class="stat-chip"><span class="stat-chip-val" id="cnt-done">2</span><span class="stat-chip-label">Completado</span></div>
        </div>
      </div>
      <input class="search-bar" placeholder="Buscar proyecto, ID o skill..." oninput="filterProjects(this.value)" style="margin-bottom:10px;">
      <div style="display:flex;align-items:center;gap:8px;">
        <div class="prio-chip critica" style="cursor:pointer" onclick="filterProjPrio('Critica',this)">Crítica</div>
        <div class="prio-chip alta" style="cursor:pointer" onclick="filterProjPrio('Alta',this)">Alta</div>
        <div class="prio-chip media" style="cursor:pointer" onclick="filterProjPrio('Media',this)">Media</div>
        <div class="prio-chip baja" style="cursor:pointer" onclick="filterProjPrio('Baja',this)">Baja</div>
        <div class="prio-chip" style="cursor:pointer;background:var(--bg3);color:var(--text2);border:1px solid var(--border)" onclick="filterProjPrio('Todos',this)">Todos</div>
      </div>
    </div>
    <div class="table-wrap">
      <table class="data-table" style="table-layout:fixed;">
        <thead><tr id="proj-thead-row">
          <th style="width:65px;" class="tm-th-resizable" draggable="true">ID</th>
          <th style="width:220px;" class="tm-th-resizable" draggable="true">Proyecto</th>
          <th style="width:65px;" class="tm-th-resizable" draggable="true">Prioridad</th>
          <th style="width:80px;" class="tm-th-resizable" draggable="true">Estado</th>
          <th style="width:50px;" class="tm-th-resizable" draggable="true">Horas</th>
          <th style="width:130px;" class="tm-th-resizable" draggable="true">PM Asignado</th>
          <th style="width:100px;" class="tm-th-resizable" draggable="true">Skill</th>
          <th style="width:120px;" class="tm-th-resizable" draggable="true">Fechas</th>
        </tr></thead>
        <tbody id="proj-tbody"><tr><td colspan="8" style="text-align:center;padding:20px;color:var(--text2);"><span class="loading-spinner"></span>Cargando proyectos...</td></tr></tbody>
      </table>
    </div>
  </div>
</div>
<div class="page" id="page-kanban">
  <div class="kanban-page">
    <div class="kanban-header">
      <div style="display:flex;align-items:center;gap:10px;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#a5b4fc" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18"/><path d="M15 3v18"/></svg>
        <div class="kanban-title">Tablero Kanban — Flujo de Trabajo</div>
      </div>
      <div class="kanban-meta">
        <span style="color:var(--blue);font-weight:600;">RUN</span>
        <span style="color:var(--green);font-weight:600;">BUILD</span>
        <span style="background:var(--bg3);border:1px solid var(--border);border-radius:6px;padding:2px 10px;" id="kanban-total">Total: 0</span>
        <button class="btn-add-new" onclick="openKanbanForm()" style="padding:4px 12px;font-size:11px;">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="vertical-align:middle;margin-right:3px;"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Nueva Tarea
        </button>
      </div>
    </div>
    <div class="kanban-body" id="kanban-body">
      <div style="display:flex;align-items:center;justify-content:center;width:100%;color:var(--text2);gap:8px;">
        <span class="loading-spinner"></span>Cargando tablero...
      </div>
    </div>
    <!-- Metrics & Charts area -->
    <div id="kanban-metrics-area" style="border-top:1px solid var(--border);background:var(--bg2);padding:14px 20px;overflow-y:auto;max-height:340px;display:none;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
        <div style="font-size:13px;font-weight:700;display:flex;align-items:center;gap:6px;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#a5b4fc" stroke-width="1.8"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          Métricas de Flujo & Analytics
        </div>
        <button onclick="document.getElementById('kanban-metrics-area').style.display='none'" style="background:none;border:none;color:var(--text3);cursor:pointer;font-size:16px;">✕</button>
      </div>
      <!-- KPI row -->
      <div style="display:grid;grid-template-columns:repeat(6,1fr);gap:8px;margin-bottom:14px;" id="kb-kpis"></div>
      <!-- Charts row -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
        <div style="background:var(--bg3);border:1px solid var(--border);border-radius:10px;padding:12px;">
          <div style="font-size:11px;font-weight:700;color:var(--text2);text-transform:uppercase;margin-bottom:8px;letter-spacing:.3px;">Diagrama de Flujo Acumulado (CFD)</div>
          <canvas id="kb-cfd-chart" height="160"></canvas>
        </div>
        <div style="background:var(--bg3);border:1px solid var(--border);border-radius:10px;padding:12px;">
          <div style="font-size:11px;font-weight:700;color:var(--text2);text-transform:uppercase;margin-bottom:8px;letter-spacing:.3px;">Control Chart (Lead Time)</div>
          <canvas id="kb-control-chart" height="160"></canvas>
        </div>
      </div>
    </div>
    <div style="border-top:1px solid var(--border);background:var(--bg2);padding:6px 20px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;">
      <button onclick="toggleKanbanMetrics()" style="background:var(--purple-bg);border:1px solid rgba(165,180,252,.3);color:var(--purple);border-radius:6px;padding:4px 12px;font-size:11px;font-weight:600;cursor:pointer;">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:middle;margin-right:3px;"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
        Métricas &amp; Gráficas
      </button>
      <div style="display:flex;gap:12px;font-size:11px;color:var(--text3);" id="kb-footer-stats"></div>
    </div>
  </div>
</div>
<!-- MODAL: KANBAN TAREA -->
<div class="fm-overlay" id="fm-kanban" onclick="if(event.target===this)closeKanbanForm()">
  <div class="fm-box" style="width:680px;">
    <div style="padding:14px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#a5b4fc" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18"/><path d="M15 3v18"/></svg>
      <span style="font-size:15px;font-weight:700;" id="kb-form-title">Nueva Tarea Kanban</span>
      <button onclick="closeKanbanForm()" style="margin-left:auto;background:none;border:none;color:var(--text2);cursor:pointer;font-size:18px;">✕</button>
    </div>
    <div style="padding:18px;overflow-y:auto;max-height:70vh;">
      <input type="hidden" id="kb-edit-id">
      <div class="sap-grid" style="margin-bottom:14px;">
        <div class="sap-field sap-full">
          <label class="sap-label">Título</label>
          <input class="sap-input" id="kb-titulo" placeholder="Descripción breve de la tarea...">
        </div>
      </div>
      <div class="sap-grid" style="margin-bottom:14px;">
        <div class="sap-field">
          <label class="sap-label">Tipo</label>
          <select class="sap-input" id="kb-tipo">
            <option value="RUN">RUN (Operación)</option>
            <option value="BUILD">BUILD (Proyecto)</option>
          </select>
        </div>
        <div class="sap-field">
          <label class="sap-label">Prioridad</label>
          <select class="sap-input" id="kb-prioridad">
            <option value="Crítica">Crítica (P1)</option>
            <option value="Alta">Alta (P2)</option>
            <option value="Media" selected>Media (P3)</option>
            <option value="Baja">Baja (P4)</option>
          </select>
        </div>
      </div>
      <div class="sap-grid" style="margin-bottom:14px;">
        <div class="sap-field">
          <label class="sap-label">Columna</label>
          <select class="sap-input" id="kb-columna">
            <option value="Backlog">Backlog</option>
            <option value="Análisis">Análisis</option>
            <option value="En Progreso">En Progreso</option>
            <option value="Code Review">Code Review</option>
            <option value="Testing">Testing</option>
            <option value="Despliegue">Despliegue</option>
            <option value="Bloqueado">Bloqueado</option>
            <option value="Completado">Completado</option>
          </select>
        </div>
        <div class="sap-field">
          <label class="sap-label">Técnico Asignado</label>
          <select class="sap-input" id="kb-tecnico">
            <option value="">Sin asignar</option>
          </select>
        </div>
      </div>
      <div class="sap-grid" style="margin-bottom:14px;">
        <div class="sap-field">
          <label class="sap-label">Vincular a Proyecto</label>
          <select class="sap-input" id="kb-proyecto">
            <option value="">Ninguno</option>
          </select>
        </div>
        <div class="sap-field">
          <label class="sap-label">Vincular a Incidencia</label>
          <select class="sap-input" id="kb-incidencia">
            <option value="">Ninguna</option>
          </select>
        </div>
      </div>
      <div class="sap-grid" style="margin-bottom:14px;">
        <div class="sap-field">
          <label class="sap-label">Horas Estimadas</label>
          <input class="sap-input mono" id="kb-horas-est" type="number" min="0" step="0.5" value="0">
        </div>
        <div class="sap-field">
          <label class="sap-label">Horas Reales</label>
          <input class="sap-input mono" id="kb-horas-real" type="number" min="0" step="0.5" value="0">
        </div>
      </div>
      <div class="sap-field" style="margin-bottom:14px;">
        <label class="sap-label">Descripción / Notas</label>
        <textarea class="sap-textarea" id="kb-descripcion" placeholder="Detalles de la tarea..."></textarea>
      </div>
      <div class="sap-field" style="margin-bottom:14px;">
        <label class="sap-label">Bloqueador (si aplica)</label>
        <input class="sap-input" id="kb-bloqueador" placeholder="Ej: Esperando respuesta de proveedor...">
      </div>
      <!-- Fechas (read-only info) -->
      <div id="kb-fechas-info" style="display:none;background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:10px;margin-bottom:14px;">
        <div style="font-size:10px;font-weight:700;color:var(--text2);text-transform:uppercase;margin-bottom:6px;">Fechas Automáticas</div>
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;font-size:11px;">
          <div><span style="color:var(--text3);">Creación:</span> <span id="kb-f-creacion" style="font-family:var(--mono);">--</span></div>
          <div><span style="color:var(--text3);">Inicio Ejecución:</span> <span id="kb-f-ejecucion" style="font-family:var(--mono);">--</span></div>
          <div><span style="color:var(--text3);">Cierre:</span> <span id="kb-f-cierre" style="font-family:var(--mono);">--</span></div>
        </div>
      </div>
    </div>
    <div style="padding:12px 18px;border-top:1px solid var(--border);display:flex;gap:8px;justify-content:flex-end;">
      <button class="btn-fm-back" onclick="closeKanbanForm()">Cancelar</button>
      <button class="btn-fm-submit" onclick="saveKanbanTarea()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:middle;margin-right:4px;"><polyline points="20 6 9 17 4 12"/></svg>
        <span id="kb-btn-save-text">Crear Tarea</span>
      </button>
    </div>
  </div>
</div>
<!-- ══════════════════ PAGE: BUDGET ══════════════════ -->
<div class="page" id="page-budget">
  <div class="budget-page">
    <div class="budget-header">
      <div class="budget-kpi-row">
        <div class="bgt-kpi">
          <div class="bgt-kpi-icon" style="background:rgba(16,185,129,.15);"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div>
          <div class="bgt-kpi-val" style="color:#10b981;" id="bgt-kpi-bac">€ 0</div>
          <div class="bgt-kpi-label">BAC Total Portfolio</div>
          <div class="bgt-kpi-sub">Budget at Completion</div>
        </div>
        <div class="bgt-kpi">
          <div class="bgt-kpi-icon" style="background:rgba(56,189,248,.15);"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#38bdf8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg></div>
          <div class="bgt-kpi-val" style="color:#38bdf8;" id="bgt-kpi-labor">€ 0</div>
          <div class="bgt-kpi-label">Labor Interno</div>
          <div class="bgt-kpi-sub">Personal FTE</div>
        </div>
        <div class="bgt-kpi">
          <div class="bgt-kpi-icon" style="background:rgba(251,191,36,.15);"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2" stroke-linecap="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg></div>
          <div class="bgt-kpi-val" style="color:#fbbf24;" id="bgt-kpi-opex">€ 0</div>
          <div class="bgt-kpi-label">OPEX Total</div>
          <div class="bgt-kpi-sub">Gastos Operacionales</div>
        </div>
        <div class="bgt-kpi">
          <div class="bgt-kpi-icon" style="background:rgba(249,115,22,.15);"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2" stroke-linecap="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg></div>
          <div class="bgt-kpi-val" style="color:#f97316;" id="bgt-kpi-capex">€ 0</div>
          <div class="bgt-kpi-label">CAPEX Total</div>
          <div class="bgt-kpi-sub">Inversiones Capital</div>
        </div>
        <div class="bgt-kpi">
          <div class="bgt-kpi-icon" style="background:rgba(139,92,246,.15);"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg></div>
          <div class="bgt-kpi-val" style="color:#8b5cf6;" id="bgt-kpi-prov">€ 0</div>
          <div class="bgt-kpi-label">Proveedores Ext.</div>
          <div class="bgt-kpi-sub">Terceros y Vendors</div>
        </div>
        <div class="bgt-kpi">
          <div class="bgt-kpi-icon" style="background:rgba(244,114,182,.15);"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#f472b6" stroke-width="2" stroke-linecap="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></div>
          <div class="bgt-kpi-val" style="color:#f472b6;" id="bgt-kpi-count">0</div>
          <div class="bgt-kpi-label">Presupuestos</div>
          <div class="bgt-kpi-sub" id="bgt-kpi-count-sub">0 aprobados</div>
        </div>
      </div>
      <div style="display:flex;align-items:center;gap:8px;">
        <input class="search-bar" placeholder="Buscar por ID, proyecto, responsable…" oninput="filterBudgets(this.value)" style="margin:0;flex:1;max-width:380px;">
        <div style="display:flex;gap:5px;">
          <button class="filter-chip active" id="bgt-f-all"   onclick="filterBgtEstado('',this)">Todos</button>
          <button class="filter-chip" id="bgt-f-bor"          onclick="filterBgtEstado('BORRADOR',this)">Borrador</button>
          <button class="filter-chip" id="bgt-f-rev"          onclick="filterBgtEstado('EN_REVISION',this)">En Revisión</button>
          <button class="filter-chip" id="bgt-f-apr"          onclick="filterBgtEstado('APROBADO',this)">Aprobado</button>
        </div>
        <button class="btn-add-new" onclick="openBudgetForm()">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Nuevo Presupuesto
        </button>
      </div>
    </div>
    <div class="budget-table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>ID Presupuesto</th>
            <th>Proyecto</th>
            <th>Responsable</th>
            <th>Estado</th>
            <th style="text-align:right;">Labor</th>
            <th style="text-align:right;">Proveedores</th>
            <th style="text-align:right;">OPEX</th>
            <th style="text-align:right;">CAPEX</th>
            <th style="text-align:right;">RRHH</th>
            <th style="text-align:right;">Reservas</th>
            <th style="text-align:right;color:#10b981;">BAC Total</th>
            <th>Ver.</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody id="budget-tbody">
          <tr><td colspan="13" style="text-align:center;padding:48px;color:var(--text3);">
            <div style="font-size:28px;opacity:.25;margin-bottom:8px;">💰</div>
            Cargando presupuestos…
          </td></tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- ══════════════════ WAR ROOM COGNITIVO ══════════════════ -->
<div class="page" id="page-warroom">
  <div class="wr-page">
    <!-- Sidebar Nav -->
    <div class="wr-sidebar">
      <div style="padding:6px 8px 10px;display:flex;align-items:center;gap:8px;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#a855f7" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v4a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3z"/><path d="M19 10v1a7 7 0 0 1-14 0v-1"/><path d="M12 18v4"/><path d="M8 22h8"/></svg>
        <span style="font-size:13px;font-weight:800;color:#a855f7;">WAR ROOM</span>
      </div>
      <div class="wr-sidebar-title">Centro de Control</div>
      <div class="wr-nav-item active" onclick="wrShowSection('dashboard',this)">
        <div class="wr-nav-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="9" rx="1"/><rect x="14" y="3" width="7" height="5" rx="1"/><rect x="14" y="12" width="7" height="9" rx="1"/><rect x="3" y="16" width="7" height="5" rx="1"/></svg></div>
        Command Center
      </div>
      <div class="wr-nav-item" onclick="wrShowSection('chat',this)">
        <div class="wr-nav-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></div>
        Chat Multi-Agente
      </div>
      <div class="wr-sidebar-title">Inteligencia</div>
      <div class="wr-nav-item" onclick="wrShowSection('alerts',this)">
        <div class="wr-nav-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg></div>
        Alertas
        <span class="wr-nav-badge" id="wr-nav-alerts-badge" style="display:none;">0</span>
      </div>
      <div class="wr-nav-item" onclick="wrShowSection('compliance',this)">
        <div class="wr-nav-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
        Compliance
      </div>
      <div class="wr-nav-item" onclick="wrShowSection('postmortem',this)">
        <div class="wr-nav-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg></div>
        Post-Mortem
      </div>
      <div class="wr-nav-item" onclick="wrShowSection('simulator',this)">
        <div class="wr-nav-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2"/><path d="M8.5 2h7"/></svg></div>
        Simulador What-If
      </div>
      <div class="wr-sidebar-title">Operaciones</div>
      <div class="wr-nav-item" onclick="wrShowSection('sessions',this)">
        <div class="wr-nav-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg></div>
        Sesiones Crisis
      </div>
      <div class="wr-nav-item" onclick="wrShowSection('metrics',this)">
        <div class="wr-nav-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2a10 10 0 1 0 10 10H12V2z"/><path d="M20 12a8 8 0 0 0-8-8v8h8z" fill="rgba(168,85,247,.2)"/></svg></div>
        Métricas IA
      </div>
    </div>

    <!-- Content Area -->
    <div class="wr-content">

      <!-- ═══ DASHBOARD (COMMAND CENTER) ═══ -->
      <div class="wr-section active" id="wr-sec-dashboard">
        <div class="wr-section-title">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#a855f7" stroke-width="1.8"><rect x="3" y="3" width="7" height="9" rx="1"/><rect x="14" y="3" width="7" height="5" rx="1"/><rect x="14" y="12" width="7" height="9" rx="1"/><rect x="3" y="16" width="7" height="5" rx="1"/></svg>
          Command Center
        </div>
        <div class="wr-kpi-row" id="wr-dashboard-kpis">
          <div class="wr-kpi"><div class="wr-kpi-icon" style="background:var(--red-bg);"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg></div><div class="wr-kpi-val" id="wr-kpi-alertas" style="color:var(--red);">--</div><div class="wr-kpi-label">Alertas Activas</div></div>
          <div class="wr-kpi"><div class="wr-kpi-icon" style="background:var(--purple-bg);"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#a855f7" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div><div class="wr-kpi-val" id="wr-kpi-compliance" style="color:#a855f7;">--</div><div class="wr-kpi-label">Compliance Pendiente</div></div>
          <div class="wr-kpi"><div class="wr-kpi-icon" style="background:var(--yellow-bg);"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--yellow)" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg></div><div class="wr-kpi-val" id="wr-kpi-postmortem" style="color:var(--yellow);">--</div><div class="wr-kpi-label">Post-Mortems Draft</div></div>
          <div class="wr-kpi"><div class="wr-kpi-icon" style="background:var(--green-bg);"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2"><path d="M12 2a10 10 0 1 0 10 10H12V2z"/></svg></div><div class="wr-kpi-val" id="wr-kpi-sims" style="color:var(--green);">--</div><div class="wr-kpi-label">Simulaciones 7d</div></div>
        </div>
        <!-- Semáforo RUN / BUILD -->
        <div class="wr-semaforo">
          <div class="wr-sem-item">
            <div class="wr-sem-dot" id="wr-sem-run"></div>
            <div><div class="wr-sem-label">RUN</div><div class="wr-sem-sub" id="wr-sem-run-text">Cargando...</div></div>
          </div>
          <div class="wr-sem-item">
            <div class="wr-sem-dot" id="wr-sem-build"></div>
            <div><div class="wr-sem-label">BUILD</div><div class="wr-sem-sub" id="wr-sem-build-text">Cargando...</div></div>
          </div>
        </div>
        <!-- Timeline 24h -->
        <div style="font-size:13px;font-weight:700;margin-bottom:10px;display:flex;align-items:center;gap:6px;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--text2)" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Timeline de Actividad (últimas acciones)
        </div>
        <div class="wr-timeline" id="wr-timeline-feed">
          <div class="no-data">Cargando timeline...</div>
        </div>
      </div>

      <!-- ═══ CHAT MULTI-AGENTE ═══ -->
      <div class="wr-section" id="wr-sec-chat">
        <div class="wr-chat-layout">
          <!-- Agent selector -->
          <div class="wr-chat-agents">
            <div class="wr-agent-group">
              <div class="wr-agent-group-title"><div class="wr-agent-dot" style="background:var(--blue);"></div> AGENTES RUN</div>
              <div class="wr-agent-item" onclick="wrSelectAgent('AG-001',this)"><div class="wr-agent-avatar" style="background:var(--blue);">01</div><div><div style="font-size:11px;font-weight:600;">AG-001</div><div style="font-size:9px;color:var(--text3);">Dispatcher</div></div></div>
              <div class="wr-agent-item" onclick="wrSelectAgent('AG-002',this)"><div class="wr-agent-avatar" style="background:#2563eb;">02</div><div><div style="font-size:11px;font-weight:600;">AG-002</div><div style="font-size:9px;color:var(--text3);">Resource Mgr RUN</div></div></div>
              <div class="wr-agent-item" onclick="wrSelectAgent('AG-003',this)"><div class="wr-agent-avatar" style="background:#0891b2;">03</div><div><div style="font-size:11px;font-weight:600;">AG-003</div><div style="font-size:9px;color:var(--text3);">Forecaster</div></div></div>
              <div class="wr-agent-item" onclick="wrSelectAgent('AG-004',this)"><div class="wr-agent-avatar" style="background:#0e7490;">04</div><div><div style="font-size:11px;font-weight:600;">AG-004</div><div style="font-size:9px;color:var(--text3);">Buffer Gatekeeper</div></div></div>
            </div>
            <div class="wr-agent-group">
              <div class="wr-agent-group-title"><div class="wr-agent-dot" style="background:var(--green);"></div> AGENTES BUILD</div>
              <div class="wr-agent-item" onclick="wrSelectAgent('AG-005',this)"><div class="wr-agent-avatar" style="background:var(--green);">05</div><div><div style="font-size:11px;font-weight:600;">AG-005</div><div style="font-size:9px;color:var(--text3);">Estratega PMO</div></div></div>
              <div class="wr-agent-item" onclick="wrSelectAgent('AG-006',this)"><div class="wr-agent-avatar" style="background:#059669;">06</div><div><div style="font-size:11px;font-weight:600;">AG-006</div><div style="font-size:9px;color:var(--text3);">Resource Mgr BUILD</div></div></div>
              <div class="wr-agent-item" onclick="wrSelectAgent('AG-007',this)"><div class="wr-agent-avatar" style="background:#047857;">07</div><div><div style="font-size:11px;font-weight:600;">AG-007</div><div style="font-size:9px;color:var(--text3);">Planificador</div></div></div>
            </div>
            <div class="wr-agent-group">
              <div class="wr-agent-group-title"><div class="wr-agent-dot" style="background:#a855f7;"></div> AGENTES WAR ROOM</div>
              <div class="wr-agent-item active" onclick="wrSelectAgent('AG-008',this)"><div class="wr-agent-avatar" style="background:#7c3aed;">08</div><div><div style="font-size:11px;font-weight:600;">AG-008</div><div style="font-size:9px;color:var(--text3);">Compliance</div></div></div>
              <div class="wr-agent-item" onclick="wrSelectAgent('AG-009',this)"><div class="wr-agent-avatar" style="background:#9333ea;">09</div><div><div style="font-size:11px;font-weight:600;">AG-009</div><div style="font-size:9px;color:var(--text3);">Post-Mortem</div></div></div>
              <div class="wr-agent-item" onclick="wrSelectAgent('AG-010',this)"><div class="wr-agent-avatar" style="background:#a855f7;">10</div><div><div style="font-size:11px;font-weight:600;">AG-010</div><div style="font-size:9px;color:var(--text3);">Simulador</div></div></div>
              <div class="wr-agent-item" onclick="wrSelectAgent('AG-012',this)"><div class="wr-agent-avatar" style="background:#c084fc;">12</div><div><div style="font-size:11px;font-weight:600;">AG-012</div><div style="font-size:9px;color:var(--text3);">Alert Correlator</div></div></div>
            </div>
          </div>
          <!-- Chat main -->
          <div class="wr-chat-main">
            <div class="wr-chat-header">
              <div class="wr-agent-avatar" id="wr-chat-av" style="background:#7c3aed;">08</div>
              <div>
                <div class="wr-chat-header-name" id="wr-chat-agent-name">AG-008 Compliance Auditor</div>
                <div class="wr-chat-header-sub" id="wr-chat-agent-sub">Temp: 0.2 · Precisión normativa</div>
              </div>
              <div class="wr-chat-online" style="margin-left:auto;"></div>
              <span style="font-size:11px;color:var(--green);font-weight:600;">Online</span>
            </div>
            <div class="wr-chat-messages" id="wr-chat-messages">
              <div style="text-align:center;padding:40px;color:var(--text3);font-size:12px;">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--text3)" stroke-width="1" style="margin:0 auto 8px;display:block;"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                Selecciona un agente y escribe tu mensaje<br>para iniciar una conversación con el War Room.
              </div>
            </div>
            <div class="wr-chat-input-bar">
              <input class="wr-chat-input" id="wr-chat-input" placeholder="Escribe tu mensaje al agente..." onkeydown="if(event.key==='Enter')wrSendChat()">
              <button class="wr-chat-send" onclick="wrSendChat()">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- ═══ ALERTAS INTELIGENTES ═══ -->
      <div class="wr-section" id="wr-sec-alerts">
        <div class="wr-section-title">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f85149" stroke-width="1.8"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
          Alertas Inteligentes
        </div>
        <div class="wr-filter-bar" id="wr-alert-filters">
          <div class="wr-filter-chip active" onclick="wrFilterAlerts('ALL',this)">Todas</div>
          <div class="wr-filter-chip" onclick="wrFilterAlerts('CRITICAL',this)">Critical</div>
          <div class="wr-filter-chip" onclick="wrFilterAlerts('HIGH',this)">High</div>
          <div class="wr-filter-chip" onclick="wrFilterAlerts('MEDIUM',this)">Medium</div>
          <div class="wr-filter-chip" onclick="wrFilterAlerts('LOW',this)">Low</div>
        </div>
        <div id="wr-alerts-feed">
          <div class="no-data">Cargando alertas...</div>
        </div>
      </div>

      <!-- ═══ COMPLIANCE ═══ -->
      <div class="wr-section" id="wr-sec-compliance">
        <div class="wr-section-title">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#a855f7" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Compliance & Auditoría
        </div>
        <div class="wr-kpi-row" id="wr-compliance-kpis" style="grid-template-columns:repeat(3,1fr);"></div>
        <div class="wr-filter-bar">
          <div class="wr-filter-chip active" onclick="wrFilterAudits('ALL',this)">Todos</div>
          <div class="wr-filter-chip" onclick="wrFilterAudits('ITIL4_SLA',this)">ITIL4</div>
          <div class="wr-filter-chip" onclick="wrFilterAudits('PMBOK7_DELIVERABLE',this)">PMBOK7</div>
          <div class="wr-filter-chip" onclick="wrFilterAudits('GDPR_DATA',this)">GDPR</div>
          <div class="wr-filter-chip" onclick="wrFilterAudits('DORA_RESILIENCE',this)">DORA</div>
          <div class="wr-filter-chip" onclick="wrFilterAudits('ISO27001_SECURITY',this)">ISO27001</div>
        </div>
        <div id="wr-compliance-feed">
          <div class="no-data">Cargando auditorías...</div>
        </div>
      </div>

      <!-- ═══ POST-MORTEM ═══ -->
      <div class="wr-section" id="wr-sec-postmortem">
        <div class="wr-section-title">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--yellow)" stroke-width="1.8"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          Informes Post-Mortem
        </div>
        <div id="wr-postmortem-feed">
          <div class="no-data">Cargando post-mortems...</div>
        </div>
      </div>

      <!-- ═══ SIMULADOR WHAT-IF ═══ -->
      <div class="wr-section" id="wr-sec-simulator">
        <div class="wr-section-title">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0ea5e9" stroke-width="1.8"><path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2"/><path d="M8.5 2h7"/></svg>
          Simulador What-If
        </div>
        <div class="wr-sim-form">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px;">
            <div class="sap-field">
              <label class="sap-label">Tipo de Escenario</label>
              <select class="sap-input" id="wr-sim-type">
                <option value="RESOURCE_REALLOCATION">Reasignación de Recursos</option>
                <option value="PROJECT_DELAY">Retraso de Proyecto</option>
                <option value="P1_CASCADE">Cascada P1 (3 incidencias simultáneas)</option>
                <option value="BUDGET_CUT">Recorte Presupuestario</option>
                <option value="TEAM_SCALING">Escalado de Equipo</option>
                <option value="FREEZE_PERIOD">Periodo de Freeze</option>
                <option value="SKILL_GAP">Brecha de Skills</option>
                <option value="VENDOR_FAILURE">Fallo de Proveedor</option>
                <option value="REGULATORY_CHANGE">Cambio Regulatorio</option>
              </select>
            </div>
            <div class="sap-field">
              <label class="sap-label">Nombre de la Simulación</label>
              <input class="sap-input" id="wr-sim-name" placeholder="Describe el escenario...">
            </div>
          </div>
          <div class="sap-field" style="margin-bottom:14px;">
            <label class="sap-label">Descripción del Escenario</label>
            <textarea class="sap-textarea" id="wr-sim-desc" placeholder="Detalla el escenario what-if que quieres simular..."></textarea>
          </div>
          <button class="btn-add-new" onclick="wrRunSimulation()" style="background:linear-gradient(135deg,#7c3aed,#a855f7);border-color:#a855f7;box-shadow:0 2px 8px rgba(124,58,237,.25);">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:middle;margin-right:4px;"><path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2"/></svg>
            Ejecutar Simulación
          </button>
        </div>
        <div id="wr-sim-results" style="display:none;">
          <div style="font-size:13px;font-weight:700;margin-bottom:10px;">Resultados de la Simulación</div>
          <div class="wr-sim-results" id="wr-sim-cases"></div>
          <div id="wr-sim-recommendations" style="margin-top:12px;"></div>
        </div>
        <div style="font-size:13px;font-weight:700;margin:16px 0 10px;">Simulaciones Anteriores</div>
        <div id="wr-sim-history">
          <div class="no-data">Cargando simulaciones...</div>
        </div>
      </div>

      <!-- ═══ SESIONES WAR ROOM ═══ -->
      <div class="wr-section" id="wr-sec-sessions">
        <div class="wr-section-title">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="1.8"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          Sesiones de Crisis
        </div>
        <button class="btn-add-new" onclick="wrCreateSession()" style="margin-bottom:14px;background:linear-gradient(135deg,#7c3aed,#a855f7);border-color:#a855f7;">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="vertical-align:middle;margin-right:4px;"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Nueva Sesión
        </button>
        <div id="wr-sessions-feed">
          <div class="no-data">Cargando sesiones...</div>
        </div>
      </div>

      <!-- ═══ MÉTRICAS IA ═══ -->
      <div class="wr-section" id="wr-sec-metrics">
        <div class="wr-section-title">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#a855f7" stroke-width="1.8"><path d="M12 2a10 10 0 1 0 10 10H12V2z"/><path d="M20 12a8 8 0 0 0-8-8v8h8z" fill="rgba(168,85,247,.15)"/></svg>
          Métricas de Agentes IA
        </div>
        <div class="wr-metric-grid" id="wr-metrics-grid">
          <div class="no-data" style="grid-column:1/-1;">Cargando métricas...</div>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- ══════════════════ PAGE: DOCUMENTACIÓN ══════════════════ -->
<div class="page" id="page-docs">
  <div class="gov-page">
    <div class="team-header" style="padding:10px 20px 8px;">
      <div class="team-header-top" style="margin-bottom:8px;">
        <div class="page-title" style="display:flex;align-items:center;gap:10px;">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#0ea5e9" stroke-width="1.5"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
          Repositorio de Documentación <span style="font-size:11px;color:var(--text2);font-weight:400;" id="docs-count">0 documentos</span>
        </div>
        <div style="display:flex;gap:6px;">
          <button onclick="openDocForm()" class="btn-add-new" style="padding:3px 10px;font-size:11px;background:linear-gradient(135deg,#0284c7,#0ea5e9);border-color:#0ea5e9;">+ Documento</button>
          <button onclick="toggleDocStats()" style="background:rgba(14,165,233,.15);border:1px solid rgba(14,165,233,.3);color:#0ea5e9;border-radius:6px;padding:3px 10px;font-size:11px;font-weight:600;cursor:pointer;">Dashboard</button>
        </div>
      </div>
      <!-- Stats panel -->
      <div id="docs-stats" style="display:none;margin-bottom:8px;">
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:8px;" id="docs-kpis"></div>
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;" id="docs-breakdown"></div>
        <div style="text-align:right;margin-top:4px;"><span style="font-size:10px;color:var(--text3);cursor:pointer;" onclick="toggleDocStats()">▲ Minimizar</span></div>
      </div>
      <!-- Filters -->
      <div style="display:flex;gap:8px;margin-bottom:6px;flex-wrap:wrap;">
        <input class="search-bar" placeholder="Buscar documentos..." oninput="filterDocs(this.value)" style="margin:0;flex:1;min-width:200px;">
        <select class="sap-input" id="doc-filter-silo" onchange="filterDocsApply()" style="width:auto;padding:4px 10px;font-size:11px;">
          <option value="">Todos los Silos</option><option value="BUILD">BUILD</option><option value="RUN">RUN</option><option value="TRANSVERSAL">TRANSVERSAL</option>
        </select>
        <select class="sap-input" id="doc-filter-tipo" onchange="filterDocsApply()" style="width:auto;padding:4px 10px;font-size:11px;">
          <option value="">Todos los Tipos</option><option value="proyecto">Proyecto</option><option value="incidencia">Incidencia</option><option value="gobernanza">Gobernanza</option><option value="formacion">Formación</option><option value="herramienta">Herramienta</option><option value="plantilla">Plantilla</option>
        </select>
        <select class="sap-input" id="doc-filter-depto" onchange="filterDocsApply()" style="width:auto;padding:4px 10px;font-size:11px;">
          <option value="">Todos los Departamentos</option>
        </select>
      </div>
    </div>
    <!-- Folder breadcrumb -->
    <div style="padding:4px 20px;background:var(--bg2);border-bottom:1px solid var(--border);display:flex;align-items:center;gap:4px;font-size:11px;color:var(--text2);" id="docs-breadcrumb">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
      <span style="cursor:pointer;color:#0ea5e9;" onclick="filterDocsApply()">CognitivePMO_Documentación</span>
    </div>
    <!-- Documents grid -->
    <div style="flex:1;overflow-y:auto;padding:14px 20px;">
      <div id="docs-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:10px;">
        <div class="no-data">Cargando documentos...</div>
      </div>
    </div>
  </div>
</div>
<!-- Modal: Nuevo Documento -->
<div class="fm-overlay" id="fm-doc" onclick="if(event.target===this)fmClose('fm-doc')">
  <div class="fm-box" style="width:620px;">
    <div style="padding:14px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0ea5e9" stroke-width="1.8"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
      <span style="font-size:15px;font-weight:700;" id="doc-form-title">Nuevo Documento</span>
      <button onclick="fmClose('fm-doc')" style="margin-left:auto;background:none;border:none;color:var(--text2);cursor:pointer;font-size:18px;">✕</button>
    </div>
    <div style="padding:18px;overflow-y:auto;max-height:70vh;">
      <input type="hidden" id="doc-edit-id">
      <div class="sap-field" style="margin:0 0 10px;"><label class="sap-label">Título del Documento</label>
        <input class="sap-input" id="doc-titulo" placeholder="Ej: Plan de Proyecto — Migración OpenShift"></div>
      <div class="sap-grid" style="margin-bottom:10px;">
        <div class="sap-field" style="margin:0;"><label class="sap-label">Tipo</label>
          <select class="sap-input" id="doc-tipo">
            <option value="proyecto">Proyecto</option><option value="incidencia">Incidencia</option><option value="gobernanza">Gobernanza</option>
            <option value="formacion">Formación</option><option value="herramienta">Herramienta</option><option value="plantilla">Plantilla</option>
          </select></div>
        <div class="sap-field" style="margin:0;"><label class="sap-label">Silo</label>
          <select class="sap-input" id="doc-silo" onchange="docSiloChanged()">
            <option value="BUILD">BUILD</option><option value="RUN">RUN</option><option value="TRANSVERSAL">TRANSVERSAL</option>
          </select></div>
      </div>
      <div class="sap-grid" style="margin-bottom:10px;">
        <div class="sap-field" style="margin:0;"><label class="sap-label">Departamento</label>
          <select class="sap-input" id="doc-depto"><option value="">— Seleccionar —</option></select></div>
        <div class="sap-field" style="margin:0;"><label class="sap-label">Proyecto Vinculado (opcional)</label>
          <select class="sap-input" id="doc-proyecto"><option value="">— Ninguno —</option></select></div>
      </div>
      <div class="sap-field" style="margin:0 0 10px;"><label class="sap-label">Descripción</label>
        <textarea class="sap-textarea" id="doc-desc" placeholder="Descripción del documento..." style="min-height:50px;"></textarea></div>
      <div class="sap-grid" style="margin-bottom:10px;">
        <div class="sap-field" style="margin:0;"><label class="sap-label">Tags (separados por coma)</label>
          <input class="sap-input" id="doc-tags" placeholder="PMBOK, seguridad, infra..."></div>
        <div class="sap-field" style="margin:0;"><label class="sap-label">Creado por</label>
          <input class="sap-input" id="doc-creador" placeholder="Jose Antonio Martinez" value="Jose Antonio Martinez"></div>
      </div>
      <div class="sap-field" style="margin:0 0 10px;"><label class="sap-label">URL de Google Drive (enlace compartido)</label>
        <input class="sap-input" id="doc-drive-url" placeholder="https://drive.google.com/file/d/..."></div>
      <div style="background:var(--bg3);border:2px dashed var(--border);border-radius:10px;padding:20px;text-align:center;cursor:pointer;transition:all .15s;" id="doc-dropzone" onclick="document.getElementById('doc-file-input').click()" ondragover="event.preventDefault();this.style.borderColor='#0ea5e9'" ondragleave="this.style.borderColor=''" ondrop="event.preventDefault();this.style.borderColor='';docHandleDrop(event)">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--text3)" stroke-width="1.5" style="margin:0 auto 6px;display:block;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        <div style="font-size:12px;color:var(--text2);">Arrastra un archivo aquí o <strong style="color:#0ea5e9;">haz clic para seleccionar</strong></div>
        <div style="font-size:10px;color:var(--text3);margin-top:4px;">PDF, DOCX, XLSX, PPTX, MD, TXT (máx 50MB)</div>
        <div id="doc-file-info" style="display:none;margin-top:8px;font-size:11px;color:var(--green);font-weight:600;"></div>
        <input type="file" id="doc-file-input" style="display:none;" accept=".pdf,.docx,.xlsx,.pptx,.md,.txt,.csv,.json" onchange="docFileSelected(this)">
      </div>
    </div>
    <div style="padding:12px 18px;border-top:1px solid var(--border);display:flex;gap:8px;justify-content:flex-end;">
      <button class="btn-fm-back" onclick="fmClose('fm-doc')">Cancelar</button>
      <button class="btn-fm-submit" onclick="saveDoc()" style="background:linear-gradient(135deg,#0284c7,#0ea5e9);border-color:#0ea5e9;" id="doc-btn-save">Registrar Documento</button>
    </div>
  </div>
</div>
