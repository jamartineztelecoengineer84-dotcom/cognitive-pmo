# Cognitive PMO - environment configuration
# Copy to .env and fill with real values. Never commit .env.

# --- Database (PostgreSQL) ---
DB_HOST=postgres
DB_PORT=5432
DB_NAME=cognitive_pmo
DB_USER=pmo_admin
DB_PASSWORD=change-me-strong-password

# --- API ---
API_PORT=8088
FRONTEND_PORT=3030

# --- LLM providers ---
# Anthropic (Claude API) - https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: local Ollama / Flowise gateway
FLOWISE_URL=http://localhost:3000

# --- Email (Resend) - https://resend.com/ ---
RESEND_API_KEY=re_...
RESEND_FROM=noreply@yourdomain.com
RESEND_ADMIN_EMAIL=admin@yourdomain.com
